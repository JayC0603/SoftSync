@inherits LayoutComponentBase
@inject LocalizationService L

@* Static layout for Account pages. No JS interop or language toggle so it is
   safe under static SSR (where auth cookies can be written). *@

<div class="ss-aurora" aria-hidden="true">
    <span></span><span></span><span></span>
</div>

<main class="account-page">
    <div class="account-shell">
        <section class="account-brand" aria-label="SoftSync">
            <a href="/" class="account-logo">
                <img src="images/logo.png" alt="SoftSync" />
                <span>SoftSync</span>
            </a>

            <div class="account-brand-copy">
                <span class="account-eyebrow">@L["auth.brand.eyebrow"]</span>
                <h1>@L["auth.brand.title"]<br /><span>@L["auth.brand.titleAccent"]</span></h1>
                <p>@L["auth.brand.description"]</p>
            </div>

            <div class="account-brand-orbit" aria-hidden="true">
                <div class="account-brand-mascot"><img src="images/syncy-robot.png" alt="" /></div>
            </div>
        </section>

        <section class="account-form-panel">
            <a href="/" class="account-logo account-logo-mobile">
                <img src="images/logo.png" alt="SoftSync" />
                <span>SoftSync</span>
            </a>
            <div class="ss-card account-card">
                @Body
            </div>
            <a class="account-home-link" href="/">← @L["auth.backHome"]</a>
        </section>
    </div>
</main>

<style>
    .account-page {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 32px;
        position: relative;
    }

    .account-shell {
        width: min(1040px, 100%);
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(400px, .95fr);
        overflow: hidden;
        border: 1px solid rgba(99, 102, 241, .16);
        border-radius: 28px;
        background: rgba(255, 255, 255, .72);
        box-shadow: 0 28px 80px rgba(67, 56, 202, .14);
        backdrop-filter: blur(18px);
    }

    .account-brand {
        min-height: 650px;
        padding: 42px 48px;
        position: relative;
        overflow: hidden;
        color: #fff;
        background: linear-gradient(145deg, #316ff6 0%, #6848ed 48%, #a84eea 100%);
    }

    .account-brand::before,
    .account-brand::after {
        content: "";
        position: absolute;
        border: 1px solid rgba(255, 255, 255, .22);
        border-radius: 50%;
    }

    .account-brand::before { width: 420px; height: 420px; right: -180px; top: -130px; }
    .account-brand::after { width: 310px; height: 310px; left: -155px; bottom: -150px; }

    .account-logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: inherit;
        text-decoration: none !important;
        font-size: 1.45rem;
        font-weight: 800;
        position: relative;
        z-index: 2;
    }

    .account-logo img { width: 42px; height: 42px; border-radius: 12px; object-fit: cover; }
    .account-logo-mobile { display: none; color: #5b55e7; margin-bottom: 24px; }
    .account-brand-copy { position: relative; z-index: 2; margin-top: 100px; max-width: 440px; }

    .account-eyebrow {
        display: inline-block;
        padding: 7px 12px;
        border: 1px solid rgba(255, 255, 255, .36);
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .08em;
        background: rgba(255, 255, 255, .1);
    }

    .account-brand h1 { margin: 22px 0 18px; font-size: clamp(2.4rem, 4vw, 3.7rem); line-height: 1.04; font-weight: 800; letter-spacing: -.04em; }
    .account-brand h1 span { color: #d9e7ff; }
    .account-brand p { max-width: 320px; margin: 0; color: rgba(255, 255, 255, .82); font-size: 1.05rem; line-height: 1.7; }

    .account-brand-orbit { position: absolute; right: 18px; bottom: 18px; width: 126px; height: 126px; border: 1px solid rgba(255,255,255,.34); border-radius: 50%; display: grid; place-items: center; }
    .account-brand-mascot { width: 104px; height: 104px; display: grid; place-items: center; overflow: visible; background: transparent; }
    .account-brand-mascot img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 12px 18px rgba(30,24,100,.28)); }

    .account-form-panel { padding: 48px 52px 32px; display: flex; flex-direction: column; justify-content: center; background: rgba(255,255,255,.84); }
    .account-card { padding: 0 !important; border: 0 !important; box-shadow: none !important; background: transparent !important; }
    .account-home-link { align-self: center; margin-top: 24px; color: #70778a; text-decoration: none; font-size: .88rem; }
    .account-home-link:hover { color: #5b55e7; }

    @@media (max-width: 820px) {
        .account-page { padding: 20px; align-items: start; }
        .account-shell { display: block; max-width: 500px; border-radius: 22px; }
        .account-brand { display: none; }
        .account-form-panel { min-height: calc(100vh - 40px); padding: 32px 28px 24px; }
        .account-logo-mobile { display: inline-flex; align-self: center; }
    }

    @@media (max-width: 420px) {
        .account-page { padding: 0; }
        .account-shell { min-height: 100vh; border: 0; border-radius: 0; }
        .account-form-panel { min-height: 100vh; padding: 26px 20px; }
    }
</style>
