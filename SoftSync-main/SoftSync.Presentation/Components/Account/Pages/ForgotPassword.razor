@page "/Account/ForgotPassword"
@layout AccountLayout
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SoftSync.BLL.Auth
@using SoftSync.Common.Enums
@using SoftSync.DAL.Entities
@inject UserManager<ApplicationUser> UserManager
@inject VerificationCodeService CodeService
@inject IdentityRedirectManager RedirectManager
@inject LocalizationService L

<PageTitle>@L["auth.forgot.title"]</PageTitle>

<h2 class="tw:font-bold tw:mb-2 tw:text-center">@L["auth.forgot.title"]</h2>
<p class="text-muted tw:text-center tw:mb-6">@L["auth.forgot.subtitle"]</p>

<StatusMessage Message="@message" />

<EditForm Model="Input" method="post" OnValidSubmit="SendCode" FormName="forgot-password">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger tw:mb-3" role="alert" />

    <div class="tw:mb-3">
        <label class="form-label tw:font-medium">@L["auth.forgot.channel"]</label>
        <InputRadioGroup @bind-Value="Input.Channel">
            <div class="form-check">
                <InputRadio Value="ResetChannel.Email" class="form-check-input" id="chEmail" />
                <label class="form-check-label" for="chEmail">@L["auth.forgot.viaEmail"]</label>
            </div>
            <div class="form-check">
                <InputRadio Value="ResetChannel.Sms" class="form-check-input" id="chSms" />
                <label class="form-check-label" for="chSms">@L["auth.forgot.viaSms"]</label>
            </div>
        </InputRadioGroup>
    </div>

    <div class="tw:mb-4">
        <label class="form-label tw:font-medium">@L["auth.forgot.destination"]</label>
        <InputText @bind-Value="Input.Destination" class="form-control form-control-lg" placeholder="@L["auth.forgot.destinationPlaceholder"]" />
        <ValidationMessage For="() => Input.Destination" class="text-danger" />
    </div>

    <button type="submit" class="ss-btn-primary tw:w-full tw:py-3 tw:text-lg">@L["auth.sendCode"]</button>
</EditForm>

<div class="tw:text-center tw:mt-4 tw:text-sm">
    <a href="Account/Login">@L["auth.backToLogin"]</a>
</div>

@code {
    private string? message;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = new();

    private async Task SendCode()
    {
        var isEmail = Input.Channel == ResetChannel.Email;

        var user = isEmail
            ? await UserManager.FindByEmailAsync(Input.Destination)
            : UserManager.Users.FirstOrDefault(u => u.PhoneNumber == Input.Destination);

        // Don't reveal whether the account exists — but only send if it does.
        if (user is not null)
        {
            var purpose = isEmail ? VerificationPurpose.PasswordResetEmail : VerificationPurpose.PasswordResetSms;
            try
            {
                await CodeService.IssueAsync(purpose, Input.Destination, user.Id);
            }
            catch (InvalidOperationException ex)
            {
                message = "Error: " + ex.Message;
                return;
            }
        }

        RedirectManager.RedirectTo("Account/ResetPassword",
            new Dictionary<string, object?>
            {
                ["channel"] = Input.Channel.ToString(),
                ["destination"] = Input.Destination
            });
    }

    public enum ResetChannel { Email, Sms }

    private sealed class InputModel
    {
        public ResetChannel Channel { get; set; } = ResetChannel.Email;

        [Required(ErrorMessage = "Vui lòng nhập email hoặc số điện thoại.")]
        public string Destination { get; set; } = "";
    }
}
