@page "/Account/ResetPassword"
@layout AccountLayout
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SoftSync.BLL.Auth
@using SoftSync.Common.Enums
@using SoftSync.DAL.Entities
@inject UserManager<ApplicationUser> UserManager
@inject VerificationCodeService CodeService
@inject IdentityRedirectManager RedirectManager
@inject LocalizationService L

<PageTitle>@L["auth.reset.title"]</PageTitle>

<h2 class="tw:font-bold tw:mb-2 tw:text-center">@L["auth.reset.title"]</h2>
<p class="text-muted tw:text-center tw:mb-6">@L["auth.reset.subtitle"]</p>

<StatusMessage Message="@message" />

<EditForm Model="Input" method="post" OnValidSubmit="Reset" FormName="reset-password">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger tw:mb-3" role="alert" />

    <div class="tw:mb-3">
        <label class="form-label tw:font-medium">@L["auth.enterCode"]</label>
        <InputText @bind-Value="Input.Code" class="form-control form-control-lg" inputmode="numeric" autocomplete="one-time-code" />
        <ValidationMessage For="() => Input.Code" class="text-danger" />
    </div>
    <div class="tw:mb-3">
        <label class="form-label tw:font-medium">@L["auth.newPassword"]</label>
        <InputText type="password" @bind-Value="Input.Password" class="form-control form-control-lg" autocomplete="new-password" />
        <ValidationMessage For="() => Input.Password" class="text-danger" />
    </div>
    <div class="tw:mb-4">
        <label class="form-label tw:font-medium">@L["auth.confirmPassword"]</label>
        <InputText type="password" @bind-Value="Input.ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
        <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
    </div>

    <button type="submit" class="ss-btn-primary tw:w-full tw:py-3 tw:text-lg">@L["auth.reset.submit"]</button>
</EditForm>

<div class="tw:text-center tw:mt-4 tw:text-sm">
    <a href="Account/Login">@L["auth.backToLogin"]</a>
</div>

@code {
    private string? message;

    [SupplyParameterFromForm] private InputModel Input { get; set; } = new();
    [SupplyParameterFromQuery] private string? Channel { get; set; }
    [SupplyParameterFromQuery] private string? Destination { get; set; }

    private async Task Reset()
    {
        if (string.IsNullOrEmpty(Destination) || string.IsNullOrEmpty(Channel))
        {
            message = "Error: " + L["auth.error.resetContextMissing"];
            return;
        }

        var isEmail = string.Equals(Channel, "Email", StringComparison.OrdinalIgnoreCase);
        var purpose = isEmail ? VerificationPurpose.PasswordResetEmail : VerificationPurpose.PasswordResetSms;

        var verify = await CodeService.VerifyAsync(purpose, Destination, Input.Code);
        if (verify != VerificationResult.Success)
        {
            message = "Error: " + MapError(verify);
            return;
        }

        var user = isEmail
            ? await UserManager.FindByEmailAsync(Destination)
            : UserManager.Users.FirstOrDefault(u => u.PhoneNumber == Destination);
        if (user is null)
        {
            message = "Error: " + L["auth.error.invalidLogin"];
            return;
        }

        // Code verified — use Identity's own token to actually change the password.
        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, Input.Password);

        if (result.Succeeded)
        {
            RedirectManager.RedirectToWithStatus(
                "Account/Login", L["auth.reset.success"], HttpContext);
        }
        else
        {
            message = "Error: " + string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    private string MapError(VerificationResult result) => result switch
    {
        VerificationResult.Expired => L["auth.error.codeExpired"],
        VerificationResult.TooManyAttempts => L["auth.error.tooManyAttempts"],
        VerificationResult.NotFound => L["auth.error.codeNotFound"],
        _ => L["auth.error.codeInvalid"]
    };

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Vui lòng nhập mã.")]
        public string Code { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập mật khẩu mới.")]
        [StringLength(100, ErrorMessage = "Mật khẩu phải từ {2} đến {1} ký tự.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare(nameof(Password), ErrorMessage = "Mật khẩu nhập lại không khớp.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
