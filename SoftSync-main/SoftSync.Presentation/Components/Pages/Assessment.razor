@page "/assessment/{UserId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IAssessmentService AssessmentService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<div class="max-800 tw:mx-auto">
    @if (storageRestored && questions is not null && questions.Count > 0)
    {
        <StepIndicator CurrentStep="@(currentQuestionIndex + 1)" TotalSteps="@questions.Count" />
    }

    @if (questions == null || !storageRestored)
    {
        <div class="tw:text-center tw:py-12">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="tw:mt-4">@L["assessment.preparing"]</p>
        </div>
    }
    else if (questions.Count == 0)
    {
        <div class="ss-card tw:p-12 tw:text-center">
            <i class="bi bi-exclamation-circle tw:text-4xl text-warning"></i>
            <p class="tw:mt-4 tw:mb-6">@L["assessment.noQuestions"]</p>
            <button class="ss-btn-primary tw:px-8" @onclick="ReloadQuestionsAsync">
                <i class="bi bi-arrow-clockwise tw:me-2"></i>@L["assessment.retry"]
            </button>
        </div>
    }
    else if (currentQuestionIndex < questions.Count)
    {
        var q = questions[currentQuestionIndex];
        <div class="ss-card tw:p-12">
            <div class="tw:flex tw:justify-between tw:items-center tw:mb-4">
                <span class="badge bg-primary tw:px-4 tw:py-2">@L["assessment.question"] @(currentQuestionIndex + 1) @L["assessment.of"] @questions.Count</span>
                <span class="badge bg-light text-primary tw:px-4 tw:py-2"><i class="bi bi-tag tw:me-1"></i>@SkillLabel(q)</span>
            </div>

            <div class="progress tw:mb-6" style="height: 8px; border-radius: 6px;">
                <div class="progress-bar" style="width: @(((currentQuestionIndex) * 100) / questions.Count)%; background: var(--gradient);"></div>
            </div>

            <h3 class="tw:font-bold tw:mb-6">@QuestionLabel(q)</h3>

            @if (MilestoneMessage() is { } milestone)
            {
                <div class="assessment-milestone tw:mb-5">
                    <i class="bi bi-stars tw:me-2"></i>@milestone
                </div>
            }

            <div class="tw:grid tw:gap-4">
                @foreach (var opt in q.Options)
                {
                    <button class="btn btn-outline-primary tw:text-start tw:p-6 tw:text-xl @(selectedOptionId == opt.Id ? "active" : "")"
                            @onclick="() => SelectOptionAsync(opt.Id)">
                        @OptionLabel(opt)
                    </button>
                }
            </div>

            <div class="tw:mt-12 tw:flex tw:justify-between tw:gap-4">
                <button class="btn btn-outline-primary tw:px-8" @onclick="PreviousQuestionAsync" disabled="@(currentQuestionIndex == 0)">
                    <i class="bi bi-arrow-left tw:me-2"></i>@L["assessment.back"]
                </button>
                <button class="ss-btn-primary tw:px-12" @onclick="NextQuestion" disabled="@(selectedOptionId == 0)">
                    @(currentQuestionIndex == questions.Count - 1 ? L["assessment.finish"] : L["assessment.nextQuestion"])
                    @if (currentQuestionIndex < questions.Count - 1)
                    {
                        <i class="bi bi-arrow-right tw:ms-2"></i>
                    }
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="tw:text-center tw:py-12">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="tw:mt-4">@L["assessment.analyzing"]</p>
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    private List<AssessmentQuestionDto>? questions;
    private int currentQuestionIndex = 0;
    private int selectedOptionId = 0;
    private readonly Dictionary<int, int> answers = new();
    private bool storageRestored;

    protected override async Task OnInitializedAsync()
    {
        var signedInUserId = await AuthProvider.GetUserIdAsync();
        if (signedInUserId <= 0)
        {
            Nav.NavigateTo("Account/Login", forceLoad: true);
            return;
        }

        if (UserId <= 0 || UserId != signedInUserId)
            UserId = signedInUserId;

        var existingResults = await AssessmentService.GetLatestResultsAsync(UserId);
        if (existingResults.Any())
        {
            Nav.NavigateTo($"/assessment-complete/{UserId}", true);
            return;
        }

        await LoadQuestionsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || questions is null)
            return;

        if (questions.Count == 0)
        {
            storageRestored = true;
            StateHasChanged();
            return;
        }

        var draft = await JS.InvokeAsync<AssessmentDraft?>("ssAssessment.get", UserId);
        if (!TryRestoreDraft(draft))
            await PersistDraftAsync();

        storageRestored = true;
        StateHasChanged();
    }

    private async Task ReloadQuestionsAsync()
    {
        questions = null;
        storageRestored = false;
        await LoadQuestionsAsync();
        if (questions is { Count: > 0 })
        {
            var draft = await JS.InvokeAsync<AssessmentDraft?>("ssAssessment.get", UserId);
            if (!TryRestoreDraft(draft))
                await PersistDraftAsync();
        }
        storageRestored = true;
    }

    private async Task LoadQuestionsAsync()
    {
        var loadedQuestions = (await AssessmentService.GetAssessmentQuestionsAsync(UserId)).ToList();

        // Shuffle the options of each question so the "best" answer isn't always
        // last (the seed bank is authored A→D = score 1→4). Scoring is unaffected:
        // the server scores by OptionId/ScoreValue, not display position. Done once
        // here so a mid-quiz language toggle re-render doesn't reshuffle.
        var rng = new Random();
        var skillGroups = loadedQuestions
            .GroupBy(q => q.SkillId)
            .Select(group => group.ToList())
            .ToList();

        Shuffle(skillGroups, rng);
        foreach (var group in skillGroups)
        {
            Shuffle(group, rng);
            foreach (var q in group)
            {
                Shuffle(q.Options, rng);
            }
        }

        questions = skillGroups.SelectMany(group => group).ToList();
    }

    private bool TryRestoreDraft(AssessmentDraft? draft)
    {
        if (draft is null || questions is null ||
            draft.QuestionIds.Count != questions.Count ||
            draft.QuestionIds.ToHashSet().SetEquals(questions.Select(q => q.Id)) == false)
            return false;

        var questionLookup = questions.ToDictionary(q => q.Id);
        questions = draft.QuestionIds.Select(id => questionLookup[id]).ToList();

        foreach (var question in questions)
        {
            if (!draft.OptionIds.TryGetValue(question.Id, out var savedOptionIds) ||
                savedOptionIds.Count != question.Options.Count ||
                !savedOptionIds.ToHashSet().SetEquals(question.Options.Select(o => o.Id)))
                continue;

            var optionLookup = question.Options.ToDictionary(o => o.Id);
            question.Options = savedOptionIds.Select(id => optionLookup[id]).ToList();
        }

        answers.Clear();
        foreach (var answer in draft.Answers)
        {
            if (questionLookup.TryGetValue(answer.Key, out var question) &&
                question.Options.Any(option => option.Id == answer.Value))
                answers[answer.Key] = answer.Value;
        }

        currentQuestionIndex = Math.Clamp(draft.CurrentQuestionIndex, 0, questions.Count - 1);
        RestoreCurrentAnswer();
        return true;
    }

    private async Task PersistDraftAsync()
    {
        if (questions is null || questions.Count == 0)
            return;

        var draft = new AssessmentDraft
        {
            CurrentQuestionIndex = currentQuestionIndex,
            QuestionIds = questions.Select(q => q.Id).ToList(),
            OptionIds = questions.ToDictionary(q => q.Id, q => q.Options.Select(o => o.Id).ToList()),
            Answers = new Dictionary<int, int>(answers)
        };
        await JS.InvokeVoidAsync("ssAssessment.set", UserId, draft);
    }

    private static void Shuffle<T>(IList<T> items, Random rng)
    {
        for (var i = items.Count - 1; i > 0; i--)
        {
            var j = rng.Next(i + 1);
            (items[i], items[j]) = (items[j], items[i]);
        }
    }

    // Pick the localized text, falling back to English when a Vietnamese
    // string is missing. The page inherits LocalizedComponentBase, so a
    // mid-quiz language toggle re-renders and swaps these instantly.
    private bool IsVi => L.Current == SoftSync.Presentation.Services.AppLanguage.Vi;
    private string Tx(string en, string vi) => IsVi ? vi : en;

    private string QuestionLabel(AssessmentQuestionDto q) =>
        IsVi && !string.IsNullOrWhiteSpace(q.QuestionTextVi) ? q.QuestionTextVi : q.QuestionText;

    private string OptionLabel(AssessmentOptionDto o) =>
        IsVi && !string.IsNullOrWhiteSpace(o.OptionTextVi) ? o.OptionTextVi : o.OptionText;

    private string SkillLabel(AssessmentQuestionDto q) =>
        IsVi && !string.IsNullOrWhiteSpace(q.SkillNameVi) ? q.SkillNameVi : q.SkillName;

    private string? MilestoneMessage()
    {
        if (questions is null || currentQuestionIndex >= questions.Count)
            return null;

        var current = questions[currentQuestionIndex];
        var positionInSkill = questions
            .Take(currentQuestionIndex + 1)
            .Count(q => q.SkillId == current.SkillId);

        if (positionInSkill == 1 && currentQuestionIndex > 0)
        {
            var previous = questions[currentQuestionIndex - 1];
            return L["assessment.milestone.skillComplete"]
                .Replace("{skill}", SkillLabel(previous), StringComparison.Ordinal);
        }

        var totalInSkill = questions.Count(q => q.SkillId == current.SkillId);
        var oneThird = (int)Math.Ceiling(totalInSkill / 3d);
        var twoThirds = (int)Math.Ceiling(totalInSkill * 2d / 3d);

        if (positionInSkill == totalInSkill)
            return Tx($"Question {positionInSkill}/{totalInSkill} for this skill — you've got this!",
                $"Câu {positionInSkill}/{totalInSkill} của kỹ năng này — cố lên nào!");
        if (positionInSkill == oneThird || positionInSkill == twoThirds)
            return Tx($"You are on question {positionInSkill}/{totalInSkill} for this skill. Keep going! 💪",
                $"Bạn đang ở câu {positionInSkill}/{totalInSkill} của kỹ năng này, tiếp tục nhé! 💪");
        return null;
    }

    private async Task SelectOptionAsync(int id)
    {
        selectedOptionId = id;
        SaveCurrentAnswer();
        await PersistDraftAsync();
    }

    private async Task PreviousQuestionAsync()
    {
        SaveCurrentAnswer();
        if (currentQuestionIndex == 0)
            return;

        currentQuestionIndex--;
        RestoreCurrentAnswer();
        await PersistDraftAsync();
    }

    private void SaveCurrentAnswer()
    {
        if (questions is null || selectedOptionId == 0)
            return;

        answers[questions[currentQuestionIndex].Id] = selectedOptionId;
    }

    private void RestoreCurrentAnswer()
    {
        var questionId = questions![currentQuestionIndex].Id;
        selectedOptionId = answers.TryGetValue(questionId, out var optionId) ? optionId : 0;
    }

    private async Task NextQuestion()
    {
        SaveCurrentAnswer();
        
        if (currentQuestionIndex < questions!.Count - 1)
        {
            currentQuestionIndex++;
            RestoreCurrentAnswer();
            await PersistDraftAsync();
        }
        else
        {
            currentQuestionIndex++; // Move to processing state
            var submittedAnswers = answers
                .Select(answer => new UserAnswerDto { QuestionId = answer.Key, OptionId = answer.Value })
                .ToList();
            await AssessmentService.SubmitAssessmentAsync(UserId, submittedAnswers);
            await JS.InvokeVoidAsync("ssAssessment.clear", UserId);
            Nav.NavigateTo($"/assessment-result/{UserId}");
        }
    }

    private sealed class AssessmentDraft
    {
        public int CurrentQuestionIndex { get; set; }
        public List<int> QuestionIds { get; set; } = [];
        public Dictionary<int, List<int>> OptionIds { get; set; } = [];
        public Dictionary<int, int> Answers { get; set; } = [];
    }
}

<style>
    .max-800 { max-width: 800px; }
    .btn-outline-primary {
        border: 2px solid #e2e8f0;
        color: var(--text);
        border-radius: 1rem;
    }
    .btn-outline-primary:hover {
        background: #f8fafc;
        border-color: var(--primary);
        color: var(--primary);
    }
    .btn-outline-primary.active {
        background: var(--gradient-soft);
        border-color: var(--primary);
        color: var(--primary);
    }
    .assessment-milestone {
        padding: 0.85rem 1rem;
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 14px;
        background: var(--gradient-soft);
        color: var(--primary);
        font-weight: 700;
    }
</style>
