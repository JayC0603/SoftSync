@page "/time-management-games"
@page "/time-management-games/{InitialTab:int}"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Time Management Lab</PageTitle>
<main class="tm-page">
 <button class="tm-back" @onclick='()=>Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i> Roadmap</button>
 <header class="tm-hero"><div><span>TIME MANAGEMENT LAB</span><h1>Làm chủ thời gian,<br/><em>làm chủ mục tiêu</em></h1><p>Ba thử thách thực tế giúp bạn lập lịch, chọn đúng ưu tiên và phân loại công việc thông minh.</p></div><div class="tm-score"><b>@TotalPoints</b><span>điểm tích lũy</span></div></header>
 <nav class="tm-tabs">@foreach(var g in Games.Select((x,i)=>(x,i))){<button class="@(tab==g.i?"active":"")" @onclick="()=>tab=g.i"><i class="bi @g.x.Icon"></i><span><small>GAME @(g.i+1)</small><b>@g.x.Name</b></span></button>}</nav>

 @if(tab==0){<section class="tm-panel"><header><div><small>GAME 1</small><h2>My Timetable</h2><p>Tạo lịch, nhận nhắc nhở và check-in đúng giờ để tích điểm.</p></div><button class="outline" @onclick="EnableNotifications"><i class="bi bi-bell"></i> Bật nhắc lịch</button></header>
  <div class="tt-grid"><EditForm Model="draft" OnValidSubmit="AddSchedule"><div class="tm-form"><label>Tên công việc<input @bind="draft.Title" placeholder="Ví dụ: Làm assignment" required/></label><label>Ngày<input type="date" @bind="draft.Date" required/></label><div><label>Bắt đầu<input type="time" @bind="draft.Start" required/></label><label>Kết thúc<input type="time" @bind="draft.End" required/></label></div><label>Loại công việc<select @bind="draft.Category"><option>Học tập</option><option>Deadline</option><option>Họp nhóm</option><option>Đi làm</option><option>Nghỉ ngơi</option></select></label><button type="submit"><i class="bi bi-plus-lg"></i> Thêm vào lịch</button></div></EditForm>
  <div class="tt-list">@if(schedules.Count==0){<div class="empty"><i class="bi bi-calendar2-plus"></i><b>Chưa có lịch</b><span>Thêm công việc đầu tiên ở bên trái.</span></div>}@foreach(var item in schedules.OrderBy(x=>x.Start)){<article class="@(item.Completed?"done":"")"><time><b>@item.Start.ToString("HH:mm")</b><span>@item.End.ToString("HH:mm")</span></time><div><small>@item.Category · @item.Start.ToString("dd/MM")</small><h3>@item.Title</h3>@if(item.Completed){<em><i class="bi bi-patch-check-fill"></i> Đã check-in · +10 điểm</em>}else{<label class="checkin"><i class="bi bi-camera"></i> Tải ảnh check-in<InputFile OnChange="e=>CheckIn(item,e)" accept="image/*"/></label>}</div>@if(item.ImageUrl is not null){<img src="@item.ImageUrl" alt="Ảnh check-in"/>}</article>}</div></div>
 </section>}
 else if(tab==1){<section class="tm-panel"><header><div><small>GAME 2</small><h2>Priority Sort</h2><p>Kéo thả để xếp việc cần làm trước lên đầu danh sách.</p></div><button class="outline" @onclick="ResetPriority"><i class="bi bi-arrow-repeat"></i> Đề mới</button></header><div class="sort-layout"><div class="sort-list">@for(var i=0;i<priorityItems.Count;i++){var idx=i;var item=priorityItems[i];<article draggable="true" @ondragstart="()=>dragIndex=idx" @ondragover:preventDefault @ondrop="()=>DropPriority(idx)"><i class="bi bi-grip-vertical"></i><span><small>ƯU TIÊN @(idx+1)</small><b>@item.Text</b></span><em class="@item.Kind">@item.Label</em></article>}</div><aside><h3>Gợi ý suy nghĩ</h3><p><i class="bi bi-exclamation-circle"></i> Việc có deadline gần hoặc giờ cố định nên làm trước.</p><p><i class="bi bi-bullseye"></i> Việc quan trọng cho ngày mai đứng trước mục tiêu tuần sau.</p><p><i class="bi bi-phone"></i> Giải trí nên để sau nhiệm vụ chính.</p><button @onclick="ScorePriority">Chấm thứ tự</button>@if(priorityScore.HasValue){<div class="mini-result"><b>@priorityScore/10</b><span>@priorityFeedback</span></div>}</aside></div></section>}
 else {<section class="tm-panel"><header><div><small>GAME 3</small><h2>Eisenhower Matrix</h2><p>Kéo từng nhiệm vụ vào đúng nhóm quan trọng và khẩn cấp.</p></div><button class="outline" @onclick="ResetMatrix"><i class="bi bi-arrow-repeat"></i> Làm lại</button></header><div class="matrix-source"><b>Nhiệm vụ chưa phân loại</b><div>@foreach(var task in matrixTasks.Where(x=>x.Placed<0)){<span draggable="true" @ondragstart="()=>dragTask=task">@task.Text</span>}</div></div><div class="matrix">@foreach(var q in Quadrants.Select((x,i)=>(x,i))){<section class="q-@q.i" @ondragover:preventDefault @ondrop="()=>DropMatrix(q.i)"><header><span>@(q.i+1)</span><div><b>@q.x.Title</b><small>@q.x.Action</small></div></header>@foreach(var task in matrixTasks.Where(x=>x.Placed==q.i)){<p draggable="true" @ondragstart="()=>dragTask=task">@task.Text</p>}</section>}</div><div class="matrix-actions"><button @onclick="ScoreMatrix">Chấm ma trận</button>@if(matrixScore.HasValue){<b>@matrixScore/10 · @matrixFeedback</b>}</div></section>}
</main>

@code{
 [Parameter] public int InitialTab{get;set;} private int tab,TotalPoints,dragIndex=-1;private IJSObjectReference? module;private Timer? timer;private ScheduleDraft draft=new();private readonly List<ScheduleItem>schedules=[];
 private readonly GameInfo[] Games=[new("My Timetable","bi-calendar2-week"),new("Priority Sort","bi-sort-down"),new("Eisenhower Matrix","bi-grid-1x2")];
 protected override async Task OnAfterRenderAsync(bool first){if(first){module=await JS.InvokeAsync<IJSObjectReference>("import","/js/timeManagementGames.js");timer=new Timer(async _=>await CheckReminders(),null,TimeSpan.Zero,TimeSpan.FromSeconds(30));}}
 private async Task EnableNotifications(){if(module is not null)await module.InvokeAsync<string>("requestNotifications");}
 private void AddSchedule(){if(string.IsNullOrWhiteSpace(draft.Title))return;var start=draft.Date.Date+draft.Start.ToTimeSpan();var end=draft.Date.Date+draft.End.ToTimeSpan();if(end<=start)return;schedules.Add(new(draft.Title,draft.Category,start,end));draft=new(){Date=draft.Date,Start=draft.Start,End=draft.End};}
 private async Task CheckReminders(){var now=DateTime.Now;foreach(var x in schedules.Where(x=>!x.Notified&&!x.Completed&&x.Start<=now&&x.End>now)){x.Notified=true;if(module is not null)await module.InvokeVoidAsync("notify","Đến giờ: "+x.Title,$"{x.Start:HH:mm}–{x.End:HH:mm} · Hãy bắt đầu nhiệm vụ nhé!");}await InvokeAsync(StateHasChanged);}
 private async Task CheckIn(ScheduleItem item,InputFileChangeEventArgs e){var file=e.File;if(file.Size>5*1024*1024)return;using var stream=file.OpenReadStream(5*1024*1024);using var ms=new MemoryStream();await stream.CopyToAsync(ms);item.ImageUrl=$"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";item.Completed=true;var now=DateTime.Now;item.OnTime=now>=item.Start.AddMinutes(-15)&&now<=item.End.AddMinutes(30);var pts=item.OnTime?10:5;TotalPoints+=pts;}
 private List<PriorityItem> priorityItems=[];private int? priorityScore;private string priorityFeedback="";protected override void OnInitialized(){tab=Math.Clamp(InitialTab,0,2);ResetPriority();ResetMatrix();}
 private void ResetPriority(){priorityItems=[new("Lướt TikTok 30 phút",5,"Giải trí","low"),new("Ôn bài kiểm tra tuần sau",4,"Quan trọng","medium"),new("Nộp bài lúc 22h",1,"Deadline","urgent"),new("Chuẩn bị thuyết trình ngày mai",3,"Ngày mai","high"),new("Họp nhóm lúc 19h",2,"Giờ cố định","urgent")];priorityScore=null;}
 private void DropPriority(int target){if(dragIndex<0||dragIndex==target)return;var x=priorityItems[dragIndex];priorityItems.RemoveAt(dragIndex);priorityItems.Insert(target,x);dragIndex=-1;}
 private void ScorePriority(){var errors=priorityItems.Select((x,i)=>Math.Abs(x.Correct-(i+1))).Sum();priorityScore=Math.Max(0,10-errors);priorityFeedback=priorityScore>=9?"Bạn ưu tiên rất hợp lý!":priorityScore>=6?"Khá tốt, hãy chú ý deadline và giờ cố định.":"Hãy phân biệt việc gấp với việc gây xao nhãng.";TotalPoints+=priorityScore.Value;}
 private List<MatrixTask> matrixTasks=[];private MatrixTask? dragTask;private int? matrixScore;private string matrixFeedback="";private readonly Quadrant[] Quadrants=[new("Quan trọng · Khẩn cấp","Làm ngay"),new("Quan trọng · Không khẩn cấp","Lên kế hoạch"),new("Không quan trọng · Khẩn cấp","Xử lý nhanh/ủy quyền"),new("Không quan trọng · Không khẩn cấp","Hạn chế")];
 private void ResetMatrix(){matrixTasks=[new("Nộp bài tối nay",0),new("Chuẩn bị CV thực tập",1),new("Lướt mạng xã hội",3),new("Họp nhóm lúc 19h",0),new("Ôn bài kiểm tra tuần sau",1),new("Trả lời tin nhắn quảng cáo",3)];matrixScore=null;}
 private void DropMatrix(int q){if(dragTask is null)return;dragTask.Placed=q;dragTask=null;}
 private void ScoreMatrix(){var correct=matrixTasks.Count(x=>x.Placed==x.Correct);matrixScore=(int)Math.Round(correct/(double)matrixTasks.Count*10);matrixFeedback=correct==matrixTasks.Count?"Phân loại chính xác!":"Đúng "+correct+"/"+matrixTasks.Count+" nhiệm vụ.";TotalPoints+=matrixScore.Value;}
 public async ValueTask DisposeAsync(){timer?.Dispose();if(module is not null)await module.DisposeAsync();}
 private sealed record GameInfo(string Name,string Icon);private sealed class ScheduleDraft{public string Title{get;set;}="";public string Category{get;set;}="Học tập";public DateTime Date{get;set;}=DateTime.Today;public TimeOnly Start{get;set;}=new(19,0);public TimeOnly End{get;set;}=new(20,0);}private sealed class ScheduleItem(string title,string category,DateTime start,DateTime end){public string Title{get;}=title;public string Category{get;}=category;public DateTime Start{get;}=start;public DateTime End{get;}=end;public bool Completed{get;set;}public bool OnTime{get;set;}public bool Notified{get;set;}public string? ImageUrl{get;set;}}private sealed record PriorityItem(string Text,int Correct,string Label,string Kind);private sealed class MatrixTask(string text,int correct){public string Text{get;}=text;public int Correct{get;}=correct;public int Placed{get;set;}=-1;}private sealed record Quadrant(string Title,string Action);
}

<style>
.tm-page{--p:#6847eb;--ink:#19163d;--muted:#6b7280;max-width:1280px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:var(--ink)}button,input,select{font:inherit}.tm-back{border:0;background:none;color:#747b8c;font-weight:800}.tm-hero{display:flex;justify-content:space-between;align-items:center;margin:1rem 0;padding:clamp(1.5rem,4vw,3rem);border-radius:28px;background:radial-gradient(circle at 85% 10%,#f9d8ff,transparent 15rem),linear-gradient(135deg,#fff,#eee9ff);box-shadow:0 22px 55px #4c1d9518}.tm-hero>div>span,.tm-panel small{color:var(--p);font-size:.65rem;font-weight:900;letter-spacing:.09em}.tm-hero h1{margin:.5rem 0;font-size:clamp(2.2rem,5vw,3.8rem);line-height:1.08}.tm-hero em{color:var(--p);font-style:normal}.tm-hero p{color:var(--muted)}.tm-score{display:grid;place-items:center;min-width:130px;height:130px;border-radius:50%;background:#fff}.tm-score b{font-size:2.2rem;color:var(--p)}.tm-score span{font-size:.65rem}.tm-tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem;margin-bottom:1rem}.tm-tabs button{display:flex;align-items:center;gap:.7rem;padding:1rem;text-align:left;color:var(--ink);border:1px solid #ded8f5;border-radius:16px;background:#fff}.tm-tabs button>i{font-size:1.4rem;color:var(--p)}.tm-tabs small,.tm-tabs b{display:block}.tm-tabs small{font-size:.58rem}.tm-tabs .active{color:#fff;background:linear-gradient(135deg,#6847eb,#8b5cf6)}.tm-tabs .active i{color:#fff}.tm-panel{padding:clamp(1rem,3vw,1.8rem);border:1px solid #ded8f5;border-radius:24px;background:#fff}.tm-panel>header{display:flex;justify-content:space-between;gap:1rem}.tm-panel h2{margin:.2rem 0}.tm-panel header p{margin:.2rem 0 1rem;color:var(--muted)}.outline{height:max-content;padding:.65rem .8rem;color:var(--p);border:1px solid #cfc5f5;border-radius:10px;background:#fff;font-weight:800}.tt-grid{display:grid;grid-template-columns:320px 1fr;gap:1rem}.tm-form{display:grid;gap:.7rem;padding:1rem;border-radius:15px;background:#f8f7fc}.tm-form label{display:grid;gap:.3rem;font-size:.7rem;font-weight:800}.tm-form input,.tm-form select{padding:.65rem;border:1px solid #dcd7ea;border-radius:9px}.tm-form>div{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}.tm-form button,.sort-layout aside button,.matrix-actions button{padding:.7rem;color:#fff;border:0;border-radius:10px;background:var(--p);font-weight:800}.tt-list{display:grid;gap:.6rem}.tt-list article{display:grid;grid-template-columns:70px 1fr auto;gap:.8rem;align-items:center;padding:.8rem;border:1px solid #ebe7f8;border-radius:14px}.tt-list time{display:grid;text-align:center}.tt-list time b{color:var(--p)}.tt-list time span{font-size:.65rem}.tt-list h3{margin:.2rem 0}.tt-list em{color:#16865e;font-size:.7rem}.tt-list img{width:70px;height:55px;object-fit:cover;border-radius:9px}.checkin{display:inline-flex;gap:.4rem;color:var(--p);font-size:.7rem;font-weight:800;cursor:pointer}.checkin input{display:none}.done{background:#f0fbf6}.empty{display:grid;place-items:center;min-height:180px;color:#8b91a0}.empty i{font-size:2rem}.sort-layout{display:grid;grid-template-columns:1fr 280px;gap:1rem}.sort-list{display:grid;gap:.5rem}.sort-list article{display:grid;grid-template-columns:25px 1fr auto;align-items:center;padding:1rem;border:1px solid #e4def7;border-radius:13px;cursor:grab}.sort-list small,.sort-list b{display:block}.sort-list small{font-size:.55rem}.sort-list em{padding:.35rem .5rem;border-radius:7px;font-size:.65rem;font-style:normal;background:#eeeaff}.sort-list .urgent{color:#b42318;background:#fee4e2}.sort-layout aside{padding:1rem;border-radius:14px;background:#f8f7fc}.sort-layout aside p{font-size:.75rem;line-height:1.5}.mini-result{margin-top:1rem}.mini-result b{font-size:1.8rem;color:var(--p)}.mini-result span{display:block;font-size:.72rem}.matrix-source{margin-bottom:1rem;padding:1rem;border-radius:14px;background:#f8f7fc}.matrix-source>div{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem}.matrix-source span,.matrix section p{padding:.55rem .7rem;border:1px solid #dfd8f4;border-radius:9px;background:#fff;font-size:.72rem;cursor:grab}.matrix{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}.matrix>section{min-height:170px;padding:1rem;border-radius:15px}.matrix section header{display:flex;gap:.6rem}.matrix section header>span{display:grid;place-items:center;width:30px;height:30px;border-radius:8px;background:#fff}.matrix section small{display:block}.q-0{background:#ffe8e5}.q-1{background:#e9f1ff}.q-2{background:#fff4d9}.q-3{background:#eff1f5}.matrix-actions{display:flex;align-items:center;gap:1rem;margin-top:1rem}.matrix-actions b{color:var(--p)}@@media(max-width:800px){.tm-hero{align-items:start;flex-direction:column}.tm-tabs,.tt-grid,.sort-layout{grid-template-columns:1fr}.matrix{grid-template-columns:1fr}}
</style>
