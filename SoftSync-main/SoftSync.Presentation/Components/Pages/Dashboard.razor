@page "/dashboard"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IUserService UserService
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject IAssessmentService AssessmentService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@if (user is null)
{
    <div class="dash-loading">@L["dashboard.loading"]</div>
}
else
{
    <div class="dash-shell">
        <aside class="dash-side">
            <strong>SoftSync<br /><span>Space</span></strong>
            <nav>
                <button class="active"><i class="bi bi-house-door-fill"></i><span>Home</span></button>
                <button @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-robot"></i><span>AI Assistant</span></button>
                <button @onclick='() => Nav.NavigateTo("/case-studies")'><i class="bi bi-book"></i><span>@L["dashboard.scenarios"]</span></button>
                <button @onclick='() => Nav.NavigateTo("/progress")'><i class="bi bi-graph-up-arrow"></i><span>@L["dashboard.progress"]</span></button>
                <button @onclick='() => Nav.NavigateTo("/community")'><i class="bi bi-people"></i><span>Community</span></button>
                <button @onclick='() => Nav.NavigateTo("/settings")'><i class="bi bi-gem"></i><span>Premium</span></button>
            </nav>
            <div class="side-premium"><i class="bi bi-stars"></i><b>Premium</b><small>Unlock your full learning experience.</small><button @onclick='() => Nav.NavigateTo("/settings")'>Upgrade</button></div>
        </aside>
        <header class="dash-welcome">
            <div><span>@L["dashboard.eyebrow"]</span><h1>@L["dashboard.hello"], @FirstName(user.PublicName)! 👋</h1><p>@L["dashboard.subtitle"]</p></div>
            <div class="dash-hero-mascot"><div><strong>@L["dashboard.continueTitle"]</strong><button @onclick='() => Nav.NavigateTo("/roadmap")'>@L["dashboard.continueLearning"] →</button></div><img src="/images/syncy-robot.png" alt="SYNCY" /></div>
        </header>

        <section class="dash-stats">
            <div><i class="bi bi-stars xp"></i><span><strong>@user.ExperiencePoints</strong>@L["dashboard.xp"]</span></div>
            <div><i class="bi bi-graph-up-arrow level"></i><span><strong>@user.Level</strong>@L["dashboard.level"]</span></div>
            <div><i class="bi bi-check2-circle done"></i><span><strong>@completedItems/@totalItems</strong>@L["dashboard.completed"]</span></div>
            <div><i class="bi bi-fire streak"></i><span><strong>0</strong>@L["dashboard.streak"]</span></div>
        </section>

        <div class="dash-grid">
            <section class="dash-card dash-roadmap">
                <div class="dash-card-head"><h2>@L["dashboard.roadmap"]</h2><button @onclick='() => Nav.NavigateTo("/roadmap")'>@L["dashboard.viewDetails"] →</button></div>
                @if (progress.Count == 0)
                {
                    <div class="dash-empty"><i class="bi bi-compass"></i><p>@L["dashboard.noProgress"]</p><button @onclick='() => Nav.NavigateTo($"/assessment/{user.Id}")'>@L["dashboard.startAssessment"]</button></div>
                }
                else
                {
                    @foreach (var item in progress.Take(5))
                    {
                        <div class="skill-row"><div><span>@item.SkillName</span><b>@item.PercentComplete%</b></div><div class="skill-track"><i style="width:@item.PercentComplete%"></i></div></div>
                    }
                }
            </section>

            <section class="dash-card dash-today">
                <div class="dash-card-head"><h2>✨ @L["dashboard.today"]</h2></div>
                <button class="task" @onclick='() => Nav.NavigateTo($"/assessment/{user.Id}")'><i class="bi bi-clipboard-check"></i><span>@L["dashboard.taskAssessment"]</span><b>›</b></button>
                <button class="task" @onclick='() => Nav.NavigateTo("/case-studies")'><i class="bi bi-controller"></i><span>@L["dashboard.taskScenario"]</span><b>›</b></button>
                <button class="task" @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-robot"></i><span>@L["dashboard.taskAssistant"]</span><b>›</b></button>
                <button class="dash-primary" @onclick='() => Nav.NavigateTo("/roadmap")'>@L["dashboard.startNow"]</button>
            </section>

            <aside class="dash-card dash-mentor">
                <div class="dash-card-head"><h2>@L["dashboard.mentor"]</h2></div>
                <div class="mentor-profile"><img src="/images/syncy-robot.png" alt="Nova" /><div><strong>Nova</strong><span>Communication Mentor</span></div></div>
                <blockquote>“@L["dashboard.mentorQuote"]”</blockquote>
                <button class="mentor-chat" @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-chat-dots"></i> @L["dashboard.chatNova"]</button>
            </aside>
        </div>

        <section class="dash-bottom">
            <div class="dash-card weekly"><div class="dash-card-head"><h2>📈 @L["dashboard.weekly"]</h2></div>@foreach(var item in progress.Take(3)){<div class="mini-progress"><span>@item.SkillName</span><div><i style="width:@item.PercentComplete%"></i></div><b>@item.PercentComplete%</b></div>}</div>
            <div class="dash-card achievements"><div class="dash-card-head"><h2>🏆 @L["dashboard.achievements"]</h2></div><div class="badge-row"><span>⭐<small>First Step</small></span><span>🔥<small>Streak</small></span><span>🎓<small>Learner</small></span><span>🏆<small>Listener</small></span></div></div>
        </section>
    </div>

    <aside class="dash-syncy @(syncyOpen ? "open" : "")">
        @if (syncyOpen)
        {
            <div class="dash-syncy-panel">
                <div class="dash-syncy-head">
                    <img src="/images/syncy-robot.png" alt="SYNCY" />
                    <div><strong>SYNCY AI</strong><span>@L["chatbot.tagline"]</span></div>
                    <button title="Close" @onclick="() => syncyOpen = false"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="dash-syncy-message"><strong>👋 @L["chatbot.welcome.title"]</strong><p>@L["chatbot.welcome.desc"]</p></div>
                <div class="dash-syncy-actions">
                    <button @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-robot"></i> AI Chat</button>
                    <button @onclick='() => Nav.NavigateTo($"/assessment/{user.Id}")'><i class="bi bi-clipboard-check"></i> @L["dashboard.assessment"]</button>
                    <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-signpost-split"></i> @L["dashboard.roadmap"]</button>
                    <button @onclick='() => Nav.NavigateTo("/community")'><i class="bi bi-people"></i> Community Hub</button>
                </div>
            </div>
        }
        else
        {
            <button class="dash-syncy-fab" title="SYNCY AI" @onclick="() => syncyOpen = true">
                <img src="/images/syncy-robot.png" alt="SYNCY AI" /><span></span><b>@L["dashboard.needHelp"]<small>@L["dashboard.chatSyncy"]</small></b>
            </button>
        }
    </aside>
}

@code {
    private UserDto? user; private List<ProgressDto> progress = []; private int completedItems; private int totalItems; private bool syncyOpen;
    protected override async Task OnInitializedAsync()
    {
        var id = await AuthProvider.GetUserIdAsync(); user = await UserService.GetUserByIdAsync(id);
        if (user is null || user.Age <= 0 || string.IsNullOrWhiteSpace(user.Goal)) { Nav.NavigateTo("/profile-setup", true); return; }
        progress = (await ProgressService.GetUserProgressAsync(id)).ToList();
        var roadmap = await RoadmapService.GetUserRoadmapAsync(id); totalItems = roadmap.Items.Count; completedItems = roadmap.Items.Count(x => x.IsCompleted);
    }
    private static string FirstName(string value) => value.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? value;
}

