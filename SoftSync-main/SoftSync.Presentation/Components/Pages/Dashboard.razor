@page "/dashboard"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Services
@inject IUserService UserService
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@if (user is null)
{
    <div class="dash-loading"><span></span>@T("Đang chuẩn bị không gian học tập...", "Preparing your learning space...")</div>
}
else
{
    <main class="dash-home">
        <section class="dash-hero">
            <div class="dash-hero-copy">
                <h1>@T("Chào buổi sáng", "Good morning"), @FirstName(user.PublicName)! <span>👋</span></h1>
                <p>@T("Hôm nay bạn muốn cải thiện kỹ năng nào?", "Which skill would you like to improve today?")</p>
                <div class="dash-hero-actions">
                    <button class="primary" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-play-circle-fill"></i>@T("Tiếp tục bài học", "Continue lesson")</button>
                    <button @onclick="NavigateToAssessment"><i class="bi bi-graph-up-arrow"></i>@T("Đánh giá kỹ năng", "Assess skills")</button>
                </div>
            </div>
            <div class="dash-syncy">
                <div class="syncy-bubble">@T("Xin chào! Mình là", "Hi! I'm")<strong>Syncy</strong><span>@T("Mình ở đây để đồng hành cùng bạn mỗi ngày!", "I'm here to learn with you every day!")</span></div>
                <img src="/images/syncy-robot.png" alt="Syncy AI" />
            </div>
        </section>

        <section class="journey-card">
            <div class="journey-art"><i class="bi bi-chat-heart-fill"></i><span><i class="bi bi-chat-dots-fill"></i></span></div>
            <div class="journey-copy">
                <small>@T("Tiếp tục hành trình", "Continue your journey")</small>
                <h2>@CurrentSkill</h2>
                <p><i class="bi bi-play-btn-fill"></i> @T("Bài tiếp theo", "Next lesson"): @CurrentTitle</p>
                <div class="journey-progress"><span style="width:@CurrentPercent%"></span></div><b>@CurrentPercent%</b>
            </div>
            <div class="journey-action"><span><i class="bi bi-stopwatch"></i> 15 @T("phút", "min")</span><button @onclick='() => Nav.NavigateTo("/roadmap")'>@T("Học tiếp", "Continue") <i class="bi bi-chevron-right"></i></button></div>
        </section>

        <div class="dash-content">
            <div class="dash-left">
                <section class="quick-section">
                    <h3>@T("Khám phá nhanh", "Quick explore")</h3>
                    <div class="quick-links">
                        <button @onclick="NavigateToAssessment"><i class="bi bi-clipboard2-check-fill purple"></i><strong>@T("Đánh giá", "Assessment")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-map-fill blue"></i><strong>@T("Lộ trình", "Roadmap")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/case-studies")'><i class="bi bi-bullseye teal"></i><strong>@T("Luyện tập", "Practice")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-patch-question-fill purple"></i><strong>@T("Hỏi Syncy", "Ask Syncy")</strong><b>›</b></button>
                    </div>
                </section>

                <section class="recommend-section">
                    <h3>@T("Có thể bạn quan tâm", "You may be interested")</h3>
                    <div class="course-cards">
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-person-video3 blue"></i><span><strong>@T("Thuyết trình tự tin", "Confident presenting")</strong><small>@T("Trình bày ý tưởng rõ ràng, thuyết phục và cuốn hút.", "Present ideas clearly and persuasively.")</small><em><i class="bi bi-clock"></i> 20 @T("phút", "min")</em></span></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-people-fill teal"></i><span><strong>@T("Làm việc nhóm hiệu quả", "Effective teamwork")</strong><small>@T("Hợp tác, chia sẻ và đạt mục tiêu chung.", "Collaborate and achieve shared goals.")</small><em><i class="bi bi-clock"></i> 18 @T("phút", "min")</em></span></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-head-side-heart-fill purple"></i><span><strong>@T("Quản lý cảm xúc", "Emotion management")</strong><small>@T("Nhận diện và kiểm soát cảm xúc để phát triển bản thân.", "Recognize and regulate your emotions.")</small><em><i class="bi bi-clock"></i> 16 @T("phút", "min")</em></span></button>
                    </div>
                </section>
            </div>

            <section class="week-card">
                <header><h3>@T("Kết quả tuần này", "This week's results")</h3><button @onclick='() => Nav.NavigateTo("/progress")'>@T("Xem chi tiết", "View details") <i class="bi bi-chevron-right"></i></button></header>
                <div class="week-stats">
                    <div><i class="bi bi-book-fill purple"></i><span><strong>@completedItems</strong><small>@T("bài học", "lessons")</small></span></div>
                    <div><i class="bi bi-star-fill gold"></i><span><strong>@user.ExperiencePoints</strong><small>XP</small></span></div>
                    <div><i class="bi bi-fire orange"></i><span><small>@T("Chuỗi", "Streak")</small><strong class="orange-text">4 @T("ngày", "days")</strong></span></div>
                </div>
                <div class="week-days">
                    @foreach (var day in WeekDays)
                    {
                        <div><small>@day</small><span class="@(day is "T2" or "T3" or "T4" or "T5" ? "done" : "")">@(day is "T2" or "T3" or "T4" or "T5" ? "✓" : "")</span></div>
                    }
                    <i class="bi bi-fire"></i>
                </div>
            </section>
        </div>

        <section class="mentor-bar">
            <header><div><h3><i class="bi bi-stars"></i> @T("Đội ngũ cố vấn đồng hành", "Mentors accompanying you")</h3><p>@T("Những chuyên gia giàu kinh nghiệm luôn sẵn sàng hỗ trợ hành trình phát triển của bạn.", "Experienced experts are ready to support your development journey.")</p></div></header>
            <div class="mentor-items mentor-cards">
                <article>
                    <div class="mentor-photo"><span></span><img src="/images/mentor-nguyen-hoang-van-anh.png" alt="Nguyễn Hoàng Vân Anh" /></div>
                    <div class="mentor-info"><em><i class="bi bi-stars"></i> @T("Cố vấn chuyên môn", "Professional advisor")</em><h4>Th.S. Nguyễn Hoàng Vân Anh</h4><strong>@T("Chuyên gia tâm lý và phát triển cá nhân", "Psychology and personal development expert")</strong><p>@T("Đồng hành cùng người học xây dựng tư duy tích cực và phát triển năng lực cá nhân bền vững.", "Helping learners build positive thinking and sustainable personal capabilities.")</p><div class="mentor-tags"><span><i class="bi bi-person-heart"></i> @T("Tâm lý", "Psychology")</span><span><i class="bi bi-compass-fill"></i> @T("Phát triển", "Development")</span></div><button @onclick='() => OpenMentor("van-anh")'>@T("Xem chi tiết", "View details") <i class="bi bi-arrow-right"></i></button></div>
                </article>
                <article>
                    <div class="mentor-photo"><span></span><img src="/images/mentor-nguyen-thuy-to-tram.png" alt="Nguyễn Thuỵ Tố Trâm" /></div>
                    <div class="mentor-info"><em><i class="bi bi-gem"></i> @T("Cố vấn chính", "Lead mentor")</em><h4>Th.S. Nguyễn Thuỵ Tố Trâm</h4><strong>@T("Chuyên gia kỹ năng mềm và cộng đồng", "Soft skills and community expert")</strong><p>@T("Truyền cảm hứng và hỗ trợ người học ứng dụng kỹ năng mềm vào học tập, công việc và cuộc sống.", "Inspiring learners to apply soft skills in study, work and life.")</p><div class="mentor-tags"><span><i class="bi bi-chat-dots-fill"></i> @T("Kỹ năng mềm", "Soft skills")</span><span><i class="bi bi-heart-fill"></i> @T("Cộng đồng", "Community")</span></div><button @onclick='() => OpenMentor("to-tram")'>@T("Xem chi tiết", "View details") <i class="bi bi-arrow-right"></i></button></div>
                </article>
                <article>
                    <div class="mentor-photo"><span></span><img src="/images/mentor-nguyen-xuan.png" alt="Nguyễn Xuân" /></div>
                    <div class="mentor-info"><em><i class="bi bi-stars"></i> @T("Cố vấn chuyên môn", "Professional advisor")</em><h4>Th.S. Nguyễn Xuân</h4><strong>@T("Chuyên gia giáo dục và công nghệ", "Education and technology expert")</strong><p>@T("Kết nối kinh nghiệm giáo dục với công nghệ để tạo ra trải nghiệm học tập thực tế và hiệu quả.", "Connecting education and technology for practical, effective learning.")</p><div class="mentor-tags"><span><i class="bi bi-award-fill"></i> @T("Kinh nghiệm", "Experience")</span><span><i class="bi bi-cpu-fill"></i> EdTech</span></div><button @onclick='() => OpenMentor("xuan")'>@T("Xem chi tiết", "View details") <i class="bi bi-arrow-right"></i></button></div>
                </article>
            </div>
        </section>

        @if (SelectedMentor is { } mentor)
        {
            <div class="mentor-modal-backdrop" role="presentation" @onclick="CloseMentor">
                <section class="mentor-modal" role="dialog" aria-modal="true" aria-labelledby="mentor-modal-title" @onclick:stopPropagation="true">
                    <button class="mentor-modal-close" @onclick="CloseMentor" aria-label="@T("Đóng", "Close")"><i class="bi bi-x-lg"></i></button>
                    <header><img src="@mentor.Image" alt="@mentor.Name" /><div><span>@T(mentor.RoleVi, mentor.RoleEn)</span><h2 id="mentor-modal-title">@mentor.Name</h2><p>@T(mentor.PositionVi, mentor.PositionEn)</p></div></header>
                    <div class="mentor-highlights">
                        @foreach (var highlight in mentor.Highlights)
                        {
                            <div><i class="bi bi-stars"></i><span>@T(highlight.Vi, highlight.En)</span></div>
                        }
                    </div>
                    <div class="mentor-biography"><h3>@T("Giới thiệu", "About")</h3><p>@T(mentor.BioVi, mentor.BioEn)</p></div>
                </section>
            </div>
        }
    </main>
}

@code {
    private UserDto? user;
    private List<ProgressDto> progress = [];
    private List<RoadmapItemDto> roadmapItems = [];
    private int completedItems;
    private MentorDetail? SelectedMentor;
    private bool Vi => L.Current == AppLanguage.Vi;
    private string T(string vi, string en) => Vi ? vi : en;
    private string[] WeekDays => Vi ? ["T2", "T3", "T4", "T5", "T6", "T7", "CN"] : ["M", "T", "W", "T", "F", "S", "S"];
    private RoadmapItemDto? CurrentItem => roadmapItems.FirstOrDefault(x => !x.IsCompleted) ?? roadmapItems.LastOrDefault();
    private string CurrentTitle => CurrentItem?.Title ?? T("Lắng nghe chủ động", "Active listening");
    private string CurrentSkill => progress.FirstOrDefault()?.SkillName ?? T("Giao tiếp hiệu quả", "Effective communication");
    private int CurrentPercent => progress.Count == 0 ? 0 : Math.Clamp(progress.Max(x => x.PercentComplete), 0, 100);

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var id = await AuthProvider.GetUserIdAsync();
        user = await UserService.GetUserByIdAsync(id);
        if (user is null || user.Age <= 0 || string.IsNullOrWhiteSpace(user.Goal)) { Nav.NavigateTo("/profile-setup", true); return; }
        progress = (await ProgressService.GetUserProgressAsync(id)).ToList();
        var roadmap = await RoadmapService.GetUserRoadmapAsync(id);
        roadmapItems = roadmap.Items.OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
        completedItems = roadmapItems.Count(x => x.IsCompleted);
    }

    private void NavigateToAssessment() => Nav.NavigateTo($"/assessment/{user?.Id ?? 0}");
    private void OpenMentor(string id) => SelectedMentor = Mentors.First(x => x.Id == id);
    private void CloseMentor() => SelectedMentor = null;
    private static string FirstName(string value) => value.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? value;

    private static readonly MentorDetail[] Mentors =
    [
        new("van-anh", "Th.S. Nguyễn Hoàng Vân Anh", "/images/mentor-nguyen-hoang-van-anh.png", "Cố vấn chuyên môn", "Professional advisor", "Chuyên gia tâm lý và phát triển cá nhân", "Psychology and personal development expert",
            "Thạc sĩ Nguyễn Hoàng Vân Anh có kinh nghiệm trong lĩnh vực tâm lý, giáo dục và phát triển cá nhân. Cô đồng hành cùng người học xây dựng sự tự tin, hiểu bản thân và hình thành những thói quen phát triển bền vững.",
            "Nguyen Hoang Van Anh holds a master's degree and has experience in psychology, education and personal development. She helps learners build confidence, understand themselves and develop sustainable growth habits.",
            [("Kiến thức chuyên sâu về tâm lý học ứng dụng", "Expertise in applied psychology"), ("Kinh nghiệm tư vấn và đồng hành cùng người trẻ", "Experience advising and mentoring young people"), ("Định hướng phát triển cá nhân phù hợp với từng người học", "Personalized development guidance")]),
        new("to-tram", "Th.S. Nguyễn Thuỵ Tố Trâm", "/images/mentor-nguyen-thuy-to-tram.png", "Cố vấn chính", "Lead mentor", "Chuyên gia kỹ năng mềm và phát triển cộng đồng", "Soft skills and community development expert",
            "Thạc sĩ Nguyễn Thuỵ Tố Trâm là người định hướng chuyên môn cho SoftSync. Cô có nhiều năm hoạt động trong đào tạo kỹ năng mềm, xây dựng cộng đồng và hỗ trợ người học ứng dụng kiến thức vào những tình huống thực tế.",
            "Nguyen Thuy To Tram holds a master's degree and leads SoftSync's academic direction. She has extensive experience in soft-skills education, community building and helping learners apply knowledge to real situations.",
            [("Đào tạo kỹ năng giao tiếp và làm việc nhóm", "Communication and teamwork training"), ("Xây dựng môi trường học tập tích cực và hòa nhập", "Building positive and inclusive learning environments"), ("Kết nối kiến thức với trải nghiệm thực tế", "Connecting knowledge with real-world experience")]),
        new("xuan", "Th.S. Nguyễn Xuân", "/images/mentor-nguyen-xuan.png", "Cố vấn chuyên môn", "Professional advisor", "Chuyên gia giáo dục và công nghệ", "Education and technology expert",
            "Thạc sĩ Nguyễn Xuân có kinh nghiệm trong giáo dục, quản lý và ứng dụng công nghệ vào đào tạo. Thầy góp phần phát triển phương pháp học tập thực tiễn, giúp người học tiếp cận kỹ năng mềm một cách trực quan và hiệu quả.",
            "Nguyen Xuan holds a master's degree and has experience in education, management and educational technology. He develops practical learning approaches that make soft skills visual, accessible and effective.",
            [("Kinh nghiệm trong quản lý và đào tạo", "Experience in management and education"), ("Ứng dụng công nghệ trong thiết kế trải nghiệm học tập", "Applying technology to learning experience design"), ("Phát triển nội dung EdTech gắn với nhu cầu thực tế", "Developing EdTech content for real learner needs")])
    ];

    private sealed record MentorDetail(string Id, string Name, string Image, string RoleVi, string RoleEn, string PositionVi, string PositionEn, string BioVi, string BioEn, (string Vi, string En)[] Highlights);
}

<style>
    .ss-main-content:has(> .dash-home){width:100%;max-width:none;padding:0!important;background:#fbfcff}
    .dash-loading{min-height:70vh;display:grid;place-items:center;align-content:center;gap:1rem;color:#626a85;font-weight:700}.dash-loading span{width:44px;height:44px;border:4px solid #e7e5ff;border-top-color:#6848ef;border-radius:50%;animation:spin .8s linear infinite}@@keyframes spin{to{transform:rotate(360deg)}}
    .dash-home{--ink:#0c1740;--muted:#5e698b;width:100%;max-width:1500px;margin:auto;padding:0 1.7rem 2rem;color:var(--ink)}button{cursor:pointer}
    .dash-hero{position:relative;min-height:278px;margin:0 -1.7rem;padding:2.7rem 2.2rem 1.8rem;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;background:radial-gradient(circle at 75% 55%,rgba(168,185,255,.26),transparent 28%),linear-gradient(105deg,#fff 5%,#fbf8ff 46%,#eef6ff)}.dash-hero:after{content:"";position:absolute;right:-45px;top:-210px;width:480px;height:480px;border:2px solid rgba(255,255,255,.8);border-radius:50%}.dash-hero-copy{position:relative;z-index:2}.dash-hero h1{margin:0;font-size:2.65rem;font-weight:900;letter-spacing:-.045em}.dash-hero h1 span{font-size:2rem}.dash-hero-copy>p{margin:.8rem 0 1.45rem;color:#344161;font-size:1.12rem}.dash-hero-actions{display:flex;gap:.8rem}.dash-hero-actions button{min-height:54px;padding:.8rem 1.45rem;border:1px solid #cfd3e8;border-radius:13px;color:#1d2c5d;background:rgba(255,255,255,.75);font-weight:800}.dash-hero-actions i{margin-right:.55rem;color:#563be8;font-size:1.2rem}.dash-hero-actions .primary{border-color:transparent;color:#fff;background:linear-gradient(100deg,#5938ed,#7435ee);box-shadow:0 12px 28px rgba(86,56,232,.25)}.dash-hero-actions .primary i{color:#fff}.dash-syncy{position:relative;z-index:2;display:flex;justify-content:center;align-items:flex-end}.dash-syncy img{position:absolute;right:12%;bottom:-65px;width:310px;height:300px;object-fit:contain}.syncy-bubble{position:absolute;z-index:2;left:5%;bottom:62px;width:190px;padding:1rem 1.1rem;border-radius:22px;color:#24356d;background:#fff;box-shadow:0 15px 35px rgba(82,73,150,.11);font-size:.78rem}.syncy-bubble:after{content:"";position:absolute;right:-17px;top:32px;border-width:10px 0 10px 18px;border-style:solid;border-color:transparent transparent transparent #fff}.syncy-bubble strong,.syncy-bubble span{display:block}.syncy-bubble strong{margin:.1rem 0;color:#6540e8;font-size:1.1rem}.syncy-bubble span{line-height:1.45}
