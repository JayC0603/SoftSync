    .dash-loading{min-height:70vh;display:grid;place-items:center;align-content:center;gap:1rem;color:#626a85;font-weight:700}.dash-loading span{width:44px;height:44px;border:4px solid #e7e5ff;border-top-color:#6848ef;border-radius:50%;animation:spin .8s linear infinite}@@keyframes spin{to{transform:rotate(360deg)}}
    .dash-home{--ink:#0c1740;--muted:#5e698b;width:100%;max-width:1500px;margin:auto;padding:0 1.7rem 2rem;color:var(--ink)}button{cursor:pointer}
    .dash-hero{position:relative;min-height:278px;margin:0 -1.7rem;padding:2.7rem 2.2rem 1.8rem;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;background:radial-gradient(circle at 75% 55%,rgba(168,185,255,.26),transparent 28%),linear-gradient(105deg,#fff 5%,#fbf8ff 46%,#eef6ff)}.dash-hero:after{content:"";position:absolute;right:-45px;top:-210px;width:480px;height:480px;border:2px solid rgba(255,255,255,.8);border-radius:50%}.dash-hero-copy{position:relative;z-index:2}.dash-hero h1{margin:0;font-size:2.65rem;font-weight:900;letter-spacing:-.045em}.dash-hero h1 span{font-size:2rem}.dash-hero-copy>p{margin:.8rem 0 1.45rem;color:#344161;font-size:1.12rem}.dash-hero-actions{display:flex;gap:.8rem}.dash-hero-actions button{min-height:54px;padding:.8rem 1.45rem;border:1px solid #cfd3e8;border-radius:13px;color:#1d2c5d;background:rgba(255,255,255,.75);font-weight:800}.dash-hero-actions i{margin-right:.55rem;color:#563be8;font-size:1.2rem}.dash-hero-actions .primary{border-color:transparent;color:#fff;background:linear-gradient(100deg,#5938ed,#7435ee);box-shadow:0 12px 28px rgba(86,56,232,.25)}.dash-hero-actions .primary i{color:#fff}.dash-syncy{position:relative;z-index:2;display:flex;justify-content:center;align-items:flex-end}.dash-syncy img{position:absolute;right:12%;bottom:-65px;width:310px;height:300px;object-fit:contain}.syncy-bubble{position:absolute;z-index:2;left:5%;bottom:62px;width:190px;padding:1rem 1.1rem;border-radius:22px;color:#24356d;background:#fff;box-shadow:0 15px 35px rgba(82,73,150,.11);font-size:.78rem}.syncy-bubble:after{content:"";position:absolute;right:-17px;top:32px;border-width:10px 0 10px 18px;border-style:solid;border-color:transparent transparent transparent #fff}.syncy-bubble strong,.syncy-bubble span{display:block}.syncy-bubble strong{margin:.1rem 0;color:#6540e8;font-size:1.1rem}.syncy-bubble span{line-height:1.45}
    .journey-card{position:relative;z-index:3;min-height:190px;margin-top:-1rem;padding:1.15rem 1.5rem;display:grid;grid-template-columns:245px minmax(0,1fr) 210px;align-items:center;gap:1.25rem;border:1px solid #e3e5f2;border-radius:23px;background:rgba(255,255,255,.96);box-shadow:0 16px 40px rgba(61,56,127,.12)}.journey-art{position:relative;height:150px;display:grid;place-items:center;border-radius:18px;color:#fff;background:linear-gradient(140deg,#6875ee,#b6b9ff);font-size:4rem;overflow:hidden}.journey-art:before,.journey-art:after{content:"";position:absolute;width:100px;height:100px;border-radius:50%;background:#f0d4c3}.journey-art:before{left:20px;bottom:-45px}.journey-art:after{right:20px;bottom:-45px;background:#c7dbef}.journey-art>i{z-index:1}.journey-art span{position:absolute;right:28px;top:20px;width:48px;height:35px;display:grid;place-items:center;border-radius:18px;background:#fff;color:#7650e9;font-size:1.2rem}.journey-copy small{color:#603dee;font-weight:800}.journey-copy h2{margin:.45rem 0;font-size:1.9rem}.journey-copy p{margin:0 0 .75rem;color:#354264}.journey-copy p i{color:#6552e8}.journey-progress{display:inline-block;width:70%;height:10px;border-radius:99px;background:#e8e9f1;overflow:hidden}.journey-progress span{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,#6438ed,#8246ee)}.journey-copy>b{margin-left:.65rem;color:#5637eb}.journey-action{display:grid;justify-items:end;gap:1.4rem}.journey-action>span{color:#5f6987;font-size:.8rem}.journey-action button{width:100%;min-height:58px;border:0;border-radius:14px;color:#fff;background:linear-gradient(100deg,#6931ec,#7b35ed);font-size:1.05rem;font-weight:800}.journey-action button i{float:right;margin-top:.25rem}
    .dash-content{margin-top:1.1rem;display:grid;grid-template-columns:minmax(0,1.7fr) minmax(330px,1fr);gap:1.1rem}.dash-content h3,.mentor-bar h3{margin:0 0 .65rem;font-size:1rem}.dash-left{min-width:0}.quick-links{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.65rem}.quick-links button{min-width:0;min-height:70px;padding:.65rem;display:flex;align-items:center;gap:.65rem;border:1px solid #e0e3ef;border-radius:14px;color:var(--ink);background:#fff}.quick-links button>i{width:42px;height:42px;flex:0 0 42px;display:grid;place-items:center;border-radius:11px;color:#fff;font-size:1.2rem}.purple{background:#7544e9}.blue{background:#3579e5}.teal{background:#20aaa5}.quick-links strong{min-width:0;flex:1;text-align:left;font-size:.75rem}.quick-links b{color:#66728e;font-size:1.25rem}.recommend-section{margin-top:1rem}.course-cards{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.7rem}.course-cards button{min-width:0;min-height:115px;padding:.75rem;display:flex;align-items:flex-start;gap:.65rem;border:1px solid #e0e3ef;border-radius:14px;color:var(--ink);background:#fff;text-align:left}.course-cards button>i{width:42px;height:42px;flex:0 0 42px;display:grid;place-items:center;border-radius:11px;color:#fff;font-size:1.2rem}.course-cards span,.course-cards strong,.course-cards small,.course-cards em{display:block}.course-cards strong{font-size:.7rem}.course-cards small{margin:.25rem 0;color:var(--muted);font-size:.58rem;line-height:1.35}.course-cards em{color:#64708d;font-size:.57rem;font-style:normal}
    .week-card{padding:1.15rem 1.35rem;border:1px solid #dfe3ef;border-radius:18px;background:#fff;box-shadow:0 9px 25px rgba(61,56,127,.05)}.week-card header,.mentor-bar header{display:flex;align-items:center;justify-content:space-between}.week-card header button,.mentor-bar header button{border:0;color:#1462dc;background:transparent;font-size:.7rem}.week-stats{margin:1rem 0;padding-bottom:1rem;display:grid;grid-template-columns:repeat(3,1fr);border-bottom:1px solid #e4e7f0}.week-stats>div{display:flex;align-items:center;gap:.65rem;padding:0 .7rem;border-right:1px solid #e5e7f0}.week-stats>div:first-child{padding-left:0}.week-stats>div:last-child{border:0}.week-stats>div>i{width:43px;height:43px;flex:0 0 43px;display:grid;place-items:center;border-radius:12px;color:#fff;font-size:1.15rem}.week-stats .gold{background:#fbb53e}.week-stats .orange{background:#ff7c3d}.week-stats span,.week-stats strong,.week-stats small{display:block}.week-stats strong{font-size:1.05rem}.week-stats small{color:#5e6987;font-size:.62rem}.orange-text{color:#f26922}.week-days{display:grid;grid-template-columns:repeat(7,1fr) 52px;align-items:end;gap:.3rem}.week-days div{display:grid;justify-items:center;gap:.55rem}.week-days div small{font-size:.58rem}.week-days div span{width:22px;height:22px;display:grid;place-items:center;border:1.5px dashed #7890b6;border-radius:50%;color:#fff;font-size:.6rem}.week-days div span.done{border-style:solid;border-color:#6941eb;background:#6941eb}.week-days>i{width:48px;height:48px;display:grid;place-items:center;border:1px solid #e1e4ee;border-radius:50%;color:#f68b22;font-size:1.4rem}
    .mentor-bar{margin-top:1.1rem}.mentor-items{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));border:1px solid #dfe3ef;border-radius:17px;background:#fff;box-shadow:0 9px 25px rgba(61,56,127,.05)}.mentor-items article{min-width:0;padding:.7rem 1rem;display:flex;align-items:center;gap:.65rem;border-right:1px solid #e7e9f1}.mentor-items article:last-child{border:0}.mentor-items img{width:48px;height:48px;flex:0 0 48px;border-radius:50%;object-fit:cover;background:#f2efff}.mentor-items span,.mentor-items strong,.mentor-items small{display:block;min-width:0}.mentor-items strong{overflow:hidden;font-size:.7rem;text-overflow:ellipsis;white-space:nowrap}.mentor-items small{margin-top:.2rem;color:var(--muted);font-size:.6rem}
    html[data-theme="dark"] .ss-main-content:has(> .dash-home){background:#111329}html[data-theme="dark"] .dash-home{--ink:#f5f4ff;--muted:#b5bbd0}html[data-theme="dark"] .dash-hero{background:linear-gradient(105deg,#18152f,#201b45 55%,#172341)}html[data-theme="dark"] .dash-hero-copy>p{color:#cbd2e8}html[data-theme="dark"] :is(.journey-card,.quick-links button,.course-cards button,.week-card,.mentor-items){border-color:rgba(160,144,255,.2);background:rgba(29,26,59,.94)}
    @@media(max-width:1000px){.dash-hero{grid-template-columns:1.15fr .85fr}.dash-syncy img{right:-5%;width:260px}.syncy-bubble{display:none}.journey-card{grid-template-columns:180px 1fr 170px}.dash-content{grid-template-columns:1fr}.quick-links{grid-template-columns:repeat(4,1fr)}.week-card{grid-row:2}.mentor-items{grid-template-columns:1fr 1fr}}
    @@media(max-width:700px){.dash-home{padding:0 .75rem 6rem}.dash-hero{min-height:440px;margin:0 -.75rem;padding:1.4rem 1rem;grid-template-columns:1fr}.dash-hero h1{font-size:2rem}.dash-hero-actions{display:grid;grid-template-columns:1fr}.dash-syncy img{right:50%;bottom:-75px;width:240px;transform:translateX(50%)}.journey-card{margin-top:-.5rem;padding:1rem;grid-template-columns:1fr}.journey-art{display:none}.journey-action{justify-items:stretch;gap:.65rem}.journey-action>span{text-align:right}.quick-links{grid-template-columns:1fr 1fr}.course-cards{grid-template-columns:1fr}.week-stats{grid-template-columns:1fr;gap:.65rem}.week-stats>div{border:0;padding:0}.week-days{grid-template-columns:repeat(7,1fr)}.week-days>i{display:none}.mentor-items{grid-template-columns:1fr}.mentor-items article{border:0;border-bottom:1px solid #e7e9f1}.journey-copy h2{font-size:1.45rem}}
