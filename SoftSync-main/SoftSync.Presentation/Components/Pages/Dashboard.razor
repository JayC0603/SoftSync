@page "/dashboard"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Services
@inject IUserService UserService
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@if (user is null)
{
    <div class="dash-loading"><span></span>@T("Đang chuẩn bị không gian học tập...", "Preparing your learning space...")</div>
}
else
{
    <main class="dash-home">
        <section class="dash-hero">
            <div class="dash-hero-copy">
                <h1>@T("Chào buổi sáng", "Good morning"), @FirstName(user.PublicName)! <span>👋</span></h1>
                <p>@T("Hôm nay bạn muốn cải thiện kỹ năng nào?", "Which skill would you like to improve today?")</p>
                <div class="dash-hero-actions">
                    <button class="primary" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-play-circle-fill"></i>@T("Tiếp tục bài học", "Continue lesson")</button>
                    <button @onclick="NavigateToAssessment"><i class="bi bi-graph-up-arrow"></i>@T("Đánh giá kỹ năng", "Assess skills")</button>
                </div>
            </div>
            <div class="dash-syncy">
                <div class="syncy-bubble">@T("Xin chào! Mình là", "Hi! I'm")<strong>Syncy</strong><span>@T("Mình ở đây để đồng hành cùng bạn mỗi ngày!", "I'm here to learn with you every day!")</span></div>
                <img src="/images/syncy-robot.png" alt="Syncy AI" />
            </div>
        </section>

        <section class="journey-card">
            <div class="journey-art"><i class="bi bi-chat-heart-fill"></i><span><i class="bi bi-chat-dots-fill"></i></span></div>
            <div class="journey-copy">
                <small>@T("Tiếp tục hành trình", "Continue your journey")</small>
                <h2>@CurrentSkill</h2>
                <p><i class="bi bi-play-btn-fill"></i> @T("Bài tiếp theo", "Next lesson"): @CurrentTitle</p>
                <div class="journey-progress"><span style="width:@CurrentPercent%"></span></div><b>@CurrentPercent%</b>
            </div>
            <div class="journey-action"><span><i class="bi bi-stopwatch"></i> 15 @T("phút", "min")</span><button @onclick='() => Nav.NavigateTo("/roadmap")'>@T("Học tiếp", "Continue") <i class="bi bi-chevron-right"></i></button></div>
        </section>

        <div class="dash-content">
            <div class="dash-left">
                <section class="quick-section">
                    <h3>@T("Khám phá nhanh", "Quick explore")</h3>
                    <div class="quick-links">
                        <button @onclick="NavigateToAssessment"><i class="bi bi-clipboard2-check-fill purple"></i><strong>@T("Đánh giá", "Assessment")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-map-fill blue"></i><strong>@T("Lộ trình", "Roadmap")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/case-studies")'><i class="bi bi-bullseye teal"></i><strong>@T("Luyện tập", "Practice")</strong><b>›</b></button>
                        <button @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-patch-question-fill purple"></i><strong>@T("Hỏi Syncy", "Ask Syncy")</strong><b>›</b></button>
                    </div>
                </section>

                <section class="recommend-section">
                    <h3>@T("Có thể bạn quan tâm", "You may be interested")</h3>
                    <div class="course-cards">
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-person-video3 blue"></i><span><strong>@T("Thuyết trình tự tin", "Confident presenting")</strong><small>@T("Trình bày ý tưởng rõ ràng, thuyết phục và cuốn hút.", "Present ideas clearly and persuasively.")</small><em><i class="bi bi-clock"></i> 20 @T("phút", "min")</em></span></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-people-fill teal"></i><span><strong>@T("Làm việc nhóm hiệu quả", "Effective teamwork")</strong><small>@T("Hợp tác, chia sẻ và đạt mục tiêu chung.", "Collaborate and achieve shared goals.")</small><em><i class="bi bi-clock"></i> 18 @T("phút", "min")</em></span></button>
                        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-head-side-heart-fill purple"></i><span><strong>@T("Quản lý cảm xúc", "Emotion management")</strong><small>@T("Nhận diện và kiểm soát cảm xúc để phát triển bản thân.", "Recognize and regulate your emotions.")</small><em><i class="bi bi-clock"></i> 16 @T("phút", "min")</em></span></button>
                    </div>
                </section>
            </div>

            <section class="week-card">
                <header><h3>@T("Kết quả tuần này", "This week's results")</h3><button @onclick='() => Nav.NavigateTo("/progress")'>@T("Xem chi tiết", "View details") <i class="bi bi-chevron-right"></i></button></header>
                <div class="week-stats">
                    <div><i class="bi bi-book-fill purple"></i><span><strong>@completedItems</strong><small>@T("bài học", "lessons")</small></span></div>
                    <div><i class="bi bi-star-fill gold"></i><span><strong>@user.ExperiencePoints</strong><small>XP</small></span></div>
                    <div><i class="bi bi-fire orange"></i><span><small>@T("Chuỗi", "Streak")</small><strong class="orange-text">4 @T("ngày", "days")</strong></span></div>
                </div>
                <div class="week-days">
                    @foreach (var day in WeekDays)
                    {
                        <div><small>@day</small><span class="@(day is "T2" or "T3" or "T4" or "T5" ? "done" : "")">@(day is "T2" or "T3" or "T4" or "T5" ? "✓" : "")</span></div>
                    }
                    <i class="bi bi-fire"></i>
                </div>
            </section>
        </div>

        <section class="mentor-bar">
            <header><h3>@T("Đội ngũ cố vấn", "Our mentors")</h3><button @onclick='() => Nav.NavigateTo("/community")'>@T("Xem tất cả", "View all") <i class="bi bi-arrow-right"></i></button></header>
            <div class="mentor-items">
                <article><img src="/images/mentor-nguyen-hoang-van-anh.png" alt="Nguyễn Hoàng Vân Anh" /><span><strong>Nguyễn Hoàng Vân Anh</strong><small>@T("Chuyên gia giao tiếp", "Communication expert")</small></span></article>
                <article><img src="/images/mentor-nguyen-thuy-to-tram.png" alt="Nguyễn Thuỵ Tố Trâm" /><span><strong>Nguyễn Thuỵ Tố Trâm</strong><small>@T("Huấn luyện viên kỹ năng", "Skills coach")</small></span></article>
                <article><img src="/images/mentor-nguyen-xuan.png" alt="Nguyễn Xuân" /><span><strong>Nguyễn Xuân</strong><small>@T("Chuyên gia EdTech", "EdTech expert")</small></span></article>
            </div>
        </section>
    </main>
}

@code {
    private UserDto? user;
    private List<ProgressDto> progress = [];
    private List<RoadmapItemDto> roadmapItems = [];
    private int completedItems;
    private bool Vi => L.Current == AppLanguage.Vi;
    private string T(string vi, string en) => Vi ? vi : en;
    private string[] WeekDays => Vi ? ["T2", "T3", "T4", "T5", "T6", "T7", "CN"] : ["M", "T", "W", "T", "F", "S", "S"];
    private RoadmapItemDto? CurrentItem => roadmapItems.FirstOrDefault(x => !x.IsCompleted) ?? roadmapItems.LastOrDefault();
    private string CurrentTitle => CurrentItem?.Title ?? T("Lắng nghe chủ động", "Active listening");
    private string CurrentSkill => progress.FirstOrDefault()?.SkillName ?? T("Giao tiếp hiệu quả", "Effective communication");
    private int CurrentPercent => progress.Count == 0 ? 0 : Math.Clamp(progress.Max(x => x.PercentComplete), 0, 100);

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var id = await AuthProvider.GetUserIdAsync();
        user = await UserService.GetUserByIdAsync(id);
        if (user is null || user.Age <= 0 || string.IsNullOrWhiteSpace(user.Goal)) { Nav.NavigateTo("/profile-setup", true); return; }
        progress = (await ProgressService.GetUserProgressAsync(id)).ToList();
        var roadmap = await RoadmapService.GetUserRoadmapAsync(id);
        roadmapItems = roadmap.Items.OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
        completedItems = roadmapItems.Count(x => x.IsCompleted);
    }

    private void NavigateToAssessment() => Nav.NavigateTo($"/assessment/{user?.Id ?? 0}");
    private static string FirstName(string value) => value.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? value;
}

<style>
