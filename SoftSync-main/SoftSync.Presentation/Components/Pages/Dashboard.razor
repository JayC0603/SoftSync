@page "/dashboard"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Services
@inject IUserService UserService
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

@if (user is null)
{
    <div class="home-loading"><span></span>@T("Đang chuẩn bị không gian học tập...", "Preparing your learning space...")</div>
}
else
{
    <main class="home-v2">
        <section class="home-main">
            <header class="welcome-copy">
                <div class="morning"><i class="bi bi-sun-fill"></i> @T("Chào buổi sáng", "Good Morning"), @FirstName(user.PublicName)! <i class="bi bi-sun-fill"></i></div>
                <h1>@T("Xin chào", "Hello"), @FirstName(user.PublicName)! <span>👋</span></h1>
                <p>@T("Hôm nay là một ngày tuyệt vời để phát triển bản thân!", "Today is a great day to grow and improve yourself!")</p>
                <div class="streak-card"><i class="bi bi-fire"></i><span>@T("Chuỗi học tập", "Learning streak")<strong>7 @T("ngày", "days")</strong><small>@T("Giữ vững phong độ nhé!", "Keep up the momentum!")</small></span></div>
            </header>

            <section class="continue-card">
                <div class="continue-copy">
                    <span class="learning-pill"><i class="bi bi-play-fill"></i> @T("Đang học", "Learning")</span>
                    <h2>@T("Bài", "Lesson") @CurrentStep: @CurrentTitle</h2>
                    <div class="lesson-progress"><span style="width:@CurrentPercent%"></span></div><b>@CurrentPercent%</b>
                    <div class="continue-foot"><span><i class="bi bi-clock"></i> 12 @T("phút còn lại", "minutes left")</span><button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-play-fill"></i> @T("Tiếp tục học", "Continue learning")</button></div>
                </div>
                <img src="/images/syncy-fish.png" alt="SYNCY mascot" />
            </section>

            <section class="stat-grid">
                <article><i class="bi bi-stars stat-xp"></i><div><strong>@user.ExperiencePoints <small>XP</small></strong><span>@T("Tổng kinh nghiệm", "Total experience")</span></div><em style="width:@user.LevelProgressPercent%"></em></article>
                <article><i class="bi bi-gem stat-level"></i><div><strong>@T("Cấp", "Level") @user.Level</strong><span>@T("Cấp hiện tại", "Current level")</span></div><em style="width:@user.LevelProgressPercent%"></em></article>
                <article><i class="bi bi-clipboard2-check-fill stat-done"></i><div><strong>@completedItems <small>/ @totalItems</small></strong><span>@T("Bài hoàn thành", "Lessons completed")</span></div><em style="width:@CompletionPercent%"></em></article>
                <article><i class="bi bi-fire stat-fire"></i><div><strong>7 @T("ngày", "days")</strong><span>@T("Liên tiếp", "In a row")</span></div><em style="width:76%"></em></article>
            </section>

            <div class="content-grid">
                <section class="panel roadmap-panel">
                    <div class="panel-head"><h3><i class="bi bi-map-fill"></i> @T("Lộ trình của bạn", "Your roadmap")</h3><button @onclick='() => Nav.NavigateTo("/roadmap")'>@T("Xem toàn bộ lộ trình", "View full roadmap") <i class="bi bi-arrow-right"></i></button></div>
                    <div class="roadmap-list">
                        @foreach (var item in VisibleRoadmap)
                        {
                            var index = roadmapItems.IndexOf(item) + 1;
                            var current = !item.IsCompleted && index == CurrentStep;
                            <button class="roadmap-row @(item.IsCompleted ? "done" : current ? "current" : "locked")" disabled="@(!item.IsCompleted && !current)" @onclick='() => Nav.NavigateTo("/roadmap")'>
                                <i class="bi @(item.IsCompleted ? "bi-check-lg" : current ? "bi-stars" : "bi-lock-fill")"></i>
                                <span><strong>@DisplayTitle(item, index)</strong><small>@item.Description</small></span>
                                <em>@(item.IsCompleted ? T("Đã hoàn thành", "Completed") : current ? T("Đang học", "Learning") : T("Bị khóa", "Locked"))</em>
                            </button>
                        }
                    </div>
                </section>

                <section class="panel suggestion-panel">
                    <div class="panel-head"><h3><i class="bi bi-stars"></i> @T("Gợi ý hôm nay", "Today's suggestion")</h3><small>@T("Dành riêng cho bạn", "Made for you")</small></div>
                    <div class="suggestion-body"><div class="suggestion-icon"><i class="bi bi-clipboard2-check"></i><i class="bi bi-clock-fill"></i></div><div><h4>@T("Hoàn thành bài học", "Complete the lesson")<br />@CurrentTitle</h4><p>@T("Bạn đang tiến rất tốt! Hoàn thành bài học này để nắm vững cách sắp xếp công việc hiệu quả.", "You're doing great! Complete this lesson to strengthen your practical skills.")</p><button @onclick='() => Nav.NavigateTo("/roadmap")'>@T("Bắt đầu ngay", "Start now") <i class="bi bi-arrow-right"></i></button></div></div>
                </section>

                <section class="panel skills-panel">
                    <div class="panel-head"><h3><i class="bi bi-map-fill"></i> @T("Tiến độ kỹ năng", "Skill progress")</h3><button @onclick='() => Nav.NavigateTo("/progress")'>@T("Xem phân tích chi tiết", "View detailed analysis") <i class="bi bi-arrow-right"></i></button></div>
                    <div class="skill-rings">
                        @foreach (var item in SkillCards)
                        {
                            <div><div class="ring" style="--value:@item.PercentComplete;--ring:@RingColor(item.PercentComplete)"><span>@item.PercentComplete%</span></div><small>@item.SkillName</small></div>
                        }
                    </div>
                </section>

                <section class="panel achievements-panel">
                    <div class="panel-head"><h3><i class="bi bi-trophy-fill"></i> @T("Thành tích gần đây", "Recent achievements")</h3><button @onclick='() => Nav.NavigateTo("/progress")'>@T("Xem tất cả", "View all") <i class="bi bi-arrow-right"></i></button></div>
                    <div class="achievement-list">
                        <div><i class="bi bi-play-fill violet"></i><strong>@T("Người bắt đầu", "First step")</strong><small>@user.CreatedAt.ToString("dd/MM/yyyy")</small></div>
                        <div><i class="bi bi-check-lg green"></i><strong>@T("Hoàn thành bài", "Lesson finisher")</strong><small>@completedItems @T("bài", "lessons")</small></div>
                        <div><i class="bi bi-star-fill blue"></i><strong>@T("Học tập đều đặn", "Consistent learner")</strong><small>@user.ExperiencePoints XP</small></div>
                        <div><i class="bi bi-fire orange"></i><strong>@T("Tập trung cao", "Highly focused")</strong><small>@T("Hôm nay", "Today")</small></div>
                    </div>
                </section>
            </div>
        </section>

        <aside class="syncy-column">
            <section class="syncy-panel">
                <div class="syncy-title"><h3><i class="bi bi-stars"></i> SYNCY AI</h3><button aria-label="Settings" @onclick='() => Nav.NavigateTo("/settings")'><i class="bi bi-gear"></i></button></div>
                <div class="syncy-message"><strong>@T("Xin chào", "Hello") @FirstName(user.PublicName)! 👋</strong><p>@T("Đây là kế hoạch học tập được SYNCY gợi ý cho bạn hôm nay.", "Here is the learning plan SYNCY suggests for you today.")</p></div>
                <button class="syncy-task" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-bullseye"></i><span><strong>@CurrentTitle</strong><small><i class="bi bi-clock"></i> 12 @T("phút", "minutes")</small></span><b>›</b></button>
                <button class="syncy-task" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-book-fill"></i><span><strong>@T("Làm Mini Quiz", "Take Mini Quiz")</strong><small><i class="bi bi-clock"></i> 5 @T("phút", "minutes")</small></span><b>›</b></button>
                <button class="syncy-task" @onclick='() => Nav.NavigateTo("/progress")'><i class="bi bi-bar-chart-fill"></i><span><strong>@T("Xem tiến độ kỹ năng", "View skill progress")</strong><small><i class="bi bi-clock"></i> 3 @T("phút", "minutes")</small></span><b>›</b></button>
                <button class="syncy-chat" @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-chat-dots-fill"></i> @T("Chat với SYNCY", "Chat with SYNCY")</button>
            </section>
            <section class="did-you-know"><i class="bi bi-lightbulb-fill"></i><div><strong>@T("Bạn có biết?", "Did you know?")</strong><p>@T("Học 15 phút mỗi ngày giúp bạn ghi nhớ tốt hơn 80% kiến thức!", "Studying 15 minutes a day can help you retain up to 80% more!")</p></div><img src="/images/syncy-fish.png" alt="SYNCY" /></section>
        </aside>
    </main>
}

@code {
    private UserDto? user;
    private List<ProgressDto> progress = [];
    private List<RoadmapItemDto> roadmapItems = [];
    private int completedItems;
    private int totalItems;

    private bool Vi => L.Current == AppLanguage.Vi;
    private string T(string vi, string en) => Vi ? vi : en;
    private int CurrentStep => Math.Max(1, roadmapItems.FindIndex(x => !x.IsCompleted) + 1);
    private RoadmapItemDto? CurrentItem => roadmapItems.FirstOrDefault(x => !x.IsCompleted) ?? roadmapItems.LastOrDefault();
    private string CurrentTitle => CurrentItem?.Title ?? T("Ưu tiên công việc", "Prioritizing tasks");
    private int CurrentPercent => progress.Count == 0 ? 0 : Math.Clamp(progress.Max(x => x.PercentComplete), 0, 100);
    private int CompletionPercent => totalItems == 0 ? 0 : completedItems * 100 / totalItems;
    private IEnumerable<RoadmapItemDto> VisibleRoadmap => roadmapItems.Take(5);
    private IEnumerable<ProgressDto> SkillCards => progress.Take(4).Concat(DefaultSkills()).Take(4);

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        var id = await AuthProvider.GetUserIdAsync();
        user = await UserService.GetUserByIdAsync(id);
        if (user is null || user.Age <= 0 || string.IsNullOrWhiteSpace(user.Goal)) { Nav.NavigateTo("/profile-setup", true); return; }
        progress = (await ProgressService.GetUserProgressAsync(id)).ToList();
        var roadmap = await RoadmapService.GetUserRoadmapAsync(id);
        roadmapItems = roadmap.Items.OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
        totalItems = roadmapItems.Count;
        completedItems = roadmapItems.Count(x => x.IsCompleted);
    }

    private IEnumerable<ProgressDto> DefaultSkills()
    {
        var defaults = new[] { T("Quản lý thời gian", "Time management"), T("Giao tiếp", "Communication"), T("Tư duy phản biện", "Critical thinking"), T("Làm việc nhóm", "Teamwork") };
        foreach (var (name, index) in defaults.Select((name, index) => (name, index)))
            if (!progress.Any(x => string.Equals(x.SkillName, name, StringComparison.OrdinalIgnoreCase)))
                yield return new ProgressDto { SkillName = name, PercentComplete = index == 0 ? CompletionPercent : 0 };
    }

    private string DisplayTitle(RoadmapItemDto item, int index) => index == 1 ? $"{T("Video giới thiệu", "Introduction video")}" : $"{T("Bài", "Lesson")} {index - 1}: {item.Title}";
    private static string RingColor(int value) => value >= 60 ? "#7657f6" : value >= 40 ? "#2698ec" : value >= 30 ? "#35ad66" : "#ff841c";
    private static string FirstName(string value) => value.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? value;
}

