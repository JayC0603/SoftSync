    }
    html[data-theme="dark"] .assistant-heading {
        border-color: rgba(167, 139, 250, 0.45);
        background:
            linear-gradient(135deg, rgba(15, 23, 42, 0.9), rgba(46, 16, 101, 0.78)),
            radial-gradient(circle at 15% 0%, rgba(129, 140, 248, 0.34), transparent 48%);
        box-shadow:
            0 22px 58px rgba(0, 0, 0, 0.42),
            inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }
    html[data-theme="dark"] .assistant-title {
        color: #f8fafc;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.58);
    }
    html[data-theme="dark"] .assistant-subtitle {
        color: #ddd6fe;
        text-shadow: 0 2px 14px rgba(0, 0, 0, 0.62);
    }
    html[data-theme="dark"] .assistant-chat-card {
        border-color: rgba(196, 181, 253, 0.48);
        background:
            radial-gradient(circle at 12% 0%, rgba(139, 92, 246, 0.22), transparent 42%),
            linear-gradient(145deg, rgba(45, 39, 86, 0.78), rgba(30, 27, 75, 0.72));
        box-shadow:
            0 24px 60px rgba(15, 8, 45, 0.32),
            inset 0 1px 0 rgba(255, 255, 255, 0.1);
        -webkit-backdrop-filter: blur(20px) saturate(145%);
        backdrop-filter: blur(20px) saturate(145%);
    }
    html[data-theme="dark"] .assistant-input .form-control {
        background: rgba(45, 39, 86, 0.76);
        border-color: rgba(196, 181, 253, 0.48);
        color: #f8fafc;
    }
    html[data-theme="dark"] .assistant-input .form-control::placeholder {
        color: #c4b5fd;
    }
    html[data-theme="dark"] .chat-assistant {
        background: linear-gradient(135deg, rgba(67, 56, 132, 0.88), rgba(49, 46, 129, 0.78)) !important;
        border: 1px solid rgba(196, 181, 253, 0.3);
        box-shadow: 0 10px 28px rgba(15, 8, 45, 0.22);
    }
    html[data-theme="dark"] .quick-actions button { color: #ddd6fe; border-color: rgba(167, 139, 250, .42); background: rgba(139, 92, 246, .16); }
    /* Premium assistant workspace */
    .assistant-layout{display:grid;grid-template-columns:230px minmax(0,1fr);max-width:1420px;min-height:calc(100vh - 125px);margin:0 auto;border:1px solid rgba(255,255,255,.55);border-radius:28px;overflow:hidden;background:rgba(248,247,255,.94);box-shadow:0 24px 70px rgba(49,46,129,.2)}
    .assistant-side{display:flex;flex-direction:column;gap:.4rem;padding:1.4rem;background:linear-gradient(165deg,#17133f,#282063);color:#ddd6fe}.assistant-side-brand{display:flex;align-items:center;gap:.65rem;margin-bottom:1rem;color:#fff;font-size:1.15rem}.assistant-side-brand img{width:42px;height:42px;border-radius:12px}.assistant-side>button{display:flex;align-items:center;gap:.7rem;width:100%;padding:.75rem;border:0;border-radius:12px;background:transparent;color:#c4b5fd;text-align:left;font-size:.82rem}.assistant-side>button:hover{color:#fff;background:rgba(124,92,252,.18)}.assistant-side .new-chat{justify-content:center;margin-bottom:1.2rem;padding:.85rem;color:#fff;background:linear-gradient(135deg,#7c5cfc,#5b21f4);font-weight:800}.side-label{margin:.6rem 0 .25rem;color:#8b7ccc;font-size:.68rem;font-weight:900;letter-spacing:.12em}.side-mascot{margin-top:auto;text-align:center}.side-mascot img{width:115px;height:115px;object-fit:contain;filter:drop-shadow(0 12px 22px rgba(124,92,252,.4))}.side-mascot p{margin:0;color:#b8afe8;font-size:.72rem;line-height:1.5}
    .assistant-shell{min-width:0;padding:2rem 3rem;background:radial-gradient(circle at 85% 15%,rgba(216,207,255,.8),transparent 30%),linear-gradient(145deg,rgba(255,255,255,.96),rgba(244,241,255,.92))}.assistant-hero{display:flex;align-items:center;justify-content:space-between;min-height:170px}.assistant-hero>div>span{color:#6d4aff;font-size:1.7rem}.assistant-hero p{display:inline;margin-left:.6rem;color:#334155;font-weight:700}.assistant-hero h1{margin:.35rem 0;color:#111827;font-size:2rem;font-weight:850}.assistant-hero h1 b{color:#6d4aff}.assistant-hero small{color:#64748b;font-size:.95rem}.assistant-hero>img{width:190px;height:170px;object-fit:contain;filter:drop-shadow(0 18px 28px rgba(109,74,255,.25))}
    .assistant-chat-card{display:flex;flex-direction:column;min-height:190px;max-height:330px;margin:.5rem 0 1rem;padding:1.35rem;border:1px solid #ebe7f6;border-radius:22px;background:rgba(255,255,255,.9);box-shadow:0 10px 30px rgba(76,29,149,.07)}.assistant-chat-card .chat-assistant{max-width:70%;background:#fff!important;border:0;box-shadow:none;color:#1e293b!important}.assistant-input{display:flex;align-items:center;gap:.75rem;padding:.55rem .65rem .55rem 1.25rem;border:1px solid #e4def7;border-radius:999px;background:#fff;box-shadow:0 10px 28px rgba(76,29,149,.1)}.assistant-input input{flex:1;min-width:0;padding:.65rem 0;border:0;outline:0;background:transparent;color:#1e293b}.assistant-input>i{color:#475569}.assistant-input button{display:grid;place-items:center;width:46px;height:46px;border:0;border-radius:50%;background:linear-gradient(135deg,#7c5cfc,#5b21f4);color:#fff}.assistant-input button:disabled{opacity:.45}
    .assistant-prompts{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem;margin-top:1.5rem}.assistant-prompts button{display:flex;align-items:flex-start;gap:.7rem;padding:1rem;border:1px solid #ebe7f6;border-radius:18px;background:#fff;color:#334155;text-align:left;box-shadow:0 8px 24px rgba(76,29,149,.06)}.assistant-prompts button:hover{transform:translateY(-2px);border-color:#c4b5fd}.assistant-prompts i{display:grid;place-items:center;flex:0 0 40px;height:40px;border-radius:12px;background:#f0ebff;color:#6d4aff;font-size:1.1rem}.assistant-prompts b,.assistant-prompts small{display:block}.assistant-prompts b{color:#5b21b6;font-size:.82rem}.assistant-prompts small{margin-top:.25rem;color:#64748b;font-size:.68rem;line-height:1.35}
    html[data-theme="dark"] .assistant-layout{background:#17132f;border-color:rgba(196,181,253,.2)}html[data-theme="dark"] .assistant-shell{background:radial-gradient(circle at 85% 15%,rgba(76,61,145,.5),transparent 32%),linear-gradient(145deg,#201b42,#17132f)}html[data-theme="dark"] .assistant-hero p,html[data-theme="dark"] .assistant-hero h1{color:#fff}html[data-theme="dark"] .assistant-hero small{color:#cbd5e1}html[data-theme="dark"] .assistant-chat-card,html[data-theme="dark"] .assistant-input,html[data-theme="dark"] .assistant-prompts button{background:rgba(35,30,70,.88);border-color:rgba(196,181,253,.2)}html[data-theme="dark"] .assistant-input input{color:#fff}html[data-theme="dark"] .assistant-prompts button{color:#ddd6fe}html[data-theme="dark"] .assistant-prompts small{color:#cbd5e1}
    @@media(max-width:1000px){.assistant-layout{grid-template-columns:1fr}.assistant-side{display:none}.assistant-shell{padding:1.5rem}.assistant-prompts{grid-template-columns:1fr 1fr}}@@media(max-width:620px){.assistant-hero>img{width:110px}.assistant-hero h1{font-size:1.45rem}.assistant-prompts{grid-template-columns:1fr}.assistant-chat-card .chat-assistant{max-width:95%}}
</style>
