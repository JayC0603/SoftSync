@page "/assistant"
@page "/assistant/{UserId:int}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IAiAssistantService AssistantService
@inject NavigationManager Nav

<div class="assistant-layout">
    <aside class="assistant-side">
        <div class="assistant-side-brand"><img src="/images/logo.png" alt="" /><strong>SoftSync</strong></div>
        <button class="new-chat" @onclick="NewChat"><i class="bi bi-plus-lg"></i> @L["assistant.newChat"]</button>
        <span class="side-label">@L["assistant.suggested"]</span>
        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-book"></i> @L["assistant.exploreLessons"]</button>
        <button @onclick='() => Nav.NavigateTo("/progress")'><i class="bi bi-graph-up-arrow"></i> @L["assistant.trackProgress"]</button>
        <button @onclick='() => Nav.NavigateTo("/community")'><i class="bi bi-people"></i> @L["assistant.joinCommunity"]</button>
        <div class="side-mascot"><img src="/images/syncy-robot.png" alt="SYNCY" /><p>@L["assistant.sideQuote"] ✨</p></div>
    </aside>

    <main class="assistant-shell">
        <section class="assistant-hero">
            <div><span>✦</span><p>@L["assistant.heroHi"]</p><h1><b>SoftSync</b> AI Assistant</h1><small>@L["assistant.subtitle"]</small></div>
            <img src="/images/syncy-robot.png" alt="SYNCY AI" />
        </section>

    <div class="assistant-chat-card overflow-auto">
        @foreach (var msg in messages)
        {
            <div class="chat-bubble @(msg.Sender == SoftSync.Common.Enums.ChatSender.User ? "chat-user" : "chat-assistant")">
                <div class="chat-content">@(msg.ContentKey is not null ? L[msg.ContentKey] : (L.Current == SoftSync.Presentation.Services.AppLanguage.Vi ? msg.ViContent : msg.EnContent))</div>
                @if (msg.Actions.Count > 0)
                {
                    <div class="quick-actions">
                        @foreach (var action in msg.Actions)
                        {
                            <button type="button" @onclick="() => HandleAction(action)">@action.Label</button>
                        }
                    </div>
                }
            </div>
        }
        @if (isTyping)
        {
            <div class="chat-bubble chat-assistant text-muted">
                <span class="spinner-grow spinner-grow-sm" role="status"></span> @L["assistant.typing"]
            </div>
        }
    </div>

    <div class="assistant-input">
        <input type="text" placeholder="@L["assistant.inputPlaceholder"]"
               @bind="userInput" @bind:event="oninput" @onkeyup="HandleKeyUp" />
        <i class="bi bi-paperclip"></i>
        <button @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(userInput))">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>

        <section class="assistant-prompts">
            <button @onclick='() => SetPrompt("lesson")'><i class="bi bi-book"></i><span><b>@L["assistant.prompt.lesson"]</b><small>@L["assistant.prompt.lessonSub"]</small></span></button>
            <button @onclick='() => SetPrompt("practice")'><i class="bi bi-bullseye"></i><span><b>@L["assistant.prompt.practice"]</b><small>@L["assistant.prompt.practiceSub"]</small></span></button>
            <button @onclick='() => SetPrompt("advice")'><i class="bi bi-lightbulb"></i><span><b>@L["assistant.prompt.advice"]</b><small>@L["assistant.prompt.adviceSub"]</small></span></button>
            <button @onclick='() => Nav.NavigateTo("/progress")'><i class="bi bi-graph-up-arrow"></i><span><b>@L["assistant.prompt.progress"]</b><small>@L["assistant.prompt.progressSub"]</small></span></button>
        </section>
    </main>
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = default!;
    private string userInput = "";
    private bool isTyping = false;
    private List<AssistantMessage> messages = new()
    {
        new AssistantMessage
        {
            ContentKey = "assistant.welcome"
        }
    };

    private void NewChat()
    {
        messages = [new AssistantMessage { ContentKey = "assistant.welcome" }];
        userInput = "";
    }

    private void SetPrompt(string type) => userInput = type switch
    {
        "lesson" => L["assistant.prompt.lessonText"],
        "practice" => L["assistant.prompt.practiceText"],
        _ => L["assistant.prompt.adviceText"]
    };

    protected override async Task OnInitializedAsync()
    {
        // Fall back to the signed-in user when no id is supplied via the route.
        if (UserId == 0) UserId = await AuthProvider.GetUserIdAsync();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;

        var userMsg = userInput;
        userInput = "";
        messages.Add(new AssistantMessage { Sender = SoftSync.Common.Enums.ChatSender.User, EnContent = userMsg, ViContent = userMsg });

        isTyping = true;
        StateHasChanged();

        // Simulate AI response delay
        await Task.Delay(1000);
        var viReply = await AssistantService.GetReplyAsync("[vi]" + userMsg, UserId);
        var enReply = await AssistantService.GetReplyAsync("[en]" + userMsg, UserId);
        messages.Add(new AssistantMessage { ViContent = viReply, EnContent = enReply });
        isTyping = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private void HandleAction(ChatAction action)
    {
        switch (action.Key)
        {
            case "assessment": Nav.NavigateTo($"/assessment/{UserId}"); break;
            case "roadmap": Nav.NavigateTo("/roadmap"); break;
            case "cases": Nav.NavigateTo("/case-studies"); break;
            case "community": Nav.NavigateTo("/community"); break;
            case "progress": Nav.NavigateTo("/progress"); break;
            case "upgrade": Nav.NavigateTo("/settings"); break;
            case "mentor": AddBot("👥 SoftSync hướng tới việc kết nối người dùng với Mentor và Expert trong các phiên bản tiếp theo. Hiện tại, bạn có thể sử dụng AI Mentor để được hỗ trợ, định hướng và khám phá cộng đồng.", new ChatAction("Khám phá cộng đồng", "community")); break;
            case "about": AddBot("🌊 Chào mừng bạn đến với SoftSync Space!\n\nSoftSync là nền tảng ứng dụng AI giúp học sinh, sinh viên và người trẻ phát triển kỹ năng mềm qua bài đánh giá, tình huống mô phỏng và cộng đồng học tập.\n\nSYNCY giúp bạn rèn luyện giao tiếp, lãnh đạo, quản lý thời gian, tư duy phản biện và giải quyết vấn đề; đồng thời phân tích điểm mạnh và gợi ý lộ trình phù hợp.\n\nBạn muốn tìm hiểu thêm về phần nào?", new ChatAction("❤️ Sứ mệnh", "mission"), new ChatAction("🚀 Cách hoạt động", "how"), new ChatAction("✨ Điểm khác biệt", "difference"), new ChatAction("👥 Mentor", "mentor"), new ChatAction("📈 Dashboard", "dashboard"), new ChatAction("🎮 Game", "game"), new ChatAction("🌍 Tầm nhìn", "vision")); break;
            case "premium": AddBot("💎 SoftSync Premium – 69.000đ/tháng\n\nNâng cấp để trải nghiệm các tính năng nâng cao và được AI hỗ trợ chuyên sâu hơn.\n\n✅ AI phản hồi nhanh và ưu tiên xử lý\n✅ Truy cập các AI Mentor chuyên biệt\n✅ Phân tích kỹ năng và báo cáo chi tiết\n✅ Lộ trình học tập cá nhân hóa\n✅ Mở khóa tình huống nâng cao\n✅ Thống kê tiến độ theo thời gian\n\nChỉ khoảng 2.300đ/ngày cho hành trình phát triển kỹ năng cùng AI.", new ChatAction("💎 Nâng cấp Premium", "upgrade"), new ChatAction("📋 So sánh Free & Premium", "compare"), new ChatAction("❓ Hỏi thêm về Premium", "ask-premium")); break;
            case "compare": AddBot("📋 Free: AI Chat, đánh giá kỹ năng, AI Mentor và Dashboard cơ bản.\n\n⭐ Premium (69K/tháng): AI Mentor đầy đủ, phân tích chuyên sâu, Dashboard chi tiết, tình huống nâng cao, báo cáo PDF và hỗ trợ ưu tiên.", new ChatAction("💎 Nâng cấp Premium", "upgrade")); break;
            case "ask-premium": userInput = "Mình muốn hỏi thêm về SoftSync Premium"; break;
            case "mission": AddBot("❤️ Sứ mệnh của SoftSync là giúp người trẻ hiểu năng lực của mình và rèn kỹ năng mềm theo cách dễ tiếp cận, thực tế và có định hướng."); break;
            case "how": AddBot("🚀 Đầu tiên, AI giúp bạn đánh giá kỹ năng. Sau đó, SYNCY phân tích kết quả, đề xuất lộ trình cá nhân hóa và gợi ý bài học, trò chơi hoặc tình huống thực tế. Tiến độ được ghi nhận để bạn thấy sự phát triển theo thời gian."); break;
            case "difference": AddBot("✨ SoftSync kết hợp đánh giá, AI Mentor, lộ trình cá nhân hóa và luyện tập qua tình huống trong cùng một hành trình."); break;
            case "dashboard": AddBot("📈 Dashboard giúp bạn theo dõi kết quả đánh giá, kỹ năng đang phát triển và hoạt động đã hoàn thành.", new ChatAction("Xem tiến độ", "progress")); break;
            case "game": AddBot("🎮 Game và tình huống mô phỏng giúp bạn luyện cách phản ứng trước vấn đề thực tế và nhận phản hồi trong môi trường an toàn.", new ChatAction("Thử tình huống", "cases")); break;
            case "vision": AddBot("🌍 SoftSync hướng tới một không gian học tập nơi mỗi người trẻ đều có AI đồng hành, lộ trình phù hợp và cơ hội kết nối với cộng đồng Mentor trong tương lai."); break;
        }
    }

    private void AddBot(string content, params ChatAction[] actions) => messages.Add(new() { EnContent = content, ViContent = content, Actions = actions.ToList() });
    private sealed class AssistantMessage { public SoftSync.Common.Enums.ChatSender Sender { get; set; } = SoftSync.Common.Enums.ChatSender.Assistant; public string? ContentKey { get; set; } public string EnContent { get; set; } = ""; public string ViContent { get; set; } = ""; public List<ChatAction> Actions { get; set; } = []; }
    private sealed record ChatAction(string Label, string Key);
}

<style>
    .max-800 { max-width: 800px; }
    .overflow-auto { overflow-y: auto; }
    .chat-content { white-space: pre-line; line-height: 1.65; }
    .quick-actions { display: flex; flex-wrap: wrap; gap: .55rem; margin-top: 1rem; }
    .quick-actions button { border: 1px solid rgba(99, 102, 241, .3); border-radius: 999px; background: rgba(99, 102, 241, .09); color: #4338ca; padding: .5rem .8rem; font-size: .82rem; font-weight: 700; transition: .18s ease; }
    .quick-actions button:hover { color: #fff; background: linear-gradient(135deg, #6366f1, #8b5cf6); transform: translateY(-1px); }
