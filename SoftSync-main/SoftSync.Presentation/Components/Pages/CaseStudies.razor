@page "/case-studies"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject ICaseStudyService CaseStudyService

<div class="case-workspace">
    <header class="case-hero">
        <div><h1>@L["caseStudies.titlePrefix"] <b>@L["caseStudies.titleHighlight"]</b></h1><p>@L["caseStudies.subtitle"]</p><span></span></div>
        <img src="/images/syncy-fish.png" alt="SYNCY" />
    </header>

    @if (caseStudy is null)
    {
        <div class="case-loading"><div class="spinner-border text-primary"></div><p>@L["caseStudies.loading"]</p></div>
    }
    else
    {
        <section class="case-card">
            <div class="case-card-head"><div class="case-head-icon"><i class="bi bi-people-fill"></i></div><strong>@L["caseStudies.label"] <span>@caseStudy.Title</span></strong><i class="bi bi-chat-dots-fill case-chat-art"></i></div>
            <div class="case-body">
                <aside class="scenario-art"><div><i class="bi bi-person"></i><b>×</b></div></aside>
                <main>
                    <h2>@caseStudy.Scenario</h2><i class="title-line"></i>
                    <h3>@L["caseStudies.howRespond"]</h3>
                    <div class="case-options">
                        @for (var i = 0; i < caseStudy.Options.Count; i++)
                        {
                            var option = caseStudy.Options[i];
                            <button class="option-@(i % 3)" @onclick="() => SelectOption(option)" disabled="@(feedback is not null)">
                                <span><i class="bi @(i == 0 ? "bi-person-check" : i == 1 ? "bi-chat-square-text" : "bi-lightbulb")"></i></span>
                                <b>@option.OptionText</b><i class="bi bi-chevron-right"></i>
                            </button>
                        }
                    </div>
                    @if (feedback is not null)
                    {
                        <div class="case-feedback @(isCorrect ? "good" : "learn")"><i class="bi @(isCorrect ? "bi-check-circle-fill" : "bi-lightbulb-fill")"></i><div><strong>@(isCorrect ? L["caseStudies.correctTitle"] : L["caseStudies.incorrectTitle"])</strong><p>@feedback</p></div><button @onclick="LoadNext">@L["caseStudies.tryAnother"] →</button></div>
                    }
                </main>
            </div>
        </section>
        <div class="case-note"><i class="bi bi-lightbulb-fill"></i><span>@L["caseStudies.noWrongAnswer"]</span> ✨</div>
    }
</div>

@code {
    private CaseStudyDto? caseStudy; private string? feedback; private bool isCorrect;
    protected override async Task OnInitializedAsync() => await LoadNext();
    private async Task LoadNext()
    {
        feedback = null;
        var list = (await CaseStudyService.GetCaseStudiesBySkillAsync(1)).ToList();
        if (list.Count == 0) return;
        caseStudy = await CaseStudyService.GetCaseStudyByIdAsync(list[Random.Shared.Next(list.Count)].Id);
    }
    private void SelectOption(CaseStudyOptionDto option) { feedback = option.Feedback; isCorrect = option.IsRecommended; }
}

<style>
    .case-workspace{max-width:1160px;margin:auto;padding:1rem 0 3rem}.case-hero{display:flex;align-items:center;justify-content:space-between;min-height:220px;padding:1rem 2rem}.case-hero h1{margin:0;color:#111827;font-size:2.2rem;font-weight:900}.case-hero h1 b{color:#7c5cfc}.case-hero p{margin:.6rem 0;color:#475569;font-weight:650}.case-hero div>span{display:block;width:55px;height:4px;border-radius:99px;background:#7c5cfc}.case-hero img{width:230px;height:210px;object-fit:contain;filter:drop-shadow(0 18px 30px rgba(109,74,255,.25))}.case-loading{display:grid;place-items:center;min-height:350px}.case-card{overflow:hidden;border:1px solid rgba(255,255,255,.9);border-radius:24px;background:rgba(255,255,255,.82);box-shadow:0 20px 55px rgba(76,29,149,.14);backdrop-filter:blur(24px)}.case-card-head{display:flex;align-items:center;gap:.8rem;min-height:82px;padding:1rem 1.8rem;border-bottom:1px solid #ebe7f6;background:linear-gradient(135deg,rgba(255,255,255,.8),rgba(237,232,255,.7));color:#5b42db}.case-head-icon{display:grid;place-items:center;width:48px;height:48px;border-radius:50%;background:#7c5cfc;color:#fff;box-shadow:0 8px 20px rgba(109,74,255,.3)}.case-card-head strong{font-size:1.15rem}.case-card-head span{font-weight:850}.case-chat-art{margin-left:auto;color:#a78bfa;font-size:3rem}.case-body{display:grid;grid-template-columns:180px 1fr;gap:2rem;padding:2.2rem 3rem 2.7rem}.scenario-art{display:grid;place-items:start center;padding-top:1rem}.scenario-art>div{position:relative;display:grid;place-items:center;width:120px;height:120px;border-radius:50%;background:linear-gradient(145deg,#f5f1ff,#e9e4ff);color:#6d4aff;font-size:3.5rem}.scenario-art b{position:absolute;right:10px;bottom:12px;display:grid;place-items:center;width:28px;height:28px;border-radius:50%;background:#ec4899;color:#fff;font-size:1rem}.case-body h2{margin:0;color:#17203b;font-size:1.2rem;font-weight:850;line-height:1.5}.title-line{display:block;width:46px;height:3px;margin:.8rem 0 1.7rem;border-radius:99px;background:#7c5cfc}.case-body h3{color:#5b42a8;font-size:.82rem;font-weight:900;text-transform:uppercase}.case-options{display:grid;gap:.75rem}.case-options button{display:flex;align-items:center;gap:1rem;width:100%;padding:.9rem 1rem;border:1px solid #b9a9ff;border-radius:13px;background:rgba(255,255,255,.7);color:#17203b;text-align:left;transition:.18s}.case-options button:hover:not(:disabled){transform:translateX(4px);box-shadow:0 10px 24px rgba(109,74,255,.12)}.case-options button>span{display:grid;place-items:center;flex:0 0 42px;height:42px;border-radius:50%;background:#ede8ff;color:#6d4aff;font-size:1.1rem}.case-options button>b{flex:1}.case-options button>i{color:#6d4aff}.case-options .option-1{border-color:#f3a3c7}.case-options .option-1>span{background:#ffe7f1;color:#db2777}.case-options .option-2{border-color:#93c5fd}.case-options .option-2>span{background:#e8f2ff;color:#2563eb}.case-feedback{display:flex;align-items:center;gap:.8rem;margin-top:1rem;padding:1rem;border-radius:14px;background:#eefbf3;color:#166534}.case-feedback.learn{background:#fff8e6;color:#92400e}.case-feedback div{flex:1}.case-feedback p{margin:.2rem 0 0;font-size:.78rem}.case-feedback button{border:0;background:transparent;color:inherit;font-weight:800}.case-note{display:flex;align-items:center;justify-content:center;gap:.7rem;width:fit-content;max-width:90%;margin:1.5rem auto 0;padding:.75rem 1.2rem;border:1px solid rgba(255,255,255,.9);border-radius:999px;background:rgba(255,255,255,.66);color:#64748b;backdrop-filter:blur(16px)}.case-note i{color:#7c5cfc}html[data-theme="dark"] .case-hero h1,html[data-theme="dark"] .case-body h2{color:#fff}html[data-theme="dark"] .case-hero p{color:#ddd6fe}html[data-theme="dark"] .case-card{background:rgba(30,27,75,.86);border-color:rgba(196,181,253,.24)}html[data-theme="dark"] .case-card-head{background:linear-gradient(135deg,#373080,#272250);border-color:rgba(196,181,253,.18)}html[data-theme="dark"] .case-options button{background:rgba(49,46,129,.35);color:#f8fafc}html[data-theme="dark"] .case-note{background:rgba(30,27,75,.72);color:#ddd6fe}
    @@media(max-width:760px){.case-workspace{padding-inline:1rem}.case-hero{min-height:160px;padding:1rem}.case-hero img{width:130px}.case-hero h1{font-size:1.7rem}.case-body{grid-template-columns:1fr;padding:1.4rem}.scenario-art{display:none}.case-card-head{padding:1rem}.case-chat-art{display:none}}
    .case-hero img { width: 245px; height: 210px; object-fit: contain; mix-blend-mode: multiply; }
    html[data-theme="dark"] .case-hero img { mix-blend-mode: screen; }
</style>
