@page "/time-management-quiz"
@rendermode InteractiveServer
@inject NavigationManager Nav
<PageTitle>Trắc nghiệm Quản lý thời gian</PageTitle>
<main class="tmq"><button class="back" @onclick='()=>Nav.NavigateTo("/time-management-lesson")'><i class="bi bi-arrow-left"></i> Video bài giảng</button>@if(!submitted){<header><span>TRẮC NGHIỆM · 20 CÂU</span><h1>Kiểm tra kỹ năng <em>quản lý thời gian</em></h1><div><b>@(current+1)/@Questions.Count</b><i><span style="width:@Progress%"></span></i></div></header><article><small>CÂU @(current+1)</small><h2>@Current.Text</h2><div class="answers">@for(var i=0;i<Current.Options.Length;i++){var idx=i;<button class="@(answers[current]==idx?"selected":"")" @onclick="()=>Choose(idx)"><b>@("ABCD"[idx])</b><span>@Current.Options[idx]</span><i class="bi bi-check-circle-fill"></i></button>}</div><footer><button disabled="@(current==0)" @onclick="Prev"><i class="bi bi-arrow-left"></i> Trước</button>@if(current<Questions.Count-1){<button class="primary" disabled="@(answers[current]<0)" @onclick="Next">Tiếp theo <i class="bi bi-arrow-right"></i></button>}else{<button class="primary" disabled="@answers.Any(x=>x<0)" @onclick="Submit">Nộp bài</button>}</footer></article>}else{<section class="result"><div class="ring"><b>@Score</b><span>/20</span></div><span>KẾT QUẢ</span><h1>@ResultTitle</h1><p>@ResultText</p><div><button @onclick="Restart"><i class="bi bi-arrow-repeat"></i> Làm lại</button><button class="primary" @onclick='()=>Nav.NavigateTo("/time-management-games/0")'>Tiếp tục thực hành <i class="bi bi-arrow-right"></i></button></div><details><summary>Xem đáp án</summary>@foreach(var q in Questions.Select((q,i)=>(q,i))){<p class="@(answers[q.i]==q.q.Correct?"right":"wrong")"><b>Câu @(q.i+1)</b> @q.q.Options[q.q.Correct]</p>}</details></section>}</main>
@code{private int current;private bool submitted;private int[] answers=[];private Question Current=>Questions[current];private double Progress=>(current+1d)/Questions.Count*100;private int Score=>Questions.Select((q,i)=>(q,i)).Count(x=>answers[x.i]==x.q.Correct);private string ResultTitle=>Score>=18?"Xuất sắc!":Score>=14?"Nắm kiến thức khá tốt":Score>=10?"Đã có nền tảng":"Cần xem lại bài giảng";private string ResultText=>Score>=14?"Bạn đã hiểu cách ưu tiên, tập trung và vượt qua trì hoãn.":"Hãy xem lại Pomodoro, Eat the Frog và Ma trận Eisenhower trước khi thử lại.";protected override void OnInitialized()=>answers=Enumerable.Repeat(-1,Questions.Count).ToArray();private void Choose(int i)=>answers[current]=i;private void Next()=>current++;private void Prev()=>current--;private void Submit()=>submitted=true;private void Restart(){current=0;submitted=false;answers=Enumerable.Repeat(-1,Questions.Count).ToArray();}
private sealed record Question(string Text,string[] Options,int Correct);private static readonly List<Question> Questions=[
new("Điều gì thường được xem là “kẻ thù” lớn nhất của quản lý thời gian?",["Thiếu ngủ","Sự trì hoãn","Lịch quá dày","Hoạt động ngoại khóa"],1),new("Lý do tâm lý phổ biến khiến người ta trì hoãn nhiệm vụ khó?",["Quên hạn nộp","Nhiệm vụ quá dễ","Sợ thất bại hoặc làm không đủ tốt","Muốn thử thách phút chót"],2),new("Trì hoãn kéo dài có thể dẫn đến điều gì?",["Tăng sáng tạo","Rèn chịu áp lực","Bỏ lỡ mục tiêu, căng thẳng và lo âu","Nhận ra việc không quan trọng"],2),new("Khác biệt lớn nhất khi quản lý thời gian lúc trưởng thành?",["Càng lớn càng phải tự chủ động lên kế hoạch","Phổ thông có nhiều thời gian rảnh","Phổ thông phải tự lên kế hoạch mọi việc","Không khác biệt"],0),new("Bước đầu để ước lượng thời gian nhiệm vụ?",["Hỏi người khác","Đọc và hiểu yêu cầu, độ dài, độ phức tạp","Dành đúng một giờ","Vừa làm vừa canh"],1),new("Daily Top Three mang lại lợi ích gì?",["Làm ba việc rồi nghỉ","Xác định và hoàn thành ba nhiệm vụ quan trọng nhất","Chia ngày thành ba phần","Ghi nhớ ba sự kiện"],1),new("Pomodoro giảm mệt mỏi bằng cách nào?",["Làm ba giờ nghỉ một giờ","Phiên 25 phút xen kẽ nghỉ 3–5 phút","Vừa làm vừa ăn","Xong hết mới nghỉ"],1),new("Theo Eat the Frog, nên làm gì đầu tiên?",["Việc dễ nhất","Việc thích nhất","Nhiệm vụ lớn hoặc khó chịu hay né tránh","Trả lời tin nhắn"],2),new("Eisenhower dựa trên hai yếu tố nào?",["Khó và dễ","Thời gian và chi phí","Quan trọng và khẩn cấp","Yêu cầu nhiều phía"],2),new("Nhiệm vụ giá trị lớn, hạn sáng mai thuộc nhóm nào?",["Quan trọng không khẩn cấp","Khẩn cấp và quan trọng","Khẩn cấp không quan trọng","Không khẩn cấp, không quan trọng"],1),new("Cách xử lý thông minh với dự án lớn?",["Thức trắng đêm","Chia nhỏ và phân bổ trong tuần","Đợi sát hạn","Làm kết luận trước"],1),new("Cách hạn chế điện thoại gây xao nhãng?",["Bật TV","Úp điện thoại trước mặt","Cất ngoài tầm mắt hoặc phòng khác","Vừa học vừa nhắn"],2),new("Vì sao multitasking không hiệu quả?",["Tốn điện","Não không xử lý tốt nhiều luồng phức tạp cùng lúc","Làm quá nhanh","Chán phim"],1),new("Biết nhịp sinh học giúp gì?",["Xin đổi giờ","Chọn khung giờ năng lượng cao để làm việc khó","Có lý do ngủ nướng","Ăn ngon hơn"],1),new("Chữ T trong SMART nghĩa là gì?",["Làm cùng lúc","Đo bằng kiểm tra","Có thời hạn cụ thể","Tốn nhiều thời gian"],2),new("Cách tận dụng lại quỹ thời gian?",["Bỏ ăn ngủ","Dùng khoảng thời gian chết cho việc nhỏ","Xin nghỉ","Làm nhiều việc cùng lúc"],1),new("Cramming gây hậu quả xấu vì sao?",["Uống nhiều cà phê","Căng thẳng, thiếu ngủ, quá tải và khó nhớ lâu","Học ngoài bài thi","Giảng viên không vui"],1),new("Nên làm gì khi học khối lượng lớn?",["Học bốn giờ liên tục","Nghỉ ngắn hoặc tự hỏi sau mỗi 10–25 phút","Nghe nhạc to","Chỉ đọc tóm tắt"],1),new("Vì sao nên đưa ăn, ngủ, tập thể dục vào lịch?",["Lịch trông bận","Sức khỏe tốt giúp làm việc bền vững","Thể hiện kỷ luật","Để người khác thấy chăm"],1),new("Hiệu ứng Domino trong quản lý thời gian là gì?",["Một trì hoãn nhỏ kéo theo vấn đề cho việc sau","Xong việc này tự xong việc khác","Xếp sách như domino","Chơi trước khi học"],0)];}
<style>.tmq{max-width:900px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:#19163d}.back{border:0;background:none;color:#747b8c;font-weight:800}.tmq>header{margin:1rem 0;padding:1.5rem;border-radius:22px;background:linear-gradient(135deg,#fff,#eee9ff)}.tmq header>span,.tmq article>small,.result>span{color:#6847eb;font-size:.65rem;font-weight:900;letter-spacing:.08em}.tmq h1{margin:.4rem 0}.tmq h1 em{color:#6847eb;font-style:normal}.tmq header>div{display:flex;align-items:center;gap:.8rem}.tmq header i{flex:1;height:7px;overflow:hidden;border-radius:10px;background:#ded8f5}.tmq header i span{display:block;height:100%;background:#6847eb}.tmq article,.result{padding:clamp(1rem,3vw,2rem);border:1px solid #ded8f5;border-radius:22px;background:#fff}.answers{display:grid;gap:.6rem}.answers button{display:grid;grid-template-columns:36px 1fr auto;align-items:center;gap:.7rem;padding:.8rem;text-align:left;border:1px solid #e2ddf3;border-radius:12px;background:#fff}.answers button>b{display:grid;place-items:center;width:32px;height:32px;border-radius:9px;background:#eeeaff;color:#6847eb}.answers button>i{opacity:0;color:#6847eb}.answers .selected{border-color:#6847eb;background:#f7f4ff}.answers .selected i{opacity:1}.tmq article footer,.result>div{display:flex;justify-content:space-between;gap:.7rem;margin-top:1rem}.tmq footer button,.result button{padding:.7rem .9rem;border:1px solid #d8d1f1;border-radius:10px;background:#fff;font-weight:800}.tmq .primary{color:#fff;border-color:#6847eb;background:#6847eb}.result{text-align:center}.ring{display:grid!important;place-items:center;width:120px;height:120px;margin:0 auto 1rem!important;border:10px solid #dcd5f7;border-top-color:#6847eb;border-radius:50%}.ring b{font-size:2rem}.ring span{font-size:.7rem}.result>div{justify-content:center}.result details{margin-top:1.5rem;text-align:left}.result details p{padding:.5rem;border-radius:8px;font-size:.75rem}.right{background:#ecfdf3}.wrong{background:#fff1f1}</style>
