    html[data-theme="dark"] .rp-page{--ink:#f8fafc;--muted:#cbd5e1}html[data-theme="dark"] .rp-hero,html[data-theme="dark"] .rp-workspace>aside,html[data-theme="dark"] .rp-chat,html[data-theme="dark"] .rp-result,html[data-theme="dark"] .rp-chat textarea{background:#211c47;border-color:rgba(167,139,250,.2)}html[data-theme="dark"] .rp-messages,html[data-theme="dark"] .rp-rubrics article{background:#171532}html[data-theme="dark"] .rp-messages .ai p{background:#2b2557}@@media(max-width:850px){.rp-hero{grid-template-columns:1fr}.rp-hero-meta{grid-template-columns:repeat(3,1fr)}.rp-workspace{grid-template-columns:1fr}.rp-result>header{grid-template-columns:130px 1fr}.rp-result header>button{grid-column:1/-1}.rp-rubrics,.rp-diagnostic{grid-template-columns:1fr}}@@media(max-width:520px){.rp-hero-meta{grid-template-columns:1fr}.rp-result>header{grid-template-columns:1fr}.rp-score{margin:auto}.rp-messages>div{max-width:92%}}
