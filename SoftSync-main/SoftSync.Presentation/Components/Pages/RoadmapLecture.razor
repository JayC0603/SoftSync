@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@page "/communication-lesson"
@page "/communication-lesson-2"
@page "/communication-lesson-3"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IRoadmapService RoadmapService
@inject NavigationManager Nav

<div class="max-900 mx-auto">
    <div class="tw:mb-4">
        <button class="btn btn-link text-muted tw:no-underline tw:px-0" @onclick="BackToRoadmap">
            <i class="bi bi-arrow-left tw:me-1"></i> @L["roadmap.backToRoadmap"]
        </button>
    </div>

    @if (item == null)
    {
        <div class="ss-card tw:p-12 tw:text-center">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="ss-card ss-glass-interactive tw:p-12 lecture-shell">
            <div class="tw:flex tw:items-center tw:justify-between tw:mb-4">
                <div>
                    <span class="text-primary tw:font-bold tw:text-sm tw:uppercase">@L["roadmap.week"] @DisplayWeekNumber</span>
                    <h2 class="tw:font-bold tw:mb-0">@item.Title</h2>
                </div>
                <span class="badge bg-primary">@item.SkillName</span>
            </div>

            <div class="lecture-video tw:mb-4">
                <video controls preload="metadata" playsinline poster="/images/background-softsync.png">
                    <source src="@VideoSource" type="video/mp4" />
                    Trình duyệt của bạn không hỗ trợ phát video HTML5.
                </video>
                <div class="lecture-video-caption">
                    <span><i class="bi bi-play-circle-fill"></i> VIDEO BÀI GIẢNG</span>
                    <div><strong>Kỹ năng Giao tiếp · Bài @DisplayWeekNumber</strong><small>Video hướng dẫn từ Mentor SoftSync</small></div>
                </div>
            </div>

            @if (item.IsCompleted)
            {
                <div class="lecture-complete lecture-complete--compact tw:mb-4">
                    <i class="bi bi-patch-check-fill"></i>
                    <div><strong>Bạn đã hoàn thành Game 1</strong><span>Bạn vẫn có thể xem lại video bài giảng bất cứ lúc nào.</span></div>
                </div>
            }

            <p class="text-muted tw:mb-0">
                @item.Description
            </p>

            <div class="tw:mt-8 tw:text-end">
                @if (item.IsCompleted)
                {
                    <button class="ss-btn-primary tw:px-8 tw:py-3" disabled style="opacity:.65; cursor:not-allowed;">
                        Đã hoàn thành Game 1
                    </button>
                }
                else if (item.WeekNumber == 1 || IsCommunicationLessonTwo || IsCommunicationLessonThree)
                {
                    <button class="ss-btn-primary tw:px-8 tw:py-3" @onclick="GoToGame">
                        @L["roadmap.continueToGame"] <i class="bi bi-arrow-right tw:ms-2"></i>
                    </button>
                }
                else
                {
                    <button class="ss-btn-primary tw:px-8 tw:py-3" disabled title="@L["roadmap.gameUnavailable"]" style="opacity:.65; cursor:not-allowed;">
                        @L["roadmap.gameUnavailable"]
                    </button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }

    private RoadmapItemDto? item;
    private bool IsCommunicationLessonTwo => Nav.Uri.Contains("/communication-lesson-2", StringComparison.OrdinalIgnoreCase);
    private bool IsCommunicationLessonThree => Nav.Uri.Contains("/communication-lesson-3", StringComparison.OrdinalIgnoreCase);
    private int DisplayWeekNumber => IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : item?.WeekNumber ?? 1;
    private string VideoSource => IsCommunicationLessonThree
        ? "/videos/communication-mentor-lesson-3.mp4"
        : IsCommunicationLessonTwo ? "/videos/communication-mentor-lesson-2.mp4" : "/videos/communication-mentor-lesson-1.mp4";

    protected override async Task OnInitializedAsync()
    {
        if (UserId == 0 && ItemId == 0)
        {
            item = new RoadmapItemDto
            {
                Id = 0,
                WeekNumber = IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : 1,
                SkillName = "Kỹ năng Giao tiếp",
                Title = IsCommunicationLessonThree
                    ? "Làm chủ giọng nói và ngôn ngữ cận lời"
                    : IsCommunicationLessonTwo ? "Thực hành giao tiếp qua tình huống"
                    : "Nền tảng giao tiếp và lắng nghe chủ động",
                Description = IsCommunicationLessonThree
                    ? "Tìm hiểu tốc độ nói, độ rõ chữ, khoảng lặng và tông giọng trước khi bước vào bài luyện ghi âm."
                    : IsCommunicationLessonTwo ? "Xem bài giảng từ Mentor trước khi thực hành Quiz 2 với các tình huống giao tiếp mô phỏng."
                    : "Ôn tập các thành phần cốt lõi của giao tiếp, lắng nghe chủ động, rào cản nhận thức và giao tiếp khẳng định ôn hòa."
            };
            return;
        }

        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        item = roadmap.Items.FirstOrDefault(i => i.Id == ItemId);
        if (item is null)
            Nav.NavigateTo($"/roadmap/{UserId}", true);
    }

    private void GoToGame() => Nav.NavigateTo(IsCommunicationLessonThree
        ? "/communication-voice-practice"
        : IsCommunicationLessonTwo ? "/communication-roleplay"
        : UserId == 0 ? "/communication-quiz" : $"/roadmap/game/{UserId}/{ItemId}");

    private void BackToRoadmap() => Nav.NavigateTo(UserId == 0 ? "/roadmap" : $"/roadmap/{UserId}");
}

<style>
    .max-900 { max-width: 900px; }
    .lecture-shell {
        border-radius: 24px;
    }
    .lecture-placeholder {
        min-height: 320px;
        border-radius: 22px;
        border: 2px dashed rgba(99, 102, 241, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: var(--primary);
        background: rgba(99, 102, 241, 0.06);
    }
    .lecture-video {
        overflow: hidden;
        border: 1px solid rgba(99, 102, 241, 0.16);
        border-radius: 22px;
        background: #090b18;
        box-shadow: 0 20px 48px rgba(30, 27, 75, 0.18);
    }
    .lecture-video video {
        display: block;
        width: 100%;
        max-height: 520px;
        aspect-ratio: 16 / 9;
        object-fit: contain;
        background: #090b18;
    }
    .lecture-video-caption {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 18px;
        color: #e9e7ff;
        background: linear-gradient(135deg, #201b49, #302366);
    }
    .lecture-video-caption > span {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        color: #c4b5fd;
        font-size: .7rem;
        font-weight: 850;
        letter-spacing: .08em;
        white-space: nowrap;
    }
    .lecture-video-caption div { display: flex; flex-direction: column; }
    .lecture-video-caption small { color: rgba(233, 231, 255, .68); }

    .lecture-complete {
        min-height: 320px;
        border-radius: 22px;
        border: 1px solid rgba(16, 185, 129, 0.18);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 1.1rem;
        color: #059669;
        background: rgba(16, 185, 129, 0.08);
        text-align: center;
        padding: 24px;
    }
    .lecture-complete--compact {
        min-height: 0;
        flex-direction: row;
        justify-content: flex-start;
        padding: 16px 18px;
        text-align: left;
    }
    .lecture-complete--compact i { font-size: 1.6rem; }
    .lecture-complete--compact div { display: flex; flex-direction: column; }
    .lecture-complete--compact span { font-size: .82rem; }
    @@media (max-width: 560px) {
        .lecture-video-caption { align-items: flex-start; flex-direction: column; gap: 6px; }
    }
</style>
