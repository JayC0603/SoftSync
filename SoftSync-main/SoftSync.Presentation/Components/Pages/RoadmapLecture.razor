@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@page "/communication-lesson"
@page "/communication-lesson-2"
@page "/communication-lesson-3"
@page "/communication-lesson-4"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<div class="max-900 mx-auto">
    <div class="tw:mb-4">
        <button class="btn btn-link text-muted tw:no-underline tw:px-0" @onclick="BackToRoadmap">
            <i class="bi bi-arrow-left tw:me-1"></i> @L["roadmap.backToRoadmap"]
        </button>
    </div>

    @if (item == null)
    {
        <div class="ss-card tw:p-12 tw:text-center">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="ss-card ss-glass-interactive tw:p-12 lecture-shell">
            <div class="tw:flex tw:items-center tw:justify-between tw:mb-4">
                <div>
                    <span class="text-primary tw:font-bold tw:text-sm tw:uppercase">@L["roadmap.week"] @DisplayWeekNumber</span>
                    <h2 class="tw:font-bold tw:mb-0">@DisplayTitle</h2>
                </div>
                <span class="badge bg-primary">@DisplaySkillName</span>
            </div>

            <nav class="learning-stepper" aria-label="@Tx("Learning steps", "Các bước học")">
                @foreach (var step in LearningSteps)
                {
                    <button class="@StepClass(step.Value)" @onclick="() => GoToStep(step.Value)">
                        <span>@(StepIsComplete(step.Value) ? "✓" : step.Number.ToString())</span>
                        <small>@step.Label</small>
                    </button>
                }
            </nav>

            @if (currentStep == LearningStep.Video)
            {
                @if (HasVideo)
                {
                    <div class="lecture-video tw:mb-4">
                        <video controls preload="metadata" playsinline poster="/images/background-softsync.png" @onended="CompleteVideoAsync">
                            <source src="@VideoSource" type="video/mp4" />
                            @Tx("Your browser does not support HTML5 video.", "Trình duyệt của bạn không hỗ trợ video HTML5.")
                        </video>
                        <div class="lecture-video-caption">
                            <span><i class="bi bi-play-circle-fill"></i> @Tx("VIDEO LESSON", "VIDEO BÀI GIẢNG")</span>
                            <div><strong>@DisplaySkillName · @Tx("Lesson", "Bài") @DisplayWeekNumber</strong><small>@Tx("Guided by a SoftSync Mentor", "Video hướng dẫn từ Mentor SoftSync")</small></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="lecture-placeholder tw:mb-4"><i class="bi bi-camera-video-off tw:me-2"></i> @Tx("Video coming soon", "Video đang được cập nhật")</div>
                }
            }
            else if (currentStep == LearningStep.Script)
            {
                <article class="guided-content guided-script">
                    <header><i class="bi bi-file-earmark-text-fill"></i><div><small>VIDEO @DisplayWeekNumber · SCRIPT</small><h3>@(IsListeningVideoTwo ? Tx("Introduction to Listening Skills", "Giới thiệu về kỹ năng lắng nghe") : IsTimeManagementVideoOne ? Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp") : DisplayTitle)</h3></div></header>
                    @if (IsTimeManagementVideoOne)
                    {
                        <section>
                            <h4>@Tx("1. Communication is a two-way street", "1. Giao tiếp là “con đường hai chiều”")</h4>
                            <p>@Tx("Effective communication is not only about sending a message, but also receiving feedback. A basic communication process includes:", "Giao tiếp hiệu quả không chỉ là gửi đi thông điệp mà còn là tiếp nhận phản hồi. Một quá trình giao tiếp cơ bản bao gồm:")</p>
                            <ul>
                                <li><strong>@Tx("Sender:", "Người gửi:")</strong> @Tx("The person who creates and delivers the message.", "Người tạo ra và truyền đạt thông điệp.")</li>
                                <li><strong>@Tx("Message:", "Thông điệp:")</strong> @Tx("The content and meaning conveyed through speech, writing, or gestures.", "Nội dung, ý nghĩa bạn muốn truyền tải qua lời nói, chữ viết hoặc cử chỉ.")</li>
                                <li><strong>@Tx("Channel:", "Kênh truyền tải:")</strong> @Tx("The method used to deliver the message, such as face-to-face conversation, email, telephone, or social media.", "Cách thức thông điệp được gửi đi như nói trực tiếp, email, điện thoại hoặc mạng xã hội.")</li>
                                <li><strong>@Tx("Receiver:", "Người nhận:")</strong> @Tx("The person who receives and decodes the message.", "Người tiếp nhận và giải mã thông điệp đó.")</li>
                                <li><strong>@Tx("Feedback:", "Phản hồi:")</strong> @Tx("The receiver's response, which tells the sender whether the message was understood correctly.", "Sự hồi đáp của người nhận giúp người gửi biết thông điệp đã được hiểu đúng hay chưa.")</li>
                            </ul>
                        </section>
                        <section>
                            <h4>@Tx("2. Essential skills for students", "2. Các kỹ năng then chốt cho sinh viên")</h4>
                            <ul>
                                <li><strong>@Tx("Active Listening:", "Lắng nghe chủ động (Active Listening):")</strong> @Tx("This is the most important skill. Do not merely hear sounds; give your full attention, avoid interrupting, and confirm what you heard to prevent misunderstandings.", "Đây là kỹ năng quan trọng nhất. Đừng chỉ “nghe” thấy âm thanh; hãy tập trung hoàn toàn, không ngắt lời và xác nhận lại những gì bạn đã nghe để tránh hiểu lầm.")</li>
                                <li><strong>@Tx("Nonverbal communication:", "Giao tiếp phi ngôn ngữ:")</strong> @Tx("Even in silence, you communicate through eye contact, gestures, clothing, and posture. Body language often carries more weight than words.", "Ngay cả khi im lặng, bạn vẫn đang giao tiếp thông qua ánh mắt, điệu bộ, trang phục và tư thế ngồi. Ngôn ngữ cơ thể thường có sức nặng hơn cả lời nói.")</li>
                                <li><strong>@Tx("Netiquette:", "Quy tắc ứng xử mạng (Netiquette):")</strong> @Tx("In an academic setting, keep emails to lecturers professional by using complete sentences, a clear subject line, and a formal greeting.", "Trong môi trường học thuật, hãy giữ sự chuyên nghiệp khi viết email cho giảng viên: dùng câu chữ hoàn chỉnh, tiêu đề rõ ràng và lời chào trang trọng.")</li>
                            </ul>
                        </section>
                        <section>
                            <h4>@Tx("3. Tips for successful communication", "3. Bí quyết để giao tiếp thành công")</h4>
                            <ul>
                                <li><strong>@Tx("Prepare carefully:", "Luôn chuẩn bị kỹ:")</strong> @Tx("Before a presentation or important meeting, organize your ideas logically and clearly.", "Trước một buổi thuyết trình hay cuộc gặp quan trọng, hãy sắp xếp ý tưởng một cách logic và rõ ràng.")</li>
                                <li><strong>@Tx("Understand the context:", "Thấu hiểu bối cảnh:")</strong> @Tx("Talking with friends in the cafeteria is very different from participating in a classroom discussion. A strong communicator adapts their style to the audience and situation.", "Cách bạn nói chuyện với bạn bè tại căng tin sẽ khác hoàn toàn với cách bạn thảo luận trong lớp học. Một người giao tiếp giỏi luôn biết điều chỉnh phong cách phù hợp với đối tượng và tình huống.")</li>
                                <li><strong>@Tx("Communicate ethically:", "Giao tiếp có đạo đức:")</strong> @Tx("Base communication on respect, honesty, and fairness. Do not share misleading information or content that may harm others.", "Luôn dựa trên sự tôn trọng, trung thực và công bằng với người nghe. Đừng đưa ra những thông tin sai lệch hoặc gây tổn thương người khác.")</li>
                                <li><strong>@Tx("Use simple language:", "Sử dụng ngôn từ đơn giản:")</strong> @Tx("Choose precise, easy-to-understand words and avoid excessive jargon or slang when the listener may not know it.", "Hãy chọn từ ngữ chính xác, dễ hiểu và tránh lạm dụng biệt ngữ (jargon) hoặc từ lóng nếu người nghe không quen thuộc với chúng.")</li>
                            </ul>
                            <p>@Tx("Developing communication skills is a long journey that requires patience and self-adjustment. Strong communication helps you learn more effectively and make a professional impression on future employers.", "Việc rèn luyện kỹ năng giao tiếp là một hành trình dài cần sự kiên nhẫn và tự điều chỉnh. Khi bạn giao tiếp tốt, bạn không chỉ học tập hiệu quả hơn mà còn tạo được ấn tượng chuyên nghiệp trong mắt nhà tuyển dụng tương lai.")</p>
                        </section>
                    }
                    else if (IsListeningVideoTwo)
                    {
                        <section>
                            <p>@Tx("Listening is not merely receiving sound. It is an active process of understanding and sharing meaning with others. Effective communication is a two-way street, so genuine connection starts with understanding the other person's message.", "Lắng nghe không chỉ là việc tiếp nhận âm thanh, mà là một quá trình chủ động nhằm thấu hiểu và chia sẻ ý nghĩa với người khác. Đây là kỹ năng nền tảng vì giao tiếp hiệu quả luôn là “con đường hai chiều”: bạn không thể kết nối tốt nếu không hiểu thông điệp của đối phương.")</p>
                        </section>
                        <section>
                            <h4>@Tx("1. Hearing versus listening", "1. Phân biệt giữa “Nghe” và “Lắng nghe”")</h4>
                            <ul>
                                <li><strong>@Tx("Hearing:", "Nghe (Hearing):")</strong> @Tx("A passive physical response of the ears to sound.", "Là phản xạ vật lý thụ động của tai đối với âm thanh.")</li>
                                <li><strong>@Tx("Listening:", "Lắng nghe (Listening):")</strong> @Tx("An active mental process that requires concentration to interpret and remember information. You may hear a lecture, but without listening you will not truly understand it.", "Là một quá trình tâm lý chủ động, đòi hỏi sự tập trung để diễn giải và ghi nhớ thông tin. Bạn có thể nghe thấy tiếng giảng bài nhưng nếu không lắng nghe, bạn sẽ không thực sự hiểu nội dung đó.")</li>
                            </ul>
                        </section>
                        <section>
                            <h4>@Tx("2. Principles of active listening", "2. Các nguyên tắc của Lắng nghe chủ động")</h4>
                            <ul>
                                <li><strong>@Tx("Stop talking:", "Ngừng nói:")</strong> @Tx("You cannot listen while talking or rehearsing your answer in your head.", "Bạn không thể lắng nghe khi đang mải nói hoặc chuẩn bị sẵn câu trả lời trong đầu.")</li>
                                <li><strong>@Tx("Remove distractions:", "Loại bỏ xao nhãng:")</strong> @Tx("Put away your phone, turn off music, and focus completely on the speaker.", "Cất điện thoại, tắt nhạc và tập trung hoàn toàn vào người đối diện.")</li>
                                <li><strong>@Tx("Show empathy:", "Thấu cảm (Empathy):")</strong> @Tx("Try to understand the speaker's emotions and perspective before judging or giving advice.", "Cố gắng hiểu cảm xúc và góc nhìn của người nói thay vì vội vàng phán xét hay đưa ra lời khuyên.")</li>
                                <li><strong>@Tx("Confirm the message:", "Xác nhận lại thông tin:")</strong> @Tx("Repeat or summarize what you heard to make sure you understood correctly.", "Nhắc lại hoặc tóm tắt những gì bạn vừa nghe để đảm bảo mình đã hiểu đúng ý đối phương.")</li>
                                <li><strong>@Tx("Notice nonverbal cues:", "Chú ý tín hiệu phi ngôn ngữ:")</strong> @Tx("Observe eye contact, facial expressions, and gestures because they often reveal feelings more clearly than words.", "Quan sát ánh mắt, nét mặt và cử chỉ tay vì chúng thường phản ánh cảm xúc thật hơn cả lời nói.")</li>
                            </ul>
                        </section>
                        <section>
                            <h4>@Tx("3. Effective listening in class", "3. Bí quyết lắng nghe hiệu quả trong lớp học")</h4>
                            <ul>
                                <li><strong>@Tx("Choose your seat:", "Chọn vị trí ngồi:")</strong> @Tx("Sitting near the front helps maintain eye contact and reduces distractions.", "Ngồi ở những bàn đầu giúp bạn duy trì tương tác mắt với giảng viên và giảm thiểu sự xao nhãng.")</li>
                                <li><strong>@Tx("Recognize lecturer signals:", "Nhận diện tín hiệu từ giảng viên:")</strong> @Tx("Repeated ideas, a change in tone, or notes on the board often signal important content.", "Chú ý khi giảng viên lặp lại một ý tưởng, thay đổi tông giọng hoặc viết lên bảng—đây thường là nội dung quan trọng.")</li>
                                <li><strong>@Tx("Ask questions:", "Đặt câu hỏi:")</strong> @Tx("Questions clarify uncertainty and show that you are actively processing information.", "Đặt câu hỏi giúp làm rõ điểm chưa hiểu và thể hiện bạn đang thực sự xử lý thông tin.")</li>
                                <li><strong>@Tx("Take notes:", "Ghi chú (Note-taking):")</strong> @Tx("Note-taking keeps your attention on key ideas and supports later recall.", "Ghi chép giúp duy trì sự tập trung vào các điểm chính và hỗ trợ ghi nhớ sau này.")</li>
                            </ul>
                        </section>
                        <section>
                            <h4>@Tx("4. Benefits of strong listening", "4. Lợi ích của việc rèn luyện kỹ năng lắng nghe")</h4>
                            <ul>
                                <li><strong>@Tx("Build trust:", "Xây dựng lòng tin:")</strong> @Tx("People feel respected and understood, strengthening relationships with friends and teachers.", "Người khác cảm thấy được tôn trọng và thấu hiểu, giúp quan hệ với bạn bè và thầy cô tốt đẹp hơn.")</li>
                                <li><strong>@Tx("Support career success:", "Thành công trong sự nghiệp:")</strong> @Tx("Employers value listening because it is foundational to conflict resolution and effective teamwork.", "Nhà tuyển dụng đánh giá cao người biết lắng nghe vì đây là nền tảng để giải quyết xung đột và làm việc nhóm hiệu quả.")</li>
                            </ul>
                            <p>@Tx("Good listening takes time and persistence to develop, but it helps you learn better and create a professional impression.", "Lắng nghe giỏi cần thời gian và sự kiên trì để rèn luyện, nhưng sẽ giúp bạn học tập tốt hơn và tạo ấn tượng chuyên nghiệp trong tương lai.")</p>
                        </section>
                    }
                    else
                    {
                        <div class="guided-empty"><i class="bi bi-hourglass-split"></i><p>@Tx("This lesson's script will be updated soon.", "Script của bài học này sẽ sớm được cập nhật.")</p></div>
                    }
                </article>
            }
            else if (currentStep == LearningStep.Summary)
            {
                <article class="guided-content guided-summary">
                    <header><i class="bi bi-lightbulb-fill"></i><div><small>@Tx("LESSON SUMMARY", "TÓM TẮT BÀI HỌC")</small><h3>@DisplayTitle</h3></div></header>
                    @if (IsListeningVideoTwo)
                    {
                        <ul>
                            <li>@Tx("Hearing is passive; listening is an active process of understanding and remembering.", "Nghe là phản xạ thụ động; lắng nghe là quá trình chủ động để hiểu và ghi nhớ.")</li>
                            <li>@Tx("Active listening requires focus, empathy, confirmation, and attention to nonverbal cues.", "Lắng nghe chủ động cần sự tập trung, thấu cảm, xác nhận lại và chú ý tín hiệu phi ngôn ngữ.")</li>
                            <li>@Tx("In class, sit strategically, notice lecturer signals, ask questions, and take notes.", "Trong lớp học, hãy chọn vị trí phù hợp, nhận diện tín hiệu giảng viên, đặt câu hỏi và ghi chú.")</li>
                            <li>@Tx("Strong listening builds trust and supports teamwork, conflict resolution, and career success.", "Lắng nghe tốt giúp xây dựng lòng tin, làm việc nhóm, giải quyết xung đột và phát triển sự nghiệp.")</li>
                        </ul>
                    }
                    else
                    {
                        <p>@DisplayDescription</p>
                    }
                    <div class="summary-callout"><i class="bi bi-check2-circle"></i><span>@Tx("Review the key ideas, then continue to the quiz to check your understanding.", "Ôn lại các ý chính, sau đó làm Quiz để kiểm tra mức độ hiểu bài.")</span></div>
                </article>
            }
            else if (currentStep == LearningStep.Scenario)
            {
                <article class="guided-content guided-scenario">
                    <header><i class="bi bi-chat-square-text-fill"></i><div><small>@Tx("APPLIED SCENARIO", "TÌNH HUỐNG ỨNG DỤNG")</small><h3>@Tx("Choose how you would respond", "Chọn cách bạn sẽ xử lý")</h3></div></header>
                    <p class="scenario-prompt">@ScenarioPrompt</p>
                    <div class="scenario-options">
                        @foreach (var option in ScenarioOptions.Select((value, index) => new { value, index }))
                        {
                            <button class="@(selectedScenarioOption == option.index ? "selected" : "")" @onclick="() => CompleteScenarioAsync(option.index)">
                                <span>@((char)('A' + option.index))</span>
                                <div><strong>@option.value.Title</strong><small>@option.value.Description</small></div>
                                @if (selectedScenarioOption == option.index) { <i class="bi bi-check-circle-fill"></i> }
                            </button>
                        }
                    </div>
                    @if (item.IsScenarioCompleted)
                    {
                        <div class="scenario-feedback"><i class="bi bi-check2-circle"></i>@Tx("Your choice has been saved. Reflect on why this response is appropriate before continuing.", "Lựa chọn đã được lưu. Hãy suy nghĩ vì sao cách xử lý này phù hợp trước khi tiếp tục.")</div>
                    }
                </article>
            }
            else if (currentStep == LearningStep.Reflection)
            {
                <article class="guided-content guided-reflection">
                    <header><i class="bi bi-journal-check"></i><div><small>@Tx("REFLECTION", "PHẢN TƯ")</small><h3>@Tx("What will you apply after this lesson?", "Bạn sẽ áp dụng điều gì sau bài học này?")</h3></div></header>
                    <p>@Tx("Write a short reflection about one idea you learned and one action you will try in a real situation.", "Viết ngắn về một điều bạn học được và một hành động bạn sẽ thử áp dụng trong tình huống thực tế.")</p>
                    <textarea @bind="reflectionText" maxlength="2000" rows="7" placeholder="@Tx("I learned that... Next time, I will...", "Tôi học được rằng... Lần tới, tôi sẽ...")"></textarea>
                    <div class="reflection-meta"><span>@reflectionText.Length / 2000</span><button @onclick="SaveReflectionAsync" disabled="@(string.IsNullOrWhiteSpace(reflectionText) || savingReflection)"><i class="bi bi-cloud-check"></i>@(savingReflection ? Tx("Saving...", "Đang lưu...") : Tx("Save reflection", "Lưu phản tư"))</button></div>
                    @if (!string.IsNullOrWhiteSpace(reflectionMessage))
                    {
                        <div class="reflection-message @(item.IsReflectionCompleted ? "success" : "error")">@reflectionMessage</div>
                    }
                </article>
            }

            @if (item.IsCompleted)
            {
                <div class="lecture-complete lecture-complete--compact tw:mb-4">
                    <i class="bi bi-patch-check-fill"></i>
                    <div><strong>@Tx("Week completed", "Tuần học đã hoàn thành")</strong><span>@Tx("All six learning steps are saved. You can review them anytime.", "Cả 6 bước học đã được lưu. Bạn vẫn có thể xem lại bất cứ lúc nào.")</span></div>
                </div>
            }
            else if (item.IsVideoCompleted)
            {
                <div class="lecture-complete lecture-complete--compact tw:mb-4">
                    <i class="bi bi-check-circle-fill"></i>
                    <div><strong>@Tx("Video completed", "Đã xem xong video")</strong><span>@Tx("Your result is saved and the video now has a green tick on the Roadmap.", "Kết quả đã được lưu và video đã chuyển sang tích xanh trên Roadmap.")</span></div>
                </div>
            }

            <nav class="lecture-navigation tw:mt-8" aria-label="@Tx("Lesson navigation", "Điều hướng bài học")">
                <button class="lecture-nav-back" @onclick="GoBackStep">
                    <i class="bi bi-arrow-left"></i> @BackLabel
                </button>
                <button class="ss-btn-primary lecture-nav-next" @onclick="GoNextStep" disabled="@(!CanContinue)">
                    @NextLabel <i class="bi bi-arrow-right"></i>
                </button>
            </nav>
            @if (!CanContinue)
            {
                <small class="continue-hint">@Tx("Watch the video to the end to unlock the next step.", "Hãy xem hết video để mở khóa bước tiếp theo.")</small>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    [SupplyParameterFromQuery(Name = "step")] public string? StepName { get; set; }

    private RoadmapItemDto? item;
    private List<RoadmapItemDto> roadmapItems = [];
    private LearningStep currentStep = LearningStep.Video;
    private int selectedScenarioOption = -1;
    private string reflectionText = string.Empty;
    private string reflectionMessage = string.Empty;
    private bool savingReflection;
    private bool IsCommunicationLessonTwo => Nav.Uri.Contains("/communication-lesson-2", StringComparison.OrdinalIgnoreCase);
    private bool IsCommunicationLessonThree => Nav.Uri.Contains("/communication-lesson-3", StringComparison.OrdinalIgnoreCase);
    private bool IsCommunicationLessonFour => Nav.Uri.Contains("/communication-lesson-4", StringComparison.OrdinalIgnoreCase);
    private int DisplayWeekNumber => IsCommunicationLessonFour ? 4 : IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : item?.WeekNumber ?? 1;
    private string DisplaySkillName => item is null ? string.Empty : SkillKey(item) switch
    {
        "communication" => Tx("Communication", "Giao tiếp"),
        "time" => Tx("Time Management", "Quản lý thời gian"),
        "critical" => Tx("Critical Thinking", "Tư duy phản biện"),
        _ => item.SkillName
    };
    private string DisplayTitle => item is null ? string.Empty : UserId > 0
        ? IsPracticeItem(item) ? Tx($"{DisplaySkillName} Practice", $"Thực hành {DisplaySkillName}") : Tx($"{DisplaySkillName} Foundations", $"Nền tảng {DisplaySkillName}")
        : IsCommunicationLessonFour ? Tx("Advanced Communication", "Bài giảng giao tiếp nâng cao")
        : IsCommunicationLessonThree ? Tx("Mastering Voice and Paralanguage", "Làm chủ giọng nói và ngôn ngữ cận lời")
        : IsCommunicationLessonTwo ? Tx("Situational Communication Practice", "Thực hành giao tiếp qua tình huống")
        : Tx("Communication and Active Listening Foundations", "Nền tảng giao tiếp và lắng nghe chủ động");
    private string DisplayDescription => item is null ? string.Empty : UserId > 0
        ? IsPracticeItem(item)
            ? Tx($"Apply {DisplaySkillName.ToLowerInvariant()} in realistic situations, review feedback, and reflect after each attempt.", $"Áp dụng {DisplaySkillName.ToLowerInvariant()} vào tình huống thực tế, xem phản hồi và tự đánh giá sau mỗi lượt thực hành.")
            : Tx($"Learn the core principles of {DisplaySkillName.ToLowerInvariant()} and complete short guided exercises.", $"Nắm kiến thức cốt lõi của {DisplaySkillName.ToLowerInvariant()} và hoàn thành các bài luyện tập ngắn có hướng dẫn.")
        : item.Description;
    private string VideoSource => IsCommunicationLessonFour
        ? "/videos/communication-mentor-lesson-4.mp4"
        : IsCommunicationLessonThree ? "/videos/communication-mentor-lesson-3.mp4"
        : IsCommunicationLessonTwo ? "/videos/communication-mentor-lesson-2.mp4"
        : UserId == 0 ? "/videos/communication-mentor-lesson-1.mp4"
        : PersonalizedVideoSource();
    private bool HasVideo => !string.IsNullOrWhiteSpace(VideoSource);
    private int CurrentItemIndex => item is null ? -1 : roadmapItems.FindIndex(x => x.Id == item.Id);
    private RoadmapItemDto? PreviousItem => CurrentItemIndex > 0 ? roadmapItems[CurrentItemIndex - 1] : null;
    private RoadmapItemDto? NextItem => CurrentItemIndex >= 0 && CurrentItemIndex < roadmapItems.Count - 1 ? roadmapItems[CurrentItemIndex + 1] : null;
    private bool HasNextLesson => UserId > 0 ? NextItem is not null : !IsCommunicationLessonFour;
    private bool IsTimeManagementVideoOne => item is not null
        && SkillKey(item) == "time"
        && (UserId == 0 ? !IsCommunicationLessonTwo && !IsCommunicationLessonThree && !IsCommunicationLessonFour : SkillLessonOrdinal(item) == 1);
    private bool IsListeningVideoTwo => item is not null
        && SkillKey(item) == "communication"
        && (UserId == 0 ? IsCommunicationLessonTwo : SkillLessonOrdinal(item) == 2);
    private bool CanContinue => currentStep switch
    {
        LearningStep.Video => RoadmapReviewMode.Enabled || item?.IsVideoCompleted == true || !HasVideo,
        LearningStep.Scenario => RoadmapReviewMode.Enabled || item?.IsScenarioCompleted == true,
        LearningStep.Reflection => item?.IsReflectionCompleted == true,
        _ => true
    };
    private string BackLabel => currentStep == LearningStep.Video ? Tx("Roadmap", "Lộ trình") : Tx("Back", "Quay lại");
    private string NextLabel => currentStep switch
    {
        LearningStep.Video => Tx("Next: Script", "Tiếp theo: Script"),
        LearningStep.Script => Tx("Next: Summary", "Tiếp theo: Tóm tắt"),
        LearningStep.Summary => Tx("Start quiz", "Làm Quiz"),
        LearningStep.Scenario => Tx("Next: Reflection", "Tiếp theo: Phản tư"),
        LearningStep.Reflection when HasNextLesson => Tx("Next week", "Tuần tiếp theo"),
        LearningStep.Reflection => Tx("Finish roadmap", "Hoàn thành lộ trình"),
        _ => Tx("Continue", "Tiếp tục")
    };
    private IEnumerable<LearningStepDisplay> LearningSteps =>
    [
        new(1, LearningStep.Video, Tx("Video", "Video")),
        new(2, LearningStep.Script, Tx("Script", "Script")),
        new(3, LearningStep.Summary, Tx("Summary", "Tóm tắt")),
        new(4, LearningStep.Quiz, Tx("Quiz", "Quiz")),
        new(5, LearningStep.Scenario, Tx("Scenario", "Tình huống")),
        new(6, LearningStep.Reflection, Tx("Reflection", "Phản tư"))
    ];

    protected override async Task OnInitializedAsync()
    {
        currentStep = ParseStep(StepName);

        if (UserId == 0 && ItemId == 0)
        {
            item = new RoadmapItemDto
            {
                Id = 0,
                WeekNumber = IsCommunicationLessonFour ? 4 : IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : 1,
                SkillName = "Kỹ năng Giao tiếp",
                Title = IsCommunicationLessonFour
                    ? "Bài giảng giao tiếp nâng cao"
                    : IsCommunicationLessonThree ? "Làm chủ giọng nói và ngôn ngữ cận lời"
                    : IsCommunicationLessonTwo ? "Thực hành giao tiếp qua tình huống"
                    : "Nền tảng giao tiếp và lắng nghe chủ động",
                Description = IsCommunicationLessonFour
                    ? "Tiếp tục phát triển kỹ năng giao tiếp qua hướng dẫn chuyên sâu từ Mentor SoftSync."
                    : IsCommunicationLessonThree ? "Tìm hiểu tốc độ nói, độ rõ chữ, khoảng lặng và tông giọng trước khi bước vào bài luyện ghi âm."
                    : IsCommunicationLessonTwo ? "Xem bài giảng từ Mentor trước khi thực hành Quiz 2 với các tình huống giao tiếp mô phỏng."
                    : "Ôn tập các thành phần cốt lõi của giao tiếp, lắng nghe chủ động, rào cản nhận thức và giao tiếp khẳng định ôn hòa."
            };
            return;
        }

        var signedInUserId = await AuthProvider.GetUserIdAsync();
        if (signedInUserId <= 0)
        {
            Nav.NavigateTo("/Account/Login", true);
            return;
        }

        if (UserId != signedInUserId)
        {
            Nav.NavigateTo($"/roadmap/{signedInUserId}", true);
            return;
        }

        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        roadmapItems = roadmap.Items
            .Where(x => !string.IsNullOrWhiteSpace(x.SkillName))
            .OrderBy(x => x.WeekNumber)
            .ThenBy(x => x.Id)
            .ToList();
        item = roadmapItems.FirstOrDefault(i => i.Id == ItemId);
        if (item is null)
            Nav.NavigateTo($"/roadmap/{UserId}", true);
        else if (!RoadmapReviewMode.Enabled && !item.IsCompleted
            && CurrentItemIndex > 0 && PreviousItem?.IsCompleted != true)
        {
            Nav.NavigateTo($"/roadmap/{UserId}", true);
            return;
        }
        else
        {
            reflectionText = item.ReflectionText;
            currentStep = ResolveInitialStep(item, StepName);
        }
    }

    private static LearningStep ResolveInitialStep(RoadmapItemDto value, string? requestedStep)
    {
        var requested = string.IsNullOrWhiteSpace(requestedStep)
            ? ParseStep(value.LastLearningStep)
            : ParseStep(requestedStep);

        var highest = value.IsReflectionCompleted ? LearningStep.Reflection
            : value.IsScenarioCompleted ? LearningStep.Reflection
            : value.IsPracticeCompleted ? LearningStep.Scenario
            : value.SummaryCompletedAtUtc.HasValue ? LearningStep.Quiz
            : value.ScriptCompletedAtUtc.HasValue ? LearningStep.Summary
            : value.IsVideoCompleted ? LearningStep.Script
            : LearningStep.Video;
        return requested <= highest ? requested : highest;
    }

    private async Task CompleteVideoAsync()
    {
        if (item is null || UserId <= 0 || ItemId <= 0 || item.IsVideoCompleted)
            return;

        if (await RoadmapService.MarkVideoCompleteAsync(ItemId, UserId))
        {
            item.IsVideoCompleted = true;
            item.VideoCompletedAtUtc = DateTime.UtcNow;
            item.IsCompleted = item.IsPracticeCompleted && item.IsScenarioCompleted && item.IsReflectionCompleted;
        }
    }

    private string PersonalizedVideoSource()
    {
        if (item is null) return string.Empty;
        var value = $"{item.SkillName} {item.Title}";
        var sameSkill = roadmapItems.Where(x => SameSkill(x, item)).ToList();
        var ordinal = Math.Clamp(sameSkill.FindIndex(x => x.Id == item.Id), 0, 3);

        if (value.Contains("Giao tiếp", StringComparison.OrdinalIgnoreCase) || value.Contains("Communication", StringComparison.OrdinalIgnoreCase))
            return new[] { "/videos/communication-mentor-lesson-1.mp4", "/videos/communication-mentor-lesson-2.mp4", "/videos/communication-mentor-lesson-3.mp4", "/videos/communication-mentor-lesson-4.mp4" }[ordinal];
        if (value.Contains("Quản lý thời gian", StringComparison.OrdinalIgnoreCase) || value.Contains("Time Management", StringComparison.OrdinalIgnoreCase))
            return new[] { "/videos/time-management-mentor-lesson.mp4", "/videos/time-management-mentor-lesson-2.mp4", "/videos/time-management-mentor-lesson-3.mp4", "/videos/time-management-mentor-lesson-4.mp4" }[ordinal];

        return string.Empty;
    }

    private static bool SameSkill(RoadmapItemDto left, RoadmapItemDto right)
        => string.Equals(left.SkillName, right.SkillName, StringComparison.OrdinalIgnoreCase);

    private int SkillLessonOrdinal(RoadmapItemDto value)
    {
        var sameSkill = roadmapItems.Where(x => SameSkill(x, value)).ToList();
        var index = sameSkill.FindIndex(x => x.Id == value.Id);
        return index < 0 ? 0 : index + 1;
    }

    private static bool IsPracticeItem(RoadmapItemDto value)
        => value.Title.Contains("Thực hành", StringComparison.OrdinalIgnoreCase)
            || value.Title.Contains("Practice", StringComparison.OrdinalIgnoreCase);

    private static string SkillKey(RoadmapItemDto value)
    {
        var text = $"{value.SkillName} {value.Title}";
        if (text.Contains("Giao tiếp", StringComparison.OrdinalIgnoreCase) || text.Contains("Communication", StringComparison.OrdinalIgnoreCase)) return "communication";
        if (text.Contains("Quản lý thời gian", StringComparison.OrdinalIgnoreCase) || text.Contains("Time Management", StringComparison.OrdinalIgnoreCase)) return "time";
        if (text.Contains("Tư duy phản biện", StringComparison.OrdinalIgnoreCase) || text.Contains("Critical Thinking", StringComparison.OrdinalIgnoreCase)) return "critical";
        return "other";
    }

    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;

    private static LearningStep ParseStep(string? value) => value?.ToLowerInvariant() switch
    {
        "script" => LearningStep.Script,
        "summary" => LearningStep.Summary,
        "scenario" => LearningStep.Scenario,
        "reflection" => LearningStep.Reflection,
        _ => LearningStep.Video
    };

    private string StepClass(LearningStep step)
        => $"{(step == currentStep ? "active" : "")} {(StepIsComplete(step) ? "complete" : "")}";

    private bool StepIsComplete(LearningStep step) => step switch
    {
        LearningStep.Video => item?.IsVideoCompleted == true,
        LearningStep.Script => item?.ScriptCompletedAtUtc.HasValue == true || item?.IsPracticeCompleted == true,
        LearningStep.Summary => item?.SummaryCompletedAtUtc.HasValue == true || item?.IsPracticeCompleted == true,
        LearningStep.Quiz => item?.IsPracticeCompleted == true,
        LearningStep.Scenario => item?.IsScenarioCompleted == true,
        LearningStep.Reflection => item?.IsReflectionCompleted == true,
        _ => false
    };

    private async Task GoToStep(LearningStep step)
    {
        if (step == LearningStep.Quiz)
        {
            if (RoadmapReviewMode.Enabled || item?.IsVideoCompleted == true || !HasVideo)
            {
                await SaveStepAsync(LearningStep.Quiz);
                GoToGame();
            }
            return;
        }

        if (!RoadmapReviewMode.Enabled && step > LearningStep.Video && item?.IsVideoCompleted != true && HasVideo)
            return;
        if (!RoadmapReviewMode.Enabled && step >= LearningStep.Scenario && item?.IsPracticeCompleted != true)
            return;
        if (!RoadmapReviewMode.Enabled && step >= LearningStep.Reflection && item?.IsScenarioCompleted != true)
            return;

        await SetStepAsync(step);
    }

    private async Task GoBackStep()
    {
        if (currentStep == LearningStep.Video) { BackToRoadmap(); return; }
        if (currentStep == LearningStep.Scenario) { GoToGame(); return; }
        await SetStepAsync(currentStep - 1);
    }

    private async Task GoNextStep()
    {
        if (!CanContinue) return;
        if (currentStep == LearningStep.Video) { await SetStepAsync(LearningStep.Script); return; }
        if (currentStep == LearningStep.Script) { await SetStepAsync(LearningStep.Summary); return; }
        if (currentStep == LearningStep.Summary) { await SaveStepAsync(LearningStep.Quiz); GoToGame(); return; }
        if (currentStep == LearningStep.Scenario) { await SetStepAsync(LearningStep.Reflection); return; }
        if (currentStep == LearningStep.Reflection) { GoToNextLesson(); return; }
    }

    private async Task SetStepAsync(LearningStep step)
    {
        if (await SaveStepAsync(step))
            currentStep = step;
    }

    private async Task<bool> SaveStepAsync(LearningStep step)
    {
        if (UserId <= 0 || ItemId <= 0)
            return true;

        var saved = await RoadmapService.SaveLearningStepAsync(ItemId, UserId, StepValue(step));
        if (saved && item is not null)
        {
            item.LastLearningStep = StepValue(step);
            if (step == LearningStep.Summary)
                item.ScriptCompletedAtUtc ??= DateTime.UtcNow;
            if (step == LearningStep.Quiz)
                item.SummaryCompletedAtUtc ??= DateTime.UtcNow;
        }
        return saved;
    }

    private static string StepValue(LearningStep step) => step.ToString().ToLowerInvariant();

    private void GoToGame() => Nav.NavigateTo(IsCommunicationLessonThree
        ? "/communication-voice-practice"
        : IsCommunicationLessonTwo ? "/communication-roleplay"
        : UserId == 0 ? "/communication-quiz" : $"/roadmap/game/{UserId}/{ItemId}");

    private async Task CompleteScenarioAsync(int optionIndex)
    {
        selectedScenarioOption = optionIndex;
        if (item is null || UserId <= 0 || ItemId <= 0 || item.IsScenarioCompleted)
            return;

        if (await RoadmapService.MarkScenarioCompleteAsync(ItemId, UserId))
        {
            item.IsScenarioCompleted = true;
            item.ScenarioCompletedAtUtc = DateTime.UtcNow;
        }
    }

    private async Task SaveReflectionAsync()
    {
        if (item is null || UserId <= 0 || ItemId <= 0 || string.IsNullOrWhiteSpace(reflectionText))
            return;

        savingReflection = true;
        reflectionMessage = string.Empty;
        if (await RoadmapService.SaveReflectionAsync(ItemId, UserId, reflectionText))
        {
            item.ReflectionText = reflectionText.Trim();
            item.IsReflectionCompleted = true;
            item.ReflectionCompletedAtUtc ??= DateTime.UtcNow;
            item.IsCompleted = item.IsVideoCompleted && item.IsPracticeCompleted && item.IsScenarioCompleted && item.IsReflectionCompleted;
            reflectionMessage = Tx("Reflection saved. This week is now complete.", "Đã lưu phản tư. Tuần học hiện đã hoàn thành.");
        }
        else
        {
            reflectionMessage = Tx("Could not save your reflection. Please try again.", "Không thể lưu phản tư. Vui lòng thử lại.");
        }
        savingReflection = false;
    }

    private void GoToPreviousLesson()
    {
        if (UserId > 0 && PreviousItem is not null)
        {
            Nav.NavigateTo($"/roadmap/lecture/{UserId}/{PreviousItem.Id}");
            return;
        }

        if (UserId == 0)
        {
            if (IsCommunicationLessonFour) { Nav.NavigateTo("/communication-lesson-3"); return; }
            if (IsCommunicationLessonThree) { Nav.NavigateTo("/communication-lesson-2"); return; }
            if (IsCommunicationLessonTwo) { Nav.NavigateTo("/communication-lesson"); return; }
        }

        BackToRoadmap();
    }

    private void GoToNextLesson()
    {
        if (UserId > 0 && NextItem is not null)
        {
            Nav.NavigateTo($"/roadmap/lecture/{UserId}/{NextItem.Id}");
            return;
        }

        if (UserId == 0)
        {
            if (IsCommunicationLessonTwo) { Nav.NavigateTo("/communication-lesson-3"); return; }
            if (IsCommunicationLessonThree) { Nav.NavigateTo("/communication-lesson-4"); return; }
            if (!IsCommunicationLessonFour) { Nav.NavigateTo("/communication-lesson-2"); return; }
        }

        BackToRoadmap();
    }

    private void BackToRoadmap() => Nav.NavigateTo(UserId == 0 ? "/roadmap" : $"/roadmap/{UserId}");

    private string ScenarioPrompt => SkillKey(item!) switch
    {
        "time" => Tx("Your group project is due tomorrow, but several tasks are still unfinished and new messages keep interrupting you. What should you do first?", "Dự án nhóm đến hạn vào ngày mai nhưng vẫn còn nhiều việc chưa xong và tin nhắn liên tục làm bạn gián đoạn. Bạn nên làm gì trước?"),
        "communication" => Tx("A teammate misunderstands your feedback and becomes defensive. How should you respond?", "Một thành viên hiểu sai góp ý của bạn và trở nên phòng thủ. Bạn nên phản hồi thế nào?"),
        _ => Tx("You receive two conflicting sources for an important assignment. What is the best next step?", "Bạn nhận được hai nguồn thông tin mâu thuẫn cho một bài tập quan trọng. Bước tiếp theo phù hợp nhất là gì?")
    };
    private IReadOnlyList<ScenarioOption> ScenarioOptions =>
    [
        new(Tx("Pause and prioritize", "Dừng lại và xác định ưu tiên"), Tx("Clarify the goal, rank the remaining tasks, and focus on the highest-impact action.", "Làm rõ mục tiêu, xếp hạng việc còn lại và tập trung vào hành động có tác động lớn nhất.")),
        new(Tx("React immediately", "Phản ứng ngay lập tức"), Tx("Handle every new request as soon as it appears, without reviewing priorities.", "Xử lý mọi yêu cầu mới ngay khi xuất hiện mà không xem lại mức độ ưu tiên.")),
        new(Tx("Avoid the situation", "Tránh tình huống"), Tx("Wait for someone else to decide what should happen next.", "Chờ người khác quyết định bước tiếp theo.") )
    ];

    private enum LearningStep { Video, Script, Summary, Quiz, Scenario, Reflection }
    private sealed record LearningStepDisplay(int Number, LearningStep Value, string Label);
    private sealed record ScenarioOption(string Title, string Description);
}

