@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@page "/communication-lesson"
@page "/communication-lesson-2"
@page "/communication-lesson-3"
@page "/communication-lesson-4"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<div class="max-900 mx-auto">
    <div class="tw:mb-4">
        <button class="btn btn-link text-muted tw:no-underline tw:px-0" @onclick="BackToRoadmap">
            <i class="bi bi-arrow-left tw:me-1"></i> @L["roadmap.backToRoadmap"]
        </button>
    </div>

    @if (item == null)
    {
        <div class="ss-card tw:p-12 tw:text-center">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        <div class="ss-card ss-glass-interactive tw:p-12 lecture-shell">
            <div class="tw:flex tw:items-center tw:justify-between tw:mb-4">
                <div>
                    <span class="text-primary tw:font-bold tw:text-sm tw:uppercase">@L["roadmap.week"] @DisplayWeekNumber</span>
                    <h2 class="tw:font-bold tw:mb-0">@DisplayTitle</h2>
                </div>
                <span class="badge bg-primary">@DisplaySkillName</span>
            </div>

            <nav class="learning-stepper" aria-label="@Tx("Learning steps", "Các bước học")">
                @foreach (var step in LearningSteps)
                {
                    <button class="@StepClass(step.Value)" @onclick="() => GoToStep(step.Value)">
                        <span>@(StepIsComplete(step.Value) ? "✓" : step.Number.ToString())</span>
                        <small>@step.Label</small>
                    </button>
                }
            </nav>

            @if (currentStep == LearningStep.Video)
            {
                @if (HasVideo)
                {
                    <div class="lecture-video tw:mb-4">
                        <video controls preload="metadata" playsinline poster="/images/background-softsync.png" @onended="CompleteVideoAsync">
                            <source src="@VideoSource" type="video/mp4" />
                            @Tx("Your browser does not support HTML5 video.", "Trình duyệt của bạn không hỗ trợ video HTML5.")
                        </video>
                        <div class="lecture-video-caption">
                            <span><i class="bi bi-play-circle-fill"></i> @Tx("VIDEO LESSON", "VIDEO BÀI GIẢNG")</span>
                            <div><strong>@DisplaySkillName · @Tx("Lesson", "Bài") @DisplayWeekNumber</strong><small>@Tx("Guided by a SoftSync Mentor", "Video hướng dẫn từ Mentor SoftSync")</small></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="lecture-placeholder tw:mb-4"><i class="bi bi-camera-video-off tw:me-2"></i> @Tx("Video coming soon", "Video đang được cập nhật")</div>
                }
            }
            else if (currentStep == LearningStep.Script)
            {
                <article class="guided-content guided-script">
                    <header><i class="bi bi-file-earmark-text-fill"></i><div><small>VIDEO @DisplayWeekNumber · SCRIPT</small><h3>@DisplayTitle</h3></div></header>
                    @if (IsCommunicationVideoOne)
                    {
                        <section>
                            <h4>1. Giao tiếp là “con đường hai chiều”</h4>
                            <p>Giao tiếp hiệu quả không chỉ là gửi đi thông điệp mà còn là tiếp nhận phản hồi. Quá trình này gồm người gửi, thông điệp, kênh truyền tải, người nhận và phản hồi.</p>
                            <ul>
                                <li><strong>Người gửi:</strong> Người tạo ra và truyền đạt thông điệp.</li>
                                <li><strong>Thông điệp:</strong> Nội dung được truyền tải qua lời nói, chữ viết hoặc cử chỉ.</li>
                                <li><strong>Kênh truyền tải:</strong> Nói trực tiếp, email, điện thoại hoặc mạng xã hội.</li>
                                <li><strong>Người nhận và phản hồi:</strong> Tiếp nhận, giải mã và hồi đáp để xác nhận mức độ thấu hiểu.</li>
                            </ul>
                        </section>
                        <section>
                            <h4>2. Các kỹ năng then chốt cho sinh viên</h4>
                            <ul>
                                <li><strong>Lắng nghe chủ động:</strong> Tập trung hoàn toàn, không ngắt lời và xác nhận lại nội dung đã nghe.</li>
                                <li><strong>Giao tiếp phi ngôn ngữ:</strong> Chú ý ánh mắt, điệu bộ, trang phục và tư thế.</li>
                                <li><strong>Quy tắc ứng xử mạng:</strong> Viết email chuyên nghiệp với tiêu đề rõ ràng và lời chào trang trọng.</li>
                            </ul>
                        </section>
                        <section>
                            <h4>3. Bí quyết để giao tiếp thành công</h4>
                            <ul>
                                <li>Chuẩn bị và sắp xếp ý tưởng logic trước những cuộc trao đổi quan trọng.</li>
                                <li>Điều chỉnh phong cách theo đối tượng và bối cảnh.</li>
                                <li>Giao tiếp dựa trên sự tôn trọng, trung thực và công bằng.</li>
                                <li>Dùng từ ngữ chính xác, dễ hiểu và hạn chế biệt ngữ không cần thiết.</li>
                            </ul>
                            <p>Rèn luyện giao tiếp là hành trình cần sự kiên nhẫn và tự điều chỉnh, giúp bạn học tập hiệu quả và tạo ấn tượng chuyên nghiệp.</p>
                        </section>
                    }
                    else
                    {
                        <div class="guided-empty"><i class="bi bi-hourglass-split"></i><p>@Tx("This lesson's script will be updated soon.", "Script của bài học này sẽ sớm được cập nhật.")</p></div>
                    }
                </article>
            }
            else
            {
                <article class="guided-content guided-summary">
                    <header><i class="bi bi-lightbulb-fill"></i><div><small>@Tx("LESSON SUMMARY", "TÓM TẮT BÀI HỌC")</small><h3>@DisplayTitle</h3></div></header>
                    <p>@DisplayDescription</p>
                    <div class="summary-callout"><i class="bi bi-check2-circle"></i><span>@Tx("Review the key ideas, then continue to the quiz to check your understanding.", "Ôn lại các ý chính, sau đó làm Quiz để kiểm tra mức độ hiểu bài.")</span></div>
                </article>
            }

            @if (item.IsCompleted)
            {
                <div class="lecture-complete lecture-complete--compact tw:mb-4">
                    <i class="bi bi-patch-check-fill"></i>
                    <div><strong>@Tx("Week completed", "Tuần học đã hoàn thành")</strong><span>@Tx("Your video and practice results are saved. You can review them anytime.", "Video và bài luyện tập đã được lưu. Bạn vẫn có thể xem lại bất cứ lúc nào.")</span></div>
                </div>
            }
            else if (item.IsVideoCompleted)
            {
                <div class="lecture-complete lecture-complete--compact tw:mb-4">
                    <i class="bi bi-check-circle-fill"></i>
                    <div><strong>@Tx("Video completed", "Đã xem xong video")</strong><span>@Tx("Your result is saved and the video now has a green tick on the Roadmap.", "Kết quả đã được lưu và video đã chuyển sang tích xanh trên Roadmap.")</span></div>
                </div>
            }

            <nav class="lecture-navigation tw:mt-8" aria-label="@Tx("Lesson navigation", "Điều hướng bài học")">
                <button class="lecture-nav-back" @onclick="GoBackStep">
                    <i class="bi bi-arrow-left"></i> @BackLabel
                </button>
                <button class="ss-btn-primary lecture-nav-next" @onclick="GoNextStep" disabled="@(!CanContinue)">
                    @NextLabel <i class="bi bi-arrow-right"></i>
                </button>
            </nav>
            @if (!CanContinue)
            {
                <small class="continue-hint">@Tx("Watch the video to the end to unlock the next step.", "Hãy xem hết video để mở khóa bước tiếp theo.")</small>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    [SupplyParameterFromQuery(Name = "step")] public string? StepName { get; set; }

    private RoadmapItemDto? item;
    private List<RoadmapItemDto> roadmapItems = [];
    private LearningStep currentStep = LearningStep.Video;
    private bool IsCommunicationLessonTwo => Nav.Uri.Contains("/communication-lesson-2", StringComparison.OrdinalIgnoreCase);
    private bool IsCommunicationLessonThree => Nav.Uri.Contains("/communication-lesson-3", StringComparison.OrdinalIgnoreCase);
    private bool IsCommunicationLessonFour => Nav.Uri.Contains("/communication-lesson-4", StringComparison.OrdinalIgnoreCase);
    private int DisplayWeekNumber => IsCommunicationLessonFour ? 4 : IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : item?.WeekNumber ?? 1;
    private string DisplaySkillName => item is null ? string.Empty : SkillKey(item) switch
    {
        "communication" => Tx("Communication", "Giao tiếp"),
        "time" => Tx("Time Management", "Quản lý thời gian"),
        "critical" => Tx("Critical Thinking", "Tư duy phản biện"),
        _ => item.SkillName
    };
    private string DisplayTitle => item is null ? string.Empty : UserId > 0
        ? IsPracticeItem(item) ? Tx($"{DisplaySkillName} Practice", $"Thực hành {DisplaySkillName}") : Tx($"{DisplaySkillName} Foundations", $"Nền tảng {DisplaySkillName}")
        : IsCommunicationLessonFour ? Tx("Advanced Communication", "Bài giảng giao tiếp nâng cao")
        : IsCommunicationLessonThree ? Tx("Mastering Voice and Paralanguage", "Làm chủ giọng nói và ngôn ngữ cận lời")
        : IsCommunicationLessonTwo ? Tx("Situational Communication Practice", "Thực hành giao tiếp qua tình huống")
        : Tx("Communication and Active Listening Foundations", "Nền tảng giao tiếp và lắng nghe chủ động");
    private string DisplayDescription => item is null ? string.Empty : UserId > 0
        ? IsPracticeItem(item)
            ? Tx($"Apply {DisplaySkillName.ToLowerInvariant()} in realistic situations, review feedback, and reflect after each attempt.", $"Áp dụng {DisplaySkillName.ToLowerInvariant()} vào tình huống thực tế, xem phản hồi và tự đánh giá sau mỗi lượt thực hành.")
            : Tx($"Learn the core principles of {DisplaySkillName.ToLowerInvariant()} and complete short guided exercises.", $"Nắm kiến thức cốt lõi của {DisplaySkillName.ToLowerInvariant()} và hoàn thành các bài luyện tập ngắn có hướng dẫn.")
        : item.Description;
    private string VideoSource => IsCommunicationLessonFour
        ? "/videos/communication-mentor-lesson-4.mp4"
        : IsCommunicationLessonThree ? "/videos/communication-mentor-lesson-3.mp4"
        : IsCommunicationLessonTwo ? "/videos/communication-mentor-lesson-2.mp4"
        : UserId == 0 ? "/videos/communication-mentor-lesson-1.mp4"
        : PersonalizedVideoSource();
    private bool HasVideo => !string.IsNullOrWhiteSpace(VideoSource);
    private int CurrentItemIndex => item is null ? -1 : roadmapItems.FindIndex(x => x.Id == item.Id);
    private RoadmapItemDto? PreviousItem => CurrentItemIndex > 0 ? roadmapItems[CurrentItemIndex - 1] : null;
    private RoadmapItemDto? NextItem => CurrentItemIndex >= 0 && CurrentItemIndex < roadmapItems.Count - 1 ? roadmapItems[CurrentItemIndex + 1] : null;
    private bool HasNextLesson => UserId > 0 ? NextItem is not null : !IsCommunicationLessonFour;
    private bool IsCommunicationVideoOne => item is not null
        && SkillKey(item) == "communication"
        && (UserId == 0 ? !IsCommunicationLessonTwo && !IsCommunicationLessonThree && !IsCommunicationLessonFour : SkillLessonOrdinal(item) == 1);
    private bool CanContinue => currentStep != LearningStep.Video || item?.IsVideoCompleted == true || !HasVideo;
    private string BackLabel => currentStep == LearningStep.Video ? Tx("Roadmap", "Lộ trình") : Tx("Back", "Quay lại");
    private string NextLabel => currentStep switch
    {
        LearningStep.Video => Tx("Next: Script", "Tiếp theo: Script"),
        LearningStep.Script => Tx("Next: Summary", "Tiếp theo: Tóm tắt"),
        _ when item?.IsPracticeCompleted == true && HasNextLesson => Tx("Next week", "Tuần tiếp theo"),
        _ when item?.IsPracticeCompleted == true => Tx("Finish roadmap", "Hoàn thành lộ trình"),
        _ => Tx("Start quiz", "Làm Quiz")
    };
    private IEnumerable<LearningStepDisplay> LearningSteps =>
    [
        new(1, LearningStep.Video, Tx("Video", "Video")),
        new(2, LearningStep.Script, Tx("Script", "Script")),
        new(3, LearningStep.Summary, Tx("Summary", "Tóm tắt")),
        new(4, LearningStep.Quiz, Tx("Quiz", "Quiz"))
    ];

    protected override async Task OnInitializedAsync()
    {
        currentStep = ParseStep(StepName);

        if (UserId == 0 && ItemId == 0)
        {
            item = new RoadmapItemDto
            {
                Id = 0,
                WeekNumber = IsCommunicationLessonFour ? 4 : IsCommunicationLessonThree ? 3 : IsCommunicationLessonTwo ? 2 : 1,
                SkillName = "Kỹ năng Giao tiếp",
                Title = IsCommunicationLessonFour
                    ? "Bài giảng giao tiếp nâng cao"
                    : IsCommunicationLessonThree ? "Làm chủ giọng nói và ngôn ngữ cận lời"
                    : IsCommunicationLessonTwo ? "Thực hành giao tiếp qua tình huống"
                    : "Nền tảng giao tiếp và lắng nghe chủ động",
                Description = IsCommunicationLessonFour
                    ? "Tiếp tục phát triển kỹ năng giao tiếp qua hướng dẫn chuyên sâu từ Mentor SoftSync."
                    : IsCommunicationLessonThree ? "Tìm hiểu tốc độ nói, độ rõ chữ, khoảng lặng và tông giọng trước khi bước vào bài luyện ghi âm."
                    : IsCommunicationLessonTwo ? "Xem bài giảng từ Mentor trước khi thực hành Quiz 2 với các tình huống giao tiếp mô phỏng."
                    : "Ôn tập các thành phần cốt lõi của giao tiếp, lắng nghe chủ động, rào cản nhận thức và giao tiếp khẳng định ôn hòa."
            };
            return;
        }

        var signedInUserId = await AuthProvider.GetUserIdAsync();
        if (signedInUserId <= 0)
        {
            Nav.NavigateTo("/Account/Login", true);
            return;
        }

        if (UserId != signedInUserId)
        {
            Nav.NavigateTo($"/roadmap/{signedInUserId}", true);
            return;
        }

        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        roadmapItems = roadmap.Items
            .Where(x => !string.IsNullOrWhiteSpace(x.SkillName))
            .OrderBy(x => x.WeekNumber)
            .ThenBy(x => x.Id)
            .ToList();
        item = roadmapItems.FirstOrDefault(i => i.Id == ItemId);
        if (item is null)
            Nav.NavigateTo($"/roadmap/{UserId}", true);
    }

    private async Task CompleteVideoAsync()
    {
        if (item is null || UserId <= 0 || ItemId <= 0 || item.IsVideoCompleted)
            return;

        if (await RoadmapService.MarkVideoCompleteAsync(ItemId, UserId))
        {
            item.IsVideoCompleted = true;
            item.VideoCompletedAtUtc = DateTime.UtcNow;
            item.IsCompleted = item.IsPracticeCompleted;
        }
    }

    private string PersonalizedVideoSource()
    {
        if (item is null) return string.Empty;
        var value = $"{item.SkillName} {item.Title}";
        var sameSkill = roadmapItems.Where(x => SameSkill(x, item)).ToList();
        var ordinal = Math.Clamp(sameSkill.FindIndex(x => x.Id == item.Id), 0, 3);

        if (value.Contains("Giao tiếp", StringComparison.OrdinalIgnoreCase) || value.Contains("Communication", StringComparison.OrdinalIgnoreCase))
            return new[] { "/videos/communication-mentor-lesson-1.mp4", "/videos/communication-mentor-lesson-2.mp4", "/videos/communication-mentor-lesson-3.mp4", "/videos/communication-mentor-lesson-4.mp4" }[ordinal];
        if (value.Contains("Quản lý thời gian", StringComparison.OrdinalIgnoreCase) || value.Contains("Time Management", StringComparison.OrdinalIgnoreCase))
            return new[] { "/videos/time-management-mentor-lesson.mp4", "/videos/time-management-mentor-lesson-2.mp4", "/videos/time-management-mentor-lesson-3.mp4", "/videos/time-management-mentor-lesson-4.mp4" }[ordinal];

        return string.Empty;
    }

    private static bool SameSkill(RoadmapItemDto left, RoadmapItemDto right)
        => string.Equals(left.SkillName, right.SkillName, StringComparison.OrdinalIgnoreCase);

    private int SkillLessonOrdinal(RoadmapItemDto value)
    {
        var sameSkill = roadmapItems.Where(x => SameSkill(x, value)).ToList();
        var index = sameSkill.FindIndex(x => x.Id == value.Id);
        return index < 0 ? 0 : index + 1;
    }

    private static bool IsPracticeItem(RoadmapItemDto value)
        => value.Title.Contains("Thực hành", StringComparison.OrdinalIgnoreCase)
            || value.Title.Contains("Practice", StringComparison.OrdinalIgnoreCase);

    private static string SkillKey(RoadmapItemDto value)
    {
        var text = $"{value.SkillName} {value.Title}";
        if (text.Contains("Giao tiếp", StringComparison.OrdinalIgnoreCase) || text.Contains("Communication", StringComparison.OrdinalIgnoreCase)) return "communication";
        if (text.Contains("Quản lý thời gian", StringComparison.OrdinalIgnoreCase) || text.Contains("Time Management", StringComparison.OrdinalIgnoreCase)) return "time";
        if (text.Contains("Tư duy phản biện", StringComparison.OrdinalIgnoreCase) || text.Contains("Critical Thinking", StringComparison.OrdinalIgnoreCase)) return "critical";
        return "other";
    }

    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;

    private static LearningStep ParseStep(string? value) => value?.ToLowerInvariant() switch
    {
        "script" => LearningStep.Script,
        "summary" => LearningStep.Summary,
        _ => LearningStep.Video
    };

    private string StepClass(LearningStep step)
        => $"{(step == currentStep ? "active" : "")} {(StepIsComplete(step) ? "complete" : "")}";

    private bool StepIsComplete(LearningStep step) => step switch
    {
        LearningStep.Video => item?.IsVideoCompleted == true,
        LearningStep.Script => currentStep > LearningStep.Script || item?.IsPracticeCompleted == true,
        LearningStep.Summary => item?.IsPracticeCompleted == true,
        LearningStep.Quiz => item?.IsPracticeCompleted == true,
        _ => false
    };

    private void GoToStep(LearningStep step)
    {
        if (step == LearningStep.Quiz)
        {
            if (item?.IsVideoCompleted == true || !HasVideo) GoToGame();
            return;
        }

        if (step > LearningStep.Video && item?.IsVideoCompleted != true && HasVideo)
            return;

        currentStep = step;
    }

    private void GoBackStep()
    {
        if (currentStep == LearningStep.Video) { BackToRoadmap(); return; }
        currentStep--;
    }

    private void GoNextStep()
    {
        if (!CanContinue) return;
        if (currentStep == LearningStep.Video) { currentStep = LearningStep.Script; return; }
        if (currentStep == LearningStep.Script) { currentStep = LearningStep.Summary; return; }
        if (item?.IsPracticeCompleted == true) { GoToNextLesson(); return; }
        GoToGame();
    }

    private void GoToGame() => Nav.NavigateTo(IsCommunicationLessonThree
        ? "/communication-voice-practice"
        : IsCommunicationLessonTwo ? "/communication-roleplay"
        : UserId == 0 ? "/communication-quiz" : $"/roadmap/game/{UserId}/{ItemId}");

    private void GoToPreviousLesson()
    {
        if (UserId > 0 && PreviousItem is not null)
        {
            Nav.NavigateTo($"/roadmap/lecture/{UserId}/{PreviousItem.Id}");
            return;
        }

        if (UserId == 0)
        {
            if (IsCommunicationLessonFour) { Nav.NavigateTo("/communication-lesson-3"); return; }
            if (IsCommunicationLessonThree) { Nav.NavigateTo("/communication-lesson-2"); return; }
            if (IsCommunicationLessonTwo) { Nav.NavigateTo("/communication-lesson"); return; }
        }

        BackToRoadmap();
    }

    private void GoToNextLesson()
    {
        if (UserId > 0 && NextItem is not null)
        {
            Nav.NavigateTo($"/roadmap/lecture/{UserId}/{NextItem.Id}");
            return;
        }

        if (UserId == 0)
        {
            if (IsCommunicationLessonTwo) { Nav.NavigateTo("/communication-lesson-3"); return; }
            if (IsCommunicationLessonThree) { Nav.NavigateTo("/communication-lesson-4"); return; }
            if (!IsCommunicationLessonFour) { Nav.NavigateTo("/communication-lesson-2"); return; }
        }

        BackToRoadmap();
    }

    private void BackToRoadmap() => Nav.NavigateTo(UserId == 0 ? "/roadmap" : $"/roadmap/{UserId}");

    private enum LearningStep { Video, Script, Summary, Quiz }
    private sealed record LearningStepDisplay(int Number, LearningStep Value, string Label);
}

<style>
    .max-900 { max-width: 900px; }
    .lecture-shell {
        border-radius: 24px;
    }
    .learning-stepper {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin: 18px 0 22px;
    }
    .learning-stepper button {
        position: relative;
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 10px 12px;
        color: #64748b;
        border: 1px solid rgba(99, 102, 241, .14);
        border-radius: 13px;
        background: rgba(248, 250, 252, .82);
        text-align: left;
    }
    .learning-stepper button > span {
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        width: 27px;
        height: 27px;
        border-radius: 50%;
        background: #e9e7ff;
        color: var(--primary);
        font-size: .7rem;
        font-weight: 900;
    }
    .learning-stepper button small { font-weight: 800; }
    .learning-stepper button.active { color: var(--primary); border-color: rgba(99,102,241,.4); background: rgba(99,102,241,.08); }
    .learning-stepper button.active > span { color: #fff; background: var(--primary); }
    .learning-stepper button.complete > span { color: #fff; background: #22a66f; }
    .lecture-placeholder {
        min-height: 320px;
        border-radius: 22px;
        border: 2px dashed rgba(99, 102, 241, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: var(--primary);
        background: rgba(99, 102, 241, 0.06);
    }
    .lecture-video {
        overflow: hidden;
        border: 1px solid rgba(99, 102, 241, 0.16);
        border-radius: 22px;
        background: #090b18;
        box-shadow: 0 20px 48px rgba(30, 27, 75, 0.18);
    }
    .lecture-video video {
        display: block;
        width: 100%;
        max-height: 520px;
        aspect-ratio: 16 / 9;
        object-fit: contain;
        background: #090b18;
    }
    .lecture-video-caption {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 18px;
        color: #e9e7ff;
        background: linear-gradient(135deg, #201b49, #302366);
    }
    .lecture-video-caption > span {
        display: inline-flex;
        align-items: center;
