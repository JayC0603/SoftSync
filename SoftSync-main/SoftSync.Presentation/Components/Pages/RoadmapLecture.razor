@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@using System.Text.Json
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp") · SoftSync</PageTitle>

<main class="lesson-page">
    @if (loading)
    {
        <div class="state"><span></span>@Tx("Loading lesson...", "Đang tải bài học...")</div>
    }
    else if (!isCommunicationLessonOne)
    {
        <button class="back" @onclick="Back"><i class="bi bi-arrow-left"></i>@Tx("Back to Roadmap", "Quay lại Roadmap")</button>
        <section class="empty"><i class="bi bi-journal-plus"></i><h1>@Tx("Content not available", "Chưa nạp nội dung")</h1><p>@Tx("This week is waiting for new video and theory content.", "Tuần này đang chờ video và lý thuyết mới.")</p></section>
    }
    else
    {
        <div class="lesson-shell">
            <header class="lesson-top">
                <button @onclick="Back"><i class="bi bi-arrow-left"></i>Roadmap</button>
                <div><small>@Tx("COMMUNICATION SKILLS · WEEK 1", "KỸ NĂNG GIAO TIẾP · TUẦN 1")</small><h1>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h1></div>
                @if (item!.IsCompleted)
                {
                    <span class="week-complete"><i class="bi bi-check-circle-fill"></i>@Tx("Week completed", "Đã hoàn thành tuần")</span>
                }
                else
                {
                    <span>@CompletedCount / 6 @Tx("steps", "bước")</span>
                }
            </header>

            <nav class="lesson-steps">
                @foreach (var step in Steps)
                {
                    var unlocked = CanOpen(step.Id);
                    <button class="@(currentStep == step.Id ? "active" : null) @(IsComplete(step.Id) ? "done" : null)" disabled="@(!unlocked)" @onclick="() => OpenStep(step.Id)">
                        <span>@(IsComplete(step.Id) ? "✓" : step.Id.ToString())</span><b>@Tx(step.En, step.Vi)</b>@if (!unlocked) { <i class="bi bi-lock-fill"></i> }
                    </button>
                }
            </nav>

            <section class="lesson-content">
                @if (IsComplete(currentStep))
                {
                    <div class="saved-complete"><i class="bi bi-check-circle-fill"></i><div><b>@Tx("Completed", "Đã học xong")</b><small>@Tx("Your progress is saved. You can review this section at any time.", "Tiến độ đã được lưu. Bạn có thể xem lại phần này bất kỳ lúc nào.")</small></div></div>
                }
                @if (currentStep == 1)
                {
                    <div class="video-wrap"><video controls preload="metadata" @onended="VideoEnded"><source src="/videos/communication-mentor-lesson-1.mp4" type="video/mp4" />@Tx("Your browser does not support video.", "Trình duyệt không hỗ trợ video.")</video></div>
                    <div class="content-heading"><div><small>@Tx("STEP 1 · VIDEO", "BƯỚC 1 · VIDEO")</small><h2>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h2><p>@Tx("Watch the entire video to unlock the Script.", "Hãy xem hết video để mở phần Script.")</p></div><span><i class="bi bi-clock"></i> Video Mentor 1</span></div>
                    @if (!item!.IsVideoCompleted) { <div class="notice"><i class="bi bi-info-circle"></i>@Tx("The Script unlocks automatically when the video ends.", "Script sẽ tự mở khi video phát hết.")</div> }
                    @if (!string.IsNullOrWhiteSpace(saveError)) { <div class="save-error"><i class="bi bi-exclamation-triangle"></i>@saveError</div> }
                    <div class="actions video-actions">
                        <button @onclick="Back"><i class="bi bi-arrow-left"></i>@Tx("Back to Roadmap", "Về Roadmap")</button>
                        <button class="primary" @onclick="CompleteVideoAndOpenScript">
                            @(item.IsVideoCompleted ? Tx("Next: Script", "Tiếp theo: Script") : Tx("I finished the video · Next", "Tôi đã xem xong · Tiếp theo")) <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                }
                else if (currentStep == 2)
                {
                    <article class="theory">
                        <div class="content-heading"><div><small>@Tx("STEP 2 · SCRIPT", "BƯỚC 2 · SCRIPT")</small><h2>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h2><p>@Tx("Theory synchronized with Video Mentor 1.", "Nội dung lý thuyết đồng bộ với Video Mentor 1.")</p></div></div>
                        @if (!IsVi)
                        {
                            <h3>1. Communication is a “two-way street”</h3>
                            <p>Effective communication means both sending a message and receiving feedback. A basic communication process includes:</p>
                            <ul><li><b>Sender:</b> The person who creates and delivers the message.</li><li><b>Message:</b> The meaning conveyed through speech, writing, or gestures.</li><li><b>Channel:</b> Face-to-face conversation, email, telephone, or social media.</li><li><b>Receiver:</b> The person who receives and interprets the message.</li><li><b>Feedback:</b> The response that confirms whether the message was understood correctly.</li></ul>
                            <h3>2. Essential skills for students</h3>
                            <ul><li><b>Active listening:</b> Focus fully, avoid interrupting, and confirm what you heard.</li><li><b>Non-verbal communication:</b> Eye contact, gestures, clothing, and posture all convey meaning.</li><li><b>Netiquette:</b> Write professional emails with clear subjects, complete sentences, and respectful greetings.</li></ul>
                            <h3>3. Tips for successful communication</h3>
                            <ul><li><b>Prepare carefully:</b> Organize ideas logically before presentations or important meetings.</li><li><b>Understand context:</b> Adapt your style to the audience and situation.</li><li><b>Communicate ethically:</b> Be respectful, honest, and fair.</li><li><b>Use simple language:</b> Choose precise, clear words and avoid unnecessary jargon.</li></ul>
                            <p class="conclusion">Communication takes patience and continuous adjustment. Strong communication improves learning and builds a professional impression for your future career.</p>
                        }
                        else
                        {
                        <h3>1. Giao tiếp là “con đường hai chiều”</h3>
                        <p>Giao tiếp hiệu quả không chỉ là gửi đi thông điệp mà còn là tiếp nhận phản hồi. Một quá trình giao tiếp cơ bản gồm:</p>
                        <ul><li><b>Người gửi:</b> Người tạo ra và truyền đạt thông điệp.</li><li><b>Thông điệp:</b> Nội dung, ý nghĩa muốn truyền tải qua lời nói, chữ viết hoặc cử chỉ.</li><li><b>Kênh truyền tải:</b> Nói trực tiếp, email, điện thoại hoặc mạng xã hội.</li><li><b>Người nhận:</b> Người tiếp nhận và giải mã thông điệp.</li><li><b>Phản hồi:</b> Sự hồi đáp giúp người gửi biết thông điệp đã được hiểu đúng hay chưa.</li></ul>
                        <h3>2. Các kỹ năng then chốt cho sinh viên</h3>
                        <ul><li><b>Lắng nghe chủ động:</b> Tập trung hoàn toàn, không ngắt lời và xác nhận lại điều đã nghe để tránh hiểu lầm.</li><li><b>Giao tiếp phi ngôn ngữ:</b> Ánh mắt, điệu bộ, trang phục và tư thế đều truyền tải thông điệp.</li><li><b>Quy tắc ứng xử mạng:</b> Viết email chuyên nghiệp, có tiêu đề rõ ràng, câu chữ hoàn chỉnh và lời chào trang trọng.</li></ul>
                        <h3>3. Bí quyết để giao tiếp thành công</h3>
                        <ul><li><b>Luôn chuẩn bị kỹ:</b> Sắp xếp ý tưởng logic trước khi thuyết trình hoặc gặp gỡ quan trọng.</li><li><b>Thấu hiểu bối cảnh:</b> Điều chỉnh phong cách phù hợp với đối tượng và tình huống.</li><li><b>Giao tiếp có đạo đức:</b> Tôn trọng, trung thực và công bằng với người nghe.</li><li><b>Sử dụng ngôn từ đơn giản:</b> Chọn từ chính xác, dễ hiểu và hạn chế biệt ngữ không cần thiết.</li></ul>
                        <p class="conclusion">Rèn luyện kỹ năng giao tiếp là một hành trình dài cần sự kiên nhẫn và tự điều chỉnh. Giao tiếp tốt giúp bạn học tập hiệu quả và tạo ấn tượng chuyên nghiệp trong tương lai.</p>
                        }
                    </article>
                    <div class="actions"><button @onclick="() => OpenStep(1)"><i class="bi bi-arrow-left"></i>@Tx("Back: Video", "Quay lại: Video")</button><button class="primary" @onclick="FinishScript">@Tx("Next: Summary", "Tiếp theo: Tóm tắt")<i class="bi bi-arrow-right"></i></button></div>
                }
                else if (currentStep == 3)
                {
                    <article class="summary-card"><i class="bi bi-stars"></i><small>@Tx("STEP 3 · SUMMARY", "BƯỚC 3 · TÓM TẮT")</small><h2>@Tx("Lesson summary", "Tóm tắt bài học")</h2><div class="summary-grid"><div><b>@Tx("Two-way communication", "Giao tiếp hai chiều")</b><p>@Tx("A message is complete only with a sender, receiver, and feedback.", "Thông điệp chỉ hoàn chỉnh khi có người gửi, người nhận và phản hồi.")</p></div><div><b>@Tx("Three foundations", "Ba kỹ năng nền tảng")</b><p>@Tx("Active listening, non-verbal language, and professional netiquette.", "Lắng nghe chủ động, giao tiếp phi ngôn ngữ và ứng xử mạng chuyên nghiệp.")</p></div><div><b>@Tx("Context-aware communication", "Giao tiếp phù hợp")</b><p>@Tx("Prepare, understand context, and communicate clearly and ethically.", "Chuẩn bị kỹ, hiểu bối cảnh và dùng ngôn từ rõ ràng, có đạo đức.")</p></div></div></article>
                    <div class="actions"><button @onclick="() => OpenStep(2)"><i class="bi bi-arrow-left"></i>@Tx("Back: Script", "Quay lại: Script")</button><button class="primary" @onclick="FinishSummary">@Tx("Next: Quiz", "Tiếp theo: Quiz")<i class="bi bi-arrow-right"></i></button></div>
                }
                else if (currentStep == 4)
                {
                    @if (quizFinished)
                    {
                        <section class="quiz-result">
                            <i class="bi bi-award-fill"></i><small>@Tx("QUIZ RESULT", "KẾT QUẢ QUIZ")</small><h2>@quizScore / 50 · @QuizPercent%</h2><h3>@QuizLevel</h3><p>@QuizComment</p><button @onclick="StartQuiz">@Tx("Try another 5 questions", "Làm 5 câu khác")</button>
                        </section>
                        <div class="actions"><button @onclick="() => OpenStep(3)"><i class="bi bi-arrow-left"></i>@Tx("Back: Summary", "Quay lại: Tóm tắt")</button>@if (quizPassed) { <button class="primary" @onclick="() => OpenStep(5)">@Tx("Next: Practice", "Tiếp theo: Thực hành")<i class="bi bi-arrow-right"></i></button> }</div>
                    }
                    else if (quizQuestions.Count > 0)
                    {
                        <section class="quiz-sheet">
                            <header><div><small>@Tx("COMMUNICATION QUIZ · 5 RANDOM QUESTIONS", "QUIZ GIAO TIẾP · 5 CÂU NGẪU NHIÊN")</small><h2>@Tx("Answer all five questions", "Trả lời đồng thời 5 câu")</h2></div><b>@quizScore / 50 @Tx("points", "điểm")</b></header>
                            <div class="quiz-progress"><i style="width:@(revealedQuestions.Count * 20)%"></i></div>
                            @foreach (var entry in quizQuestions.Select((question, index) => (question, index)))
                            {
                                var question = entry.question;
                                var revealed = revealedQuestions.Contains(question.Id);
                                <article class="quiz-card">
                                    <h3><span>@(entry.index + 1)</span>@(IsVi ? question.Vi : question.En)</h3>
                                    <div class="quiz-options">
                                        @foreach (var display in quizOptionOrders[question.Id].Select((original, displayIndex) => (original, displayIndex)))
                                        {
                                            var original = display.original;
                                            var selected = selectedAnswers.GetValueOrDefault(question.Id, -1) == original;
                                            var points = PointsFor(question, original);
                                            <button class="@(revealed && selected ? points == 10 ? "optimal" : points == 5 ? "neutral" : "negative" : null)" disabled="@revealed" @onclick="() => SelectAnswer(question, original)"><span>@("ABCD"[display.displayIndex])</span>@(IsVi ? question.OptionsVi[original] : question.OptionsEn[original])</button>
                                        }
                                    </div>
                                    @if (revealed)
                                    {
                                        var earned = PointsFor(question, selectedAnswers[question.Id]);
                                        <div class="answer-feedback @(earned == 10 ? "good" : earned == 5 ? "middle" : "bad")"><b>@Tx($"You earned {earned} points", $"Bạn được {earned} điểm")</b><p>@(earned == 10 ? (IsVi ? question.FeedbackVi : question.FeedbackEn) : Tx("This response is not optimal yet. A stronger response stays respectful and addresses the issue directly.", "Cách này chưa tối ưu. Phản hồi tốt hơn cần tôn trọng và giải quyết trực tiếp vấn đề."))</p></div>
                                    }
                                </article>
                            }
                            @if (!string.IsNullOrWhiteSpace(saveError)) { <div class="save-error">@saveError</div> }
                        </section>
                        <div class="actions"><button @onclick="() => OpenStep(3)"><i class="bi bi-arrow-left"></i>@Tx("Back: Summary", "Quay lại: Tóm tắt")</button><button class="primary" disabled="@(revealedQuestions.Count < 5)" @onclick="SubmitQuiz">@Tx("Submit and view result", "Nộp bài và xem kết quả")<i class="bi bi-arrow-right"></i></button></div>
                    }
                }
                else if (currentStep == 5)
                {
                    @if (roleplayScenario is not null)
                    {
                        <section class="roleplay">
                            <header><div><small>@Tx("PRACTICE · 3-TURN ROLE-PLAY", "THỰC HÀNH · HỘI THOẠI 3 LƯỢT")</small><h2>@(IsVi ? roleplayScenario.TitleVi : roleplayScenario.TitleEn)</h2><p>@(IsVi ? roleplayScenario.ContextVi : roleplayScenario.ContextEn)</p></div><span>@Math.Min(roleplayUserMessages.Count + 1, 3) / 3</span></header>
                            <div class="rubric-strip"><span>EQ <b>3</b></span><span>@Tx("Listening", "Lắng nghe") <b>3</b></span><span>I-statement <b>2</b></span><span>@Tx("Solution", "Giải pháp") <b>2</b></span></div>
                            <div class="chat-box">
                                @foreach (var message in RoleplayTranscript)
                                {
                                    <div class="chat-message @(message.User ? "user" : "ai")"><b>@(message.User ? Tx("You", "Bạn") : "AI")</b><p>@message.Text</p></div>
                                }
                            </div>
                            @if (roleplayResult is null)
                            {
                                <div class="chat-compose"><textarea @bind="roleplayInput" maxlength="1000" placeholder="@Tx("Write a calm, empathetic response...", "Nhập phản hồi bình tĩnh, thấu cảm...")"></textarea><button disabled="@(string.IsNullOrWhiteSpace(roleplayInput) || sendingRoleplay)" @onclick="SendRoleplay">@Tx("Send", "Gửi")<i class="bi bi-send"></i></button></div>
                            }
                            else
                            {
                                <div class="roleplay-result"><h3>@Tx("AI assessment", "Kết quả đánh giá") · @roleplayResult.TotalScore/10</h3><div><span>EQ <b>@roleplayResult.EmotionalIntelligenceScore/3</b></span><span>@Tx("Listening", "Lắng nghe") <b>@roleplayResult.ActiveListeningScore/3</b></span><span>I-statement <b>@roleplayResult.IStatementScore/2</b></span><span>@Tx("Solution", "Giải pháp") <b>@roleplayResult.SolutionScore/2</b></span></div><p>@roleplayResult.Feedback</p></div>
                            }
                        </section>
                        <div class="actions"><button @onclick="() => OpenStep(4)"><i class="bi bi-arrow-left"></i>@Tx("Back: Quiz", "Quay lại: Quiz")</button>@if (roleplayResult is not null) { <button class="primary" @onclick="() => OpenStep(6)">@Tx("Next: Reflection", "Tiếp theo: Phản tư")<i class="bi bi-arrow-right"></i></button> }</div>
                    }
                }
                else if (currentStep == 6)
                {
                    <section class="reflection-layout">
                        <div class="reflection-form">
                            <header><small>@Tx("STEP 6 · REFLECTION", "BƯỚC 6 · PHẢN TƯ")</small><h2>@Tx("Look back, then move forward", "Nhìn lại để tiến bộ")</h2><p>@Tx("Your answers are private and help turn this lesson into a practical habit.", "Câu trả lời giúp bạn biến bài học thành thói quen thực tế.")</p></header>
                            @if (item!.IsReflectionCompleted)
                            {
                                <div class="reflection-done"><i class="bi bi-check-circle-fill"></i><div><b>@Tx("Week completed", "Đã hoàn thành tuần")</b><span>@Tx("Your reflection is saved. You can review it at any time.", "Phản tư đã được lưu. Bạn có thể xem lại bất kỳ lúc nào.")</span></div></div>
                            }
                            <div class="reflection-requirement"><i class="bi bi-info-circle"></i>@Tx("Write more than 5 words for each answer.", "Mỗi câu trả lời chỉ cần trên 5 từ.")</div>
                            <label><b>1. @Tx("What is the most important thing you learned?", "Điều quan trọng nhất bạn học được là gì?")</b><textarea @bind="reflection.Learning" @bind:event="oninput" disabled="@item.IsReflectionCompleted" maxlength="1500"></textarea><small>@WordCount(reflection.Learning) @Tx("words", "từ")</small></label>
                            <label><b>2. @Tx("What did you handle well in the Quiz or Role-play?", "Trong Quiz hoặc Role-play, bạn đã làm tốt điều gì?")</b><textarea @bind="reflection.Strength" @bind:event="oninput" disabled="@item.IsReflectionCompleted" maxlength="1500"></textarea><small>@WordCount(reflection.Strength) @Tx("words", "từ")</small></label>
                            <label><b>3. @Tx("What would you change next time?", "Nếu gặp lại tình huống tương tự, bạn sẽ thay đổi điều gì?")</b><textarea @bind="reflection.Improvement" @bind:event="oninput" disabled="@item.IsReflectionCompleted" maxlength="1500"></textarea><small>@WordCount(reflection.Improvement) @Tx("words", "từ")</small></label>
                            <label class="commitment"><b><i class="bi bi-bullseye"></i>@Tx("My action commitment", "Cam kết hành động")</b><span>@Tx("Next week, I will...", "Trong tuần tới, tôi sẽ...")</span><textarea @bind="reflection.Commitment" @bind:event="oninput" disabled="@item.IsReflectionCompleted" maxlength="1000"></textarea><small>@WordCount(reflection.Commitment) @Tx("words", "từ")</small></label>
                            <div class="confidence"><div><b>@Tx("Confidence before", "Tự tin trước bài học")</b><input type="range" min="1" max="5" @bind="reflection.ConfidenceBefore" disabled="@item.IsReflectionCompleted" /><span>@reflection.ConfidenceBefore/5</span></div><div><b>@Tx("Confidence now", "Tự tin hiện tại")</b><input type="range" min="1" max="5" @bind="reflection.ConfidenceAfter" disabled="@item.IsReflectionCompleted" /><span>@reflection.ConfidenceAfter/5</span></div></div>
                            @if (!string.IsNullOrWhiteSpace(reflectionMessage)) { <div class="reflection-message @(reflectionError ? "error" : null)">@reflectionMessage</div> }
                        </div>
                        <aside class="learning-review">
                            <h3>@Tx("Your weekly results", "Kết quả tuần học")</h3>
                            <div class="result-tile"><i class="bi bi-ui-checks"></i><span>Quiz<b>@LatestQuizScore / 50</b></span></div>
                            <div class="result-tile"><i class="bi bi-chat-heart"></i><span>Role-play<b>@LatestRoleplayScore / 10</b></span></div>
                            @if (LatestRoleplay is not null)
                            {
                                <div class="mini-rubric"><span>EQ <b>@LatestRoleplay.EmotionalIntelligenceScore/3</b></span><span>@Tx("Listening", "Lắng nghe") <b>@LatestRoleplay.ActiveListeningScore/3</b></span><span>I-statement <b>@LatestRoleplay.IStatementScore/2</b></span><span>@Tx("Solution", "Giải pháp") <b>@LatestRoleplay.SolutionScore/2</b></span></div>
                            }
                            <div class="ai-reflection"><b><i class="bi bi-stars"></i>AI Feedback</b><p>@ReflectionFeedback</p></div>
                            <div class="confidence-change"><span>@Tx("Confidence change", "Thay đổi tự tin")</span><b>@reflection.ConfidenceBefore → @reflection.ConfidenceAfter</b><em>@ConfidenceDelta</em></div>
                        </aside>
                    </section>
                    <div class="actions"><button @onclick="() => OpenStep(5)"><i class="bi bi-arrow-left"></i>@Tx("Back: Practice", "Quay lại: Thực hành")</button><div class="reflection-actions">@if (!item!.IsReflectionCompleted) { <button @onclick="SaveReflectionDraft" disabled="@savingReflection">@Tx("Save draft", "Lưu bản nháp")</button><button class="primary" disabled="@(!ReflectionValid || savingReflection)" @onclick="CompleteReflection">@Tx("Complete week", "Hoàn thành tuần")<i class="bi bi-check-circle"></i></button> } else { <button class="primary" @onclick="Back">@Tx("View Roadmap", "Xem Roadmap")<i class="bi bi-arrow-right"></i></button> }</div></div>
                }
                else
                {
                    <section class="empty inner"><i class="@Steps.First(x => x.Id == currentStep).Icon"></i><h2>@Tx(Steps.First(x => x.Id == currentStep).En, Steps.First(x => x.Id == currentStep).Vi)</h2><p>@Tx("This section is waiting for content.", "Phần này đang chờ nạp nội dung tiếp theo.")</p></section>
                    <div class="actions"><button @onclick="Previous"><i class="bi bi-arrow-left"></i>@Tx("Back", "Quay lại")</button><button class="primary" @onclick="NextOrRoadmap">@Tx(currentStep < 6 ? "Next" : "Roadmap", currentStep < 6 ? "Tiếp theo" : "Về Roadmap")<i class="bi bi-arrow-right"></i></button></div>
                }
            </section>
        </div>
    }
</main>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    private RoadmapItemDto? item;
    private bool loading = true;
    private bool isCommunicationLessonOne;
    private int currentStep = 1;
    private string? saveError;
    private List<CommunicationQuizQuestion> quizQuestions = [];
    private readonly Dictionary<string, string> quizAnswers = [];
    private readonly Dictionary<int, int[]> quizOptionOrders = [];
    private readonly Dictionary<int, int> selectedAnswers = [];
    private readonly HashSet<int> revealedQuestions = [];
    private int quizScore;
    private bool quizFinished;
    private bool quizPassed;
    private RoleplayScenario? roleplayScenario;
    private readonly List<string> roleplayUserMessages = [];
    private readonly List<string> roleplayAiMessages = [];
    private string roleplayInput = string.Empty;
    private bool sendingRoleplay;
    private RoadmapRoleplayAttemptDto? roleplayResult;
    private ReflectionForm reflection = new();
    private bool savingReflection;
    private bool reflectionError;
    private string? reflectionMessage;
    private RoadmapQuizAttemptDto? LatestQuiz => item?.QuizHistory.LastOrDefault();
    private RoadmapRoleplayAttemptDto? LatestRoleplay => item?.RoleplayHistory.LastOrDefault();
    private int LatestQuizScore => LatestQuiz?.Score ?? 0;
    private double LatestRoleplayScore => LatestRoleplay?.TotalScore ?? 0;
    private int ConfidenceDelta => reflection.ConfidenceAfter - reflection.ConfidenceBefore;
    private static int WordCount(string value) => value.Split([' ', '\t', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries).Length;
    private bool ReflectionValid => WordCount(reflection.Learning) > 5 && WordCount(reflection.Strength) > 5 && WordCount(reflection.Improvement) > 5 && WordCount(reflection.Commitment) > 5;
    private string ReflectionFeedback => LatestRoleplayScore switch { < 5 => Tx("Focus on staying calm, asking a clarifying question, and proposing one concrete next step.", "Hãy tập trung giữ bình tĩnh, đặt câu hỏi làm rõ và đề xuất một bước tiếp theo cụ thể."), < 8.5 => Tx("You are progressing well. Make your I-statements and deadlines more specific.", "Bạn đang tiến bộ tốt. Hãy làm rõ hơn câu I-statement và thời hạn hành động."), _ => Tx("You communicate with empathy and a solution mindset. Keep applying this pattern in real situations.", "Bạn giao tiếp thấu cảm và hướng giải pháp tốt. Hãy tiếp tục áp dụng vào tình huống thực tế.") };
    private IEnumerable<(bool User, string Text)> RoleplayTranscript
    {
        get
        {
            if (roleplayScenario is null) yield break;
            yield return (false, IsVi ? roleplayScenario.OpeningVi : roleplayScenario.OpeningEn);
            for (var i = 0; i < roleplayUserMessages.Count; i++) { yield return (true, roleplayUserMessages[i]); if (i < roleplayAiMessages.Count) yield return (false, roleplayAiMessages[i]); }
        }
    }
    private int QuizPercent => quizScore * 100 / 50;
    private string QuizLevel => QuizPercent switch { <= 30 => Tx("Passive", "Bị động"), <= 55 => Tx("Developing", "Đang phát triển"), <= 80 => Tx("Proactive", "Chủ động"), _ => Tx("Exceptional", "Làm chủ") };
    private string QuizComment => QuizPercent switch
    {
        <= 30 => Tx("You tend to avoid issues or react emotionally. Pause before responding and ask questions instead of judging.", "Bạn có xu hướng né tránh hoặc phản ứng theo cảm xúc. Hãy dừng lại trước khi phản hồi và đặt câu hỏi thay vì phán xét."),
        <= 55 => Tx("You are developing better responses, but sometimes still avoid real dialogue. Practice expressing your needs clearly and gently.", "Bạn đang đi đúng hướng nhưng đôi khi vẫn né tránh đối thoại. Hãy diễn đạt mong muốn rõ ràng và nhẹ nhàng hơn."),
        <= 80 => Tx("You listen, communicate respectfully, and handle most conflicts well. Keep practicing calm analysis.", "Bạn biết lắng nghe, tôn trọng và xử lý phần lớn xung đột khá tốt. Hãy tiếp tục rèn phản xạ bình tĩnh."),
        _ => Tx("You stay calm, respect others, and guide difficult conversations toward solutions. Keep leading by example.", "Bạn giữ bình tĩnh, tôn trọng người khác và hướng cuộc trò chuyện đến giải pháp. Hãy tiếp tục phát huy.")
    };
    private int CompletedCount => item is null ? 0 : (item.IsVideoCompleted ? 1 : 0) + (item.ScriptCompletedAtUtc.HasValue ? 1 : 0) + (item.SummaryCompletedAtUtc.HasValue ? 1 : 0) + (item.IsPracticeCompleted ? 1 : 0) + (item.IsScenarioCompleted ? 1 : 0) + (item.IsReflectionCompleted ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        var signedIn = await AuthProvider.GetUserIdAsync();
        if (signedIn <= 0) { Nav.NavigateTo("/Account/Login", true); return; }
        UserId = signedIn;
        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        item = roadmap.Items.FirstOrDefault(x => x.Id == ItemId);
        if (item is not null)
        {
            var communication = roadmap.Items.Where(IsCommunication).OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
            isCommunicationLessonOne = communication.FirstOrDefault()?.Id == item.Id;
            currentStep = item.LastLearningStep?.ToLowerInvariant() switch { "script" => 2, "summary" => 3, "quiz" => 4, "scenario" => 5, "reflection" => 6, _ => 1 };
            if (!CanOpen(currentStep)) currentStep = Math.Clamp(CompletedCount + 1, 1, 6);
            if (currentStep == 4) StartQuiz();
            if (currentStep == 5) StartRoleplay();
            LoadReflection();
        }
        loading = false;
    }

    private static bool IsCommunication(RoadmapItemDto x) { var value = $"{x.SkillName} {x.Title}".ToLowerInvariant(); return value.Contains("giao tiếp") || value.Contains("communication"); }
    private bool CanOpen(int step) => item is not null && (item.IsCompleted || step == 1 || step == 2 && item.IsVideoCompleted || step == 3 && item.ScriptCompletedAtUtc.HasValue || step == 4 && item.SummaryCompletedAtUtc.HasValue || step == 5 && item.IsPracticeCompleted || step == 6 && item.IsScenarioCompleted);
    private bool IsComplete(int step) => item is not null && (item.IsCompleted || step switch { 1 => item.IsVideoCompleted, 2 => item.ScriptCompletedAtUtc.HasValue, 3 => item.SummaryCompletedAtUtc.HasValue, 4 => item.IsPracticeCompleted, 5 => item.IsScenarioCompleted, 6 => item.IsReflectionCompleted, _ => false });
    private async Task VideoEnded()
    {
        if (item is null || item.IsVideoCompleted) return;
        saveError = null;
        if (await RoadmapService.MarkVideoCompleteAsync(ItemId, UserId))
        {
            item.IsVideoCompleted = true;
            item.VideoCompletedAtUtc = DateTime.UtcNow;
            item.LastLearningStep = "script";
            await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "script");
        }
        else
        {
            saveError = Tx("Could not save video progress. Please reload and try again.", "Không thể lưu tiến độ video. Hãy tải lại trang và thử lại.");
        }
        StateHasChanged();
    }
    private async Task CompleteVideoAndOpenScript()
    {
        if (item is null) return;
        if (!item.IsVideoCompleted)
            await VideoEnded();
        if (item.IsVideoCompleted)
            await OpenStep(2);
    }
    private async Task OpenStep(int step) { if (!CanOpen(step)) return; currentStep = step; if (step == 4 && quizQuestions.Count == 0) StartQuiz(); if (step == 5 && roleplayScenario is null) StartRoleplay(); var key = step switch { 1 => "video", 2 => "script", 3 => "summary", 4 => "quiz", 5 => "scenario", _ => "reflection" }; await RoadmapService.SaveLearningStepAsync(ItemId, UserId, key); if (item is not null) item.LastLearningStep = key; }
    private async Task FinishScript() { if (await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "summary")) { item!.ScriptCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "summary"; currentStep = 3; } }
    private async Task FinishSummary() { if (await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "quiz")) { item!.SummaryCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "quiz"; currentStep = 4; } }
    private void Previous() => currentStep = Math.Max(1, currentStep - 1);
    private void NextOrRoadmap() { if (currentStep < 6 && CanOpen(currentStep + 1)) currentStep++; else Back(); }
    private void Back() => Nav.NavigateTo($"/roadmap/{UserId}");
    private bool IsVi => L.Current == AppLanguage.Vi;
    private string Tx(string en, string vi) => IsVi ? vi : en;
    private void StartQuiz()
    {
        var recentIds = item?.QuizHistory.SelectMany(x => x.Answers.Keys).Select(x => int.TryParse(x, out var id) ? id : 0).Where(x => x > 0).ToList() ?? [];
        var unseen = CommunicationQuizBank.Questions.Where(x => !recentIds.Contains(x.Id)).OrderBy(_ => Random.Shared.Next()).ToList();
        if (unseen.Count < 5)
        {
            var lastFive = recentIds.TakeLast(5).ToHashSet();
            unseen.AddRange(CommunicationQuizBank.Questions.Where(x => !unseen.Contains(x) && !lastFive.Contains(x.Id)).OrderBy(_ => Random.Shared.Next()));
        }
        quizQuestions = unseen.Take(5).ToList(); quizAnswers.Clear(); quizOptionOrders.Clear(); selectedAnswers.Clear(); revealedQuestions.Clear(); quizScore = 0; quizFinished = false; quizPassed = false; saveError = null;
        foreach (var question in quizQuestions) quizOptionOrders[question.Id] = Enumerable.Range(0, 4).OrderBy(_ => Random.Shared.Next()).ToArray();
    }
    private static int PointsFor(CommunicationQuizQuestion question, int option) => option == question.Optimal ? 10 : option == question.Neutral ? 5 : 0;
    private void SelectAnswer(CommunicationQuizQuestion question, int originalOption)
    {
        if (revealedQuestions.Contains(question.Id)) return;
        selectedAnswers[question.Id] = originalOption;
        revealedQuestions.Add(question.Id);
        quizScore += PointsFor(question, originalOption);
        quizAnswers[question.Id.ToString()] = "ABCD"[originalOption].ToString();
    }
    private async Task SubmitQuiz()
    {
        if (revealedQuestions.Count != 5) return;
        quizPassed = QuizPercent >= 56;
        var attempt = new RoadmapQuizAttemptDto { Answers = new(quizAnswers), Score = quizScore, TotalQuestions = 5, Passed = quizPassed };
        if (await RoadmapService.SaveQuizAttemptAsync(ItemId, UserId, attempt)) { item!.QuizHistory.Add(attempt); if (quizPassed) { item.IsPracticeCompleted = true; item.PracticeCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "scenario"; } quizFinished = true; }
        else saveError = Tx("Could not save quiz result. Please try again.", "Không thể lưu kết quả Quiz. Hãy thử lại.");
    }
    private void StartRoleplay()
    {
        var used = item?.RoleplayHistory.Select(x => x.ScenarioId).ToHashSet() ?? [];
        var choices = CommunicationRoleplayEngine.Scenarios.Where(x => !used.Contains(x.Id)).ToList();
        if (choices.Count == 0) choices = CommunicationRoleplayEngine.Scenarios.ToList();
        roleplayScenario = choices[Random.Shared.Next(choices.Count)]; roleplayUserMessages.Clear(); roleplayAiMessages.Clear(); roleplayInput = string.Empty; roleplayResult = null;
    }
    private async Task SendRoleplay()
    {
        var value = roleplayInput.Trim(); if (value.Length == 0 || roleplayScenario is null || roleplayResult is not null) return;
        sendingRoleplay = true; roleplayUserMessages.Add(value); roleplayInput = string.Empty;
        if (roleplayUserMessages.Count < 3) roleplayAiMessages.Add(CommunicationRoleplayEngine.Reply(value, roleplayUserMessages.Count, IsVi));
        else
        {
            var result = CommunicationRoleplayEngine.Grade(roleplayScenario.Id, [.. roleplayUserMessages], [.. roleplayAiMessages], IsVi);
            if (await RoadmapService.SaveRoleplayAttemptAsync(ItemId, UserId, result)) { roleplayResult = result; item!.RoleplayHistory.Add(result); item.IsScenarioCompleted = true; item.ScenarioCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "reflection"; }
            else saveError = Tx("Could not save role-play history.", "Không thể lưu lịch sử thực hành.");
        }
        sendingRoleplay = false;
    }
    private void LoadReflection()
    {
        if (string.IsNullOrWhiteSpace(item?.ReflectionText)) return;
        try { reflection = JsonSerializer.Deserialize<ReflectionForm>(item.ReflectionText) ?? new(); }
        catch (JsonException) { reflection = new() { Learning = item.ReflectionText }; }
    }
    private string SerializeReflection() => JsonSerializer.Serialize(reflection);
    private async Task SaveReflectionDraft()
    {
        savingReflection = true; reflectionError = false;
        var ok = await RoadmapService.SaveReflectionDraftAsync(ItemId, UserId, SerializeReflection());
        reflectionMessage = ok ? Tx("Draft saved.", "Đã lưu bản nháp.") : Tx("Could not save draft.", "Không thể lưu bản nháp."); reflectionError = !ok; savingReflection = false;
        if (ok && item is not null) item.ReflectionText = SerializeReflection();
    }
    private async Task CompleteReflection()
    {
        if (!ReflectionValid || item is null) return; savingReflection = true; reflectionError = false;
        var payload = SerializeReflection(); var ok = await RoadmapService.SaveReflectionAsync(ItemId, UserId, payload);
        if (ok) { item.ReflectionText = payload; item.IsReflectionCompleted = true; item.ReflectionCompletedAtUtc = DateTime.UtcNow; item.IsCompleted = true; reflectionMessage = Tx("Week completed. The next week is now unlocked.", "Đã hoàn thành tuần. Tuần tiếp theo đã được mở."); }
        else { reflectionMessage = Tx("Could not complete the week.", "Không thể hoàn thành tuần."); reflectionError = true; }
        savingReflection = false;
    }
    private static readonly (int Id, string En, string Vi, string Icon)[] Steps = [(1,"Video","Video","bi bi-play-circle"),(2,"Script","Script","bi bi-file-text"),(3,"Summary","Tóm tắt","bi bi-lightbulb"),(4,"Quiz","Quiz","bi bi-ui-checks"),(5,"Practice","Thực hành","bi bi-chat-dots"),(6,"Reflection","Phản tư","bi bi-stars")];
    private sealed class ReflectionForm { public string Learning { get; set; } = string.Empty; public string Strength { get; set; } = string.Empty; public string Improvement { get; set; } = string.Empty; public string Commitment { get; set; } = string.Empty; public int ConfidenceBefore { get; set; } = 3; public int ConfidenceAfter { get; set; } = 3; }
}

