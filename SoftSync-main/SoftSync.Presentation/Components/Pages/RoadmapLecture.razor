@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp") · SoftSync</PageTitle>

<main class="lesson-page">
    @if (loading)
    {
        <div class="state"><span></span>@Tx("Loading lesson...", "Đang tải bài học...")</div>
    }
    else if (!isCommunicationLessonOne)
    {
        <button class="back" @onclick="Back"><i class="bi bi-arrow-left"></i>@Tx("Back to Roadmap", "Quay lại Roadmap")</button>
        <section class="empty"><i class="bi bi-journal-plus"></i><h1>@Tx("Content not available", "Chưa nạp nội dung")</h1><p>@Tx("This week is waiting for new video and theory content.", "Tuần này đang chờ video và lý thuyết mới.")</p></section>
    }
    else
    {
        <div class="lesson-shell">
            <header class="lesson-top">
                <button @onclick="Back"><i class="bi bi-arrow-left"></i>Roadmap</button>
                <div><small>@Tx("COMMUNICATION SKILLS · WEEK 1", "KỸ NĂNG GIAO TIẾP · TUẦN 1")</small><h1>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h1></div>
                @if (item!.IsCompleted)
                {
                    <span class="week-complete"><i class="bi bi-check-circle-fill"></i>@Tx("Week completed", "Đã hoàn thành tuần")</span>
                }
                else
                {
                    <span>@CompletedCount / 6 @Tx("steps", "bước")</span>
                }
            </header>

            <nav class="lesson-steps">
                @foreach (var step in Steps)
                {
                    var unlocked = CanOpen(step.Id);
                    <button class="@(currentStep == step.Id ? "active" : null) @(IsComplete(step.Id) ? "done" : null)" disabled="@(!unlocked)" @onclick="() => OpenStep(step.Id)">
                        <span>@(IsComplete(step.Id) ? "✓" : step.Id.ToString())</span><b>@Tx(step.En, step.Vi)</b>@if (!unlocked) { <i class="bi bi-lock-fill"></i> }
                    </button>
                }
            </nav>

            <section class="lesson-content">
                @if (IsComplete(currentStep))
                {
                    <div class="saved-complete"><i class="bi bi-check-circle-fill"></i><div><b>@Tx("Completed", "Đã học xong")</b><small>@Tx("Your progress is saved. You can review this section at any time.", "Tiến độ đã được lưu. Bạn có thể xem lại phần này bất kỳ lúc nào.")</small></div></div>
                }
                @if (currentStep == 1)
                {
                    <div class="video-wrap"><video controls preload="metadata" @onended="VideoEnded"><source src="/videos/communication-mentor-lesson-1.mp4" type="video/mp4" />@Tx("Your browser does not support video.", "Trình duyệt không hỗ trợ video.")</video></div>
                    <div class="content-heading"><div><small>@Tx("STEP 1 · VIDEO", "BƯỚC 1 · VIDEO")</small><h2>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h2><p>@Tx("Watch the entire video to unlock the Script.", "Hãy xem hết video để mở phần Script.")</p></div><span><i class="bi bi-clock"></i> Video Mentor 1</span></div>
                    @if (!item!.IsVideoCompleted) { <div class="notice"><i class="bi bi-info-circle"></i>@Tx("The Script unlocks automatically when the video ends.", "Script sẽ tự mở khi video phát hết.")</div> }
                    @if (!string.IsNullOrWhiteSpace(saveError)) { <div class="save-error"><i class="bi bi-exclamation-triangle"></i>@saveError</div> }
                    <div class="actions video-actions">
                        <button @onclick="Back"><i class="bi bi-arrow-left"></i>@Tx("Back to Roadmap", "Về Roadmap")</button>
                        <button class="primary" @onclick="CompleteVideoAndOpenScript">
                            @(item.IsVideoCompleted ? Tx("Next: Script", "Tiếp theo: Script") : Tx("I finished the video · Next", "Tôi đã xem xong · Tiếp theo")) <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                }
                else if (currentStep == 2)
                {
                    <article class="theory">
                        <div class="content-heading"><div><small>@Tx("STEP 2 · SCRIPT", "BƯỚC 2 · SCRIPT")</small><h2>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h2><p>@Tx("Theory synchronized with Video Mentor 1.", "Nội dung lý thuyết đồng bộ với Video Mentor 1.")</p></div></div>
                        @if (!IsVi)
                        {
                            <h3>1. Communication is a “two-way street”</h3>
                            <p>Effective communication means both sending a message and receiving feedback. A basic communication process includes:</p>
                            <ul><li><b>Sender:</b> The person who creates and delivers the message.</li><li><b>Message:</b> The meaning conveyed through speech, writing, or gestures.</li><li><b>Channel:</b> Face-to-face conversation, email, telephone, or social media.</li><li><b>Receiver:</b> The person who receives and interprets the message.</li><li><b>Feedback:</b> The response that confirms whether the message was understood correctly.</li></ul>
                            <h3>2. Essential skills for students</h3>
                            <ul><li><b>Active listening:</b> Focus fully, avoid interrupting, and confirm what you heard.</li><li><b>Non-verbal communication:</b> Eye contact, gestures, clothing, and posture all convey meaning.</li><li><b>Netiquette:</b> Write professional emails with clear subjects, complete sentences, and respectful greetings.</li></ul>
                            <h3>3. Tips for successful communication</h3>
                            <ul><li><b>Prepare carefully:</b> Organize ideas logically before presentations or important meetings.</li><li><b>Understand context:</b> Adapt your style to the audience and situation.</li><li><b>Communicate ethically:</b> Be respectful, honest, and fair.</li><li><b>Use simple language:</b> Choose precise, clear words and avoid unnecessary jargon.</li></ul>
                            <p class="conclusion">Communication takes patience and continuous adjustment. Strong communication improves learning and builds a professional impression for your future career.</p>
                        }
                        else
                        {
                        <h3>1. Giao tiếp là “con đường hai chiều”</h3>
                        <p>Giao tiếp hiệu quả không chỉ là gửi đi thông điệp mà còn là tiếp nhận phản hồi. Một quá trình giao tiếp cơ bản gồm:</p>
                        <ul><li><b>Người gửi:</b> Người tạo ra và truyền đạt thông điệp.</li><li><b>Thông điệp:</b> Nội dung, ý nghĩa muốn truyền tải qua lời nói, chữ viết hoặc cử chỉ.</li><li><b>Kênh truyền tải:</b> Nói trực tiếp, email, điện thoại hoặc mạng xã hội.</li><li><b>Người nhận:</b> Người tiếp nhận và giải mã thông điệp.</li><li><b>Phản hồi:</b> Sự hồi đáp giúp người gửi biết thông điệp đã được hiểu đúng hay chưa.</li></ul>
                        <h3>2. Các kỹ năng then chốt cho sinh viên</h3>
                        <ul><li><b>Lắng nghe chủ động:</b> Tập trung hoàn toàn, không ngắt lời và xác nhận lại điều đã nghe để tránh hiểu lầm.</li><li><b>Giao tiếp phi ngôn ngữ:</b> Ánh mắt, điệu bộ, trang phục và tư thế đều truyền tải thông điệp.</li><li><b>Quy tắc ứng xử mạng:</b> Viết email chuyên nghiệp, có tiêu đề rõ ràng, câu chữ hoàn chỉnh và lời chào trang trọng.</li></ul>
                        <h3>3. Bí quyết để giao tiếp thành công</h3>
                        <ul><li><b>Luôn chuẩn bị kỹ:</b> Sắp xếp ý tưởng logic trước khi thuyết trình hoặc gặp gỡ quan trọng.</li><li><b>Thấu hiểu bối cảnh:</b> Điều chỉnh phong cách phù hợp với đối tượng và tình huống.</li><li><b>Giao tiếp có đạo đức:</b> Tôn trọng, trung thực và công bằng với người nghe.</li><li><b>Sử dụng ngôn từ đơn giản:</b> Chọn từ chính xác, dễ hiểu và hạn chế biệt ngữ không cần thiết.</li></ul>
                        <p class="conclusion">Rèn luyện kỹ năng giao tiếp là một hành trình dài cần sự kiên nhẫn và tự điều chỉnh. Giao tiếp tốt giúp bạn học tập hiệu quả và tạo ấn tượng chuyên nghiệp trong tương lai.</p>
                        }
                    </article>
                    <div class="actions"><button @onclick="() => OpenStep(1)"><i class="bi bi-arrow-left"></i>@Tx("Back: Video", "Quay lại: Video")</button><button class="primary" @onclick="FinishScript">@Tx("Next: Summary", "Tiếp theo: Tóm tắt")<i class="bi bi-arrow-right"></i></button></div>
                }
                else if (currentStep == 3)
                {
                    <article class="summary-card"><i class="bi bi-stars"></i><small>@Tx("STEP 3 · SUMMARY", "BƯỚC 3 · TÓM TẮT")</small><h2>@Tx("Lesson summary", "Tóm tắt bài học")</h2><div class="summary-grid"><div><b>@Tx("Two-way communication", "Giao tiếp hai chiều")</b><p>@Tx("A message is complete only with a sender, receiver, and feedback.", "Thông điệp chỉ hoàn chỉnh khi có người gửi, người nhận và phản hồi.")</p></div><div><b>@Tx("Three foundations", "Ba kỹ năng nền tảng")</b><p>@Tx("Active listening, non-verbal language, and professional netiquette.", "Lắng nghe chủ động, giao tiếp phi ngôn ngữ và ứng xử mạng chuyên nghiệp.")</p></div><div><b>@Tx("Context-aware communication", "Giao tiếp phù hợp")</b><p>@Tx("Prepare, understand context, and communicate clearly and ethically.", "Chuẩn bị kỹ, hiểu bối cảnh và dùng ngôn từ rõ ràng, có đạo đức.")</p></div></div></article>
                    <div class="actions"><button @onclick="() => OpenStep(2)"><i class="bi bi-arrow-left"></i>@Tx("Back: Script", "Quay lại: Script")</button><button class="primary" @onclick="FinishSummary">@Tx("Next: Quiz", "Tiếp theo: Quiz")<i class="bi bi-arrow-right"></i></button></div>
                }
                else
                {
                    <section class="empty inner"><i class="@Steps.First(x => x.Id == currentStep).Icon"></i><h2>@Tx(Steps.First(x => x.Id == currentStep).En, Steps.First(x => x.Id == currentStep).Vi)</h2><p>@Tx("This section is waiting for content.", "Phần này đang chờ nạp nội dung tiếp theo.")</p></section>
                    <div class="actions"><button @onclick="Previous"><i class="bi bi-arrow-left"></i>@Tx("Back", "Quay lại")</button><button class="primary" @onclick="NextOrRoadmap">@Tx(currentStep < 6 ? "Next" : "Roadmap", currentStep < 6 ? "Tiếp theo" : "Về Roadmap")<i class="bi bi-arrow-right"></i></button></div>
                }
            </section>
        </div>
    }
</main>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    private RoadmapItemDto? item;
    private bool loading = true;
    private bool isCommunicationLessonOne;
    private int currentStep = 1;
    private string? saveError;
    private int CompletedCount => item is null ? 0 : (item.IsVideoCompleted ? 1 : 0) + (item.ScriptCompletedAtUtc.HasValue ? 1 : 0) + (item.SummaryCompletedAtUtc.HasValue ? 1 : 0) + (item.IsPracticeCompleted ? 1 : 0) + (item.IsScenarioCompleted ? 1 : 0) + (item.IsReflectionCompleted ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        var signedIn = await AuthProvider.GetUserIdAsync();
        if (signedIn <= 0) { Nav.NavigateTo("/Account/Login", true); return; }
        UserId = signedIn;
        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        item = roadmap.Items.FirstOrDefault(x => x.Id == ItemId);
        if (item is not null)
        {
            var communication = roadmap.Items.Where(IsCommunication).OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
            isCommunicationLessonOne = communication.FirstOrDefault()?.Id == item.Id;
            currentStep = item.LastLearningStep?.ToLowerInvariant() switch { "script" => 2, "summary" => 3, "quiz" => 4, "scenario" => 5, "reflection" => 6, _ => 1 };
            if (!CanOpen(currentStep)) currentStep = Math.Clamp(CompletedCount + 1, 1, 6);
        }
        loading = false;
    }

    private static bool IsCommunication(RoadmapItemDto x) { var value = $"{x.SkillName} {x.Title}".ToLowerInvariant(); return value.Contains("giao tiếp") || value.Contains("communication"); }
    private bool CanOpen(int step) => item is not null && (item.IsCompleted || step == 1 || step == 2 && item.IsVideoCompleted || step == 3 && item.ScriptCompletedAtUtc.HasValue || step == 4 && item.SummaryCompletedAtUtc.HasValue || step == 5 && item.IsPracticeCompleted || step == 6 && item.IsScenarioCompleted);
    private bool IsComplete(int step) => item is not null && (item.IsCompleted || step switch { 1 => item.IsVideoCompleted, 2 => item.ScriptCompletedAtUtc.HasValue, 3 => item.SummaryCompletedAtUtc.HasValue, 4 => item.IsPracticeCompleted, 5 => item.IsScenarioCompleted, 6 => item.IsReflectionCompleted, _ => false });
    private async Task VideoEnded()
    {
        if (item is null || item.IsVideoCompleted) return;
        saveError = null;
        if (await RoadmapService.MarkVideoCompleteAsync(ItemId, UserId))
        {
            item.IsVideoCompleted = true;
            item.VideoCompletedAtUtc = DateTime.UtcNow;
            item.LastLearningStep = "script";
            await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "script");
        }
        else
        {
            saveError = Tx("Could not save video progress. Please reload and try again.", "Không thể lưu tiến độ video. Hãy tải lại trang và thử lại.");
        }
        StateHasChanged();
    }
    private async Task CompleteVideoAndOpenScript()
    {
        if (item is null) return;
        if (!item.IsVideoCompleted)
            await VideoEnded();
        if (item.IsVideoCompleted)
            await OpenStep(2);
    }
    private async Task OpenStep(int step) { if (!CanOpen(step)) return; currentStep = step; var key = step switch { 1 => "video", 2 => "script", 3 => "summary", 4 => "quiz", 5 => "scenario", _ => "reflection" }; await RoadmapService.SaveLearningStepAsync(ItemId, UserId, key); if (item is not null) item.LastLearningStep = key; }
    private async Task FinishScript() { if (await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "summary")) { item!.ScriptCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "summary"; currentStep = 3; } }
    private async Task FinishSummary() { if (await RoadmapService.SaveLearningStepAsync(ItemId, UserId, "quiz")) { item!.SummaryCompletedAtUtc ??= DateTime.UtcNow; item.LastLearningStep = "quiz"; currentStep = 4; } }
    private void Previous() => currentStep = Math.Max(1, currentStep - 1);
    private void NextOrRoadmap() { if (currentStep < 6 && CanOpen(currentStep + 1)) currentStep++; else Back(); }
    private void Back() => Nav.NavigateTo($"/roadmap/{UserId}");
    private bool IsVi => L.Current == AppLanguage.Vi;
    private string Tx(string en, string vi) => IsVi ? vi : en;
    private static readonly (int Id, string En, string Vi, string Icon)[] Steps = [(1,"Video","Video","bi bi-play-circle"),(2,"Script","Script","bi bi-file-text"),(3,"Summary","Tóm tắt","bi bi-lightbulb"),(4,"Quiz","Quiz","bi bi-ui-checks"),(5,"Practice","Thực hành","bi bi-chat-dots"),(6,"Reflection","Phản tư","bi bi-stars")];
}

