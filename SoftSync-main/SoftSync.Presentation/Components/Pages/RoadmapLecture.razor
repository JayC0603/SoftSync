@page "/roadmap/lecture/{UserId:int}/{ItemId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.Common.Enums
@inject NavigationManager Nav

<PageTitle>@Tx("Roadmap content", "Nội dung Roadmap") · SoftSync</PageTitle>

<main class="empty-content-page">
    <button class="back" @onclick="Back"><i class="bi bi-arrow-left"></i>@Tx("Back to Roadmap", "Quay lại Roadmap")</button>
    <section>
        <span><i class="bi bi-journal-plus"></i></span>
        <small>@Tx("WEEKLY LEARNING CONTENT", "NỘI DUNG HỌC THEO TUẦN")</small>
        <h1>@Tx("Content has not been loaded", "Chưa nạp nội dung")</h1>
        <p>@Tx("This week is ready for new Video, Script, Summary, Quiz, Scenario, and Reflection content.", "Tuần này đang chờ nạp mới Video, Script, Tóm tắt, Quiz, Tình huống và Phản tư.")</p>
        <div class="steps">
            @foreach (var step in Steps)
            {
                <div><i class="@step.Icon"></i><b>@Tx(step.En, step.Vi)</b><em>@Tx("Pending", "Chờ nạp")</em></div>
            }
        </div>
    </section>
</main>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    private void Back() => Nav.NavigateTo(UserId > 0 ? $"/roadmap/{UserId}" : "/roadmap");
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
    private static readonly (string En, string Vi, string Icon)[] Steps =
    [
        ("Video", "Video", "bi bi-play-circle"),
        ("Script", "Script", "bi bi-file-text"),
        ("Summary", "Tóm tắt", "bi bi-lightbulb"),
        ("Quiz", "Quiz", "bi bi-ui-checks"),
        ("Scenario", "Tình huống", "bi bi-chat-square-text"),
        ("Reflection", "Phản tư", "bi bi-journal-check")
    ];
}

<style>
    .empty-content-page{min-height:calc(100vh - 72px);padding:2rem;background:#f5f7fa;color:#17233c}
    .empty-content-page>.back{display:flex;align-items:center;gap:.45rem;max-width:1100px;margin:0 auto 1rem;padding:.6rem 0;color:#3157d5;border:0;background:transparent;font-weight:800}
    .empty-content-page section{max-width:1100px;margin:auto;padding:clamp(2rem,5vw,4.5rem);text-align:center;border:1px solid #dfe4ec;border-radius:18px;background:#fff}
    .empty-content-page section>span{display:grid;place-items:center;width:64px;height:64px;margin:0 auto 1rem;color:#fff;border-radius:18px;background:linear-gradient(135deg,#3157d5,#6954e8);font-size:1.7rem}
    .empty-content-page small{color:#3157d5;font-weight:900;letter-spacing:.1em}.empty-content-page h1{margin:.5rem 0;font-size:2rem}.empty-content-page p{max-width:700px;margin:0 auto;color:#6c7588}
    .steps{display:grid;grid-template-columns:repeat(6,1fr);gap:.55rem;margin-top:2rem}.steps div{display:grid;gap:.35rem;padding:1rem .5rem;border:1px dashed #ccd3df;border-radius:12px;color:#737d90}.steps i{font-size:1.25rem}.steps b{color:#28334a;font-size:.75rem}.steps em{font-size:.6rem;font-style:normal}
    @@media(max-width:800px){.steps{grid-template-columns:repeat(2,1fr)}}
</style>
