@page "/time-management-inbox-rush"
@rendermode InteractiveServer
@inject NavigationManager Nav
@implements IDisposable
<PageTitle>Game 2 · Inbox Rush</PageTitle>
<main class="ir"><button class="back" @onclick='()=>Nav.NavigateTo("/time-management-lesson-2")'><i class="bi bi-arrow-left"></i> Video 2</button><header><div><span>GAME 2 · INBOX RUSH</span><h1>Một ngày, tám khung giờ.<br/><em>Bạn ưu tiên thế nào?</em></h1><p>Task mới xuất hiện mỗi 6 giây. Kéo task vào lịch trước khi hết thời gian.</p></div><div class="timer"><b>@TimeText</b><span>THỜI GIAN CÒN LẠI</span></div></header>
 @if(!started&&!finished){<section class="start"><i class="bi bi-inboxes-fill"></i><h2>Hộp thư sắp đầy!</h2><p>Mỗi task có độ khẩn cấp U, quan trọng I và thời lượng thật D. Hãy dự đoán số slot trước khi kéo vào lịch.</p><div><span><b>PS</b> Ưu tiên</span><span><b>CS</b> Ước lượng</span><span><b>AS</b> Thích ứng</span></div><button @onclick="Start">Bắt đầu 2 phút <i class="bi bi-play-fill"></i></button></section>}
 else if(!finished){<section class="game"><aside><header><div><i class="bi bi-inbox-fill"></i><b>Hộp thư việc cần làm</b></div><span>@VisibleTasks.Count task</span></header><div class="inbox">@if(VisibleTasks.Count==0){<p class="waiting"><i class="bi bi-hourglass-split"></i> Đang chờ task mới...</p>}@foreach(var task in VisibleTasks){<article class="@(task.Interrupt?"interrupt":"")" draggable="true" @ondragstart="()=>Drag(task)"><div><small>@(task.Interrupt?"⚡ PHÁT SINH GẤP":"TASK MỚI")</small><b>@task.Name</b></div><div class="chips"><span>U@task.Urgency</span><span>I@task.Importance</span><label>Dự đoán <select @bind="task.Estimate"><option value="1">1 slot</option><option value="2">2 slot</option><option value="3">3 slot</option></select></label></div></article>}</div></aside><article class="day"><header><div><small>THỜI KHOÁ BIỂU NGÀY</small><h2>8 khung giờ tập trung</h2></div><span>@slots.Count(x=>x is not null)/8 đã xếp</span></header><div class="slots">@for(var i=0;i<8;i++){var idx=i;<section class="@(slots[i] is null?"":"filled")" @ondragover:preventDefault @ondrop="()=>Drop(idx)"><time>@(8+i):00</time>@if(slots[i] is null){<span><i class="bi bi-plus-circle"></i> Thả task vào đây</span>}else{<b>@slots[i]!.Name</b>}</section>}</div><footer><span><i class="bi bi-info-circle"></i> Task nhiều slot cần đủ ô trống liên tiếp.</span><button @onclick="Finish">Kết thúc sớm</button></footer></article></section>}
 else {<section class="report"><header><div class="total"><b>@TotalScore</b><span>/100</span></div><div><span>BÁO CÁO NĂNG LỰC</span><h1>@ResultTitle</h1><p>@PersonalFeedback</p></div></header><div class="metrics"><article><i class="bi bi-list-ol"></i><span><b>@PS</b><small>Priority Score</small></span><p>Ưu tiên theo tầm quan trọng thay vì chỉ phản ứng với việc gấp.</p></article><article><i class="bi bi-stopwatch"></i><span><b>@CS</b><small>Calibration Score</small></span><p>Độ chính xác khi dự đoán số khung giờ cần thiết.</p></article><article><i class="bi bi-lightning-charge"></i><span><b>@AS</b><small>Adaptation Score</small></span><p>Tốc độ xử lý các task phát sinh bất ngờ.</p></article></div><div class="summary"><span><b>@scheduled.Count</b> task đã xếp</span><span><b>@failed</b> task thất bại</span><span><b>@slots.Count(x=>x is null)</b> slot trống</span></div><div class="actions"><button @onclick="Reset"><i class="bi bi-arrow-repeat"></i> Chơi lại</button><button class="primary" @onclick='()=>Nav.NavigateTo("/roadmap")'>Về Roadmap</button></div></section>}
</main>
@code{private bool started,finished;private int seconds=120,nextTask,failed;private Timer? timer;private TaskItem? dragging;private readonly TaskItem?[] slots=new TaskItem?[8];private List<TaskItem> pool=[];private readonly List<Scheduled> scheduled=[];private List<TaskItem> VisibleTasks=>pool.Where(x=>x.Visible&&!x.Scheduled&&!x.Failed).ToList();private string TimeText=>$"{seconds/60:00}:{seconds%60:00}";private int PS{get;set;}private int CS{get;set;}private int AS{get;set;}private int TotalScore{get;set;}private string ResultTitle=>TotalScore>=80?"Nhà quản lý thời gian xuất sắc":TotalScore>=60?"Khả năng thích ứng khá tốt":"Cần luyện thêm chiến lược ưu tiên";private string PersonalFeedback=>PS<CS?"Bạn ước lượng khá tốt nhưng dễ bị việc gấp làm lệch ưu tiên. Hãy nhìn mức độ quan trọng trước.":CS<60?"Bạn có xu hướng đánh giá sai thời lượng. Hãy chia nhỏ công việc trước khi xếp lịch.":AS<60?"Bạn cần phản ứng nhanh hơn với gián đoạn và bảo vệ các task quan trọng.":"Bạn cân bằng tốt giữa kế hoạch, ước lượng và việc phát sinh.";
private void Start(){started=true;BuildPool();pool[0].Visible=true;nextTask=1;timer=new Timer(async _=>await Tick(),null,1000,1000);}private async Task Tick(){if(finished)return;seconds--;if(seconds%6==0&&nextTask<pool.Count){var t=pool[nextTask++];t.Visible=true;t.RevealedAt=DateTime.UtcNow;}if(seconds<=0||slots.All(x=>x is not null))Finish();await InvokeAsync(StateHasChanged);}private void Drag(TaskItem t)=>dragging=t;private void Drop(int index){if(dragging is null)return;var t=dragging;if(index+t.Duration>8||Enumerable.Range(index,t.Duration).Any(i=>slots[i] is not null)){dragging=null;return;}for(var i=index;i<index+t.Duration;i++)slots[i]=t;t.Scheduled=true;t.Placed=index;t.Reaction=(DateTime.UtcNow-t.RevealedAt).TotalSeconds;scheduled.Add(new(t,index));dragging=null;if(slots.All(x=>x is not null))Finish();}
private void Finish(){if(finished)return;finished=true;timer?.Dispose();failed+=pool.Count(x=>x.Visible&&!x.Scheduled);var rawPs=scheduled.Sum(x=>(x.Task.Urgency+2*x.Task.Importance)*(x.Slot<=2?1.5:x.Slot<=5?1:.5));var maxPs=Math.Max(1,scheduled.Sum(x=>(x.Task.Urgency+2*x.Task.Importance)*1.5));PS=(int)Math.Round(rawPs/maxPs*100);CS=scheduled.Count==0?0:(int)Math.Round(scheduled.Average(x=>Math.Max(0,100-Math.Abs(x.Task.Estimate-x.Task.Duration)*20)));var interrupts=scheduled.Where(x=>x.Task.Interrupt).ToList();AS=interrupts.Count==0?0:(int)Math.Round(interrupts.Average(x=>Math.Max(0,100-x.Task.Reaction*5)));var penalty=failed*3+slots.Count(x=>x is null);TotalScore=Math.Clamp((int)Math.Round(.5*PS+.3*CS+.2*AS)-penalty,0,100);InvokeAsync(StateHasChanged);}private void Reset(){timer?.Dispose();started=false;finished=false;seconds=120;nextTask=failed=0;Array.Clear(slots);scheduled.Clear();pool.Clear();}
private void BuildPool(){pool=[new("Ôn tập kiểm tra 15 phút",4,4,1,false),new("Làm bài tập Toán",2,4,2,false),new("Viết bài luận Văn",2,3,2,false),new("Bạn nhờ giải bài gấp",5,1,1,true),new("Học từ vựng tiếng Anh",2,3,1,false),new("Họp câu lạc bộ",4,1,1,false),new("Nộp báo cáo thí nghiệm",5,5,2,false),new("Xem video giải trí",4,1,1,false),new("Tập văn nghệ",3,2,2,false),new("Giáo viên đổi lịch kiểm tra",5,5,1,true),new("Ôn chương 3 môn Hoá",3,4,2,false),new("Dọn góc học tập",1,2,1,false),new("Bài tập nhóm môn Lý",3,3,2,false),new("Trả lời tin nhắn lớp",4,1,1,false),new("Bố mẹ nhờ việc nhà gấp",5,2,1,true)];foreach(var t in pool.OrderBy(_=>Random.Shared.Next())){}pool=pool.OrderBy(_=>Random.Shared.Next()).ToList();pool[0].RevealedAt=DateTime.UtcNow;}
public void Dispose()=>timer?.Dispose();private sealed class TaskItem(string name,int urgency,int importance,int duration,bool interrupt){public string Name{get;}=name;public int Urgency{get;}=urgency;public int Importance{get;}=importance;public int Duration{get;}=duration;public bool Interrupt{get;}=interrupt;public bool Visible{get;set;}public bool Scheduled{get;set;}public bool Failed{get;set;}public int Estimate{get;set;}=1;public int Placed{get;set;}public DateTime RevealedAt{get;set;}=DateTime.UtcNow;public double Reaction{get;set;}}private sealed record Scheduled(TaskItem Task,int Slot);}
<style>.ir{--p:#6847eb;--ink:#19163d;--muted:#697386;max-width:1280px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:var(--ink)}.back{border:0;background:none;color:#747b8c;font-weight:800}.ir>header{display:flex;justify-content:space-between;align-items:center;margin:1rem 0;padding:2rem;border-radius:26px;background:linear-gradient(135deg,#fff,#eee9ff)}.ir>header span,.report header span{color:var(--p);font-size:.65rem;font-weight:900;letter-spacing:.08em}.ir h1{margin:.4rem 0}.ir h1 em{color:var(--p);font-style:normal}.ir>header p{color:var(--muted)}.timer{display:grid;place-items:center;min-width:130px;height:100px;border-radius:18px;background:#fff}.timer b{font-size:2rem;color:var(--p)}.start,.report{padding:2rem;text-align:center;border:1px solid #ded8f5;border-radius:22px;background:#fff}.start>i{font-size:3rem;color:var(--p)}.start>div{display:flex;justify-content:center;gap:.7rem;margin:1rem}.start>div span{padding:.7rem;border-radius:10px;background:#f6f3ff}.start button,.day footer button,.actions button{padding:.75rem 1rem;color:#fff;border:0;border-radius:10px;background:var(--p);font-weight:800}.game{display:grid;grid-template-columns:380px 1fr;gap:1rem}.game>aside,.day{border:1px solid #ded8f5;border-radius:20px;background:#fff}.game>aside>header,.day>header{display:flex;justify-content:space-between;padding:1rem;border-bottom:1px solid #eeeaf8}.inbox{display:grid;gap:.6rem;max-height:620px;overflow:auto;padding:1rem}.inbox article{padding:.8rem;border:1px solid #dfd9f4;border-radius:12px;cursor:grab}.inbox article small{color:var(--p);font-size:.57rem;font-weight:900}.inbox article b{display:block;margin:.2rem 0}.inbox .interrupt{border-color:#f79009;background:#fff7e8}.chips{display:flex;gap:.35rem;align-items:center}.chips>span{padding:.25rem .4rem;border-radius:6px;background:#eeeaff;font-size:.65rem}.chips label{margin-left:auto;font-size:.62rem}.chips select{border:1px solid #ddd6f5}.waiting{text-align:center;color:var(--muted)}.slots{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;padding:1rem}.slots section{display:grid;grid-template-columns:55px 1fr;align-items:center;min-height:62px;padding:.6rem;border:1px dashed #cfc6ee;border-radius:11px}.slots time{color:var(--p);font-weight:900}.slots span{color:#9a9fac;font-size:.7rem}.slots .filled{border-style:solid;background:#f1edff}.slots .filled b{font-size:.75rem}.day footer{display:flex;justify-content:space-between;align-items:center;padding:1rem}.day footer span{font-size:.7rem;color:var(--muted)}.report>header{display:flex;justify-content:center;align-items:center;gap:1rem}.total{display:grid;place-items:center;width:120px;height:120px;border:9px solid #dcd5f7;border-top-color:var(--p);border-radius:50%}.total b{font-size:2rem}.metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:.7rem;margin-top:1.5rem;text-align:left}.metrics article{padding:1rem;border-radius:14px;background:#f8f7fc}.metrics article>i{color:var(--p);font-size:1.3rem}.metrics span b,.metrics span small{display:block}.metrics span b{font-size:1.7rem;color:var(--p)}.metrics p{font-size:.72rem;color:var(--muted)}.summary,.actions{display:flex;justify-content:center;gap:.7rem;margin-top:1rem}.summary span{padding:.7rem;border-radius:9px;background:#eeeaff}.actions .primary{background:var(--p)}@@media(max-width:850px){.game{grid-template-columns:1fr}.metrics{grid-template-columns:1fr}.ir>header,.report>header{align-items:start;flex-direction:column}.slots{grid-template-columns:1fr}}</style>
