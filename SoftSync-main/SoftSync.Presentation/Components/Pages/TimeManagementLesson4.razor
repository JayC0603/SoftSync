@page "/time-management-lesson-4"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@inject NavigationManager Nav
<PageTitle>@Tx("Video 4 · Time Management", "Video 4 · Quản lý thời gian")</PageTitle>
<main class="tmv4"><button @onclick='()=>Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i> @Tx("Roadmap", "Lộ trình")</button><article><header><span>@Tx("VIDEO 4 · TIME MANAGEMENT", "VIDEO 4 · QUẢN LÝ THỜI GIAN")</span><h1>@Tx("Advanced lesson", "Bài giảng nâng cao")<br/>@Tx("from a SoftSync Mentor", "từ Mentor SoftSync")</h1><p>@Tx("Continue improving your ability to plan, manage priorities, and maintain effective habits.", "Tiếp tục hoàn thiện khả năng lập kế hoạch, kiểm soát ưu tiên và duy trì thói quen hiệu quả.")</p></header><video controls preload="metadata" playsinline><source src="/videos/time-management-mentor-lesson-4.mp4" type="video/mp4"/>@Tx("Your browser does not support HTML5 video.", "Trình duyệt không hỗ trợ video HTML5.")</video><footer><div><i class="bi bi-journal-check"></i><span><b>@Tx("Lesson complete", "Hoàn thành bài giảng")</b>@Tx("Review your roadmap and continue with the practice activities.", "Xem lại lộ trình và tiếp tục các hoạt động thực hành.")</span></div><button @onclick='()=>Nav.NavigateTo("/roadmap")'>@Tx("Back to Roadmap", "Về Roadmap") <i class="bi bi-arrow-right"></i></button></footer></article></main>

@code {
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
}
<style>.tmv4{max-width:1000px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:#19163d}.tmv4>button{border:0;background:none;color:#747b8c;font-weight:800}.tmv4 article{overflow:hidden;margin-top:1rem;border:1px solid #ded8f5;border-radius:26px;background:#fff;box-shadow:0 22px 55px #4c1d9518}.tmv4 header{padding:1.6rem;background:linear-gradient(135deg,#fff,#f4f0ff)}.tmv4 header span{color:#6847eb;font-size:.65rem;font-weight:900;letter-spacing:.08em}.tmv4 h1{margin:.4rem 0;font-size:clamp(2rem,4vw,3rem)}.tmv4 p,.tmv4 footer span{color:#6b7280}.tmv4 video{display:block;width:100%;max-height:580px;aspect-ratio:16/9;object-fit:contain;background:#080914}.tmv4 footer{display:flex;justify-content:space-between;align-items:center;gap:1rem;padding:1.2rem 1.6rem;background:#f8f7fc}.tmv4 footer>div{display:flex;gap:.7rem}.tmv4 footer i{color:#6847eb;font-size:1.2rem}.tmv4 footer span,.tmv4 footer b{display:block}.tmv4 footer span{font-size:.75rem}.tmv4 footer b{color:#19163d}.tmv4 footer button{padding:.8rem 1rem;color:#fff;border:0;border-radius:11px;background:#6847eb;font-weight:800}@@media(max-width:600px){.tmv4 footer{align-items:stretch;flex-direction:column}.tmv4 footer button{width:100%}}</style>
