@page "/"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<section class="ss-landing">
    <div class="ss-hero-grid">
        <div class="ss-hero-copy">
            <div class="ss-eyebrow">@L["home.tagline"]</div>
            <h1>
                @L["home.heroTitlePrefix"]<span>@L["home.heroTitleHighlight"]</span>.
            </h1>
            <p>@L["home.heroDesc"]</p>

            <div class="ss-hero-actions">
                <AuthorizeView>
                    <Authorized>
                        <button class="ss-primary-cta" @onclick='() => Nav.NavigateTo("/profile-setup")'>
                            @L["home.startJourney"] <i class="bi bi-arrow-right"></i>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button class="ss-primary-cta" @onclick='() => Nav.NavigateTo("Account/Register")'>
                            @L["auth.register"] <i class="bi bi-arrow-right"></i>
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
                <button class="ss-secondary-cta" @onclick='() => Nav.NavigateTo("/assistant")'>
                    <i class="bi bi-play-circle-fill"></i> @L["home.learnMore"]
                </button>
            </div>
        </div>

        <div class="ss-orbit-stage" aria-hidden="true">
            <div class="ss-orbit ss-orbit-one"></div>
            <div class="ss-orbit ss-orbit-two"></div>
            <div class="ss-galaxy-core"></div>
            <div class="ss-planet ss-planet-a"></div>
            <div class="ss-planet ss-planet-b"></div>
            <div class="ss-ai-orb">
                <img src="/images/syncy-fish.png" alt="" />
            </div>
            <div class="ss-feature-chip ss-chip-practice ss-glass ss-glass-interactive">
                <i class="bi bi-controller"></i>
                <div><strong>@L["home.orbit.practice.title"]</strong><span>@L["home.orbit.practice.desc"]</span></div>
            </div>
            <div class="ss-feature-chip ss-chip-assess ss-glass ss-glass-interactive">
                <i class="bi bi-graph-up-arrow"></i>
                <div><strong>@L["home.orbit.assess.title"]</strong><span>@L["home.orbit.assess.desc"]</span></div>
            </div>
            <div class="ss-feature-chip ss-chip-grow ss-glass ss-glass-interactive">
                <i class="bi bi-leaf"></i>
                <div><strong>@L["home.orbit.grow.title"]</strong><span>@L["home.orbit.grow.desc"]</span></div>
            </div>
        </div>
    </div>

    <section class="ss-mentor-panel ss-glass ss-glass-interactive">
        <div class="ss-panel-head ss-glass">
            <div>
                <div class="ss-panel-title"><i class="bi bi-stars"></i> @L["mentor.main.heading"]</div>
                <p>@L["mentor.main.headingDesc"]</p>
            </div>
        </div>

        <div class="ss-main-mentor-grid">
            <article class="ss-main-mentor ss-advisor-card ss-glass ss-glass-interactive">
                <div class="ss-main-mentor-portrait">
                    <div class="ss-main-mentor-orbit" aria-hidden="true"></div>
                    <img src="/images/mentor-nguyen-hoang-van-anh.png" alt="Th.S. Nguyễn Hoàng Vân Anh" />
                </div>

                <div class="ss-main-mentor-content">
                    <span class="ss-main-mentor-kicker"><i class="bi bi-stars"></i> @L["mentor.advisor.role"]</span>
                    <h2>Th.S. Nguyễn Hoàng Vân Anh</h2>
                    <p class="ss-main-mentor-position">@L["mentor.advisor.position"]</p>
                    <p class="ss-main-mentor-summary">@L["mentor.advisor.summary"]</p>
                    <div class="ss-main-mentor-tags">
                        <span><i class="bi bi-person-heart"></i>@L["mentor.advisor.specialty.psychology"]</span>
                        <span><i class="bi bi-compass-fill"></i>@L["mentor.advisor.specialty.development"]</span>
                    </div>
                    <button type="button" class="ss-mentor-detail-btn" @onclick="() => advisorDetailsOpen = true">
                        @L["mentor.main.viewDetails"] <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </article>

            <article class="ss-main-mentor ss-glass ss-glass-interactive">
                <div class="ss-main-mentor-portrait">
                    <div class="ss-main-mentor-orbit" aria-hidden="true"></div>
                    <img src="/images/mentor-nguyen-thuy-to-tram.png" alt="Th.S. Nguyễn Thuỵ Tố Trâm" />
                </div>

                <div class="ss-main-mentor-content">
                    <span class="ss-main-mentor-kicker"><i class="bi bi-gem"></i> @L["mentor.main.role"]</span>
                    <h2>Th.S. Nguyễn Thuỵ Tố Trâm</h2>
                    <p class="ss-main-mentor-position">@L["mentor.main.position"]</p>
                    <p class="ss-main-mentor-summary">@L["mentor.main.summary"]</p>
                    <div class="ss-main-mentor-tags">
                        <span><i class="bi bi-chat-dots-fill"></i>@L["mentor.main.specialty.softSkills"]</span>
                        <span><i class="bi bi-heart-fill"></i>@L["mentor.main.specialty.community"]</span>
                        <span><i class="bi bi-universal-access"></i>@L["mentor.main.specialty.inclusion"]</span>
                    </div>
                    <button type="button" class="ss-mentor-detail-btn" @onclick="() => mentorDetailsOpen = true">
                        @L["mentor.main.viewDetails"] <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </article>

            <article class="ss-main-mentor ss-advisor-card ss-advisor-card-right ss-glass ss-glass-interactive">
                <div class="ss-main-mentor-portrait">
                    <div class="ss-main-mentor-orbit" aria-hidden="true"></div>
                    <img src="/images/mentor-nguyen-xuan.png" alt="Th.S. Nguyễn Xuân" />
                </div>

                <div class="ss-main-mentor-content">
                    <span class="ss-main-mentor-kicker"><i class="bi bi-stars"></i> @L["mentor.advisor.role"]</span>
                    <h2>Th.S. Nguyễn Xuân</h2>
                    <p class="ss-main-mentor-position">@L["mentor.advisor.xuan.position"]</p>
                    <p class="ss-main-mentor-summary">@L["mentor.advisor.xuan.summary"]</p>
                    <div class="ss-main-mentor-tags">
                        <span><i class="bi bi-award-fill"></i>@L["mentor.advisor.xuan.specialty.experience"]</span>
                        <span><i class="bi bi-cpu-fill"></i>@L["mentor.advisor.xuan.specialty.edtech"]</span>
                    </div>
                    <button type="button" class="ss-mentor-detail-btn" @onclick="() => xuanDetailsOpen = true">
                        @L["mentor.main.viewDetails"] <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </article>
        </div>

        @if (xuanDetailsOpen)
        {
            <div class="ss-mentor-modal-backdrop" role="presentation" @onclick="() => xuanDetailsOpen = false">
                <section class="ss-mentor-modal ss-glass" role="dialog" aria-modal="true" aria-labelledby="xuan-detail-title" @onclick:stopPropagation="true">
                    <button type="button" class="ss-mentor-modal-close" @onclick="() => xuanDetailsOpen = false" aria-label="@L["mentor.main.close"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <header>
                        <img src="/images/mentor-nguyen-xuan.png" alt="Th.S. Nguyễn Xuân" />
                        <div>
                            <span>@L["mentor.advisor.role"]</span>
                            <h2 id="xuan-detail-title">Th.S. Nguyễn Xuân</h2>
                            <p>@L["mentor.advisor.xuan.position"]</p>
                        </div>
                    </header>
                    <ul>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.xuan.highlight1"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.xuan.highlight2"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.xuan.highlight3"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.xuan.highlight4"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.xuan.highlight5"]</li>
                    </ul>
                    <div class="ss-mentor-modal-bio">
                        <h3>@L["mentor.main.about"]</h3>
                        <p>@L["mentor.advisor.xuan.bio"]</p>
                    </div>
                </section>
            </div>
        }

        @if (advisorDetailsOpen)
        {
            <div class="ss-mentor-modal-backdrop" role="presentation" @onclick="() => advisorDetailsOpen = false">
                <section class="ss-mentor-modal ss-glass" role="dialog" aria-modal="true" aria-labelledby="advisor-detail-title" @onclick:stopPropagation="true">
                    <button type="button" class="ss-mentor-modal-close" @onclick="() => advisorDetailsOpen = false" aria-label="@L["mentor.main.close"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <header>
                        <img src="/images/mentor-nguyen-hoang-van-anh.png" alt="Th.S. Nguyễn Hoàng Vân Anh" />
                        <div>
                            <span>@L["mentor.advisor.role"]</span>
                            <h2 id="advisor-detail-title">Th.S. Nguyễn Hoàng Vân Anh</h2>
                            <p>@L["mentor.advisor.position"]</p>
                        </div>
                    </header>
                    <ul>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.highlight1"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.highlight2"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.highlight3"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.highlight4"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.advisor.highlight5"]</li>
                    </ul>
                    <div class="ss-mentor-modal-bio">
                        <h3>@L["mentor.main.about"]</h3>
                        <p>@L["mentor.advisor.bio"]</p>
                    </div>
                </section>
            </div>
        }

        @if (mentorDetailsOpen)
        {
            <div class="ss-mentor-modal-backdrop" role="presentation" @onclick="() => mentorDetailsOpen = false">
                <section class="ss-mentor-modal ss-glass" role="dialog" aria-modal="true" aria-labelledby="mentor-detail-title" @onclick:stopPropagation="true">
                    <button type="button" class="ss-mentor-modal-close" @onclick="() => mentorDetailsOpen = false" aria-label="@L["mentor.main.close"]">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <header>
                        <img src="/images/mentor-nguyen-thuy-to-tram.png" alt="Th.S. Nguyễn Thuỵ Tố Trâm" />
                        <div>
                            <span>@L["mentor.main.role"]</span>
                            <h2 id="mentor-detail-title">Th.S. Nguyễn Thuỵ Tố Trâm</h2>
                            <p>@L["mentor.main.position"]</p>
                        </div>
                    </header>
                    <ul>
                        <li><i class="bi bi-stars"></i>@L["mentor.main.highlight2"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.main.highlight3"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.main.highlight4"]</li>
                        <li><i class="bi bi-stars"></i>@L["mentor.main.highlight5"]</li>
                    </ul>
                    <div class="ss-mentor-modal-bio">
                        <h3>@L["mentor.main.about"]</h3>
                        <p>@L["mentor.main.bio1"]</p>
                        <p>@L["mentor.main.bio2"]</p>
                        <p>@L["mentor.main.bio3"]</p>
                    </div>
                </section>
            </div>
        }
    </section>

    <section class="ss-landing-stats">
        <div class="ss-glass ss-glass-interactive"><i class="bi bi-people-fill"></i><strong>7+</strong><span>@L["home.stat.coreSkills"]</span></div>
        <div class="ss-glass ss-glass-interactive"><i class="bi bi-pie-chart-fill"></i><strong>AI</strong><span>@L["home.stat.assessment"]</span></div>
        <div class="ss-glass ss-glass-interactive"><i class="bi bi-headset"></i><strong>24/7</strong><span>@L["home.stat.support"]</span></div>
        <div class="ss-glass ss-glass-interactive"><i class="bi bi-star-fill"></i><strong>10K+</strong><span>@L["home.stat.learners"]</span></div>
    </section>

    <aside class="ss-chat-widget @(chatbotOpen ? "open" : "")" aria-label="SoftSync assistant preview">
        @if (chatbotOpen)
        {
            <div class="ss-chat-panel ss-glass">
                <div class="ss-chat-panel-head">
                    <div class="ss-chat-avatar">
                        <img src="/images/syncy-fish.png" alt="" />
                    </div>
                    <div>
                        <strong>SYNCY AI</strong>
                        <span>@L["chatbot.tagline"]</span>
                    </div>
                    <button type="button" class="ss-chat-minimize" title="Thu nhỏ" @onclick="() => chatbotOpen = false">
                        <i class="bi bi-dash-lg"></i>
                    </button>
                    <button type="button" class="ss-chat-close" title="Thu về hình tròn" @onclick="() => chatbotOpen = false">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="ss-chat-body">
                    <div class="ss-chat-bubble">
                        @if (chatView == "welcome")
                        {
                            <strong>👋 @L["chatbot.welcome.title"]</strong>
                            <span>@L["chatbot.welcome.desc"]</span>
                        }
                        else if (chatView == "about")
                        {
                            <strong>🌊 @L["chatbot.about.title"]</strong><span>@L["chatbot.about.desc"]</span>
                        }
                        else if (chatView == "premium")
                        {
                            <strong>💎 @L["chatbot.premium.title"]</strong><span>@L["chatbot.premium.desc"]</span>
                        }
                        else if (chatView == "mentor")
                        {
                            <strong>👥 @L["chatbot.mentor.title"]</strong><span>@L["chatbot.mentor.desc"]</span>
                        }
                        else if (chatView == "how")
                        {
                            <strong>🚀 @L["chatbot.how.title"]</strong><span>@L["chatbot.how.desc"]</span>
                        }
                    </div>
                </div>

                <div class="ss-chat-actions ss-chat-actions--choices">
                    @if (chatView == "welcome")
                    {
                        <button type="button" @onclick='() => Nav.NavigateTo("/assessments")'>📋 @L["chatbot.action.assess"]</button>
                        <button type="button" @onclick='() => Nav.NavigateTo("/roadmap")'>🎯 @L["chatbot.action.roadmap"]</button>
                        <button type="button" @onclick='() => chatView = "mentor"'>👥 @L["chatbot.action.mentor"]</button>
                        <button type="button" @onclick='() => Nav.NavigateTo("/progress")'>📈 @L["chatbot.action.progress"]</button>
                        <button type="button" @onclick='() => chatView = "premium"'>💎 Premium</button>
                        <button type="button" @onclick='() => chatView = "about"'>ℹ️ @L["chatbot.action.about"]</button>
                    }
                    else if (chatView == "about")
                    {
                        <button type="button" @onclick='() => chatView = "how"'>🚀 @L["chatbot.action.how"]</button>
                        <button type="button" @onclick='() => chatView = "mentor"'>👥 Mentor</button>
                        <button type="button" @onclick='() => Nav.NavigateTo("/case-studies")'>🎮 @L["chatbot.action.cases"]</button>
                        <button type="button" class="secondary" @onclick='() => chatView = "welcome"'>← @L["chatbot.action.back"]</button>
                    }
                    else if (chatView == "premium")
                    {
                        <button type="button" @onclick='() => Nav.NavigateTo("/settings")'>💎 @L["chatbot.action.upgrade"]</button>
                        <button type="button" class="secondary" @onclick='() => Nav.NavigateTo("/assistant")'>❓ @L["chatbot.action.askMore"]</button>
                        <button type="button" class="secondary" @onclick='() => chatView = "welcome"'>← @L["chatbot.action.back"]</button>
                    }
                    else
                    {
                        <button type="button" @onclick='() => Nav.NavigateTo(chatView == "mentor" ? "/community" : "/assessments")'>@L["chatbot.action.continue"]</button>
                        <button type="button" class="secondary" @onclick='() => chatView = "welcome"'>← @L["chatbot.action.back"]</button>
                    }
                </div>
            </div>
        }
        else
        {
            <button type="button" class="ss-chat-fab" title="Mở SoftSync AI" @onclick="() => chatbotOpen = true">
                <img src="/images/syncy-fish.png" alt="" />
                <span class="ss-chat-pulse"></span>
            </button>
        }
    </aside>
</section>

<style>
    .ss-navbar {
        background: rgba(5, 8, 30, 0.82) !important;
        border-bottom-color: rgba(148, 163, 184, 0.08) !important;
        box-shadow: 0 18px 50px rgba(2, 6, 23, 0.22);
    }
    .ss-navbar .ss-gradient-text {
        background: none;
        -webkit-text-fill-color: #fff;
        color: #fff;
    }
    .ss-navbar .ss-navpill { color: rgba(226, 232, 240, 0.9); }
    .ss-navbar .ss-navpill:hover,
    .ss-navbar .ss-navpill.active {
        color: #fff;
        background: rgba(124, 58, 237, 0.34);
    }
    .ss-navbar .ss-icon-btn {
        color: #e2e8f0;
        background: rgba(255, 255, 255, 0.06);
    }
    .ss-navbar .ss-icon-btn:hover { background: rgba(124, 58, 237, 0.22); color: #fff; }
    .ss-navbar .ss-userchip { color: #fff; }

    .ss-landing {
        --ss-home-text: #f8fafc;
        --ss-home-muted: rgba(226, 232, 240, 0.86);
        --ss-home-soft: rgba(226, 232, 240, 0.74);
        --ss-home-surface: rgba(30, 41, 82, 0.66);
        --ss-home-surface-strong: rgba(10, 16, 45, 0.52);
        --ss-home-border: rgba(255, 255, 255, 0.16);
        --ss-home-shadow: rgba(2, 6, 23, 0.28);
        color: var(--ss-home-text);
        padding: clamp(2.5rem, 5vw, 5rem) clamp(1rem, 4vw, 4.5rem) 2.5rem;
        min-height: calc(100vh - 72px);
        overflow: hidden;
    }
    .ss-landing::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -8;
        background:
            radial-gradient(circle at 74% 12%, rgba(236, 72, 153, 0.22), transparent 30rem),
            radial-gradient(circle at 52% 18%, rgba(139, 92, 246, 0.2), transparent 34rem),
            linear-gradient(180deg, rgba(3, 7, 18, 0.28), rgba(3, 7, 18, 0.9)),
            url('/images/background-softsync.png');
        background-size: auto, auto, auto, cover;
        background-position: center;
        pointer-events: none;
    }

    html[data-theme="light"] .ss-navbar {
        background: rgba(245, 241, 255, 0.78) !important;
        border-bottom-color: rgba(124, 58, 237, 0.14) !important;
        box-shadow: 0 18px 48px rgba(99, 102, 241, 0.12);
    }
    html[data-theme="light"] .ss-navbar .ss-gradient-text {
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: var(--color-brand);
    }
    html[data-theme="light"] .ss-navbar .ss-navpill { color: #475569; }
    html[data-theme="light"] .ss-navbar .ss-navpill:hover,
    html[data-theme="light"] .ss-navbar .ss-navpill.active {
        color: var(--color-brand-dark);
        background: rgba(99, 102, 241, 0.12);
    }
    html[data-theme="light"] .ss-navbar .ss-icon-btn {
        color: #475569;
        background: rgba(255, 255, 255, 0.62);
    }
    html[data-theme="light"] .ss-navbar .ss-icon-btn:hover {
        color: var(--color-brand-dark);
        background: rgba(255, 255, 255, 0.86);
    }
    html[data-theme="light"] .ss-navbar .ss-userchip { color: #1e293b; }

    html[data-theme="light"] .ss-landing {
        --ss-home-text: #172033;
        --ss-home-muted: rgba(51, 65, 85, 0.82);
        --ss-home-soft: rgba(71, 85, 105, 0.72);
        --ss-home-surface: rgba(255, 255, 255, 0.5);
        --ss-home-surface-strong: rgba(255, 255, 255, 0.62);
        --ss-home-border: rgba(124, 58, 237, 0.16);
        --ss-home-shadow: rgba(99, 102, 241, 0.16);
    }
    html[data-theme="light"] .ss-landing::before {
        background:
            radial-gradient(circle at 18% 10%, rgba(96, 165, 250, 0.34), transparent 31rem),
            radial-gradient(circle at 80% 8%, rgba(236, 72, 153, 0.22), transparent 28rem),
            radial-gradient(circle at 62% 42%, rgba(167, 139, 250, 0.26), transparent 34rem),
            linear-gradient(135deg, rgba(248, 250, 252, 0.88), rgba(237, 233, 254, 0.76) 44%, rgba(255, 228, 245, 0.68)),
            url('/images/background-softsync.png');
        background-size: auto, auto, auto, auto, cover;
        background-position: center;
    }
    html[data-theme="light"] .ss-eyebrow {
        background: rgba(255, 255, 255, 0.6);
    }

    .ss-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.35fr);
        align-items: center;
        gap: clamp(2rem, 5vw, 5rem);
        max-width: 1360px;
        margin: 0 auto;
    }
    .ss-hero-copy { max-width: 520px; }
    .ss-eyebrow {
        display: inline-flex;
        padding: 0.45rem 0.85rem;
        border: 1px solid var(--ss-home-border);
        border-radius: 999px;
        background: rgba(30, 41, 82, 0.52);
        font-size: 0.85rem;
        margin-bottom: 1.4rem;
    }
    .ss-hero-copy h1 {
        font-size: clamp(3rem, 5vw, 4.75rem);
        line-height: 1.08;
        font-weight: 850;
        letter-spacing: 0;
        margin: 0 0 1.4rem;
    }
    .ss-hero-copy h1 span {
        color: #6ea8ff;
        text-shadow: 0 0 30px rgba(99, 102, 241, 0.55);
    }
    .ss-hero-copy p {
        color: var(--ss-home-muted);
        font-size: 1.08rem;
        line-height: 1.75;
        margin-bottom: 2rem;
    }
    .ss-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .ss-primary-cta,
    .ss-secondary-cta,
    .ss-panel-head button {
        height: 52px;
        border-radius: 14px;
        border: 1px solid rgba(139, 92, 246, 0.55);
        color: #fff;
        padding: 0 1.45rem;
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        font-weight: 750;
    }
    .ss-primary-cta {
        border: none;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        box-shadow: 0 18px 42px rgba(59, 130, 246, 0.28);
    }
    .ss-secondary-cta,
    .ss-panel-head button {
        background: rgba(10, 16, 45, 0.43);
        backdrop-filter: blur(18px);
    }
    html[data-theme="light"] .ss-secondary-cta {
        color: #312e81;
        background: rgba(255, 255, 255, 0.68);
        border-color: rgba(99, 102, 241, 0.36);
        box-shadow: 0 14px 34px rgba(99, 102, 241, 0.14);
    }

    .ss-orbit-stage {
        min-height: 470px;
        position: relative;
    }
    .ss-galaxy-core {
        position: absolute;
        right: 7%;
        top: 23%;
        width: min(38vw, 500px);
        aspect-ratio: 1.65;
