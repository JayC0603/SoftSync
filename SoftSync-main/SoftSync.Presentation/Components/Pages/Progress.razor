 background:radial-gradient(130% 105% at 0 0,rgba(255,255,255,.92),transparent 45%),radial-gradient(85% 95% at 100% 100%,rgba(167,139,250,.2),transparent 58%),linear-gradient(145deg,var(--liquid-surface-strong),var(--liquid-surface))!important;
 border:1px solid var(--liquid-edge)!important;
