@page "/progress"
@page "/progress/{UserId:int}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IProgressService ProgressService

<div class="max-800 mx-auto">
    <div class="ss-page-heading tw:mb-12">
        <h2 class="tw:font-bold tw:mb-1">@L["progress.title.prefix"] <span class="ss-gradient-text">@L["progress.title.highlight"]</span></h2>
        <p class="text-muted">@L["progress.subtitle"]</p>
    </div>

    @if (progressLogs == null)
    {
        <div class="tw:text-center tw:py-12">@L["progress.loading"]</div>
    }
    else if (!progressLogs.Any())
    {
        <div class="ss-card tw:p-12 tw:text-center">
            <i class="bi bi-lightning-charge tw:text-4xl text-muted tw:mb-4"></i>
            <h4>@L["progress.empty.title"]</h4>
            <p class="text-muted">@L["progress.empty.description"]</p>
            <a href="/" class="btn btn-primary tw:mt-4">@L["progress.empty.cta"]</a>
        </div>
    }
    else
    {
        <div class="tw:grid tw:grid-cols-1 tw:gap-6">
            @foreach (var p in progressLogs)
            {
                <div>
                    <div class="ss-card ss-glass-interactive tw:p-6">
                        <div class="tw:flex tw:justify-between tw:items-center tw:mb-4">
                            <h5 class="tw:font-bold tw:mb-0">@p.SkillName</h5>
                            <span class="tw:font-bold ss-gradient-text tw:text-2xl">@p.PercentComplete%</span>
                        </div>
                        <div class="progress" style="height: 20px; border-radius: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 style="width: @p.PercentComplete%; background: var(--gradient);"></div>
                        </div>
                        <div class="tw:mt-4 tw:text-sm text-muted">
                            @L["progress.lastActive"] @p.UpdatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = default!;
    private IEnumerable<ProgressDto>? progressLogs;

    protected override async Task OnInitializedAsync()
    {
        // Fall back to the signed-in user when no id is supplied via the route.
        if (UserId == 0) UserId = await AuthProvider.GetUserIdAsync();
        progressLogs = await ProgressService.GetUserProgressAsync(UserId);
    }
}

<style>
    .max-800 { max-width: 800px; }
    .ss-page-heading h2 {
        color: #111827;
        text-shadow: 0 1px 18px rgba(255,255,255,0.75);
    }
    .ss-page-heading .ss-gradient-text {
        background: none;
        -webkit-text-fill-color: #4f46e5;
        color: #4f46e5;
        text-shadow: 0 1px 18px rgba(255,255,255,0.78);
    }
    .ss-page-heading .text-muted {
        color: #4b5563 !important;
        font-weight: 600;
        text-shadow: 0 1px 14px rgba(255,255,255,0.82);
    }
    html[data-theme="dark"] .ss-page-heading h2 {
        color: #f8fafc;
        text-shadow: 0 2px 16px rgba(0,0,0,0.5);
    }
    html[data-theme="dark"] .ss-page-heading .ss-gradient-text {
        -webkit-text-fill-color: #a78bfa;
        color: #a78bfa;
        text-shadow: 0 2px 18px rgba(0,0,0,0.55);
    }
    html[data-theme="dark"] .ss-page-heading .text-muted {
        color: #cbd5e1 !important;
        text-shadow: 0 2px 16px rgba(0,0,0,0.55);
    }
</style>
