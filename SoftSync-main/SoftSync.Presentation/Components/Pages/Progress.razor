@page "/progress"
@page "/progress/{UserId:int}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject IUserService UserService
@inject NavigationManager Nav

<div class="pg-shell">
    <aside class="pg-side">
        <div class="pg-user"><img src="@(user?.AvatarUrl?.Length > 0 ? user.AvatarUrl : "/images/syncy-fish.png")" alt=""/><div><b>@(user?.PublicName ?? "SoftSync Learner")</b><span>@Tx("Level", "Cấp") @(user?.Level ?? 1) · @(user?.ExperiencePoints ?? 0) XP</span></div></div>
        <div class="pg-label">@Tx("LEARNING PROGRESS", "TIẾN ĐỘ HỌC TẬP")</div>
        <nav>
            <button class="active"><i class="bi bi-bar-chart-fill"></i>@Tx("Overview", "Tổng quan")</button>
            <button><i class="bi bi-bullseye"></i>@Tx("Skills", "Kỹ năng")</button>
            <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-map"></i>@Tx("Roadmap", "Lộ trình")</button>
            <button><i class="bi bi-pie-chart"></i>@Tx("Statistics", "Thống kê")</button>
            <button><i class="bi bi-trophy"></i>@Tx("Achievements", "Thành tích")</button>
            <button><i class="bi bi-briefcase"></i>@Tx("AI Report", "Báo cáo AI")<small>@Tx("New", "Mới")</small></button>
        </nav>
        <div class="pg-nova"><img src="/images/syncy-fish.png" alt="Nova"/><div><b>Nova AI</b><p>@Tx("Always by your side to help you improve every day!", "Luôn đồng hành và giúp bạn tiến bộ mỗi ngày!")</p></div></div>
    </aside>

    <main class="pg-main">
        <header class="pg-head"><div><h1>@Tx("Progress overview", "Tổng quan tiến độ")</h1><p>@Tx("Track and understand your learning journey", "Cập nhật hành trình học tập của bạn")</p></div><button><i class="bi bi-calendar3"></i> 17/07/2025 - 23/07/2025 <i class="bi bi-chevron-down"></i></button></header>

        <section class="pg-kpis">
            <article><div class="pg-donut" style="--p:@Overall"><b>@Overall%</b></div><div><strong>@Tx("Overall progress", "Tiến độ tổng thể")</strong><p>@Tx("Completed", "Hoàn thành") @CompletedRoadmap / @TotalRoadmap @Tx("lessons", "bài học")</p></div></article>
            <article><i class="bi bi-stars violet"></i><div><strong>@Tx("Level", "Cấp độ")</strong><b class="big">@(user?.Level ?? 1)</b><p>@Tx("Keep learning to level up", "Tiếp tục học để lên cấp")</p></div></article>
            <article><i class="bi bi-star-fill violet"></i><div><strong>@Tx("Current XP", "XP hiện tại")</strong><b class="big">@((user?.ExperiencePoints ?? 0).ToString("N0"))</b><em>+320 XP @Tx("this week", "tuần này")</em></div></article>
            <article><i class="bi bi-fire orange"></i><div><strong>@Tx("Learning streak", "Ngày học liên tiếp")</strong><b class="big">15</b><em>🔥 @Tx("Amazing streak!", "Chuỗi ngày tuyệt vời!")</em></div></article>
            <article><i class="bi bi-clock violet"></i><div><strong>@Tx("Study time this week", "Thời gian học tuần này")</strong><b class="big">3h 42m</b><em>+1h 15m @Tx("vs last week", "so với tuần trước")</em></div></article>
        </section>

        <div class="pg-grid">
            <section class="pg-card pg-analysis"><header><h2>@Tx("Skill analysis", "Phân tích kỹ năng")</h2><a>@Tx("View details", "Xem chi tiết")</a></header><div class="pg-analysis-body"><div class="pg-radar"><div class="web w1"></div><div class="web w2"></div><div class="web w3"></div><div class="shape"></div><span class="n">@Tx("Communication", "Giao tiếp")<b>85%</b></span><span class="e">@Tx("Leadership", "Lãnh đạo")<b>48%</b></span><span class="se">@Tx("Presentation", "Thuyết trình")<b>32%</b></span><span class="sw">@Tx("Critical thinking", "Tư duy phản biện")<b>66%</b></span><span class="w">@Tx("Time management", "Quản lý thời gian")<b>70%</b></span></div><aside><h3>🤖 @Tx("AI feedback", "AI nhận xét")</h3><b class="good">• @Tx("Strengths", "Điểm mạnh")</b><p>✓ @Tx("Active listening", "Lắng nghe chủ động")<br/>✓ @Tx("Teamwork", "Giao tiếp nhóm")</p><b class="bad">• @Tx("Needs improvement", "Điểm cần cải thiện")</b><p>• @Tx("Public speaking", "Thuyết trình trước đám đông")<br/>• @Tx("Negotiation", "Kỹ năng đàm phán")</p><div>✨ <b>@Tx("Nova suggests", "Gợi ý từ Nova")</b><br/>@Tx("Practice presentation lessons to improve faster.", "Học thêm bài thuyết trình để cải thiện kỹ năng này.")</div></aside></div></section>

            <section class="pg-card pg-path"><header><h2>@Tx("Roadmap progress", "Tiến độ lộ trình")</h2><a @onclick='() => Nav.NavigateTo("/roadmap")'>@Tx("View all", "Xem tất cả")</a></header><h3>@Tx("Stage 1: Communication foundation", "Giai đoạn 1: Nền tảng giao tiếp") <span>@Overall%</span></h3><div class="pg-path-list">@foreach(var entry in roadmapItems.Take(5).Select((x,i)=>(x,i))){<button class="@(entry.x.IsCompleted?"done":entry.i==ActiveRoadmap?"current":"locked")"><i>@(entry.x.IsCompleted?"✓":(entry.i+1).ToString())</i><b>1.@(entry.i+1) @entry.x.Title</b><span>@(entry.x.IsCompleted?"100%":entry.i==ActiveRoadmap?"75%":"0%")</span><i class="bi bi-chevron-down"></i></button>}</div><footer>▣ Video　▣ @Tx("Theory", "Lý thuyết")　🔗 Quiz　🎮 Game</footer></section>

            <section class="pg-card pg-week"><header><h2>@Tx("This week's statistics", "Thống kê tuần này")</h2></header><div class="pg-mini"><span>◷<b>3h 42m</b><small>+1h 15m</small></span><span>▣<b>6</b><small>+2</small></span><span>✓<b>88%</b><small>+5%</small></span><span>🎮<b>920</b><small>+120</small></span><span>☵<b>18</b><small>+5</small></span></div><div class="pg-bars">@foreach(var h in new[]{55,75,52,47,62,78,66}){<i style="height:@h%"></i>}</div><div class="pg-days"><span>T2</span><span>T3</span><span>T4</span><span>T5</span><span>T6</span><span>T7</span><span>CN</span></div></section>

            <section class="pg-card pg-badges"><header><h2>@Tx("Featured achievements", "Thành tích nổi bật")</h2><a>@Tx("View all", "Xem tất cả")</a></header><div><article><i>⭐</i><b>7 Days Streak</b><p>@Tx("Learned 7 days in a row", "Học 7 ngày liên tiếp")</p></article><article><i>🎧</i><b>Active Listener</b><p>@Tx("Completed active listening", "Hoàn thành Lắng nghe chủ động")</p></article><article><i>🏆</i><b>Quiz Expert</b><p>@Tx("Scored 80%+ in 5 quizzes", "Đạt 80%+ trong 5 quiz")</p></article><article><i>🪶</i><b>Fast Learner</b><p>@Tx("Completed 10 lessons", "Hoàn thành 10 bài học")</p></article></div></section>
        </div>
    </main>
</div>

@code{
 [Parameter]public int UserId{get;set;} [Inject]AuthenticationStateProvider AuthProvider{get;set;}=default!; private UserDto? user;private List<ProgressDto> progressLogs=[];private List<RoadmapItemDto> roadmapItems=[];
 private int TotalRoadmap=>roadmapItems.Count;private int CompletedRoadmap=>roadmapItems.Count(x=>x.IsCompleted);private int Overall=>progressLogs.Count>0?(int)progressLogs.Average(x=>x.PercentComplete):(TotalRoadmap==0?0:CompletedRoadmap*100/TotalRoadmap);private int ActiveRoadmap=>Math.Max(0,roadmapItems.FindIndex(x=>!x.IsCompleted));
 protected override async Task OnInitializedAsync(){if(UserId==0)UserId=await AuthProvider.GetUserIdAsync();if(UserId>0)user=await UserService.GetUserByIdAsync(UserId);progressLogs=(await ProgressService.GetUserProgressAsync(UserId)).ToList();roadmapItems=(await RoadmapService.GetUserRoadmapAsync(UserId)).Items.OrderBy(x=>x.WeekNumber).ToList();}
 private string Tx(string en,string vi)=>L.Current==AppLanguage.Vi?vi:en;
}

<style>
.pg-shell,.pg-shell button{font-family:inherit}.pg-shell{display:grid;grid-template-columns:250px 1fr;max-width:1560px;min-height:calc(100vh - 72px);margin:auto;color:#17203b;background:linear-gradient(135deg,rgba(250,249,255,.62),rgba(239,238,255,.38))}.pg-side{display:flex;flex-direction:column;padding:28px 16px;border-right:1px solid rgba(140,130,200,.16)}.pg-user{display:flex;align-items:center;gap:12px;padding:0 12px 30px}.pg-user img{width:62px;height:62px;border-radius:50%;object-fit:cover}.pg-user div{display:flex;flex-direction:column}.pg-user span{font-size:12px;color:#718096}.pg-label{padding:14px 14px 8px;font-size:11px;font-weight:900}.pg-side nav{display:flex;flex-direction:column;gap:5px}.pg-side nav button{display:flex;align-items:center;gap:14px;padding:11px 15px;border:0;border-radius:9px;background:transparent;color:#48546a;text-align:left}.pg-side nav button.active{color:#6246e8;background:rgba(109,82,238,.1)}.pg-side nav small{margin-left:auto;color:#6246e8;border:1px solid #cdc6ff;border-radius:9px;padding:1px 5px}.pg-nova{position:relative;margin-top:auto;text-align:center}.pg-nova img{width:180px;height:145px;object-fit:contain}.pg-nova div{padding:18px;color:#fff;border-radius:18px;background:linear-gradient(135deg,#6c50ee,#8b72f8)}.pg-nova p{font-size:12px}.pg-main{padding:26px 38px}.pg-head{display:flex;align-items:center;justify-content:space-between}.pg-head h1{margin:0;font-size:23px}.pg-head p{margin:5px 0;color:#768196}.pg-head button{padding:11px 16px;border:1px solid #dedafa;border-radius:11px;background:rgba(255,255,255,.6)}.pg-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin:20px 0}.pg-kpis article,.pg-card{background:linear-gradient(145deg,var(--liquid-surface-strong),var(--liquid-surface));border:1px solid var(--liquid-edge);box-shadow:0 14px 38px var(--liquid-shadow),inset 1px 1px 0 rgba(255,255,255,.9);backdrop-filter:blur(24px) saturate(180%)}.pg-kpis article{min-height:120px;padding:16px;border-radius:16px;display:flex;align-items:center;gap:14px}.pg-kpis article>i{display:grid;place-items:center;width:42px;height:42px;border-radius:50%;background:#efeaff;font-size:20px}.pg-kpis strong,.pg-kpis b,.pg-kpis em{display:block}.pg-kpis strong{font-size:12px}.pg-kpis .big{font-size:25px;margin:7px 0}.pg-kpis p,.pg-kpis em{font-size:10px;color:#738096;font-style:normal}.pg-kpis em{color:#18a05e}.pg-kpis .orange{color:#ef6c35}.pg-kpis .violet{color:#6d4af0}.pg-donut{--p:0;width:76px;height:76px;flex:0 0 76px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(#6547ee calc(var(--p)*1%),#e9e6fb 0);position:relative}.pg-donut:after{content:"";position:absolute;inset:8px;background:#faf9ff;border-radius:50%}.pg-donut b{z-index:1;color:#6043e6;font-size:21px}.pg-grid{display:grid;grid-template-columns:1.08fr .92fr;gap:14px}.pg-card{border-radius:18px;padding:18px;min-width:0}.pg-card header{display:flex;justify-content:space-between;align-items:center}.pg-card h2{margin:0;font-size:15px}.pg-card a{color:#6246e8;font-size:11px;cursor:pointer}.pg-analysis-body{display:grid;grid-template-columns:1.25fr .75fr;gap:22px;align-items:center}.pg-radar{position:relative;width:270px;height:240px;margin:30px auto}.web,.shape{position:absolute;inset:30px;clip-path:polygon(50% 0,100% 38%,82% 100%,18% 100%,0 38%);border:1px solid #d9d7eb;background:rgba(109,75,238,.035)}.w2{inset:55px}.w3{inset:80px}.shape{inset:45px;background:rgba(102,72,235,.22);border:2px solid #6849ed}.pg-radar>span{position:absolute;font-size:10px;text-align:center;color:#64748b}.pg-radar span b{display:block;color:#5d43df}.pg-radar .n{top:0;left:105px}.pg-radar .e{right:-4px;top:82px}.pg-radar .se{right:22px;bottom:0}.pg-radar .sw{left:20px;bottom:0}.pg-radar .w{left:-12px;top:82px}.pg-analysis aside{padding:16px;border-radius:13px;background:rgba(245,243,255,.78);font-size:11px}.pg-analysis aside h3{font-size:12px;color:#5036d7}.pg-analysis aside .good{color:#149553}.pg-analysis aside .bad{color:#e56422}.pg-analysis aside div{padding:10px;border-radius:9px;background:#ebe7ff}.pg-path>h3{font-size:12px}.pg-path>h3 span{float:right;padding:3px 8px;border-radius:10px;color:#fff;background:#6547ee}.pg-path-list{display:flex;flex-direction:column;gap:5px}.pg-path-list button{display:grid;grid-template-columns:26px 1fr auto 20px;align-items:center;gap:10px;padding:8px;border:1px solid #eceaf6;border-radius:9px;background:rgba(255,255,255,.58);text-align:left;color:#64748b}.pg-path-list button>i:first-child{display:grid;place-items:center;width:22px;height:22px;border-radius:50%;background:#eeeef5;font-style:normal}.pg-path-list button.done>i:first-child{color:#fff;background:#39aa6a}.pg-path-list button.current{color:#5b42df;border-color:#d8d0ff;background:#f3f0ff}.pg-path-list button.current>i:first-child{color:#fff;background:#6547ee}.pg-path-list b{font-size:11px}.pg-path footer{padding-top:12px;font-size:10px;color:#64748b}.pg-mini{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;margin:18px 0}.pg-mini span{display:flex;flex-direction:column;align-items:center;gap:3px;padding:9px;border-radius:10px;background:rgba(247,245,255,.8);font-size:10px}.pg-mini b{font-size:14px}.pg-mini small{color:#13a05c}.pg-bars{height:90px;display:flex;align-items:end;justify-content:space-around;border-bottom:1px solid #e3e1ee;background:repeating-linear-gradient(to top,transparent 0,transparent 29px,#eeedf5 30px)}.pg-bars i{width:18px;background:linear-gradient(#8064f4,#6547e7)}.pg-days{display:flex;justify-content:space-around;font-size:10px;color:#728096}.pg-badges>div{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:18px}.pg-badges article{text-align:center}.pg-badges article i{display:grid;place-items:center;width:70px;height:70px;margin:auto;border:5px double #7253ea;border-radius:28px;background:#ede9ff;font-style:normal;font-size:30px}.pg-badges article:nth-child(2) i{border-color:#35a868}.pg-badges article:nth-child(3) i{border-color:#ee8c25}.pg-badges article:nth-child(4) i{border-color:#4770d8}.pg-badges b{display:block;margin-top:10px;font-size:11px}.pg-badges p{font-size:9px;color:#728096}.pg-week,.pg-badges{min-height:230px}@@media(max-width:1200px){.pg-kpis{grid-template-columns:repeat(3,1fr)}.pg-grid{grid-template-columns:1fr}.pg-side{display:none}.pg-shell{grid-template-columns:1fr}}@@media(max-width:700px){.pg-main{padding:18px 12px}.pg-head{display:block}.pg-head button{margin-top:12px}.pg-kpis{grid-template-columns:1fr}.pg-analysis-body{grid-template-columns:1fr}.pg-radar{transform:scale(.82);margin:0 auto}.pg-mini,.pg-badges>div{grid-template-columns:repeat(2,1fr)}}
</style>
