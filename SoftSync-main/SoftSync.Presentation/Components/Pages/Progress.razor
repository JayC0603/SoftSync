@page "/progress"
@page "/progress/{UserId:int}"
@rendermode InteractiveServer
@attribute [StreamRendering]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IProgressService ProgressService
@inject IRoadmapService RoadmapService
@inject IUserService UserService
@inject NavigationManager Nav

<div class="pg-shell">
    <aside class="pg-side">
        <div class="pg-user"><img src="@(user?.AvatarUrl?.Length > 0 ? user.AvatarUrl : "/images/syncy-fish.png")" alt=""/><div><b>@(user?.PublicName ?? "SoftSync Learner")</b><span>@Tx("Level", "Cấp") @(user?.Level ?? 1) · @(user?.ExperiencePoints ?? 0) XP</span></div></div>
        <div class="pg-label">@Tx("LEARNING PROGRESS", "TIẾN ĐỘ HỌC TẬP")</div>
        <nav>
            <button class="active"><i class="bi bi-bar-chart-fill"></i>@Tx("Overview", "Tổng quan")</button>
            <button @onclick='() => Nav.NavigateTo("/assessment/" + UserId)'><i class="bi bi-bullseye"></i>@Tx("Skills", "Kỹ năng")</button>
            <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-map"></i>@Tx("Roadmap", "Lộ trình")</button>
            <button @onclick='ScrollToStatistics'><i class="bi bi-pie-chart"></i>@Tx("Statistics", "Thống kê")</button>
            <button @onclick='ScrollToAchievements'><i class="bi bi-trophy"></i>@Tx("Achievements", "Thành tích")</button>
            <button @onclick='() => Nav.NavigateTo("/assistant")'><i class="bi bi-briefcase"></i>@Tx("AI Report", "Báo cáo AI")</button>
        </nav>
        <div class="pg-nova"><img src="/images/syncy-fish.png" alt="Nova"/><div><b>Nova AI</b><p>@Tx("Always by your side to help you improve every day!", "Luôn đồng hành và giúp bạn tiến bộ mỗi ngày!")</p></div></div>
    </aside>

    <main class="pg-main">
        <header class="pg-head"><div><h1>@Tx("Progress overview", "Tổng quan tiến độ")</h1><p>@Tx("Track and understand your learning journey", "Cập nhật hành trình học tập của bạn")</p></div><button><i class="bi bi-calendar3"></i> @DateRange <i class="bi bi-chevron-down"></i></button></header>

        <section class="pg-kpis">
            <article><div class="pg-donut" style="--p:@Overall"><b>@Overall%</b></div><div><strong>@Tx("Overall progress", "Tiến độ tổng thể")</strong><p>@Tx("Completed", "Hoàn thành") @CompletedRoadmap / @TotalRoadmap @Tx("lessons", "bài học")</p></div></article>
            <article><i class="bi bi-stars violet"></i><div><strong>@Tx("Level", "Cấp độ")</strong><b class="big">@(user?.Level ?? 1)</b><p>@Tx("Keep learning to level up", "Tiếp tục học để lên cấp")</p></div></article>
            <article><i class="bi bi-star-fill violet"></i><div><strong>@Tx("Current XP", "XP hiện tại")</strong><b class="big">@((user?.ExperiencePoints ?? 0).ToString("N0"))</b><em>@Tx("Saved from your learning activity", "Được lưu từ hoạt động học tập")</em></div></article>
            <article><i class="bi bi-fire orange"></i><div><strong>@Tx("Learning streak", "Ngày học liên tiếp")</strong><b class="big">@ActiveDays</b><em>@Tx("active days recorded", "ngày có hoạt động được ghi nhận")</em></div></article>
            <article><i class="bi bi-clock violet"></i><div><strong>@Tx("Study time this week", "Thời gian học tuần này")</strong><b class="big">@UpdatedThisWeek</b><em>@Tx("skills updated this week", "kỹ năng cập nhật tuần này")</em></div></article>
        </section>

        <div class="pg-grid">
            <section class="pg-card pg-analysis"><header><h2>@Tx("Skill analysis", "Phân tích kỹ năng")</h2><a @onclick='() => Nav.NavigateTo("/roadmap")'>@Tx("Open roadmap", "Mở lộ trình")</a></header><div class="pg-track-progress">@foreach(var track in Tracks){var percent=TrackProgress(track);<article><i class="bi @track.Icon"></i><div><span><b>@TrackName(track)</b><strong>@percent%</strong></span><p>@TrackSummary(track)</p><div class="track-meter"><i style="width:@percent%"></i></div><small>@EstimatedCompleted(track) / @track.Modules.Count @Tx("activities completed", "hoạt động hoàn thành")</small></div></article>}</div></section>

            <section class="pg-card pg-path"><header><h2>@Tx("Complete roadmap catalog", "Danh mục lộ trình đầy đủ")</h2><a @onclick='() => Nav.NavigateTo("/roadmap")'>@Tx("View all", "Xem tất cả")</a></header><div class="pg-track-tabs">@foreach(var entry in Tracks.Select((x,i)=>(x,i))){<button class="@(selectedTrack==entry.i?"active":"")" @onclick="()=>selectedTrack=entry.i"><i class="bi @entry.x.Icon"></i><span>@TrackName(entry.x)<small>@entry.x.Modules.Count @Tx("activities", "hoạt động")</small></span></button>}</div><h3>@TrackName(CurrentTrack) <span>@TrackProgress(CurrentTrack)%</span></h3><div class="pg-path-list">@foreach(var entry in CurrentTrack.Modules.Select((x,i)=>(x,i))){var state=ModuleState(CurrentTrack,entry.i);<button class="@state" @onclick="()=>Nav.NavigateTo(entry.x.Route)"><i>@(state=="done"?"✓":(entry.i+1).ToString())</i><b>@ModuleType(entry.x.Type) · @ModuleName(entry.x)</b><span>@(state=="done"?"100%":state=="current"?Tx("Continue","Tiếp tục"):Tx("Not started","Chưa học"))</span><i class="bi bi-chevron-right"></i></button>}</div><footer>▣ Video　▣ @Tx("Theory", "Lý thuyết")　🔗 Quiz　🎮 Game</footer></section>

            <section class="pg-card pg-week" id="progress-statistics"><header><h2>@Tx("Current learning statistics", "Thống kê học tập hiện tại")</h2></header><div class="pg-mini"><span><i class="bi bi-check-circle"></i><b>@CompletedRoadmap</b><small>@Tx("completed lessons", "bài đã hoàn thành")</small></span><span><i class="bi bi-list-task"></i><b>@TotalRoadmap</b><small>@Tx("roadmap lessons", "bài trong lộ trình")</small></span><span><i class="bi bi-graph-up"></i><b>@Overall%</b><small>@Tx("average progress", "tiến độ trung bình")</small></span><span><i class="bi bi-activity"></i><b>@UpdatedThisWeek</b><small>@Tx("updated this week", "cập nhật tuần này")</small></span><span><i class="bi bi-stars"></i><b>@(user?.ExperiencePoints ?? 0)</b><small>XP</small></span></div>@if(progressLogs.Count==0){<p class="pg-no-data">@Tx("No progress has been recorded yet. Start a roadmap lesson to see statistics here.", "Chưa có tiến độ được ghi nhận. Hãy bắt đầu một bài trong lộ trình để xem thống kê tại đây.")</p>}else{<div class="skill-progress-grid">@foreach(var item in progressLogs){<article><div><strong>@item.SkillName</strong><b>@item.PercentComplete%</b></div><span><i style="width:@item.PercentComplete%"></i></span><small>@Tx("Updated", "Cập nhật") @item.UpdatedAt.ToString("dd/MM/yyyy")</small></article>}</div>}</section>

            <section class="pg-card pg-badges" id="progress-achievements"><header><h2>@Tx("Earned achievements", "Thành tích đã đạt")</h2></header><div>@if(CompletedRoadmap>=1){<article><i>⭐</i><b>@Tx("First Step", "Bước đầu tiên")</b><p>@Tx("Completed the first lesson", "Hoàn thành bài học đầu tiên")</p></article>}@if(CompletedRoadmap>=5){<article><i>🎧</i><b>@Tx("Committed Learner", "Người học chăm chỉ")</b><p>@Tx("Completed 5 lessons", "Hoàn thành 5 bài học")</p></article>}@if(Overall>=80){<article><i>🏆</i><b>@Tx("Progress Master", "Bậc thầy tiến độ")</b><p>@Tx("Reached 80% overall progress", "Đạt 80% tiến độ tổng thể")</p></article>}@if((user?.ExperiencePoints??0)>=1000){<article><i>🪶</i><b>XP 1000</b><p>@Tx("Earned 1,000 experience points", "Đạt 1.000 điểm kinh nghiệm")</p></article>}@if(CompletedRoadmap==0&&Overall<80&&(user?.ExperiencePoints??0)<1000){<p class="pg-no-data">@Tx("Complete lessons to unlock achievements.", "Hoàn thành bài học để mở khóa thành tích.")</p>}</div></section>
        </div>
    </main>
</div>

@code{
 [Parameter]public int UserId{get;set;} [Inject]AuthenticationStateProvider AuthProvider{get;set;}=default!; private UserDto? user;private List<ProgressDto> progressLogs=[];private List<RoadmapItemDto> roadmapItems=[];private int selectedTrack;
 private int TotalRoadmap=>Tracks.Sum(x=>x.Modules.Count);private int CompletedRoadmap=>Tracks.Sum(EstimatedCompleted);private int Overall=>progressLogs.Count>0?(int)progressLogs.Average(x=>x.PercentComplete):(roadmapItems.Count==0?0:roadmapItems.Count(x=>x.IsCompleted)*100/roadmapItems.Count);private LearningTrack CurrentTrack=>Tracks[selectedTrack];
 private int ActiveDays=>progressLogs.Select(x=>x.UpdatedAt.Date).Distinct().Count();
 private int UpdatedThisWeek=>progressLogs.Count(x=>x.UpdatedAt>=DateTime.Today.AddDays(-6));
 private string DateRange=>$"{DateTime.Today.AddDays(-6):dd/MM/yyyy} - {DateTime.Today:dd/MM/yyyy}";
 private int ProgressAt(int index)=>index<progressLogs.Count?progressLogs[index].PercentComplete:0;
 private string SkillNameAt(int index)=>index<progressLogs.Count?progressLogs[index].SkillName:Tx("No data","Chưa có dữ liệu");
 private ProgressDto TopSkill=>progressLogs.OrderByDescending(x=>x.PercentComplete).First();
 private ProgressDto NeedsSkill=>progressLogs.OrderBy(x=>x.PercentComplete).First();
 private int TrackProgress(LearningTrack track){var keys=track.Keys;var matches=progressLogs.Where(x=>keys.Any(k=>x.SkillName.Contains(k,StringComparison.OrdinalIgnoreCase))).ToList();return matches.Count>0?(int)matches.Average(x=>x.PercentComplete):0;}
 private int EstimatedCompleted(LearningTrack track)=>(int)Math.Round(track.Modules.Count*TrackProgress(track)/100d);
 private string ModuleState(LearningTrack track,int index){var completed=EstimatedCompleted(track);return index<completed?"done":index==completed?"current":"locked";}
 private string TrackName(LearningTrack x)=>Tx(x.NameEn,x.NameVi);private string TrackSummary(LearningTrack x)=>Tx(x.SummaryEn,x.SummaryVi);private string ModuleName(LearningModule x)=>Tx(x.NameEn,x.NameVi);private string ModuleType(string type)=>type switch{"Video"=>"Video","Quiz"=>"Quiz","Lesson"=>Tx("Lesson","Bài học"),_=>Tx("Game","Trò chơi")};
 protected override async Task OnInitializedAsync(){if(UserId==0)UserId=await AuthProvider.GetUserIdAsync();if(UserId>0)user=await UserService.GetUserByIdAsync(UserId);progressLogs=(await ProgressService.GetUserProgressAsync(UserId)).ToList();roadmapItems=(await RoadmapService.GetUserRoadmapAsync(UserId)).Items.OrderBy(x=>x.WeekNumber).ToList();}
 private void ScrollToStatistics()=>Nav.NavigateTo("/progress#progress-statistics");
 private void ScrollToAchievements()=>Nav.NavigateTo("/progress#progress-achievements");
 private string Tx(string en,string vi)=>L.Current==AppLanguage.Vi?vi:en;
 private sealed record LearningModule(string Type,string NameEn,string NameVi,string Route);
 private sealed record LearningTrack(string NameEn,string NameVi,string Icon,string SummaryEn,string SummaryVi,string[] Keys,List<LearningModule> Modules);
 private static readonly List<LearningTrack> Tracks =
 [
  new("Communication", "Giao tiếp", "bi-chat-dots", "Build confident communication through listening, feedback and practice.", "Rèn luyện giao tiếp tự tin qua lắng nghe, phản hồi và thực hành.", ["communication", "giao tiếp"],
  [
   new("Video", "Communication foundations", "Nền tảng giao tiếp", "/roadmap"),
   new("Lesson", "Active listening", "Lắng nghe chủ động", "/roadmap"),
   new("Quiz", "Communication situations", "Tình huống giao tiếp", "/roadmap")
  ]),
  new("Time management", "Quản lý thời gian", "bi-clock-history", "Plan priorities and build a sustainable study rhythm.", "Lập kế hoạch ưu tiên và xây dựng nhịp học bền vững.", ["time", "thời gian"],
  [
   new("Video", "Time management foundations", "Nền tảng quản lý thời gian", "/roadmap"),
   new("Game", "Eisenhower Matrix", "Ma trận Eisenhower", "/roadmap"),
   new("Quiz", "Priority challenge", "Thử thách ưu tiên", "/roadmap")
  ]),
  new("Critical thinking", "Tư duy phản biện", "bi-lightbulb", "Analyze information, arguments and decisions more clearly.", "Phân tích thông tin, lập luận và quyết định rõ ràng hơn.", ["critical", "phản biện"],
  [
   new("Video", "Thinking foundations", "Nền tảng tư duy", "/roadmap"),
   new("Lesson", "Argument mapping", "Bản đồ lập luận", "/roadmap"),
   new("Quiz", "Reasoning challenge", "Thử thách lập luận", "/roadmap")
  ])
 ];
}

<style>
.pg-shell{position:relative;isolation:isolate;background:linear-gradient(135deg,rgba(248,247,255,.42),rgba(235,238,255,.24))!important}
.pg-shell:before{content:"";position:fixed;inset:72px 0 0;z-index:-1;pointer-events:none;background:radial-gradient(circle at 18% 18%,rgba(196,181,253,.3),transparent 27rem),radial-gradient(circle at 82% 65%,rgba(129,140,248,.22),transparent 30rem)}
