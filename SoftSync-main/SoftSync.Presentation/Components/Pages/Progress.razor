px;display:flex;align-items:center;gap:14px}.pg-kpis article>i{display:grid;place-items:center;width:42px;height:42px;border-radius:50%;background:#efeaff;font-size:20px}.pg-kpis strong,.pg-kpis b,.pg-kpis em{display:block}.pg-kpis strong{font-size:12px}.pg-kpis .big{font-size:25px;margin:7px 0}.pg-kpis p,.pg-kpis em{font-size:10px;color:#738096;font-style:normal}.pg-kpis em{color:#18a05e}.pg-kpis .orange{color:#ef6c35}.pg-kpis .violet{color:#6d4af0}.pg-donut{--p:0;width:76px;height:76px;flex:0 0 76px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(#6547ee calc(var(--p)*1%),#e9e6fb 0);position:relative}.pg-donut:after{content:"";position:absolute;inset:8px;background:#faf9ff;border-radius:50%}.pg-donut b{z-index:1;color:#6043e6;font-size:21px}.pg-grid{display:grid;grid-template-columns:1.08fr .92fr;gap:14px}.pg-card{border-radius:18px;padding:18px;min-width:0}.pg-card header{display:flex;justify-content:space-between;align-items:center}.pg-card h2{margin:0;font-size:15px}.pg-card a{color:#6246e8;font-size:11px;cursor:pointer}.pg-analysis-body{display:grid;grid-template-columns:1.25fr .75fr;gap:22px;align-items:center}.pg-radar{position:relative;width:270px;height:240px;margin:30px auto}.web,.shape{position:absolute;inset:30px;clip-path:polygon(50% 0,100% 38%,82% 100%,18% 100%,0 38%);border:1px solid #d9d7eb;background:rgba(109,75,238,.035)}.w2{inset:55px}.w3{inset:80px}.shape{inset:45px;background:rgba(102,72,235,.22);border:2px solid #6849ed}.pg-radar>span{position:absolute;font-size:10px;text-align:center;color:#64748b}.pg-radar span b{display:block;color:#5d43df}.pg-radar .n{top:0;left:105px}.pg-radar .e{right:-4px;top:82px}.pg-radar .se{right:22px;bottom:0}.pg-radar .sw{left:20px;bottom:0}.pg-radar .w{left:-12px;top:82px}.pg-analysis aside{padding:16px;border-radius:13px;background:rgba(245,243,255,.78);font-size:11px}.pg-analysis aside h3{font-size:12px;color:#5036d7}.pg-analysis aside .good{color:#149553}.pg-analysis aside .bad{colo