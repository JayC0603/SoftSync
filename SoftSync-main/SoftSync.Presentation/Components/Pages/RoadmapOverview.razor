    .roadmap-sidebar{padding:1.4rem;border-right:1px solid var(--line);background:#fbfcff}.overall-card,.xp-card,.streak{border:1px solid var(--line);border-radius:10px;background:#fff;box-shadow:0 4px 14px #21356508}.overall-card{padding:1rem}.overall-card h3{margin:0 0 .8rem;font-size:.75rem}.overall-body{display:flex;align-items:center;gap:.8rem}.progress-ring{display:grid;place-items:center;width:62px;height:62px;border-radius:50%;background:conic-gradient(var(--blue) calc(var(--value)*1%),#e9edf6 0);position:relative}.progress-ring:after{content:"";position:absolute;inset:7px;border-radius:50%;background:#fff}.progress-ring b{z-index:1;font-size:.9rem}.overall-body span,.overall-body strong{display:block}.overall-body span{font-size:.65rem;color:var(--muted)}.overall-body strong{margin-top:.25rem;font-size:.68rem}.xp-card{display:flex;align-items:center;gap:.55rem;margin-top:.65rem;padding:.8rem;font-size:.67rem}.xp-card>i{color:#ffb11b}.xp-card b{margin-left:auto}.sidebar-heading{margin:1.7rem 0 .7rem;color:#65718e;font-size:.62rem;letter-spacing:.04em}.skill-row{display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:.55rem;width:100%;padding:.65rem 0;border:0;background:transparent;color:var(--navy);text-align:left;font-size:.7rem}.skill-row small{font-size:.57rem;color:var(--muted)}.skill-icon{display:grid;place-items:center;width:28px;height:28px;color:#fff;border-radius:7px;background:linear-gradient(135deg,#2163ef,#6154e8)}.skill-group.skill-locked .skill-icon{background:#e5e9f3;color:#71809c}.week-tree{position:relative;margin-left:13px;padding-left:12px;border-left:2px solid #dce4f3}.tree-week{display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:.5rem;width:100%;padding:.58rem;border:0;border-radius:8px;background:transparent;text-align:left;color:var(--navy)}.tree-week>span{display:grid;place-items:center;width:21px;height:21px;margin-left:-24px;color:#607090;border-radius:50%;background:#e7ebf3;font-size:.