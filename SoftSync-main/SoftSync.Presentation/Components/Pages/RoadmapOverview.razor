@page "/roadmap"
@page "/roadmap/{UserId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@Tx("Your skill roadmap", "Lộ trình kỹ năng của bạn") · SoftSync</PageTitle>

<main class="rm-page">
    @if (loading)
    {
        <div class="rm-state"><span class="rm-spinner"></span>@Tx("Loading your roadmap...", "Đang tải lộ trình...")</div>
    }
    else if (items.Count == 0)
    {
        <div class="rm-state"><i class="bi bi-map"></i><h1>@Tx("Your roadmap is being prepared", "Lộ trình của bạn đang được chuẩn bị")</h1><button @onclick='() => Nav.NavigateTo($"/assessment/{UserId}")'>@Tx("Take assessment", "Làm bài đánh giá")</button></div>
    }
    else
    {
        <div class="rm-shell">
            <header class="rm-hero">
                <div>
                    <span>@Tx("PERSONAL LEARNING ROADMAP", "LỘ TRÌNH HỌC CÁ NHÂN")</span>
                    <h1>@Tx("Your skill roadmap", "Lộ trình kỹ năng của bạn")</h1>
                    <p>@Tx("Choose the current week and continue exactly where you stopped.", "Chọn tuần đang học và tiếp tục đúng vị trí bạn đã dừng lại.")</p>
                </div>
                <div class="rm-total">
                    <div><span>@Tx("Overall progress", "Tiến độ tổng thể")</span><b>@OverallPercent%</b></div>
                    <div class="rm-progress"><i style="width:@OverallPercent%"></i></div>
                    <small>@CompletedWeeks/@items.Count @Tx("weeks completed", "tuần hoàn thành")</small>
                </div>
            </header>

            @if (RoadmapReviewMode.Enabled)
            {
                <aside class="rm-review"><i class="bi bi-unlock-fill"></i><div><b>@Tx("Content review mode", "Chế độ kiểm tra nội dung")</b><small>@Tx("The old learning content was removed and is ready to be rebuilt.", "Nội dung học cũ đã được xóa và đang chờ nạp lại.")</small></div></aside>
            }

            <div class="rm-skills">
                @foreach (var group in SkillGroups)
                {
                    var key = group.Key;
                    var skillItems = group.ToList();
                    var skillCompleted = skillItems.Count(x => x.IsCompleted);
                    var skillPercent = skillItems.Count == 0 ? 0 : skillCompleted * 100 / skillItems.Count;
                    var skillLocked = IsSkillLocked(key);
                    <section class="rm-skill @(skillLocked ? "locked" : null)">
                        <header>
                            <div class="rm-skill-icon"><i class="@SkillIcon(key)"></i></div>
                            <div class="rm-skill-title"><span>@Tx("SKILL", "KỸ NĂNG") @(@SkillRank(key) + 1)</span><h2>@SkillName(key)</h2></div>
                            <div class="rm-skill-progress"><b>@skillCompleted/@skillItems.Count @Tx("weeks", "tuần") · @skillPercent%</b><div><i style="width:@skillPercent%"></i></div></div>
                            @if (skillLocked) { <i class="bi bi-lock-fill rm-skill-lock"></i> }
                        </header>

                        @if (!skillLocked || RoadmapReviewMode.Enabled)
                        {
                            <div class="rm-week-list">
                                @foreach (var item in skillItems)
                                {
                                    var globalIndex = items.IndexOf(item);
                                    var ordinal = WeekOrdinal(item);
                                    var unlocked = RoadmapReviewMode.Enabled || globalIndex <= ActiveIndex;
                                    var steps = CompletedSteps(item);
                                    <article class="rm-week @(item.IsCompleted ? "done" : globalIndex == ActiveIndex ? "current" : !unlocked ? "locked" : null)">
                                        <span class="rm-week-number">@(item.IsCompleted ? "✓" : ordinal)</span>
                                        <div class="rm-week-copy"><small>@Tx("WEEK", "TUẦN") @ordinal</small><h3>@WeekTitle(item, ordinal)</h3><p>@steps/6 @Tx("steps", "bước") · @EstimatedMinutes(item) @Tx("minutes", "phút")</p></div>
                                        <div class="rm-step-dots" aria-label="@steps/6">
                                            @for (var step = 1; step <= 6; step++) { <i class="@(step <= steps ? "filled" : null)"></i> }
                                        </div>
                                        @if (!unlocked)
                                        {
                                            <span class="rm-locked-label"><i class="bi bi-lock-fill"></i>@Tx("Locked", "Chưa mở")</span>
                                        }
                                        else
                                        {
                                            <button class="@(globalIndex == ActiveIndex && !item.IsCompleted ? "primary" : null)" @onclick="() => OpenWeek(item)">@(item.IsCompleted ? Tx("Review", "Xem lại") : steps > 0 ? Tx("Continue", "Tiếp tục") : Tx("Start", "Bắt đầu"))<i class="bi bi-arrow-right"></i></button>
                                        }
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rm-skill-gate"><i class="bi bi-lock-fill"></i><span>@Tx("Complete the previous skill to unlock this skill.", "Hoàn thành kỹ năng trước để mở kỹ năng này.")</span></div>
                        }
                    </section>
                }
            </div>

            <footer class="rm-rule"><i class="bi bi-shield-check"></i><div><b>@Tx("Learn in order, progress with confidence", "Học đúng thứ tự, tiến bộ vững chắc")</b><span>@Tx("Complete Reflection to finish a week. Complete every week to unlock the next skill.", "Hoàn thành Phản tư để kết thúc tuần. Hoàn thành tất cả tuần để mở kỹ năng tiếp theo.")</span></div></footer>
        </div>
    }
</main>

@code {
    [Parameter] public int UserId { get; set; }
    private List<RoadmapItemDto> items = [];
    private bool loading = true;
    private int CompletedWeeks => items.Count(x => x.IsCompleted);
    private int OverallPercent => items.Count == 0 ? 0 : CompletedWeeks * 100 / items.Count;
    private int ActiveIndex { get { var i = items.FindIndex(x => !x.IsCompleted); return i < 0 ? Math.Max(0, items.Count - 1) : i; } }
    private IEnumerable<IGrouping<string, RoadmapItemDto>> SkillGroups => items.GroupBy(SkillKey).OrderBy(x => SkillRank(x.Key));

    protected override async Task OnInitializedAsync()
    {
        var signedInUserId = await AuthProvider.GetUserIdAsync();
        if (signedInUserId <= 0) { Nav.NavigateTo("/Account/Login", true); return; }
        if (UserId > 0 && UserId != signedInUserId) { Nav.NavigateTo($"/roadmap/{signedInUserId}", true); return; }
        UserId = signedInUserId;
        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        items = roadmap.Items.Where(x => !string.IsNullOrWhiteSpace(x.SkillName)).OrderBy(x => SkillRank(SkillKey(x))).ThenBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
        loading = false;
    }

    private void OpenWeek(RoadmapItemDto item) => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{item.Id}");
    private bool IsSkillLocked(string key) { var first = items.FindIndex(x => SkillKey(x) == key); return !RoadmapReviewMode.Enabled && first > ActiveIndex; }
    private int WeekOrdinal(RoadmapItemDto item) { var list = items.Where(x => SkillKey(x) == SkillKey(item)).ToList(); return list.FindIndex(x => x.Id == item.Id) + 1; }
    private static int CompletedSteps(RoadmapItemDto item) => (item.IsVideoCompleted ? 1 : 0) + (item.ScriptCompletedAtUtc.HasValue || item.IsPracticeCompleted ? 1 : 0) + (item.SummaryCompletedAtUtc.HasValue || item.IsPracticeCompleted ? 1 : 0) + (item.IsPracticeCompleted ? 1 : 0) + (item.IsScenarioCompleted ? 1 : 0) + (item.IsReflectionCompleted ? 1 : 0);
    private static int EstimatedMinutes(RoadmapItemDto item) => 42;
    private string WeekTitle(RoadmapItemDto item, int ordinal)
    {
        if (SkillKey(item) == "communication") return ordinal switch { 1 => Tx("Communication foundations", "Nền tảng giao tiếp"), 2 => Tx("Active listening", "Lắng nghe chủ động"), 3 => Tx("Constructive feedback", "Phản hồi xây dựng"), 4 => Tx("Advanced communication", "Giao tiếp nâng cao"), _ => item.Title };
        return string.IsNullOrWhiteSpace(item.Title) ? $"{Tx("Week", "Tuần")} {ordinal}" : item.Title;
    }
    private static string SkillKey(RoadmapItemDto item)
    {
        var value = $"{item.SkillName} {item.Title}".ToLowerInvariant();
        if (value.Contains("giao tiếp") || value.Contains("communication")) return "communication";
        if (value.Contains("quản lý thời gian") || value.Contains("time management")) return "time";
        if (value.Contains("tư duy phản biện") || value.Contains("critical thinking")) return "critical";
        return "other";
    }
    private static int SkillRank(string key) => key switch { "communication" => 0, "time" => 1, "critical" => 2, _ => 3 };
    private string SkillName(string key) => key switch { "communication" => Tx("Communication skills", "Kỹ năng giao tiếp"), "time" => Tx("Time management", "Kỹ năng quản lý thời gian"), "critical" => Tx("Critical thinking", "Kỹ năng tư duy phản biện"), _ => Tx("Other skills", "Kỹ năng khác") };
    private static string SkillIcon(string key) => key switch { "communication" => "bi bi-chat-dots-fill", "time" => "bi bi-clock-fill", "critical" => "bi bi-lightbulb-fill", _ => "bi bi-stars" };
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
}

<style>
    .rm-page{--blue:#3157d5;--violet:#6954e8;--green:#2e9d69;--navy:#17233c;--muted:#6c7588;--line:#dfe4ec;min-height:calc(100vh - 72px);padding:clamp(1rem,2.4vw,2.25rem);color:var(--navy);background:#f5f7fa}.rm-shell{max-width:1240px;margin:auto}.rm-state{min-height:65vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.8rem;text-align:center}.rm-state>i{font-size:3rem;color:var(--blue)}.rm-state button{padding:.75rem 1rem;color:#fff;border:0;border-radius:9px;background:var(--blue);font-weight:800}.rm-spinner{width:30px;height:30px;border:3px solid #dbe2fa;border-top-color:var(--blue);border-radius:50%;animation:rm-spin .8s linear infinite}
    .rm-hero{display:grid;grid-template-columns:1fr minmax(280px,380px);align-items:end;gap:2rem;margin-bottom:1rem}.rm-hero>div:first-child>span{color:var(--blue);font-size:.7rem;font-weight:900;letter-spacing:.12em}.rm-hero h1{margin:.35rem 0 .25rem;font-size:clamp(1.8rem,3vw,2.65rem);letter-spacing:-.045em}.rm-hero p{margin:0;color:var(--muted)}.rm-total{padding:1rem;border:1px solid var(--line);border-radius:13px;background:#fff}.rm-total>div:first-child{display:flex;align-items:center;justify-content:space-between}.rm-total span,.rm-total small{color:var(--muted);font-size:.72rem}.rm-total b{color:var(--blue);font-size:1.35rem}.rm-progress,.rm-skill-progress>div{height:7px;margin:.65rem 0;border-radius:999px;background:#e8ebf1;overflow:hidden}.rm-progress i,.rm-skill-progress i{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--blue),var(--violet))}
    .rm-review{display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;padding:.75rem 1rem;color:#473b86;border:1px solid #d9d2ff;border-radius:12px;background:#f4f1ff}.rm-review>i{font-size:1.2rem}.rm-review>div{flex:1}.rm-review b,.rm-review small{display:block}.rm-review small{margin-top:.1rem}.rm-review button{padding:.52rem .75rem;color:#fff;border:0;border-radius:8px;background:var(--violet);font-size:.72rem;font-weight:800}
    .rm-skills{display:grid;gap:.85rem}.rm-skill{overflow:hidden;border:1px solid var(--line);border-radius:15px;background:#fff;box-shadow:0 8px 24px rgba(28,40,70,.045)}.rm-skill>header{display:grid;grid-template-columns:auto 1fr minmax(190px,270px) auto;align-items:center;gap:.85rem;padding:1rem 1.1rem}.rm-skill-icon{display:grid;place-items:center;width:44px;height:44px;color:#fff;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--violet));font-size:1.15rem}.rm-skill-title span{color:var(--blue);font-size:.58rem;font-weight:900;letter-spacing:.1em}.rm-skill-title h2{margin:.12rem 0 0;font-size:1.05rem}.rm-skill-progress b{display:block;text-align:right;font-size:.7rem}.rm-skill-progress>div{height:5px;margin:.35rem 0 0}.rm-skill-lock{color:#8a92a2}.rm-skill.locked{background:#fafbfc}.rm-skill.locked .rm-skill-icon{color:#8490a5;background:#edf0f4}
    .rm-week-list{display:grid;gap:.5rem;padding:.15rem 1rem 1rem}.rm-week{display:grid;grid-template-columns:auto minmax(0,1fr) 120px auto;align-items:center;gap:.85rem;min-height:76px;padding:.7rem .8rem;border:1px solid #e3e7ee;border-radius:11px;background:#fff}.rm-week.current{border-color:#8e9ff0;background:#f7f9ff;box-shadow:inset 3px 0 var(--blue)}.rm-week.done{box-shadow:inset 3px 0 var(--green)}.rm-week.locked{color:#818999;background:#fafbfc}.rm-week-number{display:grid;place-items:center;width:36px;height:36px;color:#5d6678;border:1px solid #d7dce5;border-radius:50%;font-weight:900}.rm-week.current .rm-week-number{color:#fff;border-color:var(--blue);background:var(--blue)}.rm-week.done .rm-week-number{color:#fff;border-color:var(--green);background:var(--green)}.rm-week-copy small{color:var(--blue);font-size:.56rem;font-weight:900;letter-spacing:.08em}.rm-week-copy h3{margin:.1rem 0;font-size:.86rem}.rm-week-copy p{margin:0;color:var(--muted);font-size:.63rem}.rm-step-dots{display:flex;gap:.25rem}.rm-step-dots i{width:15px;height:5px;border-radius:99px;background:#e2e6ed}.rm-step-dots i.filled{background:var(--green)}.rm-week.current .rm-step-dots i.filled{background:var(--blue)}.rm-week button{display:flex;align-items:center;gap:.4rem;padding:.55rem .7rem;color:var(--blue);border:1px solid #b8c4ed;border-radius:8px;background:#fff;font-size:.68rem;font-weight:850;white-space:nowrap}.rm-week button.primary{color:#fff;border-color:var(--blue);background:var(--blue)}.rm-locked-label{display:flex;align-items:center;gap:.3rem;color:#8a92a2;font-size:.65rem;font-weight:800}.rm-skill-gate{display:flex;align-items:center;gap:.5rem;padding:.75rem 1.1rem;color:#7e8798;border-top:1px solid var(--line);font-size:.72rem}.rm-rule{display:flex;align-items:center;justify-content:center;gap:.7rem;margin-top:1rem;padding:1rem;color:#667084}.rm-rule>i{color:var(--blue);font-size:1.2rem}.rm-rule b,.rm-rule span{display:block}.rm-rule b{color:var(--navy);font-size:.75rem}.rm-rule span{margin-top:.15rem;font-size:.66rem}
    html[data-theme="dark"] .rm-page{--navy:#f4f6fb;--muted:#b9c0cf;--line:rgba(148,163,184,.2);background:#0d1425}html[data-theme="dark"] .rm-total,html[data-theme="dark"] .rm-skill,html[data-theme="dark"] .rm-week{background:#182136}html[data-theme="dark"] .rm-week.current{background:#1c2845}html[data-theme="dark"] .rm-skill.locked,html[data-theme="dark"] .rm-week.locked{background:#141c2e}
    @@keyframes rm-spin{to{transform:rotate(360deg)}}
    @@media(max-width:800px){.rm-hero{grid-template-columns:1fr}.rm-skill>header{grid-template-columns:auto 1fr auto}.rm-skill-progress{grid-column:1/-1}.rm-week{grid-template-columns:auto 1fr auto}.rm-step-dots{display:none}.rm-review{align-items:flex-start;flex-wrap:wrap}.rm-review button{margin-left:3rem}}
    @@media(max-width:520px){.rm-page{padding:.75rem}.rm-week{grid-template-columns:auto 1fr}.rm-week button,.rm-locked-label{grid-column:2}.rm-skill>header{padding:.85rem}.rm-week-list{padding:.1rem .7rem .7rem}.rm-rule{align-items:flex-start}}
</style>
