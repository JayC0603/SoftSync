@page "/roadmap"
@page "/roadmap/{UserId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@Tx("Roadmap", "Lộ trình") · SoftSync</PageTitle>

<main class="coursera-roadmap">
    @if (loading)
    {
        <div class="loading"><span></span>@Tx("Loading roadmap...", "Đang tải lộ trình...")</div>
    }
    else if (items.Count == 0)
    {
        <div class="empty"><i class="bi bi-map"></i><h1>@Tx("Your roadmap is being prepared", "Lộ trình của bạn đang được chuẩn bị")</h1></div>
    }
    else
    {
        <aside class="roadmap-sidebar">
            <section class="overall-card">
                <h3>@Tx("Overall progress", "Tiến độ tổng thể")</h3>
                <div class="overall-body">
                    <div class="progress-ring" style="--value:@OverallPercent"><b>@OverallPercent%</b></div>
                    <div><span>@Tx("You have completed", "Bạn đã hoàn thành")</span><strong>@CompletedStepsTotal / @(items.Count * 6) @Tx("steps", "bước")</strong></div>
                </div>
            </section>

            <section class="xp-card"><i class="bi bi-star-fill"></i><span>@Tx("Current XP", "XP hiện tại")</span><b>@(CompletedStepsTotal * 20) XP</b></section>
            <h4 class="sidebar-heading">@Tx("YOUR ROADMAP", "ROADMAP CỦA BẠN")</h4>

            <nav class="skill-tree">
                @foreach (var group in SkillGroups)
                {
                    var skillItems = group.ToList();
                    var skillLocked = IsSkillLocked(group.Key);
                    <section class="skill-group @(skillLocked ? "skill-locked" : null)">
                        <button class="skill-row" @onclick="() => ToggleSkill(group.Key)">
                            <span class="skill-icon"><i class="@SkillIcon(group.Key)"></i></span>
                            <b>@SkillName(group.Key)</b>
                            <small>@skillItems.Count @Tx("weeks", "tuần")</small>
                            <i class="bi @(Expanded(group.Key) ? "bi-chevron-up" : "bi-chevron-right")"></i>
                        </button>
                        @if (Expanded(group.Key))
                        {
                            <div class="week-tree">
                                @foreach (var item in skillItems)
                                {
                                    var index = items.IndexOf(item);
                                    var ordinal = WeekOrdinal(item);
                                    var locked = !RoadmapReviewMode.Enabled && index > ActiveIndex;
                                    <button class="tree-week @(ReferenceEquals(item, SelectedItem) ? "selected" : null) @(item.IsCompleted ? "done" : null)" disabled="@locked" @onclick="() => SelectWeek(item)">
                                        <span>@(item.IsCompleted ? "✓" : ordinal)</span>
                                        <div><b>@Tx("Week", "Tuần") @ordinal</b><small>@WeekTitle(item, ordinal)</small></div>
                                        <em>@CompletedSteps(item)%</em>
                                        @if (locked) { <i class="bi bi-lock-fill"></i> }
                                    </button>
                                }
                            </div>
                        }
                    </section>
                }
            </nav>

            <section class="streak"><i class="bi bi-fire"></i><div><small>@Tx("LEARNING STREAK", "CHUỖI NGÀY HỌC")</small><b>7 @Tx("days", "ngày")</b><span>@Tx("Keep up the great work!", "Bạn đang duy trì rất tốt!")</span></div><div class="mascot">🐳</div></section>
        </aside>

        <section class="week-column">
            <div class="breadcrumb"><span>Roadmap</span><i class="bi bi-chevron-right"></i><span>@SkillName(SkillKey(SelectedItem))</span><i class="bi bi-chevron-right"></i><b>@Tx("Week", "Tuần") @SelectedOrdinal</b></div>
            <header class="week-header">
                <h1>@Tx("Week", "Tuần") @SelectedOrdinal: @WeekTitle(SelectedItem, SelectedOrdinal)</h1>
                <p>@WeekDescription(SelectedItem)</p>
            </header>
            <section class="week-stat">
                <div><i class="bi bi-bullseye"></i><span>@Tx("Weekly progress", "Tiến độ tuần")<b>@SelectedCompletedSteps / 6</b></span></div>
                <div><i class="bi bi-clock"></i><span>42 @Tx("minutes", "phút")<small>@Tx("Estimated time", "Thời lượng ước tính")</small></span></div>
                <div><i class="bi bi-journal-text"></i><span>6<small>@Tx("learning activities", "hoạt động học")</small></span></div>
                <div class="week-bar"><i style="width:@SelectedPercent%"></i></div>
            </section>

            <div class="lesson-list">
                @foreach (var lesson in Lessons)
                {
                    var status = LessonStatus(lesson.Step);
                    <article class="lesson @(lesson.Step == CurrentStep ? "active" : null) @(status == 2 ? "complete" : status == 0 ? "locked" : null)" @onclick="() => SelectStep(lesson.Step)">
                        <div class="lesson-number">@(status == 2 ? "✓" : lesson.Step.ToString())</div>
                        <div class="lesson-thumb"><i class="@lesson.Icon"></i><span>@lesson.Time</span></div>
                        <div class="lesson-copy"><small>@Tx("Lesson", "Bài") @lesson.Step</small><h3>@Tx(lesson.En, lesson.Vi)</h3><p>@Tx(lesson.DescEn, lesson.DescVi)</p></div>
                        <div class="lesson-action">
                            @if (status == 2) { <span class="complete-label"><i class="bi bi-check-circle-fill"></i>@Tx("Completed", "Hoàn thành")</span><button @onclick="() => OpenSelectedStep(lesson.Step)" @onclick:stopPropagation="true">@Tx("Review", "Xem lại")</button> }
                            else if (status == 1) { <button @onclick="() => OpenSelectedStep(lesson.Step)" @onclick:stopPropagation="true">@Tx("Continue", "Tiếp tục")</button><b>+30 XP</b> }
                            else { <span><i class="bi bi-lock-fill"></i>@Tx("Locked", "Chưa mở khóa")</span><b>+30 XP</b> }
                        </div>
                    </article>
                }
                <article class="weekly-challenge"><i class="bi bi-trophy"></i><div><b>@Tx("Weekly challenge", "Thử thách tuần")</b><span>@Tx("Complete all activities to earn your badge!", "Hoàn thành tất cả bài học để nhận huy hiệu!")</span></div><i class="bi bi-lock-fill"></i><b>+100 XP</b></article>
            </div>
        </section>

    }
</main>

@code {
    [Parameter] public int UserId { get; set; }
    private List<RoadmapItemDto> items = [];
    private RoadmapItemDto? selected;
    private bool loading = true;
    private int currentStep = 1;
    private readonly HashSet<string> expandedSkills = ["communication"];
    private RoadmapItemDto SelectedItem => selected ?? items[0];
    private int CurrentStep => currentStep;
    private int CompletedWeeks => items.Count(x => x.IsCompleted);
    private int CompletedStepsTotal => items.Sum(CompletedStepCount);
    private int OverallPercent => items.Count == 0 ? 0 : CompletedStepsTotal * 100 / (items.Count * 6);
    private int ActiveIndex { get { var i = items.FindIndex(x => !x.IsCompleted); return i < 0 ? items.Count - 1 : i; } }
    private int SelectedOrdinal => WeekOrdinal(SelectedItem);
    private int SelectedCompletedSteps => CompletedStepCount(SelectedItem);
    private int SelectedPercent => SelectedCompletedSteps * 100 / 6;
    private IEnumerable<IGrouping<string, RoadmapItemDto>> SkillGroups => items.GroupBy(SkillKey).OrderBy(x => SkillRank(x.Key));
    private string CurrentLessonTitle { get { var l = Lessons.First(x => x.Step == CurrentStep); return $"{Tx("Lesson", "Bài")} {l.Step}: {Tx(l.En, l.Vi)}"; } }
    private string CurrentStepTitle { get { var s = Steps.First(x => x.Id == CurrentStep); return Tx(s.En, s.Vi); } }
    private string CurrentStepIcon => Steps.First(x => x.Id == CurrentStep).Icon;

    protected override async Task OnInitializedAsync()
    {
        var id = await AuthProvider.GetUserIdAsync();
        if (id <= 0) { Nav.NavigateTo("/Account/Login", true); return; }
        UserId = id;
        var roadmap = await RoadmapService.GetUserRoadmapAsync(id);
        items = roadmap.Items.Where(x => !string.IsNullOrWhiteSpace(x.SkillName)).OrderBy(x => SkillRank(SkillKey(x))).ThenBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList();
        selected = items.Count == 0 ? null : items[Math.Max(0, ActiveIndex)];
        if (selected is not null) currentStep = Math.Clamp(SelectedCompletedSteps + 1, 1, 6);
        loading = false;
    }

    private void SelectWeek(RoadmapItemDto item) { selected = item; currentStep = Math.Clamp(CompletedStepCount(item) + 1, 1, 6); }
    private void SelectStep(int step) { if (StepStatus(step) > 0 || RoadmapReviewMode.Enabled) currentStep = step; }
    private void PreviousStep() => currentStep = Math.Max(1, currentStep - 1);
    private void NextStep() { if (currentStep < 6 && (StepStatus(currentStep + 1) > 0 || RoadmapReviewMode.Enabled)) currentStep++; else OpenSelected(); }
    private void OpenSelected() => OpenSelectedStep(CurrentStep);
    private void OpenSelectedStep(int step) => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{SelectedItem.Id}?step={step}");
    private void ToggleSkill(string key) { if (!expandedSkills.Remove(key)) expandedSkills.Add(key); }
    private bool Expanded(string key) => expandedSkills.Contains(key);
    private bool IsSkillLocked(string key) { var first = items.FindIndex(x => SkillKey(x) == key); return !RoadmapReviewMode.Enabled && first > ActiveIndex; }
    private int LessonStatus(int step) => StepStatus(step);
    private int StepStatus(int step) { var complete = SelectedCompletedSteps; return step <= complete ? 2 : step == complete + 1 || RoadmapReviewMode.Enabled ? 1 : 0; }
    private static int CompletedStepCount(RoadmapItemDto x) => x.IsCompleted ? 6 : (x.IsVideoCompleted ? 1 : 0) + (x.ScriptCompletedAtUtc.HasValue ? 1 : 0) + (x.SummaryCompletedAtUtc.HasValue ? 1 : 0) + (x.IsPracticeCompleted ? 1 : 0) + (x.IsScenarioCompleted ? 1 : 0) + (x.IsReflectionCompleted ? 1 : 0);
    private static int CompletedSteps(RoadmapItemDto x) => CompletedStepCount(x) * 100 / 6;
    private int WeekOrdinal(RoadmapItemDto item) => items.Where(x => SkillKey(x) == SkillKey(item)).ToList().FindIndex(x => x.Id == item.Id) + 1;
    private string WeekTitle(RoadmapItemDto item, int n) => SkillKey(item) switch
    {
        "communication" => n switch
        {
            1 => Tx("Communication foundations", "Nền tảng giao tiếp"),
            2 => Tx("Active listening", "Lắng nghe chủ động"),
            3 => Tx("Constructive feedback", "Phản hồi xây dựng"),
            4 => Tx("Advanced communication", "Giao tiếp nâng cao"),
            _ => Tx($"Communication · Week {n}", $"Giao tiếp · Tuần {n}")
        },
        "time" => n switch
        {
            1 => Tx("Time management foundations", "Nền tảng kỹ năng quản lý thời gian"),
            2 => Tx("Time management practice", "Thực hành kỹ năng quản lý thời gian"),
            _ => Tx($"Time management · Week {n}", $"Quản lý thời gian · Tuần {n}")
        },
        "critical" => n switch
        {
            1 => Tx("Critical thinking foundations", "Nền tảng tư duy phản biện"),
            2 => Tx("Critical thinking practice", "Thực hành tư duy phản biện"),
            _ => Tx($"Critical thinking · Week {n}", $"Tư duy phản biện · Tuần {n}")
        },
        _ => string.IsNullOrWhiteSpace(item.Title) ? $"{Tx("Week", "Tuần")} {n}" : item.Title
    };

    private string WeekDescription(RoadmapItemDto item) => SkillKey(item) switch
    {
        "communication" => Tx(
            "Build communication skills through video, synchronized theory, quizzes, and realistic practice.",
            "Rèn kỹ năng giao tiếp qua video, lý thuyết đồng bộ, quiz và tình huống thực tế."),
        "time" => Tx(
            "Learn the core principles of time management and practice building sustainable study habits.",
            "Nắm lý thuyết cốt lõi của kỹ năng quản lý thời gian và luyện tập để hình thành thói quen bền vững."),
        "critical" => Tx(
            "Strengthen critical thinking through evidence, structured reasoning, and applied exercises.",
            "Phát triển tư duy phản biện qua bằng chứng, lập luận có cấu trúc và bài tập ứng dụng."),
        _ => Tx(
            "Learn through video, theory, quiz and practical activities.",
            "Học qua video, lý thuyết, quiz và các hoạt động thực hành.")
    };
    private static string SkillKey(RoadmapItemDto x) { var v = $"{x.SkillName} {x.Title}".ToLowerInvariant(); if (v.Contains("giao tiếp") || v.Contains("communication")) return "communication"; if (v.Contains("quản lý thời gian") || v.Contains("time management")) return "time"; if (v.Contains("tư duy phản biện") || v.Contains("critical")) return "critical"; return "other"; }
    private static int SkillRank(string key) => key switch { "communication" => 0, "time" => 1, "critical" => 2, _ => 3 };
    private string SkillName(string key) => key switch { "communication" => Tx("Communication", "Giao tiếp"), "time" => Tx("Time management", "Quản lý thời gian"), "critical" => Tx("Critical thinking", "Tư duy phản biện"), _ => Tx("Other skills", "Kỹ năng khác") };
    private static string SkillIcon(string key) => key switch { "communication" => "bi bi-chat-heart", "time" => "bi bi-clock", "critical" => "bi bi-mortarboard", _ => "bi bi-stars" };
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;

    private static readonly (int Step, string En, string Vi, string DescEn, string DescVi, string Icon, string Time)[] Lessons =
    [
        (1,"Introduction","Giới thiệu","Watch the core lesson video.","Xem video bài học nền tảng.","bi bi-play-circle-fill","08:45"),
        (2,"Lesson script","Kịch bản bài học","Review the synchronized theory.","Ôn lại lý thuyết đồng bộ với video.","bi bi-file-text-fill","09:12"),
        (3,"Summary","Tóm tắt kiến thức","Consolidate the most important ideas.","Củng cố những ý quan trọng nhất.","bi bi-lightbulb-fill","05:00"),
        (4,"Mini Quiz","Bài kiểm tra ngắn","Check your understanding.","Kiểm tra mức độ hiểu bài.","bi bi-ui-checks","5 câu"),
        (5,"Practice (Role-play)","Thực hành tình huống","Apply the skill with AI.","Áp dụng kỹ năng cùng AI.","bi bi-chat-dots-fill","10:00"),
        (6,"Reflection & AI Feedback","Phản tư & AI Feedback","Reflect and receive personalized feedback.","Phản tư và nhận góp ý cá nhân hóa.","bi bi-stars","05:00")
    ];
    private static readonly (int Id, string En, string Vi, string Icon)[] Steps =
    [(1,"Video","Video","bi bi-play-circle"),(2,"Script","Script","bi bi-file-text"),(3,"Summary","Tóm tắt","bi bi-lightbulb"),(4,"Quiz","Quiz","bi bi-ui-checks"),(5,"Practice","Thực hành","bi bi-chat-dots"),(6,"AI Feedback","Phản tư","bi bi-stars")];
}

