@page "/time-management-four-boxes"
@rendermode InteractiveServer
@inject NavigationManager Nav
@implements IDisposable
<PageTitle>Game 3 · 4 Ô Việc</PageTitle>
<main class="fb"><button class="back" @onclick='()=>Nav.NavigateTo("/time-management-lesson-3")'><i class="bi bi-arrow-left"></i> Video 3</button><header><div><span>GAME 3 · 4 Ô VIỆC</span><h1>Phân loại đúng trong <em>30 giây</em></h1><p>Mỗi tình huống phân bố khác nhau. Không đoán theo khuôn mẫu — hãy đọc từng nhiệm vụ.</p></div><div class="clock @(seconds<=10?"danger":"")"><b>@seconds</b><span>GIÂY</span></div></header>
 @if(!started&&!done){<section class="intro"><div class="legend">@foreach(var q in Boxes.Select((x,i)=>(x,i))){<article class="b@q.i"><b>@q.x.Icon @q.x.Name</b><span>@q.x.Hint</span></article>}</div><button @onclick="Start">Bắt đầu tình huống ngẫu nhiên</button></section>}
 else if(!done){<section class="play"><article class="scenario"><small>TÌNH HUỐNG @(scenarioIndex+1)/20</small><p>@Current.Context</p><div class="tasks">@foreach(var t in Current.Tasks.Where(x=>x.Placed<0)){<span draggable="true" @ondragstart="()=>dragging=t"><i class="bi bi-grip-vertical"></i>@t.Text</span>}</div></article><div class="boxes">@foreach(var q in Boxes.Select((x,i)=>(x,i))){<section class="b@q.i" @ondragover:preventDefault @ondrop="()=>Drop(q.i)"><header><b>@q.x.Icon @q.x.Name</b><small>@q.x.Hint</small></header>@foreach(var t in Current.Tasks.Where(x=>x.Placed==q.i)){<p draggable="true" @ondragstart="()=>dragging=t">@t.Text</p>}</section>}</div><footer><span>@Current.Tasks.Count(x=>x.Placed>=0)/4 nhiệm vụ đã phân loại</span><button disabled="@Current.Tasks.Any(x=>x.Placed<0)" @onclick="Submit">Chấm kết quả</button></footer></section>}
 else {<section class="result"><div class="score"><b>@correct/4</b><span>@(correct==4?"HOÀN HẢO":correct>=3?"KHÁ TỐT":"CẦN LUYỆN THÊM")</span></div><h2>@FeedbackTitle</h2><p>@Current.Tip</p><div class="review">@foreach(var t in Current.Tasks){<article class="@(t.Placed==t.Correct?"ok":"bad")"><i class="bi @(t.Placed==t.Correct?"bi-check-circle-fill":"bi-x-circle-fill")"></i><span><b>@t.Text</b><small>Đáp án: @Boxes[t.Correct].Icon @Boxes[t.Correct].Name</small></span></article>}</div><div class="actions"><button @onclick="Replay"><i class="bi bi-arrow-repeat"></i> Tình huống khác</button><button class="primary" @onclick='()=>Nav.NavigateTo("/roadmap")'>Về Roadmap</button></div></section>}
</main>
@code{private bool started,done;private int seconds=30,scenarioIndex,correct;private Timer? timer;private WorkTask? dragging;private Scenario Current=>Scenarios[scenarioIndex];private string FeedbackTitle=>correct==4?"Bạn hiểu rõ ma trận Eisenhower!":correct>=3?"Chỉ còn một điểm cần xem lại":"Đừng nhầm việc gấp với việc quan trọng";private readonly Box[] Boxes=[new("🔥","LÀM NGAY","Gấp thật + quan trọng"),new("🌱","LÊN KẾ HOẠCH","Quan trọng nhưng chưa gấp"),new("⚡","XONG NHANH RỒI THÔI","Gấp nhưng ít quan trọng"),new("🗑️","BỎ QUA / LÀM SAU","Không gấp, không quan trọng")];private void Start(){scenarioIndex=Random.Shared.Next(Scenarios.Count);started=true;seconds=30;timer=new Timer(async _=>await Tick(),null,1000,1000);}private async Task Tick(){seconds--;if(seconds<=0)Submit();await InvokeAsync(StateHasChanged);}private void Drop(int box){if(dragging is null)return;dragging.Placed=box;dragging=null;}private void Submit(){if(done)return;timer?.Dispose();done=true;correct=Current.Tasks.Count(x=>x.Placed==x.Correct);}private void Replay(){foreach(var t in Current.Tasks)t.Placed=-1;done=false;started=false;correct=0;seconds=30;}public void Dispose()=>timer?.Dispose();private sealed record Box(string Icon,string Name,string Hint);private sealed class WorkTask(string text,int correct){public string Text{get;}=text;public int Correct{get;}=correct;public int Placed{get;set;}=-1;}private sealed record Scenario(string Context,List<WorkTask> Tasks,string Tip);
private static Scenario S(string context,string tasks,string keys,string tip)=>new(context,tasks.Split('|').Select((x,i)=>new WorkTask(x,keys[i]-'1')).ToList(),tip);private static readonly List<Scenario> Scenarios=[
S("Sáng mai kiểm tra Anh và bài Văn cũng đến hạn; thi cuối kỳ còn ba tuần; bạn hỏi gấp câu có thể tự tra.","Ôn kiểm tra Anh|Hoàn thành bài Văn|Ôn dần thi cuối kỳ|Trả lời bạn ngắn gọn","1123","Hai việc cùng gấp là bình thường; hãy xếp thứ tự trong Q1."),
S("Chiều nay nộp bài Tin; bạn muốn luyện gõ, dọn góc học tập và xem video hài.","Nộp bài Tin đúng hạn|Luyện gõ 10 ngón|Sắp xếp góc học tập|Xem video hài","1224","Không phải tình huống nào cũng có đủ cả bốn ô."),
S("Buổi chiều rảnh, không deadline; có bài tuần sau, tập thể dục, lời mời cấp tốc và mạng xã hội.","Đọc trước bài tuần sau|Tập thể dục|Cân nhắc lời mời cấp tốc|Lướt mạng vô định","2234","Ngày không Q1 là cơ hội đầu tư cho Q2."),
S("Mai thi Toán, ngày kia nộp tiểu luận, người thân bị ốm; phòng hơi bừa.","Ôn thi Toán|Hoàn thành tiểu luận|Chăm người thân bị ốm|Dọn phòng","1114","Ba Q1 đòi hỏi xếp thứ tự, không phải né tránh."),
S("Bài nhóm hạn tối nay; cần tìm hiểu nghề nghiệp; chat lớp và quảng cáo game liên tục.","Hoàn thành bài nhóm|Tìm hiểu định hướng|Tắt thông báo nhóm chat|Bỏ qua quảng cáo game","1233","Xử lý gộp nguồn xao nhãng, không phản ứng từng cái."),
S("Mai kiểm tra Lý, cổng đăng ký thi thử đóng tối nay; cần lập lịch tháng và ngủ đủ.","Ôn kiểm tra Lý|Đăng ký thi thử|Lập lịch ôn tháng tới|Ngủ đủ giấc","1122","Một ngày sạch xao nhãng vẫn cần ưu tiên đúng."),
S("Đơn xin nghỉ hạn 9h mai; trend ảnh đang hot; video cũ và album ảnh.","Nộp đơn đúng hạn|Cân nhắc trend ảnh|Xem lại video cũ|Sắp xếp album ảnh","1344","Không phải lúc nào cũng có việc đầu tư dài hạn."),
S("Mai hạn đăng ký môn; cần tìm hiểu, hỏi người có kinh nghiệm và tự đánh giá.","Nộp phiếu đăng ký|Tìm hiểu môn học|Hỏi người có kinh nghiệm|Tự đánh giá điểm mạnh yếu","1222","Quyết định lớn cần nhiều chuẩn bị Q2."),
S("Ngày rảnh; mục tiêu học kỹ năng mới; thông báo mạng xã hội, lời nhờ gấp và nghỉ 15 phút.","Học kỹ năng mới|Tắt thông báo|Từ chối lời nhờ không liên quan|Nghỉ vô định 15 phút","2334","Ngày rảnh kiểm tra khả năng bảo vệ Q2."),
S("Bài thu hoạch hạn chiều; có kiểm tra miệng bất chợt; bạn mượn vở và bàn học bừa.","Ôn đề phòng kiểm tra|Hoàn thành bài thu hoạch|Trả lời bạn sau|Dọn bàn học","1134","Rủi ro cao vẫn có thể là Q1 dù ngày giờ chưa rõ."),
S("Mai phỏng vấn; cần luyện trả lời, tìm hiểu nơi phỏng vấn; khảo sát lạ thúc giục.","Chuẩn bị phỏng vấn mai|Luyện trả lời|Tìm hiểu nơi phỏng vấn|Bỏ qua khảo sát lạ","1223","Q2 chuẩn bị tốt sẽ hỗ trợ Q1."),
S("Cuối tuần không việc học; hai lời mời cần phản hồi và hai hoạt động giải trí.","Trả lời lời mời thứ nhất|Trả lời lời mời thứ hai|Xem phim|Chơi game","3344","Một ngày nghỉ hoàn toàn là hợp lý nếu có giới hạn."),
S("Chiều có họp quan trọng; nên đọc chủ đề kỳ tới; bài đăng cũ và game điện thoại.","Tham gia họp đúng giờ|Tìm hiểu chủ đề kỳ tới|Xem bài đăng cũ|Chơi game vô định","1244","Không phải ngày nào cũng có giả khẩn cấp."),
S("Học phí hạn hôm nay, bài nhóm sáng mai, khám bắt buộc chiều nay; cần lập kế hoạch tuần.","Nộp học phí|Hoàn thành bài nhóm|Đi khám bắt buộc|Lập danh sách tuần tới","1112","Giữa ngày dồn Q1 vẫn nên dành ít phút cho Q2."),
S("Giữa hai kỳ thi; cần bù kiến thức, rèn kỹ năng, nghỉ có kế hoạch; series phim dài.","Bù kiến thức yếu|Rèn kỹ năng mềm|Nghỉ tái tạo có kế hoạch|Xem phim không giới hạn","2224","Nghỉ có chủ đích là Q2, giải trí vô thức là Q4."),
S("Ngày học thường: bài nộp chiều, ôn lặp lại, bạn mượn đồ và 15 phút giải lao.","Hoàn thành bài chiều nay|Ôn kiến thức định kỳ|Trả lời bạn mượn đồ|Giải lao 15 phút","1234","Một bộ đủ bốn ô không phải khuôn mẫu chung."),
S("Mai hai bài kiểm tra; cần cải thiện ghi chú; sự kiện chỉ đăng ký hôm nay nhưng không liên quan.","Ôn môn thứ nhất|Ôn môn thứ hai|Cải thiện phương pháp ghi chú|Cân nhắc sự kiện không liên quan","1123","Bảo vệ mục tiêu trước hiệu ứng khan hiếm giả."),
S("Tối không deadline; ba gián đoạn bên ngoài và mục tiêu đọc thêm tài liệu.","Từ chối cuộc gọi mời chào|Từ chối lời nhờ không cần|Bỏ qua quảng cáo giật tít|Đọc tài liệu mở rộng","3332","Nhiều Q3 liên tiếp thử khả năng giữ ưu tiên."),
S("Một việc quan trọng hôm nay và ba lựa chọn giải trí trong buổi tối.","Hoàn thành việc quan trọng|Xem phim|Chơi game|Lướt mạng","1444","Giải trí không sai nếu làm sau Q1."),
S("Tuần thi: mai thi môn đầu; cần theo lịch, ôn đều và chăm sức khỏe.","Ôn môn thi ngày mai|Theo sát lịch đang trễ|Ôn đều môn còn lại|Ngủ đủ và ăn đủ","1122","Bỏ Q2 hôm nay sẽ làm Q1 ngày sau khó hơn.")];}
<style>.fb{--p:#6847eb;--ink:#19163d;--muted:#697386;max-width:1200px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:var(--ink)}.back{border:0;background:none;color:#747b8c;font-weight:800}.fb>header{display:flex;justify-content:space-between;align-items:center;margin:1rem 0;padding:1.6rem;border-radius:24px;background:linear-gradient(135deg,#fff,#eee9ff)}.fb>header span,.scenario small{color:var(--p);font-size:.65rem;font-weight:900;letter-spacing:.08em}.fb h1{margin:.3rem 0}.fb h1 em{color:var(--p);font-style:normal}.fb>header p{color:var(--muted)}.clock{display:grid;place-items:center;min-width:100px;height:100px;border-radius:50%;background:#fff}.clock b{font-size:2.2rem;color:var(--p)}.clock span{font-size:.55rem!important}.clock.danger b{color:#d92d20}.intro,.result,.play{padding:1.2rem;border:1px solid #ded8f5;border-radius:20px;background:#fff}.legend,.boxes{display:grid;grid-template-columns:1fr 1fr;gap:.7rem}.legend article,.boxes>section{min-height:120px;padding:1rem;border-radius:14px}.legend b,.legend span{display:block}.legend span{font-size:.72rem}.b0{background:#ffe8e5}.b1{background:#e7f7ed}.b2{background:#fff3d6}.b3{background:#eff1f5}.intro>button,.play footer button,.actions button{display:block;margin:1rem auto 0;padding:.75rem 1rem;color:#fff;border:0;border-radius:10px;background:var(--p);font-weight:800}.scenario{margin-bottom:.8rem}.scenario>p{color:var(--muted)}.tasks{display:flex;flex-wrap:wrap;gap:.5rem}.tasks span,.boxes section p{padding:.65rem;border:1px solid #ddd6f5;border-radius:9px;background:#fff;font-size:.74rem;cursor:grab}.boxes section header b,.boxes section header small{display:block}.boxes section header small{font-size:.62rem}.play footer{display:flex;justify-content:space-between;align-items:center}.play footer button{margin:1rem 0 0}.score{display:grid;place-items:center;width:130px;height:130px;margin:auto;border:10px solid #dcd5f7;border-top-color:var(--p);border-radius:50%}.score b{font-size:2rem}.score span{font-size:.6rem}.result{text-align:center}.review{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;text-align:left}.review article{display:flex;gap:.5rem;padding:.7rem;border-radius:9px}.review .ok{background:#ecfdf3;color:#16794f}.review .bad{background:#fff1f1;color:#b42318}.review span b,.review span small{display:block}.review span small{font-size:.65rem}.actions{display:flex;justify-content:center;gap:.6rem}.actions button{margin:1rem 0 0}.actions button:first-child{color:var(--p);border:1px solid #d7cff3;background:#fff}@@media(max-width:700px){.fb>header{align-items:start;flex-direction:column}.legend,.boxes,.review{grid-template-columns:1fr}}</style>
