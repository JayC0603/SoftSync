@page "/content-audit/communication"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.Common.Enums
@inject NavigationManager Nav

<PageTitle>@Tx("Communication content audit", "Kiểm tra nội dung Kỹ năng giao tiếp") · SoftSync</PageTitle>

<main class="cca-page">
    <header class="cca-head">
        <button @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i>@Tx("Roadmap", "Lộ trình")</button>
        <div>
            <span>@Tx("CONTENT AUDIT", "KIỂM DUYỆT NỘI DUNG")</span>
            <h1>@Tx("Communication Skills", "Kỹ năng giao tiếp")</h1>
            <p>@Tx("Review every video, script, summary, and quiz from top to bottom. This page does not change learning progress.", "Kiểm tra toàn bộ Video, Script, Summary và Quiz từ trên xuống dưới. Trang này không thay đổi tiến độ học.")</p>
        </div>
    </header>

    <nav class="cca-index" aria-label="@Tx("Communication lessons", "Các bài Giao tiếp")">
        @foreach (var lesson in Lessons)
        {
            <a href="#communication-lesson-@lesson.Number"><b>@lesson.Number</b><span>@lesson.TitleVi</span></a>
        }
    </nav>

    <div class="cca-list">
        @foreach (var lesson in Lessons)
        {
            <section class="cca-lesson" id="communication-lesson-@lesson.Number">
                <header>
                    <div><span>VIDEO @lesson.Number</span><h2>@Tx(lesson.TitleEn, lesson.TitleVi)</h2></div>
                    <em class="@(lesson.ScriptReady ? "ready" : "missing")">@(lesson.ScriptReady ? Tx("Script ready", "Đã có Script") : Tx("Script pending", "Chưa có Script"))</em>
                </header>

                <video controls preload="metadata" poster="/images/background-softsync.png">
                    <source src="@lesson.VideoUrl" type="video/mp4" />
                </video>

                <div class="cca-checks">
                    <article><i class="bi bi-camera-video-fill"></i><div><b>Video @lesson.Number</b><small>@lesson.VideoFile</small></div><span class="ok">✓</span></article>
                    <article><i class="bi bi-file-earmark-text-fill"></i><div><b>Script @lesson.Number</b><small>@Tx(lesson.ScriptStatusEn, lesson.ScriptStatusVi)</small></div><button @onclick="() => Open(lesson.ScriptUrl)">@Tx("Open", "Mở")</button></article>
                    <article><i class="bi bi-lightbulb-fill"></i><div><b>Summary @lesson.Number</b><small>@Tx("Final review before quiz", "Ôn tập cuối trước Quiz")</small></div><button @onclick="() => Open(lesson.SummaryUrl)">@Tx("Open", "Mở")</button></article>
                    <article><i class="bi bi-ui-checks-grid"></i><div><b>Quiz @lesson.Number</b><small>@Tx(lesson.QuizStatusEn, lesson.QuizStatusVi)</small></div><button @onclick="() => Open(lesson.QuizUrl)">@Tx("Open", "Mở")</button></article>
                </div>
            </section>
        }
    </div>
</main>

@code {
    private IReadOnlyList<AuditLesson> Lessons =>
    [
        new(1, "Communication Foundations", "Nền tảng kỹ năng giao tiếp", "/videos/communication-mentor-lesson-1.mp4", "communication-mentor-lesson-1.mp4", "/communication-lesson?step=script", "/communication-lesson?step=summary", "/communication-quiz", false, "Mapping needs review", "Cần kiểm tra lại mapping", "Communication knowledge quiz", "Quiz kiến thức giao tiếp"),
        new(2, "Active Listening Skills", "Kỹ năng lắng nghe chủ động", "/videos/communication-mentor-lesson-2.mp4", "communication-mentor-lesson-2.mp4", "/communication-lesson-2?step=script", "/communication-lesson-2?step=summary", "/communication-roleplay", true, "Active listening script", "Script Lắng nghe chủ động", "Listening role-play", "Tình huống lắng nghe"),
        new(3, "Rules for Giving Feedback", "Quy tắc phản hồi người khác", "/videos/communication-mentor-lesson-3.mp4", "communication-mentor-lesson-3.mp4", "/communication-lesson-3?step=script", "/communication-lesson-3?step=summary", "/communication-quiz", true, "Constructive feedback script", "Script Phản hồi xây dựng", "Feedback scenarios", "Quiz tình huống phản hồi"),
        new(4, "Advanced Communication", "Giao tiếp nâng cao", "/videos/communication-mentor-lesson-4.mp4", "communication-mentor-lesson-4.mp4", "/communication-lesson-4?step=script", "/communication-lesson-4?step=summary", "/communication-quiz", false, "Content not approved yet", "Nội dung chưa được duyệt", "Quiz mapping pending", "Quiz chưa được duyệt")
    ];

    private void Open(string url) => Nav.NavigateTo(url);
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
    private sealed record AuditLesson(int Number, string TitleEn, string TitleVi, string VideoUrl, string VideoFile,
        string ScriptUrl, string SummaryUrl, string QuizUrl, bool ScriptReady, string ScriptStatusEn,
        string ScriptStatusVi, string QuizStatusEn, string QuizStatusVi);
}

<style>
    .cca-page{max-width:1280px;margin:auto;padding:1rem 1rem 4rem;color:#20283b}.cca-head{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1rem}.cca-head>button{display:flex;align-items:center;gap:.45rem;padding:.65rem .85rem;color:#6246db;border:1px solid #d8d0ff;border-radius:11px;background:#fff;font-weight:800}.cca-head span{color:#6d4aff;font-size:.68rem;font-weight:900;letter-spacing:.12em}.cca-head h1{margin:.25rem 0;font-size:2rem}.cca-head p{margin:0;color:#687386}.cca-index{display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin-bottom:1rem}.cca-index a{display:flex;align-items:center;gap:.6rem;padding:.65rem;color:#394258;border:1px solid #e1dcf5;border-radius:12px;background:#fff;text-decoration:none}.cca-index b{display:grid;place-items:center;width:32px;height:32px;color:#fff;border-radius:50%;background:#6d4aff}.cca-index span{font-size:.72rem;font-weight:800}.cca-list{display:grid;gap:1.2rem}.cca-lesson{padding:1rem;border:1px solid #ded8f3;border-radius:20px;background:rgba(255,255,255,.94);box-shadow:0 16px 40px rgba(64,45,130,.08)}.cca-lesson>header{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:.8rem}.cca-lesson header span{color:#6d4aff;font-size:.65rem;font-weight:900}.cca-lesson h2{margin:.15rem 0 0;font-size:1.3rem}.cca-lesson em{padding:.4rem .65rem;border-radius:999px;font-size:.65rem;font-style:normal;font-weight:850}.cca-lesson em.ready{color:#13744c;background:#e8f8ef}.cca-lesson em.missing{color:#9a6410;background:#fff4d8}.cca-lesson video{display:block;width:100%;max-height:520px;border-radius:16px;background:#09091c}.cca-checks{display:grid;grid-template-columns:repeat(4,1fr);gap:.55rem;margin-top:.75rem}.cca-checks article{display:flex;align-items:center;gap:.55rem;min-height:62px;padding:.6rem;border:1px solid #e7e3f4;border-radius:12px;background:#fcfbff}.cca-checks article>i{color:#6d4aff;font-size:1.1rem}.cca-checks article>div{min-width:0;flex:1}.cca-checks b,.cca-checks small{display:block}.cca-checks b{font-size:.74rem}.cca-checks small{margin-top:.12rem;color:#747d8e;font-size:.6rem;line-height:1.35}.cca-checks button{padding:.42rem .58rem;color:#fff;border:0;border-radius:8px;background:#6d4aff;font-size:.62rem;font-weight:800}.cca-checks .ok{color:#19a869;font-size:1rem;font-weight:900}html[data-theme="dark"] .cca-page{color:#f5f3ff}html[data-theme="dark"] .cca-lesson,html[data-theme="dark"] .cca-index a,html[data-theme="dark"] .cca-checks article,html[data-theme="dark"] .cca-head>button{background:#191733;border-color:rgba(167,139,250,.25);color:#f5f3ff}html[data-theme="dark"] .cca-head p,html[data-theme="dark"] .cca-checks small{color:#c4c7d2}
    @@media(max-width:900px){.cca-index,.cca-checks{grid-template-columns:repeat(2,1fr)}}
    @@media(max-width:600px){.cca-head{display:grid}.cca-index,.cca-checks{grid-template-columns:1fr}.cca-lesson>header{align-items:flex-start;flex-direction:column}}
</style>
