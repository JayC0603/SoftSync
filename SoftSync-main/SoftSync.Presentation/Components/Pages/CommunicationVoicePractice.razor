@page "/communication-voice-practice"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Game 3 · Luyện giọng nói</PageTitle>
<main class="vp-page">
    <button class="vp-back" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i> Roadmap</button>
    <header class="vp-hero"><div><span>GAME 3 · VOICE LAB</span><h1>Luyện giọng nói <em>30 giây</em></h1><p>Ghi âm một tình huống thực tế. Nội dung và tín hiệu cận lời được phân tích bằng hai pipeline độc lập.</p></div><div class="vp-stack"><b>STT</b><span>Nội dung · WA</span><i>+</i><b>DSP</b><span>Nhịp · Pitch · RMS</span></div></header>

    <section class="vp-grid">
        <aside><label>CHỌN ĐỀ LUYỆN</label><select @bind="selectedIndex" @bind:after="Reset">@for(var i=0;i<Scenarios.Count;i++){<option value="@i">Đề @(i+1): @Scenarios[i].Title</option>}</select><div class="vp-context"><small>BỐI CẢNH</small><p>@Current.Context</p></div><div class="vp-rules"><b>Rubric · 10 điểm</b><span>Pacing <i>3.0</i></span><span>Độ rõ chữ <i>3.0</i></span><span>Từ đệm & khoảng lặng <i>2.0</i></span><span>Tông giọng <i>2.0</i></span></div></aside>
        <article class="vp-studio">
            <div class="vp-script"><small>VĂN BẢN GỢI Ý</small><p>“@Current.Script”</p></div>
            <div class="vp-recorder @(recording ? "recording" : "")"><div class="vp-mic"><i class="bi bi-mic-fill"></i></div><b>@(recording ? "Đang ghi âm..." : result is null ? "Sẵn sàng luyện tập" : "Đã phân tích bản ghi")</b><span>@(recording ? "Nói tự nhiên, rõ ràng và có khoảng nghỉ hợp lý" : "Cho phép micro và ghi trong khoảng 30 giây")</span><button disabled="@busy" @onclick="ToggleRecording"><i class="bi @(recording ? "bi-stop-fill" : "bi-record-circle")"></i> @(recording ? "Dừng & phân tích" : "Bắt đầu ghi âm")</button></div>
            @if(result is not null){<audio controls src="@result.AudioUrl"></audio><label class="vp-transcript">BẢN GHI STT <small>(có thể sửa nếu trình duyệt nghe sai)</small><textarea @bind="transcript"></textarea><button @onclick="Score">Chấm lại từ transcript</button></label>}
        </article>
    </section>

    @if(scores is not null){<section class="vp-results"><header><div class="vp-total"><b>@scores.Total.ToString("0.0")</b><span>/10</span></div><div><small>KẾT QUẢ PHÂN TÍCH</small><h2>@scores.Label</h2><p>@scores.Note</p></div></header><div class="vp-score-grid">@foreach(var row in scores.Rows){<article><div><i class="bi @row.Icon"></i><b>@row.Name</b><strong>@(row.Score.HasValue ? row.Score.Value.ToString("0.0") : "—")/@row.Max</strong></div><p>@row.Feedback</p></article>}</div><div class="vp-tech"><b><i class="bi bi-activity"></i> Chỉ số tín hiệu</b><span>@result!.Duration.ToString("0.0")s</span><span>F0 SD @result.PitchSd.ToString("0.0") Hz</span><span>RMS variation @result.RmsVariation.ToString("0.00")</span><span>Im lặng dài nhất @result.LongestSilence.ToString("0.0")s</span></div>@if(scores.NeedsReview){<div class="vp-warning"><i class="bi bi-exclamation-triangle"></i><div><b>Cần AI/giáo viên review độ rõ chữ</b><span>STT không có word-confidence ≥ 0,8 hoặc WA dưới 85%; hệ thống không trừ điểm cứng để tránh chấm oan.</span></div></div>}</section>}
</main>

@code {
    private IJSObjectReference? module; private int selectedIndex; private bool recording,busy; private AudioMetrics? result; private string transcript=""; private ScoreResult? scores;
    private Scenario Current=>Scenarios[selectedIndex];
    protected override async Task OnAfterRenderAsync(bool first){if(first)module=await JS.InvokeAsync<IJSObjectReference>("import","/js/voicePractice.js");}
    private async Task ToggleRecording(){if(module is null)return;busy=true;try{if(!recording){Reset();await module.InvokeVoidAsync("startRecording");recording=true;}else{result=await module.InvokeAsync<AudioMetrics>("stopRecording");recording=false;transcript=result.Transcript??"";Score();}}finally{busy=false;}}
    private void Reset(){result=null;scores=null;transcript="";}
    private void Score(){if(result is null)return;var words=Tokens(transcript);var refWords=Tokens(Current.Script);var rate=result.Duration>0?words.Length/result.Duration*60:0;double pacing=rate is>=160 and<=210?3:rate is>=140 and<=230?2.3:rate>0?1:0;var wa=refWords.Length==0?0:Math.Max(0,1-(double)Distance(refWords,words)/refWords.Length);var trusted=result.Confidence>=.8;double? articulation=trusted?(wa>=.95?3:wa>=.85?2.2:null):null;var fillers=new[]{"ờ","à","ừm","thì","là","kiểu","á","mà","đấy"}.Sum(f=>words.Count(w=>w==f));double fluency=fillers<=Math.Max(2,result.Duration/30*2)?1.2:.6;fluency+=result.LongestSilence<=1.5?.8:result.LongestSilence<=2?.5:0;var tone=(result.PitchSd>=15?1:result.PitchSd>=8?.6:.3)+(result.RmsVariation>=.25?1:result.RmsVariation>=.12?.6:.3);var rows=new List<ScoreRow>{new("Tốc độ nói","bi-speedometer2",pacing,3,$"{rate:0} âm tiết/phút · mục tiêu 160–210."),new("Độ rõ chữ","bi-spellcheck",articulation,3,$"WA {wa:P0} · confidence {result.Confidence:0.00}."),new("Từ đệm & khoảng lặng","bi-pause-circle",fluency,2,$"{fillers} từ đệm · khoảng lặng dài nhất {result.LongestSilence:0.0}s."),new("Tông giọng","bi-soundwave",tone,2,$"F0 SD {result.PitchSd:0.0} Hz · RMS variation {result.RmsVariation:0.00}.")};var known=rows.Where(x=>x.Score.HasValue).Sum(x=>x.Score!.Value);scores=new(known,known>=8?"Tự nhiên và thuyết phục":known>=6?"Khá rõ ràng":"Cần luyện thêm",articulation is null?"Điểm tổng tạm tính, chưa cộng mục độ rõ chữ.":"Điểm được tính từ transcript và tín hiệu âm thanh.",articulation is null||wa<.85,rows);}
    private static string[] Tokens(string s)=>System.Text.RegularExpressions.Regex.Replace(s.ToLowerInvariant(),@"[^\p{L}\p{N}\s]"," ").Split(' ',StringSplitOptions.RemoveEmptyEntries);
    private static int Distance(string[] a,string[] b){var d=new int[a.Length+1,b.Length+1];for(int i=0;i<=a.Length;i++)d[i,0]=i;for(int j=0;j<=b.Length;j++)d[0,j]=j;for(int i=1;i<=a.Length;i++)for(int j=1;j<=b.Length;j++)d[i,j]=Math.Min(Math.Min(d[i-1,j]+1,d[i,j-1]+1),d[i-1,j-1]+(a[i-1]==b[j-1]?0:1));return d[a.Length,b.Length];}
    public async ValueTask DisposeAsync(){if(module is not null)await module.DisposeAsync();}
    private sealed record Scenario(string Title,string Context,string Script);
    private sealed class AudioMetrics{public double Duration{get;set;}public string? Transcript{get;set;}public double Confidence{get;set;}public string AudioUrl{get;set;}="";public double SilenceSeconds{get;set;}public double LongestSilence{get;set;}public double RmsVariation{get;set;}public double MeanPitch{get;set;}public double PitchSd{get;set;}}
    private sealed record ScoreRow(string Name,string Icon,double? Score,double Max,string Feedback);private sealed record ScoreResult(double Total,string Label,string Note,bool NeedsReview,List<ScoreRow> Rows);
    private static readonly List<Scenario> Scenarios=[
      new("Giới thiệu tại Ngày hội Hướng nghiệp","Bạn muốn gây ấn tượng nhanh với nhà tuyển dụng.","Em chào anh chị ạ, em tên Nguyễn Minh Nam, hiện đang học lớp 12, định hướng theo ngành Công nghệ thông tin. Em mạnh về tư duy logic và thích làm việc nhóm. Em đang tìm cơ hội học hỏi thêm ở lĩnh vực lập trình, không biết bên mình có vị trí nào phù hợp không ạ? Em cảm ơn anh chị."),
      new("Nhắc bạn nộp bài trễ","Bạn cùng nhóm trễ một ngày và báo cáo còn ba ngày.","Ê, bài của cậu tới giờ vẫn chưa gửi, trễ một ngày rồi đó. Tớ hơi lo vì chỉ còn ba ngày nữa là báo cáo. Cậu đang bận gì hả, có cần tụi mình hỗ trợ không? Tớ mong tối nay trước tám giờ cậu gửi để nhóm ghép nội dung kịp nha."),
      new("Xin đổi ca làm thêm","Lịch thi trùng ca làm tối thứ Bảy.","Em chào anh Lâm ạ, tối thứ Bảy này em có ca làm nhưng lịch thi của trường lại trùng đúng giờ đó. Em hỏi bạn Vy rồi, bạn ấy đồng ý trực thay em. Anh xem giúp em đổi ca được không ạ? Em cảm ơn anh nhiều."),
      new("Xin gia hạn vì bị bệnh","Bạn nhập viện ngay trước hạn nộp bài.","Dạ em chào thầy cô ạ, em là Trần Minh Tuấn lớp 12A1. Em đang bị sốt cao, phải nhập viện nên chưa nộp bài kịp. Em có giấy xác nhận của bệnh viện, mong thầy cô cho em xin gia hạn tới thứ Năm ạ. Em cảm ơn thầy cô nhiều."),
      new("Cân đối chi phí họp nhóm","Địa điểm được đề xuất vượt ngân sách.","Khôi ơi, ý tưởng họp ở quán đó nghe hay, nhưng chi phí chắc vượt ngân sách tụi mình đặt ra rồi. Nếu chi nhiều quá, mấy tuần sau nhóm sẽ thiếu tiền in tài liệu. Hay mình họp ở thư viện trường cho đỡ tốn, được không?"),
      new("Phân biệt sự thật và ý kiến","Bạn mở đầu bài thuyết trình tư duy phản biện.","Mọi người để ý nha, sự thật là những điều mình có thể kiểm chứng được. Còn ý kiến chỉ là quan điểm riêng của mỗi người, chưa chắc đã có bằng chứng đi kèm. Khi tìm hiểu vấn đề, mình cần phân biệt rõ đâu là sự thật, đâu là ý kiến cá nhân."),
      new("An ủi bạn khó khăn tài chính","Bạn cùng phòng đang lo hạn đóng tiền.","Tớ hiểu cậu đang rất căng thẳng vì tiền chưa kịp về mà hạn đóng thì sắp tới rồi. Cậu đừng lo quá nha, mình lên phòng công tác học sinh hỏi thử, hoặc nếu cần thì tớ có ít tiền để dành, cậu mượn tạm đóng trước cũng được."),
      new("Thương lượng địa điểm họp","Một số bạn không thoải mái với quán cà phê đắt và ồn.","Họp ở quán cà phê thì vui thật, nhưng ồn quá dễ mất tập trung. Hay tụi mình họp ở thư viện trước hai tiếng cho xong việc, rồi ai rảnh thì đi cà phê sau, mọi người thấy sao?"),
      new("Tiếp thu góp ý","Thầy cô chỉ ra lỗi lập luận trước lớp.","Dạ em cảm ơn thầy cô đã góp ý ạ. Em thấy đúng là phần lập luận của nhóm còn thiếu dẫn chứng cụ thể nên chưa thuyết phục. Em sẽ tìm thêm tài liệu và bổ sung dẫn chứng để hoàn thiện bài tốt hơn ạ."),
      new("Khuyến khích bạn rụt rè","Minh ngại phát biểu khi thảo luận.","Minh ơi, đừng ngại nha, ý kiến của cậu quan trọng với nhóm lắm. Hay Minh viết trước ý chính ra giấy hoặc nhắn vào nhóm chat, để tụi mình đọc và bàn từ từ cũng được mà."),
      new("Báo trễ vì xe hỏng","Bạn gọi nhóm trưởng trước giờ thuyết trình.","Alo Vy hả, Tuấn đây. Tớ gọi báo nhanh là xe bị thủng lốp giữa đường. Chắc tớ trễ khoảng mười lăm phút. Cậu báo nhóm cứ thuyết trình phần đầu trước cho kịp giờ nha. Xin lỗi cả nhóm nhiều."),
      new("Góp ý slide","Slide của bạn rối font, màu và chính tả.","Slide cậu tìm hình đẹp lắm, trực quan nè. Tớ nghĩ nếu mình đồng bộ lại một kiểu font và bớt màu nền nổi thì người xem sẽ dễ tập trung vào nội dung hơn. Tối nay tụi mình cùng chỉnh lại chút được không?"),
      new("Giải quyết mâu thuẫn sửa bài","Hà tự ý sửa và xóa phần bạn viết.","Hà ơi, tớ biết cậu sửa bài để kịp tiến độ, cảm ơn cậu. Nhưng cậu sửa mà không nói trước khiến tớ hơi buồn. Tối nay tụi mình gọi video mười lăm phút, đối chiếu hai bản rồi chọn bản tốt hơn nha?"),
      new("Từ chối làm bài hộ","Bạn cần tập trung cho bài kiểm tra ngày mai.","Tớ cũng muốn giúp cậu, nhưng mai tớ có bài kiểm tra quan trọng, tối nay cần tập trung ôn. Tớ không làm bài hộ cậu được. Nếu sau kỳ thi cậu vẫn chưa hiểu dạng bài này thì tụi mình học nhóm với nhau nha."),
      new("Nhắc dọn phòng theo OTFD","Phòng bừa bộn ảnh hưởng không gian học.","Bình ơi, tớ thấy tuần này rác chưa dọn, sàn nhà cũng bừa bộn. Tớ nghĩ cứ để vậy phòng mình sẽ mất vệ sinh. Điều đó làm tớ hơi căng thẳng, khó tập trung học. Từ tuần sau mình quay lại đúng lịch dọn dẹp nha?"),
      new("Xin tư vấn vì điểm kém","Bạn lo môn Toán ảnh hưởng lộ trình học.","Dạ em chào thầy cô ạ, em muốn xin tư vấn về việc học. Kỳ này em bị điểm không tốt môn Toán, mà đây là môn quan trọng cho các môn sau nên em hơi lo. Thầy cô có thể hướng dẫn em cách cải thiện kế hoạch học kỳ tới không ạ?"),
      new("Phản bác định kiến","Một bình luận trong nhóm lớp mang định kiến giới.","Mình tôn trọng ý kiến của bạn, nhưng câu này nghe hơi định kiến và không đúng với thực tế. Học giỏi hay không nằm ở cách mình tư duy và cố gắng, chứ không phải do là con trai hay con gái. Mình hãy nhìn vào kết quả thực tế cho công bằng nha."),
      new("Xin lỗi vì trễ báo cáo","Bạn quên hạn gửi báo cáo cho quản lý.","Em chào anh Lâm, em xin lỗi vì gửi báo cáo trễ so với hạn năm giờ chiều nay. Em gửi lại báo cáo đầy đủ đây ạ. Em đã cài nhắc nhở trên điện thoại để lần sau không bị trễ nữa."),
      new("Điều phối công việc nhóm","Một bạn muốn nhận hết phần thuyết trình.","Cảm ơn cậu đã xung phong thuyết trình, nhưng theo thỏa thuận nhóm thì mỗi người nên làm đều cả nghiên cứu và trình bày để ai cũng được rèn kỹ năng và điểm chia công bằng. Hay mình chia đôi phần thuyết trình lần này được không?"),
      new("Kêu gọi tham gia tình nguyện","Bạn kêu gọi cả lớp tham gia câu lạc bộ.","Tham gia hoạt động tình nguyện không chỉ là làm việc thiện. Đây còn là cơ hội để mình rèn kỹ năng mềm, quen thêm nhiều bạn mới và trưởng thành hơn mỗi ngày. Hãy bước ra khỏi lớp học và hành động ngay hôm nay để tạo nên khác biệt cho cộng đồng!")];
}

<style>
.vp-page{--p:#6847eb;--ink:#18163d;--muted:#697386;max-width:1250px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:var(--ink)}.vp-back{border:0;background:none;color:#707789;font-weight:800}.vp-hero{display:flex;justify-content:space-between;gap:2rem;margin:1rem 0;padding:2rem;border-radius:26px;background:linear-gradient(135deg,#fff,#eee9ff);box-shadow:0 18px 45px #4c1d9514}.vp-hero span,.vp-script small,.vp-context small{color:var(--p);font-size:.65rem;font-weight:900;letter-spacing:.08em}.vp-hero h1{margin:.5rem 0;font-size:clamp(2rem,5vw,3.5rem)}.vp-hero h1 em{color:var(--p);font-style:normal}.vp-hero p{color:var(--muted)}.vp-stack{display:grid;grid-template-columns:auto auto;align-content:center;gap:.25rem .7rem;padding:1rem;border-radius:18px;background:#ffffffaa}.vp-stack b{color:var(--p)}.vp-stack i{grid-column:1/-1;text-align:center}.vp-grid{display:grid;grid-template-columns:320px 1fr;gap:1rem}.vp-grid aside,.vp-studio,.vp-results{padding:1.3rem;border:1px solid #ded8f5;border-radius:22px;background:#fff}.vp-grid aside label{font-size:.65rem;font-weight:900}.vp-grid select{width:100%;margin:.5rem 0 1rem;padding:.75rem;border:1px solid #ddd6f5;border-radius:11px}.vp-context{padding:1rem;border-radius:14px;background:#f7f5ff}.vp-context p{font-size:.8rem;line-height:1.55}.vp-rules{display:grid;gap:.5rem;margin-top:1rem}.vp-rules span{display:flex;justify-content:space-between;color:var(--muted);font-size:.75rem}.vp-rules i{color:var(--p);font-style:normal;font-weight:900}.vp-script{padding:1rem;border-left:4px solid var(--p);border-radius:10px;background:#f8f7fc}.vp-script p{line-height:1.65}.vp-recorder{display:flex;flex-direction:column;align-items:center;padding:2rem;text-align:center}.vp-mic{display:grid;place-items:center;width:74px;height:74px;margin-bottom:.7rem;color:#fff;border-radius:50%;background:linear-gradient(135deg,#6847eb,#a855f7);font-size:1.7rem}.recording .vp-mic{animation:pulse 1s infinite}.vp-recorder span{margin:.35rem;color:var(--muted);font-size:.75rem}.vp-recorder button,.vp-transcript button{padding:.75rem 1rem;color:#fff;border:0;border-radius:11px;background:var(--p);font-weight:800}.vp-studio audio{width:100%}.vp-transcript{display:block;margin-top:1rem;font-size:.65rem;font-weight:900}.vp-transcript textarea{display:block;width:100%;min-height:80px;margin:.4rem 0;padding:.7rem;border:1px solid #ddd6f5;border-radius:10px}.vp-results{margin-top:1rem}.vp-results>header{display:flex;align-items:center;gap:1rem}.vp-total{display:flex;align-items:end}.vp-total b{font-size:2.7rem;color:var(--p)}.vp-score-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-top:1rem}.vp-score-grid article{padding:1rem;border-radius:14px;background:#f8f7fc}.vp-score-grid article>div{display:flex;gap:.5rem}.vp-score-grid strong{margin-left:auto;color:var(--p)}.vp-score-grid p{color:var(--muted);font-size:.75rem}.vp-tech{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1rem}.vp-tech span{padding:.45rem .6rem;border-radius:8px;background:#eeeaff;font-size:.7rem}.vp-warning{display:flex;gap:.7rem;margin-top:1rem;padding:1rem;color:#985b00;border-radius:12px;background:#fff5da}.vp-warning span{display:block;font-size:.75rem}@@keyframes pulse{50%{box-shadow:0 0 0 16px #6847eb22}}@@media(max-width:800px){.vp-grid{grid-template-columns:1fr}.vp-hero{flex-direction:column}.vp-score-grid{grid-template-columns:1fr}}
</style>
