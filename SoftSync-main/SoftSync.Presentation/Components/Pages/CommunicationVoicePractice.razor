@page "/roadmap/voice-practice/{UserId:int}/{ItemId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.Presentation.Services
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject SoftSync.BLL.Interfaces.IRoadmapService RoadmapService
@inject IAiLearningEvaluationService AiEvaluator
@implements IAsyncDisposable

<PageTitle>@Tx("Voice Practice", "Luyện giọng nói") · SoftSync</PageTitle>
<main class="vp-page">
    <button class="vp-back" @onclick="BackToLesson"><i class="bi bi-arrow-left"></i> @Tx("Back to lesson", "Quay lại bài học")</button>
    <header class="vp-hero"><div><span>GAME 5 · VOICE LAB</span><h1>@Tx("Voice practice", "Luyện giọng nói") <em>@Tx("30 seconds", "30 giây")</em></h1><p>@Tx("Record a real-life response. Content and paralinguistic signals are analyzed through two independent pipelines.", "Ghi âm một tình huống thực tế. Nội dung và tín hiệu cận lời được phân tích bằng hai pipeline độc lập.")</p></div><div class="vp-stack"><b>STT</b><span>@Tx("Content", "Nội dung") · WA</span><i>+</i><b>DSP</b><span>@Tx("Pacing", "Nhịp") · Pitch · RMS</span></div></header>

    <section class="vp-grid">
        <aside><label>@Tx("CHOOSE A PRACTICE TOPIC", "CHỌN ĐỀ LUYỆN")</label><select @bind="selectedIndex" @bind:after="Reset">@for(var i=0;i<Scenarios.Count;i++){<option value="@i">@Tx("Topic", "Đề") @(i+1): @ScenarioTitle(i)</option>}</select><div class="vp-context"><small>@Tx("CONTEXT", "BỐI CẢNH")</small><p>@CurrentContext</p></div><div class="vp-rules"><b>Rubric · 10 @Tx("points", "điểm")</b><span>Pacing <i>3.0</i></span><span>@Tx("Articulation", "Độ rõ chữ") <i>3.0</i></span><span>@Tx("Fillers & pauses", "Từ đệm & khoảng lặng") <i>2.0</i></span><span>@Tx("Tone", "Tông giọng") <i>2.0</i></span></div></aside>
        <article class="vp-studio">
            <div class="vp-script"><small>@Tx("SUGGESTED SCRIPT", "VĂN BẢN GỢI Ý")</small><p>“@CurrentScript”</p></div>
            <div class="vp-recorder @(recording ? "recording" : "")"><div class="vp-mic"><i class="bi bi-mic-fill"></i></div><b>@(recording ? Tx("Recording...", "Đang ghi âm...") : result is null ? Tx("Ready to practice", "Sẵn sàng luyện tập") : Tx("Recording analyzed", "Đã phân tích bản ghi"))</b><span>@(recording ? Tx("Speak naturally and clearly, with appropriate pauses", "Nói tự nhiên, rõ ràng và có khoảng nghỉ hợp lý") : Tx("Allow microphone access and record for about 30 seconds", "Cho phép micro và ghi trong khoảng 30 giây"))</span><button disabled="@busy" @onclick="ToggleRecording"><i class="bi @(recording ? "bi-stop-fill" : "bi-record-circle")"></i> @(recording ? Tx("Stop & analyze", "Dừng & phân tích") : Tx("Start recording", "Bắt đầu ghi âm"))</button></div>
            @if(result is not null){<audio controls src="@result.AudioUrl"></audio><label class="vp-transcript">STT @Tx("TRANSCRIPT", "BẢN GHI") <small>@Tx("(edit if browser recognition is inaccurate)", "(có thể sửa nếu trình duyệt nghe sai)")</small><textarea @bind="transcript"></textarea><button @onclick="Score">@Tx("Rescore transcript", "Chấm lại từ transcript")</button></label>}
        </article>
    </section>

    @if(scores is not null){<section class="vp-results"><header><div class="vp-total"><b>@scores.Total.ToString("0.0")</b><span>/10</span></div><div><small>@Tx("ANALYSIS RESULT", "KẾT QUẢ PHÂN TÍCH")</small><h2>@scores.Label</h2><p>@scores.Note</p></div></header><div class="vp-score-grid">@foreach(var row in scores.Rows){<article><div><i class="bi @row.Icon"></i><b>@row.Name</b><strong>@(row.Score.HasValue ? row.Score.Value.ToString("0.0") : "—")/@row.Max</strong></div><p>@row.Feedback</p></article>}</div><div class="vp-tech"><b><i class="bi bi-activity"></i> @Tx("Signal metrics", "Chỉ số tín hiệu")</b><span>@result!.Duration.ToString("0.0")s</span><span>F0 SD @result.PitchSd.ToString("0.0") Hz</span><span>RMS variation @result.RmsVariation.ToString("0.00")</span><span>@Tx("Longest silence", "Im lặng dài nhất") @result.LongestSilence.ToString("0.0")s</span></div>@if(scores.NeedsReview){<div class="vp-warning"><i class="bi bi-exclamation-triangle"></i><div><b>@Tx("AI/teacher articulation review recommended", "Cần AI/giáo viên review độ rõ chữ")</b><span>@Tx("STT confidence is below 0.8 or WA is below 85%; no fixed deduction is applied to avoid unfair scoring.", "STT không có confidence ≥ 0,8 hoặc WA dưới 85%; hệ thống không trừ điểm cứng để tránh chấm oan.")</span></div></div>}<div class="vp-disclaimer"><i class="bi bi-info-circle"></i>@Tx("Instant scoring uses browser STT and local signal analysis. Production audio should be reprocessed server-side with Whisper/FPT and Praat.", "Điểm tức thời dùng STT trình duyệt và phân tích tín hiệu cục bộ. Bản production nên xử lý lại audio bằng Whisper/FPT và Praat phía server.")</div><button class="vp-complete" disabled="@saving" @onclick="SaveAndContinue">@(saving ? Tx("Saving...", "Đang lưu...") : Tx("Save result and continue", "Lưu kết quả và tiếp tục"))</button>@if(!string.IsNullOrWhiteSpace(saveMessage)){<p class="vp-save">@saveMessage</p>}</section>}
</main>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    private IJSObjectReference? module; private int selectedIndex; private bool recording,busy; private AudioMetrics? result; private string transcript=""; private ScoreResult? scores;
    private bool saving; private string saveMessage="";
    private bool IsVi=>L.Current==AppLanguage.Vi;
    private string Tx(string en,string vi)=>IsVi?vi:en;
    private Scenario Current=>Scenarios[selectedIndex];
    private Scenario CurrentEnglish=>EnglishScenarios[selectedIndex];
    private string ScenarioTitle(int index)=>IsVi?Scenarios[index].Title:EnglishScenarios[index].Title;
    private string CurrentContext=>IsVi?Current.Context:CurrentEnglish.Context;
    private string CurrentScript=>IsVi?Current.Script:CurrentEnglish.Script;
    protected override async Task OnAfterRenderAsync(bool first){if(first)module=await JS.InvokeAsync<IJSObjectReference>("import","/js/voicePractice.js");}
    private async Task ToggleRecording(){if(module is null)return;busy=true;try{if(!recording){Reset();await module.InvokeVoidAsync("startRecording",IsVi?"vi-VN":"en-US");recording=true;}else{result=await module.InvokeAsync<AudioMetrics>("stopRecording");recording=false;transcript=result.Transcript??"";await Score();}}finally{busy=false;}}
    private void Reset(){result=null;scores=null;transcript="";}
    private async Task Score(){if(result is null)return;busy=true;try{var words=Tokens(transcript);var refWords=Tokens(CurrentScript);var rate=result.Duration>0?words.Length/result.Duration*60:0;double pacing=rate is>=160 and<=210?3:rate is>=140 and<=230?2.3:rate>0?1:0;var wa=refWords.Length==0?0:Math.Max(0,1-(double)Distance(refWords,words)/refWords.Length);var trusted=result.Confidence>=.8;double? articulation=trusted?(wa>=.95?3:wa>=.85?2.2:null):null;var fillerWords=IsVi?new[]{"ờ","à","ừm","thì","là","kiểu","á","mà","đấy"}:new[]{"um","uh","like","actually","basically","well"};var fillers=fillerWords.Sum(f=>words.Count(w=>w==f));double fluency=fillers<=Math.Max(2,result.Duration/30*2)?1.2:.6;fluency+=result.LongestSilence<=1.5?.8:result.LongestSilence<=2?.5:0;var tone=(result.PitchSd>=15?1:result.PitchSd>=8?.6:.3)+(result.RmsVariation>=.25?1:result.RmsVariation>=.12?.6:.3);var rows=new List<ScoreRow>{new(Tx("Speaking pace","Tốc độ nói"),"bi-speedometer2",pacing,3,IsVi?$"{rate:0} âm tiết/phút · mục tiêu 160–210.":$"{rate:0} words/minute · target 160–210."),new(Tx("Articulation","Độ rõ chữ"),"bi-spellcheck",articulation,3,$"WA {wa:P0} · confidence {result.Confidence:0.00}."),new(Tx("Fillers & pauses","Từ đệm & khoảng lặng"),"bi-pause-circle",fluency,2,IsVi?$"{fillers} từ đệm · khoảng lặng dài nhất {result.LongestSilence:0.0}s.":$"{fillers} filler words · longest silence {result.LongestSilence:0.0}s."),new(Tx("Tone","Tông giọng"),"bi-soundwave",tone,2,$"F0 SD {result.PitchSd:0.0} Hz · RMS variation {result.RmsVariation:0.00}.")};var note=articulation is null?Tx("The total is provisional and does not include articulation.","Điểm tổng tạm tính, chưa cộng mục độ rõ chữ."):Tx("The score is calculated from the transcript and audio signal.","Điểm được tính từ transcript và tín hiệu âm thanh.");var ai=await AiEvaluator.EvaluateVoiceAsync(new(CurrentContext,transcript,result.Duration,result.Confidence,rate,wa,fillers,result.LongestSilence,result.PitchSd,result.RmsVariation),IsVi);if(ai is not null){pacing=Math.Clamp(ai.PacingScore,0,3);articulation=Math.Clamp(ai.ArticulationScore,0,3);fluency=Math.Clamp(ai.FluencyScore,0,2);tone=Math.Clamp(ai.ToneScore,0,2);rows=[new(Tx("Speaking pace","Tốc độ nói"),"bi-speedometer2",pacing,3,IsVi?$"{rate:0} âm tiết/phút · AI + chỉ số đo.":$"{rate:0} words/minute · AI + measured signal."),new(Tx("Articulation","Độ rõ chữ"),"bi-spellcheck",articulation,3,$"WA {wa:P0} · confidence {result.Confidence:0.00}."),new(Tx("Fillers & pauses","Từ đệm & khoảng lặng"),"bi-pause-circle",fluency,2,IsVi?$"{fillers} từ đệm · khoảng lặng {result.LongestSilence:0.0}s.":$"{fillers} fillers · longest silence {result.LongestSilence:0.0}s."),new(Tx("Tone","Tông giọng"),"bi-soundwave",tone,2,$"F0 SD {result.PitchSd:0.0} Hz · RMS {result.RmsVariation:0.00}.")];note=IsVi?ai.FeedbackVi:ai.FeedbackEn;}var known=rows.Where(x=>x.Score.HasValue).Sum(x=>x.Score!.Value);scores=new(known,known>=8?Tx("Natural and persuasive","Tự nhiên và thuyết phục"):known>=6?Tx("Fairly clear","Khá rõ ràng"):Tx("Needs more practice","Cần luyện thêm"),note,articulation is null||wa<.85,rows);}finally{busy=false;}}
    private static string[] Tokens(string s)=>System.Text.RegularExpressions.Regex.Replace(s.ToLowerInvariant(),@"[^\p{L}\p{N}\s]"," ").Split(' ',StringSplitOptions.RemoveEmptyEntries);
    private static int Distance(string[] a,string[] b){var d=new int[a.Length+1,b.Length+1];for(int i=0;i<=a.Length;i++)d[i,0]=i;for(int j=0;j<=b.Length;j++)d[0,j]=j;for(int i=1;i<=a.Length;i++)for(int j=1;j<=b.Length;j++)d[i,j]=Math.Min(Math.Min(d[i-1,j]+1,d[i,j-1]+1),d[i-1,j-1]+(a[i-1]==b[j-1]?0:1));return d[a.Length,b.Length];}
    private async Task SaveAndContinue(){if(scores is null||result is null)return;saving=true;saveMessage="";var rows=scores.Rows;var attempt=new SoftSync.Common.Dtos.RoadmapRoleplayAttemptDto{ScenarioId=selectedIndex+1,UserMessages=[transcript,$"duration:{result.Duration:0.00}",$"pitchSd:{result.PitchSd:0.00};rms:{result.RmsVariation:0.000};silence:{result.LongestSilence:0.00}"],AiMessages=[scores.Note],EmotionalIntelligenceScore=rows[0].Score??0,ActiveListeningScore=rows[1].Score??0,IStatementScore=rows[2].Score??0,SolutionScore=rows[3].Score??0,TotalScore=scores.Total,Feedback=string.Join(" ",rows.Select(x=>x.Feedback))};if(await RoadmapService.SaveRoleplayAttemptAsync(ItemId,UserId,attempt))Nav.NavigateTo($"/roadmap/lecture/{UserId}/{ItemId}");else saveMessage=Tx("Could not save this practice attempt. Please try again.","Không thể lưu lượt thực hành. Hãy thử lại.");saving=false;}
    private void BackToLesson()=>Nav.NavigateTo($"/roadmap/lecture/{UserId}/{ItemId}");
    public async ValueTask DisposeAsync(){if(module is not null)await module.DisposeAsync();}
    private sealed record Scenario(string Title,string Context,string Script);
    private sealed class AudioMetrics{public double Duration{get;set;}public string? Transcript{get;set;}public double Confidence{get;set;}public string AudioUrl{get;set;}="";public double SilenceSeconds{get;set;}public double LongestSilence{get;set;}public double RmsVariation{get;set;}public double MeanPitch{get;set;}public double PitchSd{get;set;}}
    private sealed record ScoreRow(string Name,string Icon,double? Score,double Max,string Feedback);private sealed record ScoreResult(double Total,string Label,string Note,bool NeedsReview,List<ScoreRow> Rows);
    private static readonly List<Scenario> Scenarios=[
      new("Giới thiệu tại Ngày hội Hướng nghiệp","Bạn muốn gây ấn tượng nhanh với nhà tuyển dụng.","Em chào anh chị ạ, em tên Nguyễn Minh Nam, hiện đang học lớp 12, định hướng theo ngành Công nghệ thông tin. Em mạnh về tư duy logic và thích làm việc nhóm. Em đang tìm cơ hội học hỏi thêm ở lĩnh vực lập trình, không biết bên mình có vị trí nào phù hợp không ạ? Em cảm ơn anh chị."),
      new("Nhắc bạn nộp bài trễ","Bạn cùng nhóm trễ một ngày và báo cáo còn ba ngày.","Ê, bài của cậu tới giờ vẫn chưa gửi, trễ một ngày rồi đó. Tớ hơi lo vì chỉ còn ba ngày nữa là báo cáo. Cậu đang bận gì hả, có cần tụi mình hỗ trợ không? Tớ mong tối nay trước tám giờ cậu gửi để nhóm ghép nội dung kịp nha."),
      new("Xin đổi ca làm thêm","Lịch thi trùng ca làm tối thứ Bảy.","Em chào anh Lâm ạ, tối thứ Bảy này em có ca làm nhưng lịch thi của trường lại trùng đúng giờ đó. Em hỏi bạn Vy rồi, bạn ấy đồng ý trực thay em. Anh xem giúp em đổi ca được không ạ? Em cảm ơn anh nhiều."),
      new("Xin gia hạn vì bị bệnh","Bạn nhập viện ngay trước hạn nộp bài.","Dạ em chào thầy cô ạ, em là Trần Minh Tuấn lớp 12A1. Em đang bị sốt cao, phải nhập viện nên chưa nộp bài kịp. Em có giấy xác nhận của bệnh viện, mong thầy cô cho em xin gia hạn tới thứ Năm ạ. Em cảm ơn thầy cô nhiều."),
      new("Cân đối chi phí họp nhóm","Địa điểm được đề xuất vượt ngân sách.","Khôi ơi, ý tưởng họp ở quán đó nghe hay, nhưng chi phí chắc vượt ngân sách tụi mình đặt ra rồi. Nếu chi nhiều quá, mấy tuần sau nhóm sẽ thiếu tiền in tài liệu. Hay mình họp ở thư viện trường cho đỡ tốn, được không?"),
      new("Phân biệt sự thật và ý kiến","Bạn mở đầu bài thuyết trình tư duy phản biện.","Mọi người để ý nha, sự thật là những điều mình có thể kiểm chứng được. Còn ý kiến chỉ là quan điểm riêng của mỗi người, chưa chắc đã có bằng chứng đi kèm. Khi tìm hiểu vấn đề, mình cần phân biệt rõ đâu là sự thật, đâu là ý kiến cá nhân."),
      new("An ủi bạn khó khăn tài chính","Bạn cùng phòng đang lo hạn đóng tiền.","Tớ hiểu cậu đang rất căng thẳng vì tiền chưa kịp về mà hạn đóng thì sắp tới rồi. Cậu đừng lo quá nha, mình lên phòng công tác học sinh hỏi thử, hoặc nếu cần thì tớ có ít tiền để dành, cậu mượn tạm đóng trước cũng được."),
      new("Thương lượng địa điểm họp","Một số bạn không thoải mái với quán cà phê đắt và ồn.","Họp ở quán cà phê thì vui thật, nhưng ồn quá dễ mất tập trung. Hay tụi mình họp ở thư viện trước hai tiếng cho xong việc, rồi ai rảnh thì đi cà phê sau, mọi người thấy sao?"),
      new("Tiếp thu góp ý","Thầy cô chỉ ra lỗi lập luận trước lớp.","Dạ em cảm ơn thầy cô đã góp ý ạ. Em thấy đúng là phần lập luận của nhóm còn thiếu dẫn chứng cụ thể nên chưa thuyết phục. Em sẽ tìm thêm tài liệu và bổ sung dẫn chứng để hoàn thiện bài tốt hơn ạ."),
      new("Khuyến khích bạn rụt rè","Minh ngại phát biểu khi thảo luận.","Minh ơi, đừng ngại nha, ý kiến của cậu quan trọng với nhóm lắm. Hay Minh viết trước ý chính ra giấy hoặc nhắn vào nhóm chat, để tụi mình đọc và bàn từ từ cũng được mà."),
      new("Báo trễ vì xe hỏng","Bạn gọi nhóm trưởng trước giờ thuyết trình.","Alo Vy hả, Tuấn đây. Tớ gọi báo nhanh là xe bị thủng lốp giữa đường. Chắc tớ trễ khoảng mười lăm phút. Cậu báo nhóm cứ thuyết trình phần đầu trước cho kịp giờ nha. Xin lỗi cả nhóm nhiều."),
      new("Góp ý slide","Slide của bạn rối font, màu và chính tả.","Slide cậu tìm hình đẹp lắm, trực quan nè. Tớ nghĩ nếu mình đồng bộ lại một kiểu font và bớt màu nền nổi thì người xem sẽ dễ tập trung vào nội dung hơn. Tối nay tụi mình cùng chỉnh lại chút được không?"),
      new("Giải quyết mâu thuẫn sửa bài","Hà tự ý sửa và xóa phần bạn viết.","Hà ơi, tớ biết cậu sửa bài để kịp tiến độ, cảm ơn cậu. Nhưng cậu sửa mà không nói trước khiến tớ hơi buồn. Tối nay tụi mình gọi video mười lăm phút, đối chiếu hai bản rồi chọn bản tốt hơn nha?"),
      new("Từ chối làm bài hộ","Bạn cần tập trung cho bài kiểm tra ngày mai.","Tớ cũng muốn giúp cậu, nhưng mai tớ có bài kiểm tra quan trọng, tối nay cần tập trung ôn. Tớ không làm bài hộ cậu được. Nếu sau kỳ thi cậu vẫn chưa hiểu dạng bài này thì tụi mình học nhóm với nhau nha."),
      new("Nhắc dọn phòng theo OTFD","Phòng bừa bộn ảnh hưởng không gian học.","Bình ơi, tớ thấy tuần này rác chưa dọn, sàn nhà cũng bừa bộn. Tớ nghĩ cứ để vậy phòng mình sẽ mất vệ sinh. Điều đó làm tớ hơi căng thẳng, khó tập trung học. Từ tuần sau mình quay lại đúng lịch dọn dẹp nha?"),
      new("Xin tư vấn vì điểm kém","Bạn lo môn Toán ảnh hưởng lộ trình học.","Dạ em chào thầy cô ạ, em muốn xin tư vấn về việc học. Kỳ này em bị điểm không tốt môn Toán, mà đây là môn quan trọng cho các môn sau nên em hơi lo. Thầy cô có thể hướng dẫn em cách cải thiện kế hoạch học kỳ tới không ạ?"),
      new("Phản bác định kiến","Một bình luận trong nhóm lớp mang định kiến giới.","Mình tôn trọng ý kiến của bạn, nhưng câu này nghe hơi định kiến và không đúng với thực tế. Học giỏi hay không nằm ở cách mình tư duy và cố gắng, chứ không phải do là con trai hay con gái. Mình hãy nhìn vào kết quả thực tế cho công bằng nha."),
      new("Xin lỗi vì trễ báo cáo","Bạn quên hạn gửi báo cáo cho quản lý.","Em chào anh Lâm, em xin lỗi vì gửi báo cáo trễ so với hạn năm giờ chiều nay. Em gửi lại báo cáo đầy đủ đây ạ. Em đã cài nhắc nhở trên điện thoại để lần sau không bị trễ nữa."),
      new("Điều phối công việc nhóm","Một bạn muốn nhận hết phần thuyết trình.","Cảm ơn cậu đã xung phong thuyết trình, nhưng theo thỏa thuận nhóm thì mỗi người nên làm đều cả nghiên cứu và trình bày để ai cũng được rèn kỹ năng và điểm chia công bằng. Hay mình chia đôi phần thuyết trình lần này được không?"),
      new("Kêu gọi tham gia tình nguyện","Bạn kêu gọi cả lớp tham gia câu lạc bộ.","Tham gia hoạt động tình nguyện không chỉ là làm việc thiện. Đây còn là cơ hội để mình rèn kỹ năng mềm, quen thêm nhiều bạn mới và trưởng thành hơn mỗi ngày. Hãy bước ra khỏi lớp học và hành động ngay hôm nay để tạo nên khác biệt cho cộng đồng!")];
    private static readonly List<Scenario> EnglishScenarios=[
      new("Career Fair Introduction","You want to make a strong first impression on a recruiter.","Hello, my name is Minh Nam. I am a grade 12 student planning to study Information Technology. I am strong in logical thinking and enjoy teamwork. I would love to learn more about programming opportunities at your organization. Could you tell me whether there is a suitable position for me? Thank you."),
      new("Remind a teammate about a late submission","A teammate is one day late and the presentation is in three days.","Hi, I have not received your section yet, and it is already one day late. I am worried because our presentation is in three days. Are you dealing with anything that the team can help with? Please send it before eight tonight so we have enough time to combine the content."),
      new("Request a shift swap","Your exam overlaps with your Saturday evening shift.","Hello Mr. Lam. My exam this Saturday evening overlaps with my work shift. I have already asked Vy, and she has agreed to cover the shift for me. Could you please approve the shift swap? Thank you very much."),
      new("Request an extension due to illness","You were hospitalized just before an assignment deadline.","Hello, I am Minh Tuan from class 12A1. I have a high fever and was admitted to the hospital, so I could not submit my assignment on time. I have a hospital certificate. Could I have an extension until Thursday? Thank you for understanding."),
      new("Balance group meeting costs","The proposed venue exceeds the group's budget.","Khoi, the suggested venue sounds nice, but it would exceed our budget. If we spend too much now, we may not have enough money to print materials later. Could we meet at the school library instead?"),
      new("Distinguish facts from opinions","You are opening a critical-thinking presentation.","A fact is something that can be verified with evidence. An opinion is a person's viewpoint and may not have supporting evidence. When examining an issue, we should clearly separate verifiable facts from personal opinions."),
      new("Support a friend with financial difficulty","Your roommate is worried about an approaching payment deadline.","I understand that you are stressed because the payment deadline is close. Let us ask the student support office about available options. If necessary, I can also lend you a small amount temporarily so you can meet the deadline."),
      new("Negotiate a meeting location","Some teammates are uncomfortable with an expensive, noisy café.","Meeting at the café could be fun, but the noise may make it hard to focus. How about working at the library for two hours first, then anyone who is free can go for coffee afterward?"),
      new("Receive feedback","Your teacher points out a reasoning problem in front of the class.","Thank you for the feedback. I agree that our argument needs more specific evidence to be convincing. I will find reliable sources and add supporting evidence to improve the presentation."),
      new("Encourage a shy teammate","Minh is reluctant to speak during a discussion.","Minh, your ideas are important to the team. You could write down your main points first or share them in the group chat. We can read them and discuss them together at a comfortable pace."),
      new("Report being late due to vehicle trouble","You call the team leader before a presentation.","Hi Vy, this is Tuan. My tire went flat on the way, so I will probably be about fifteen minutes late. Please ask the team to begin the first section without me. I am very sorry, everyone."),
      new("Give feedback on slides","A teammate's slides use inconsistent fonts, colors, and spelling.","Your images are attractive and make the slides engaging. I think using one consistent font and fewer background colors would help the audience focus. Could we review and polish them together tonight?"),
      new("Resolve conflict over edits","Ha edited and removed your work without discussing it.","Ha, I know you edited the document to keep us on schedule, and I appreciate that. However, changing my section without telling me made me feel left out. Could we compare both versions on a fifteen-minute call tonight and choose the stronger one together?"),
      new("Decline doing someone else's assignment","You need to prepare for an important test tomorrow.","I would like to help, but I have an important test tomorrow and need to study tonight. I cannot do the assignment for you. After the test, I can help explain this type of problem if you still need support."),
      new("Ask a roommate to clean using OTFD","A messy room is affecting your study space.","Binh, the trash has not been taken out this week and the floor is untidy. I think leaving it this way will make the room unhygienic. It makes me stressed and unable to focus. Could we return to our cleaning schedule next week?"),
      new("Ask for academic advice after a low grade","You worry that a low math grade will affect future courses.","Hello, I would like some academic advice. My math grade this term was low, and math is important for my later courses. Could you help me create a better study plan for next term?"),
      new("Challenge a stereotype","Someone makes a gender stereotype in the class group.","I respect your opinion, but that statement sounds stereotypical and does not reflect reality. Academic ability depends on thinking, effort, and practice, not on gender. We should evaluate people fairly based on their actual results."),
      new("Apologize for a late report","You missed the deadline for sending a report to your manager.","Hello Mr. Lam. I apologize for sending the report after today's five o'clock deadline. I have attached the complete report now. I also set a phone reminder so this will not happen again."),
      new("Coordinate group responsibilities","One teammate wants to handle the entire presentation.","Thank you for volunteering to present. However, our agreement was that everyone should contribute to both research and presenting so we all build skills and receive fair credit. Could we divide the presentation between us this time?"),
      new("Invite classmates to volunteer","You invite the whole class to join a volunteer club.","Volunteering is not only about helping others. It is also a chance to build soft skills, meet new friends, and grow every day. Let us step beyond the classroom and take action today to make a difference in our community.")];
}

