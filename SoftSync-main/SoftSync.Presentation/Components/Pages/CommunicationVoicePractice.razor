ted);font-size:.75rem}.vp-recorder button,.vp-transcript button{padding:.75rem 1rem;color:#fff;border:0;border-radius:11px;background:var(--p);font-weight:800}.vp-studio audio{width:100%}.vp-transcript{display:block;margin-top:1rem;font-size:.65rem;font-weight:900}.vp-transcript textarea{display:block;width:100%;min-height:80px;margin:.4rem 0;padding:.7rem;border:1px solid #ddd6f5;border-radius:10px}.vp-results{margin-top:1rem}.vp-results>header{display:flex;align-items:center;gap:1rem}.vp-total{display:flex;align-items:end}.vp-total b{font-size:2.7rem;color:var(--p)}.vp-score-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-top:1rem}.vp-score-grid article{padding:1rem;border-radius:14px;background:#f8f7fc}.vp-score-grid article>div{display:flex;gap:.5rem}.vp-score-grid strong{margin-left:auto;color:var(--p)}.vp-score-grid p{color:var(--muted);font-size:.75rem}.vp-tech{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:1rem}.vp-tech span{padding:.45rem .6rem;border-radius:8px;background:#eeeaff;font-size:.7rem}.vp-warning{display:flex;gap:.7rem;margin-top:1rem;padding:1rem;color:#985b00;border-radius:12px;background:#fff5da}.vp-warning span{display:block;font-size:.75rem}@@keyframes pulse{50%{box-shadow:0 0 0 16px #6847eb22}}@@media(max-width:800px){.vp-grid{grid-template-columns:1fr}.vp-hero{flex-direction:column}.vp-score-grid{grid-template-columns:1fr}}
.vp-page{position:relative;isolation:isolate}.vp-page:before,.vp-page:after{content:"";position:fixed;z-index:-1;width:32rem;height:32rem;border-radius:50%;filter:blur(4px);pointer-events:none}.vp-page:before{left:-10rem;top:5rem;background:radial-gradient(circle,rgba(96,165,250,.3),transparent 68%)}.vp-page:after{right:-8rem;bottom:-10rem;background:radial-gradient(circle,rgba(168,85,247,.28),transparent 68%)}.vp-stack,.vp-context,.vp-script,.vp-score-grid article{border:1px solid rgba(255,255,255,.72);background:linear-gradient(145deg,rgba(255,255,255,.66),rgba(238,233,255,.38));box-shadow:inset 1px 1px 0 rgba(255,255,255,.86);-webkit-backdrop-filter:blur(14px) saturate(150%);backdrop-filter:blur(14px) saturate(150%)}.vp-grid select,.vp-transcript textarea{background:rgba(255,255,255,.68);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px)}.vp-disclaimer{display:flex;gap:.7rem;margin-top:1rem;padding:1rem;color:#51468e;border:1px solid rgba(255,255,255,.74);border-radius:12px;background:rgba(242,239,255,.62);backdrop-filter:blur(14px);font-size:.76rem}.vp-complete{display:block;margin:1rem 0 0 auto;padding:.8rem 1.1rem;color:#fff;border:1px solid rgba(255,255,255,.45);border-radius:11px;background:linear-gradient(135deg,#6847eb,#8b5cf6);box-shadow:0 12px 28px rgba(104,71,235,.28),inset 1px 1px 0 rgba(255,255,255,.35);font-weight:900}.vp-complete:disabled{opacity:.6}.vp-save{color:#a33}html[data-theme="dark"] .vp-stack,html[data-theme="dark"] .vp-context,html[data-theme="dark"] .vp-script,html[data-theme="dark"] .vp-score-grid article{color:#ede9fe;border-color:rgba(196,181,253,.22);background:rgba(49,46,129,.34)}html[data-theme="dark"] .vp-grid select,html[data-theme="dark"] .vp-transcript textarea{color:#f8fafc;background:rgba(30,27,75,.7)}
