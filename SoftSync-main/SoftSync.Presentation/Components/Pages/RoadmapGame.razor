@page "/roadmap/game/{UserId:int}/{ItemId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.Common.Enums
@inject NavigationManager Nav

<PageTitle>@Tx("Roadmap quiz", "Quiz Roadmap") · SoftSync</PageTitle>

<main class="empty-quiz">
    <section><i class="bi bi-ui-checks-grid"></i><span>QUIZ</span><h1>@Tx("Quiz has not been loaded", "Chưa nạp Quiz")</h1><p>@Tx("The old quiz was removed. This route is ready for new weekly questions.", "Quiz cũ đã được xóa. Trang này đang chờ bộ câu hỏi mới theo tuần.")</p><button @onclick="Back">@Tx("Back to week", "Quay lại tuần")</button></section>
</main>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public int ItemId { get; set; }
    private void Back() => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{ItemId}?step=summary");
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
}

<style>.empty-quiz{min-height:calc(100vh - 72px);display:grid;place-items:center;padding:1rem;background:#f5f7fa;color:#17233c}.empty-quiz section{width:min(620px,100%);padding:4rem 2rem;text-align:center;border:1px solid #dfe4ec;border-radius:18px;background:#fff}.empty-quiz section>i{display:block;margin-bottom:1rem;color:#3157d5;font-size:3rem}.empty-quiz span{color:#3157d5;font-size:.7rem;font-weight:900;letter-spacing:.1em}.empty-quiz h1{margin:.5rem 0}.empty-quiz p{color:#6c7588}.empty-quiz button{margin-top:1rem;padding:.7rem 1rem;color:#fff;border:0;border-radius:9px;background:#3157d5;font-weight:800}</style>
