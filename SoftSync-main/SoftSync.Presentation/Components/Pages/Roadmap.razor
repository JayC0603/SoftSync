 .bi-star-fill{color:#ffc43d}.rm-track{display:flex;justify-content:space-between;position:relative;margin:32px 8px 30px}.rm-track:before{content:"";position:absolute;left:5%;right:5%;top:22px;height:2px;background:#e1e4eb}.rm-track-item{z-index:1;flex:1;border:0;background:transparent;display:flex;flex-direction:column;align-items:center;gap:8px;color:#8a92a3;font-size:11px}.rm-track-item span{display:grid;place-items:center;width:44px;height:44px;border-radius:50%;border:1px solid #d9dce5;background:#f7f8fa}.rm-track-item b{max-width:110px}.rm-track-item.done span,.rm-track-item.active span{color:#fff;border-color:#6046ef;background:#6046ef}.rm-track-item.active span{box-shadow:0 0 0 7px #e7e2ff}.rm-track-item.active b{color:#5b42e7}.rm-lesson{border:1px solid #e2e3f3;border-radius:18px;padding:18px;background:rgba(255,255,255,.7)}.rm-lesson-title{display:flex;align-items:flex-start;gap:14px}.rm-lesson-title>i{color:#6046ef}.rm-lesson-title h2{font-size:18px;margin:0}.rm-lesson-title p{font-size:12px;color:#7b8498}.rm-lesson-title>span{margin-left:auto;font-size:12px}.rm-steps{display:flex;flex-direction:column;gap:9px;margin-top:12px}.rm-step{position:relative;display:grid;grid-template-columns:24px 200px 1fr 145px;align-items:center;gap:14px;border:1px solid #e3e5f0;border-radius:14px;padding:12px;background:#fff}.rm-step-no{position:absolute;left:-34px;width:24px;height:24px;display:grid;place-items:center;border-radius:50%;background:#eeeef5;color:#48546a}.rm-step.done .rm-step-no{color:#fff;background:#31b766}.rm-step.current .rm-step-no{color:#fff;background:#6349ed}.rm-step-visual{height:90px;border-radius:11px;display:grid;place-items:center;font-size:38px}.rm-step-visual.blue{color:#5155da;background:#e7eaff}.rm-step-visual.green{color:#25a55b;background:#e4f8ed}.rm-step-visual.orange{color:#ef8b19;background:#fff1df}.rm-step-visual.purple{color:#7148ee;background:#eee8ff}.rm-step-copy small{font-size:10px;font-weight:850;color:#6246e7}.rm-step-copy h3{font-size:16px;margin:6px 0}.rm-step-copy p{font-size:12px;color:#748096;margin:0}.rm-step-action{display:flex;flex-direction:column;align-items:stretch;gap:8px;text-align:center}.rm-step-action em,.rm-step-action span{font-style:normal;font-size:11px;color:#2f9a5a;background:#ecf9f1;padding:8px}.rm-step-action span{color:#697386;background:#f3f4f6}.rm-step-action button.primary{color:#fff;border:0;background:#6046ed}.rm-step-action small{font-size:10px;color:#8b93a2}.rm-reward{display:flex;align-items:center;gap:20px;margin-top:14px;padding:14px;border:1px solid #e6e4f6;border-radius:14px;background:#fff;font-size:12px}.rm-reward button{margin-left:auto;border:0;border-radius:10px;padding:10px 18px}.rm-right .rm-panel>button{width:100%}.rm-ring{float:left;width:100px;height:100px;margin:0 14px 12px 0;border-radius:50%;display:grid;place-items:center;background:conic-gradient(#6046ed calc(var(--p)*1%),#e9e7fb 0);position:relative}.rm-ring:after{content:"";position:absolute;inset:11px;border-radius:50%;background:#faf9ff}.rm-ring b{z-index:1;color:#5840df;font-size:22px}.rm-skills p,.rm-stats p,.rm-reminder p{display:flex;align-items:center;gap:10px;font-size:12px;margin:16px 0}.rm-skills i{display:grid;place-items:center;width:32px;height:32px;color:#6046ed;border-radius:50%;background:#eeeaff}.rm-stats p b{margin-left:auto}.rm-reminder p span{display:flex;flex-direction:column}.rm-reminder small{color:#8b93a2}.rm-loading{min-height:60vh;display:grid;place-items:center}.rm-loading span{width:40px;height:40px;border:4px solid #eee;border-top-color:#6046ed;border-radius:50%;animation:spin 1s linear infinite}@@keyframes spin{to{transform:rotate(360deg)}}
    .rm-summary img{right:10px;top:54px;width:70px;height:58px}
    .rm-summary h2{font-size:17px;line-height:1.2;max-width:125px;min-height:42px;overflow-wrap:anywhere}
    @@media(max-width:1150px){.rm-shell{grid-template-columns:220px 1fr}.rm-right{grid-column:1/-1;display:grid;grid-template-columns:repeat(4,1fr);border-left:0;border-top:1px solid #e5e7f5}.rm-step{grid-template-columns:24px 150px 1fr 130px}}
    @@media(max-width:800px){.rm-shell{display:block}.rm-left{border:0;display:grid;grid-template-columns:1fr 1fr}.rm-mentor{display:none}.rm-main{padding:20px 12px}.rm-track{overflow-x:auto}.rm-track-item{min-width:120px}.rm-step{grid-template-columns:1fr}.rm-step-no{left:8px;top:8px}.rm-step-visual{height:120px}.rm-right{grid-template-columns:1fr 1fr}.rm-reward{flex-wrap:wrap}}
