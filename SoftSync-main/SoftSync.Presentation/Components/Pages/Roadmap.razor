@page "/roadmap-legacy"
@page "/roadmap-legacy/{UserId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@inject IRoadmapService RoadmapService
@inject IUserService UserService
@inject IAssessmentService AssessmentService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@Tx("Your Roadmap", "Lộ trình của bạn") · SoftSync</PageTitle>

<main class="pr-page">
    @if (loading)
    {
        <div class="pr-loading"><span></span>@Tx("Personalizing your roadmap...", "Đang cá nhân hóa lộ trình của bạn...")</div>
    }
    else if (user is null)
    {
        <section class="pr-empty">
            <i class="bi bi-person-exclamation"></i>
            <h1>@Tx("We could not load your learning profile", "Không thể tải hồ sơ học tập")</h1>
            <button @onclick='() => Nav.NavigateTo("/settings")'>@Tx("Open settings", "Mở cài đặt")</button>
        </section>
    }
    else if (items.Count == 0)
    {
        <section class="pr-empty">
            <i class="bi bi-stars"></i>
            <h1>@Tx("Your roadmap is being prepared", "Lộ trình của bạn đang được chuẩn bị")</h1>
            <p>@Tx("Complete the skills assessment so SoftSync can build a plan for you.", "Hãy hoàn thành bài đánh giá để SoftSync xây dựng kế hoạch phù hợp cho bạn.")</p>
            <button @onclick='() => Nav.NavigateTo($"/assessment/{UserId}")'>@Tx("Take assessment", "Làm bài đánh giá")</button>
        </section>
    }
    else
    {
        <div class="pr-shell">
            <header class="pr-heading">
                <div class="pr-heading-copy">
                    <span class="pr-eyebrow">@(RoadmapReviewMode.Enabled ? Tx("CONTENT REVIEW MODE", "CHẾ ĐỘ KIỂM DUYỆT NỘI DUNG") : Tx("YOUR ROADMAP", "LỘ TRÌNH CỦA BẠN"))</span>
                    <h1>@(RoadmapReviewMode.Enabled ? Tx("Review all roadmap content", "Kiểm tra toàn bộ nội dung Roadmap") : Tx($"Hi {FirstName}, this plan is made for you", $"Chào {FirstName}, đây là kế hoạch dành riêng cho bạn"))</h1>
                    <p>@(RoadmapReviewMode.Enabled ? Tx("All available weeks and learning steps are temporarily unlocked.", "Tất cả tuần và các bước học hiện có đang được mở khóa tạm thời.") : Tx("Personalized from your assessment, goal, and learning rhythm.", "Được cá nhân hóa từ kết quả đánh giá, mục tiêu và nhịp học của bạn."))</p>
                    <div class="pr-personal-chips">
                        @if (RoadmapReviewMode.Enabled)
                        {
                            <span><i class="bi bi-collection-play-fill"></i><b>@items.Count @Tx("weeks available", "tuần hiện có")</b></span>
                            <span><i class="bi bi-unlock-fill"></i><b>@Tx("No progress locks", "Không khóa theo tiến độ")</b></span>
                            <span><i class="bi bi-file-earmark-text-fill"></i><b>@Tx("Ready for script review", "Sẵn sàng kiểm tra script")</b></span>
                        }
                        else
                        {
                            <span><i class="bi bi-chat-dots-fill"></i>@CurrentSkillName <b>@CurrentSkillPercent%</b></span>
                            <span><i class="bi bi-bullseye"></i>@Tx("Goal", "Mục tiêu"): <b>@GoalLabel</b></span>
                            <span><i class="bi bi-clock"></i><b>@DailyMinutes @Tx("min/day", "phút/ngày") · @StudyDays @Tx("days/week", "ngày/tuần")</b></span>
                        }
                    </div>
                </div>
                @if (!RoadmapReviewMode.Enabled)
                {
                    <button class="pr-why" @onclick="ToggleReason" aria-expanded="@showReason">
                        <i class="bi bi-question-circle"></i>@Tx("Why did I get this roadmap?", "Vì sao tôi nhận lộ trình này?")
                    </button>
                }
            </header>

            @if (!RoadmapReviewMode.Enabled && showReason)
            {
                <aside class="pr-reason-panel">
                    <i class="bi bi-stars"></i>
                    <div>
                        <strong>@Tx("How SoftSync personalized this plan", "SoftSync đã cá nhân hóa như thế nào?")</strong>
                        <p>@PersonalizationExplanation</p>
                    </div>
                    <button @onclick='() => Nav.NavigateTo("/settings")'>@Tx("Update preferences", "Cập nhật tùy chọn")</button>
                </aside>
            }

            <div class="pr-grid">
                <section class="pr-main-card">
                    <nav class="pr-weeks pr-weeks-grouped" aria-label="@Tx("Roadmap weeks", "Các tuần trong lộ trình")">
                        @foreach (var group in items.Select((value, index) => new { value, index })
                            .GroupBy(entry => SkillKey(entry.value))
                            .OrderBy(group => SkillRank(group.Key)))
                        {
                            <section class="pr-skill-group">
                                <h3><i class="@SkillIcon(group.Key)"></i>@SkillGroupName(group.Key)</h3>
                                <div>
                                    @foreach (var entry in group.OrderBy(x => SkillLessonOrdinal(x.value)))
                                    {
                                        <button class="@WeekClass(entry.value, entry.index)"
                                                disabled="@(!RoadmapReviewMode.Enabled && entry.index > ActiveIndex)"
                                                title="@(!RoadmapReviewMode.Enabled && entry.index > ActiveIndex ? Tx("Complete the current week to unlock this week.", "Hoàn thành tuần hiện tại để mở khóa tuần này.") : null)"
                                                @onclick="() => SelectWeek(entry.index)">
                                            <span>@(entry.value.IsCompleted ? "✓" : SkillLessonOrdinal(entry.value).ToString())</span>
                                            <div><b>@Tx("Lesson", "Bài") @SkillLessonOrdinal(entry.value)</b><small>@WeekStatus(entry.value, entry.index)</small></div>
                                        </button>
                                    }
                                </div>
                            </section>
                        }
                    </nav>

                    <article class="pr-week-card">
                        <header class="pr-week-head">
                            <div>
                                <span>@Tx("WEEK", "TUẦN") @(selectedIndex + 1) · @SelectedSkillName.ToUpperInvariant()</span>
                                <h2>@LocalizedItemTitle(SelectedItem)</h2>
                            </div>
                            <div class="pr-workload"><i class="bi bi-clock"></i><b>@PlannedMinutes</b> / @WeeklyCapacity @Tx("minutes", "phút")</div>
                        </header>

                        <div class="pr-recommendation">
                            <i class="bi bi-star-fill"></i>
                            <span>@SelectedRecommendation</span>
                        </div>

                        <div class="pr-module-list">
                            <article class="pr-module pr-module-video @ModuleState(0)">
                                <button class="pr-module-summary" @onclick="() => ToggleVideoPanel()">
                                    <span class="pr-module-icon"><i class="bi bi-play-fill"></i></span>
                                    <span class="pr-module-copy">
                                        <b>@Tx("Video: Core lesson", "Video: Bài học trọng tâm")</b>
                                        @if (SelectedItem.IsVideoCompleted)
                                        {
                                            <small class="pr-saved-copy">@Tx("Learned · Saved", "Đã học · Đã lưu")</small>
                                        }
                                        else
                                        {
                                            <small>12 @Tx("minutes", "phút")</small>
                                        }
                                    </span>
                                    @if (SelectedItem.IsVideoCompleted)
                                    {
                                        <i class="bi bi-check-circle-fill pr-done"></i>
                                    }
                                    else if ((RoadmapReviewMode.Enabled || selectedIndex == ActiveIndex) && CanOpenVideo)
                                    {
                                        <span class="pr-continue" @onclick:stopPropagation="true" @onclick="OpenVideo">@Tx("Continue", "Tiếp tục")</span>
                                    }
                                    <i class="bi bi-chevron-down pr-chevron @(videoExpanded ? "open" : "")"></i>
                                </button>

                                @if (videoExpanded)
                                {
                                    <div class="pr-video-detail">
                                        <nav class="pr-content-tabs">
                                            <button class="@(contentTab == ContentTab.Video ? "active" : "")" @onclick="() => contentTab = ContentTab.Video">Video</button>
                                            <button class="@(contentTab == ContentTab.Script ? "active" : "")" @onclick="() => contentTab = ContentTab.Script">Script</button>
                                            <button class="@(contentTab == ContentTab.Summary ? "active" : "")" @onclick="() => contentTab = ContentTab.Summary">@Tx("Summary", "Tóm tắt")</button>
                                        </nav>

                                        @switch (contentTab)
                                        {
                                            case ContentTab.Video:
                                                <div class="pr-content-row">
                                                    <i class="bi bi-play-circle"></i>
                                                    <div><b>@LocalizedItemTitle(SelectedItem)</b><small>@Tx("Lesson video · your progress is saved automatically when the video ends.", "Video bài học · tiến độ tự động được lưu khi video phát hết.")</small></div>
                                                    <button @onclick="OpenVideo" disabled="@(!CanOpenVideo)">@(CanOpenVideo ? Tx("Open video", "Mở video") : Tx("Coming soon", "Sắp cập nhật"))</button>
                                                </div>
                                                break;
                                            case ContentTab.Script:
                                                @if (IsTimeManagementVideoOne)
                                                {
                                                    <article class="pr-script-document" lang="@(L.Current == AppLanguage.Vi ? "vi" : "en")">
                                                        <header>
                                                            <span><i class="bi bi-file-earmark-text-fill"></i></span>
                                                            <div>
                                                                <small>VIDEO 1 · SCRIPT</small>
                                                                <h3>@Tx("Introduction to Communication Skills", "Giới thiệu về kỹ năng giao tiếp")</h3>
                                                            </div>
                                                        </header>

                                                        <section>
                                                            <h4><span>1</span> @Tx("Communication is a two-way street", "Giao tiếp là “con đường hai chiều”")</h4>
                                                            <p>@Tx("Effective communication is not only about sending a message, but also receiving feedback. A basic communication process includes:", "Giao tiếp hiệu quả không chỉ là gửi đi thông điệp mà còn là tiếp nhận phản hồi. Một quá trình giao tiếp cơ bản bao gồm:")</p>
                                                            <ul>
                                                                <li><strong>@Tx("Sender:", "Người gửi:")</strong> @Tx("The person who creates and delivers the message.", "Người tạo ra và truyền đạt thông điệp.")</li>
                                                                <li><strong>@Tx("Message:", "Thông điệp:")</strong> @Tx("The content and meaning conveyed through speech, writing, or gestures.", "Nội dung, ý nghĩa bạn muốn truyền tải qua lời nói, chữ viết hoặc cử chỉ.")</li>
                                                                <li><strong>@Tx("Channel:", "Kênh truyền tải:")</strong> @Tx("How the message is delivered, such as face-to-face conversation, email, telephone, or social media.", "Cách thức thông điệp được gửi đi như nói trực tiếp, email, điện thoại hoặc mạng xã hội.")</li>
                                                                <li><strong>@Tx("Receiver:", "Người nhận:")</strong> @Tx("The person who receives and decodes the message.", "Người tiếp nhận và giải mã thông điệp đó.")</li>
                                                                <li><strong>@Tx("Feedback:", "Phản hồi:")</strong> @Tx("The receiver's response, which helps the sender know whether the message was understood correctly.", "Sự hồi đáp của người nhận giúp người gửi biết thông điệp đã được hiểu đúng hay chưa.")</li>
                                                            </ul>
                                                        </section>

                                                        <section>
                                                            <h4><span>2</span> @Tx("Essential skills for students", "Các kỹ năng then chốt cho sinh viên")</h4>
                                                            <ul>
                                                                <li><strong>@Tx("Active Listening:", "Lắng nghe chủ động (Active Listening):")</strong> @Tx("This is the most important skill. Do not merely hear sounds; give your full attention, avoid interrupting, and confirm what you heard to prevent misunderstandings.", "Đây là kỹ năng quan trọng nhất. Đừng chỉ “nghe” thấy âm thanh; hãy tập trung hoàn toàn, không ngắt lời và xác nhận lại những gì bạn đã nghe để tránh hiểu lầm.")</li>
                                                                <li><strong>@Tx("Nonverbal communication:", "Giao tiếp phi ngôn ngữ:")</strong> @Tx("Even in silence, you communicate through eye contact, gestures, clothing, and posture. Body language often carries more weight than words.", "Ngay cả khi im lặng, bạn vẫn đang giao tiếp thông qua ánh mắt, điệu bộ, trang phục và tư thế ngồi. Ngôn ngữ cơ thể thường có sức nặng hơn cả lời nói.")</li>
                                                                <li><strong>@Tx("Netiquette:", "Quy tắc ứng xử mạng (Netiquette):")</strong> @Tx("In an academic setting, keep emails to lecturers professional by using complete sentences, a clear subject line, and a formal greeting.", "Trong môi trường học thuật, hãy giữ sự chuyên nghiệp khi viết email cho giảng viên: dùng câu chữ hoàn chỉnh, tiêu đề rõ ràng và lời chào trang trọng.")</li>
                                                            </ul>
                                                        </section>

                                                        <section>
                                                            <h4><span>3</span> @Tx("Tips for successful communication", "Bí quyết để giao tiếp thành công")</h4>
                                                            <ul>
                                                                <li><strong>@Tx("Prepare carefully:", "Luôn chuẩn bị kỹ:")</strong> @Tx("Before a presentation or important meeting, organize your ideas logically and clearly.", "Trước một buổi thuyết trình hay cuộc gặp quan trọng, hãy sắp xếp ý tưởng một cách logic và rõ ràng.")</li>
                                                                <li><strong>@Tx("Understand the context:", "Thấu hiểu bối cảnh:")</strong> @Tx("Talking with friends in the cafeteria is very different from participating in a classroom discussion. A strong communicator adapts their style to the audience and situation.", "Cách bạn nói chuyện với bạn bè tại căng tin sẽ khác hoàn toàn với cách bạn thảo luận trong lớp học. Một người giao tiếp giỏi luôn biết điều chỉnh phong cách phù hợp với đối tượng và tình huống.")</li>
                                                                <li><strong>@Tx("Communicate ethically:", "Giao tiếp có đạo đức:")</strong> @Tx("Base communication on respect, honesty, and fairness. Do not share misleading information or content that may harm others.", "Luôn dựa trên sự tôn trọng, trung thực và công bằng với người nghe. Đừng đưa ra những thông tin sai lệch hoặc gây tổn thương người khác.")</li>
                                                                <li><strong>@Tx("Use simple language:", "Sử dụng ngôn từ đơn giản:")</strong> @Tx("Choose precise, easy-to-understand words and avoid excessive jargon or slang when the listener may not know it.", "Hãy chọn từ ngữ chính xác, dễ hiểu và tránh lạm dụng biệt ngữ (jargon) hoặc từ lóng nếu người nghe không quen thuộc với chúng.")</li>
                                                            </ul>
                                                        </section>

                                                        <footer>
                                                            <i class="bi bi-lightbulb-fill"></i>
                                                            <p>@Tx("Developing communication skills is a long journey that requires patience and self-adjustment. Strong communication helps you learn more effectively and make a professional impression on future employers.", "Việc rèn luyện kỹ năng giao tiếp là một hành trình dài cần sự kiên nhẫn và tự điều chỉnh. Khi bạn giao tiếp tốt, bạn không chỉ học tập hiệu quả hơn mà còn tạo được ấn tượng chuyên nghiệp trong mắt nhà tuyển dụng tương lai.")</p>
                                                        </footer>
                                                    </article>
                                                }
                                                else
                                                {
                                                    <div class="pr-content-row pr-script-placeholder">
                                                        <i class="bi bi-file-earmark-text"></i>
                                                        <div><b>@Tx("Synchronized script", "Script đồng bộ")</b><small>@Tx("The script for this video is ready for you to update later.", "Phần script của video đang để sẵn cấu trúc để bạn cập nhật sau.")</small></div>
                                                        <span><i class="bi bi-clock-history"></i>@Tx("Timestamp ready", "Sẵn sàng gắn timestamp")</span>
                                                    </div>
                                                }
                                                break;
                                            default:
                                                <div class="pr-content-row">
                                                    <i class="bi bi-lightbulb"></i>
                                                    <div><b>@Tx("Lesson summary", "Tóm tắt bài học")</b><small>@LocalizedItemDescription(SelectedItem)</small></div>
                                                </div>
                                                break;
                                        }
                                    </div>
                                }
                            </article>

                            <article class="pr-module @ModuleState(1)">
                                <span class="pr-module-icon"><i class="bi bi-check2"></i></span>
                                <span class="pr-module-copy">
                                    <b>@Tx("Quick knowledge check", "Kiểm tra nhanh")</b>
                                    <small class="@(SelectedItem.IsPracticeCompleted ? "pr-saved-copy" : null)">@(SelectedItem.IsPracticeCompleted ? Tx("Passed · Saved", "Đã đạt · Đã lưu") : $"5 {Tx("minutes", "phút")}")</small>
                                </span>
                                @if (SelectedItem.IsPracticeCompleted) { <i class="bi bi-check-circle-fill pr-done"></i> }
                                else if ((RoadmapReviewMode.Enabled || selectedIndex == ActiveIndex && SelectedItem.IsVideoCompleted) && CanOpenPractice) { <button class="pr-continue" @onclick="OpenPractice">@Tx("Start", "Bắt đầu")</button> }
                                else { <i class="bi bi-lock-fill pr-lock"></i> }
                            </article>

                            <article class="pr-module @ModuleState(2)">
                                <span class="pr-module-icon"><i class="bi bi-chat-dots-fill"></i></span>
                                <span class="pr-module-copy"><b>@Tx("Applied scenario practice", "Thực hành tình huống")</b><small class="@(SelectedItem.IsScenarioCompleted ? "pr-saved-copy" : null)">@(SelectedItem.IsScenarioCompleted ? Tx("Completed · Saved", "Hoàn thành · Đã lưu") : $"20 {Tx("minutes", "phút")}")</small></span>
                                @if (SelectedItem.IsScenarioCompleted) { <i class="bi bi-check-circle-fill pr-done"></i> }
                                else if (RoadmapReviewMode.Enabled || SelectedItem.IsPracticeCompleted) { <button class="pr-continue" @onclick="OpenScenario">@Tx("Start", "Bắt đầu")</button> }
                                else { <i class="bi bi-lock-fill pr-lock"></i> }
                            </article>

                            <article class="pr-module @ModuleState(3)">
                                <span class="pr-module-icon"><i class="bi bi-journal-check"></i></span>
                                <span class="pr-module-copy"><b>@Tx("Reflection and feedback", "Phản tư và nhận phản hồi")</b><small class="@(SelectedItem.IsReflectionCompleted ? "pr-saved-copy" : null)">@(SelectedItem.IsReflectionCompleted ? Tx("Saved", "Đã lưu") : $"15 {Tx("minutes", "phút")}")</small></span>
                                @if (SelectedItem.IsReflectionCompleted) { <i class="bi bi-check-circle-fill pr-done"></i> }
                                else if (RoadmapReviewMode.Enabled || SelectedItem.IsScenarioCompleted) { <button class="pr-continue" @onclick="OpenReflection">@Tx("Start", "Bắt đầu")</button> }
                                else { <i class="bi bi-lock-fill pr-lock"></i> }
                            </article>
                        </div>
                    </article>
                </section>

                <aside class="pr-sidebar">
                    <section class="pr-side-card">
                        <h3>@Tx("This week's learning rhythm", "Nhịp học tuần này")</h3>
                        <div class="pr-days">
                            @for (var day = 0; day < 7; day++)
                            {
                                var capturedDay = day;
                                <span class="@DayClass(capturedDay)"><small>@DayLabel(capturedDay)</small><i>@(DayClass(capturedDay) == "done" ? "✓" : "")</i></span>
                            }
                        </div>
                        <p><b>@ActivityDays</b> @Tx("learning days", "ngày đã học") · @Tx("Streak", "Chuỗi") <strong>@StreakDays @Tx("days", "ngày")</strong></p>
                        <small class="pr-data-note">@Tx("Estimated from completed roadmap weeks.", "Tạm tính từ các tuần đã hoàn thành.")</small>
                    </section>

                    <section class="pr-side-card pr-progress-card">
                        <h3>@Tx("Personal progress", "Tiến độ cá nhân")</h3>
                        <div class="pr-progress-body">
                            <div class="pr-ring" style="--progress:@OverallPercent"><b>@OverallPercent%</b></div>
                            <div>
                                <span><i class="bi bi-calendar-check"></i><b>@CompletedCount / @items.Count</b> @Tx("weeks", "tuần")</span>
                                <span><i class="bi bi-list-task"></i><b>@CompletedActivities / @TotalActivities</b> @Tx("activities", "hoạt động")</span>
                            </div>
                        </div>
                    </section>

                    <section class="pr-side-card pr-suggestion">
                        <h3>@Tx("SoftSync recommends", "SoftSync đề xuất")</h3>
                        <div><img src="/images/syncy-robot.png" alt="Syncy" /><p>@Suggestion</p></div>
                    </section>

                    <button class="pr-adjust" @onclick='() => Nav.NavigateTo("/settings")'><i class="bi bi-calendar3"></i>@Tx("Adjust learning schedule", "Điều chỉnh lịch học")</button>
                </aside>
            </div>
        </div>
    }
</main>

@code {
    [Parameter] public int UserId { get; set; }

    private UserDto? user;
    private List<RoadmapItemDto> items = [];
    private List<AssessmentResultDto> assessments = [];
    private bool loading = true;
    private bool showReason;
    private bool videoExpanded = true;
    private int selectedIndex;
    private ContentTab contentTab = ContentTab.Script;

    private RoadmapItemDto SelectedItem => items[Math.Clamp(selectedIndex, 0, items.Count - 1)];
    private int ActiveIndex
    {
        get
        {
            var index = items.FindIndex(x => !x.IsCompleted);
            return index < 0 ? Math.Max(0, items.Count - 1) : index;
        }
    }

    private string FirstName
    {
        get
        {
            var name = user?.PublicName?.Trim();
            if (string.IsNullOrWhiteSpace(name)) return "bạn";
            return name.Split(' ', StringSplitOptions.RemoveEmptyEntries).LastOrDefault() ?? name;
        }
    }

    private int DailyMinutes => user?.DailyStudyMinutes > 0 ? user.DailyStudyMinutes : 20;
    private int StudyDays => user?.StudyDaysPerWeek > 0 ? user.StudyDaysPerWeek : 4;
    private int WeeklyCapacity => DailyMinutes * StudyDays;
    private int PlannedMinutes => 52;
    private int CompletedCount => items.Count(x => x.IsCompleted);
    private int OverallPercent => items.Count == 0 ? 0 : CompletedCount * 100 / items.Count;
    private int CompletedActivities => items.Sum(x => (x.IsVideoCompleted ? 1 : 0) + (x.IsPracticeCompleted ? 1 : 0) + (x.IsScenarioCompleted ? 1 : 0) + (x.IsReflectionCompleted ? 1 : 0));
    private int TotalActivities => items.Count * 4;
    private int ActivityDays => Math.Min(CompletedCount, 7);
    private int StreakDays => Math.Min(CompletedCount, 7);
    private string CurrentSkillName => items.Count == 0 ? Tx("Soft skills", "Kỹ năng mềm") : SkillDisplayName(items[ActiveIndex]);
    private string SelectedSkillName => SkillDisplayName(SelectedItem);
    private int CurrentSkillPercent => AssessmentPercent(items[ActiveIndex]);
    private string GoalLabel => ResolveGoalLabel(user?.Goal);
    private bool CanOpenVideo => !string.IsNullOrWhiteSpace(VideoRoute(SelectedItem));
    private bool CanOpenPractice => !string.IsNullOrWhiteSpace(PracticeRoute(SelectedItem));
    private bool IsTimeManagementVideoOne => SkillKey(SelectedItem) == "time" && SkillLessonOrdinal(SelectedItem) == 1;

    private string SelectedRecommendation => AssessmentPercent(SelectedItem) > 0
        ? Tx($"Recommended because your {SelectedSkillName} assessment is {AssessmentPercent(SelectedItem)}%.", $"Đề xuất vì điểm {SelectedSkillName} của bạn đang ở mức {AssessmentPercent(SelectedItem)}%.")
        : Tx($"Recommended from your goal and selected skill: {SelectedSkillName}.", $"Đề xuất từ mục tiêu và kỹ năng bạn đã chọn: {SelectedSkillName}.");

    private string PersonalizationExplanation => Tx(
        $"The plan prioritizes {CurrentSkillName} from your latest assessment, then fits activities into your target of {DailyMinutes} minutes per day and {StudyDays} days per week.",
        $"Lộ trình ưu tiên {CurrentSkillName} từ kết quả đánh giá gần nhất, sau đó phân bổ hoạt động theo mục tiêu {DailyMinutes} phút mỗi ngày và {StudyDays} ngày mỗi tuần.");

    private string Suggestion => DailyMinutes <= 20
        ? Tx("You learn better with short content. This week, prioritize 10–15 minute videos and concise scripts.", "Bạn phù hợp với nội dung ngắn. Tuần này hãy ưu tiên video 10–15 phút và script tóm tắt.")
        : Tx($"Your {DailyMinutes}-minute sessions can combine video, script, and one applied activity without overload.", $"Mỗi phiên {DailyMinutes} phút có thể kết hợp video, script và một hoạt động ứng dụng mà không quá tải.");

    protected override async Task OnInitializedAsync()
    {
        var signedInUserId = await AuthProvider.GetUserIdAsync();
        if (signedInUserId <= 0)
        {
            Nav.NavigateTo("/Account/Login", true);
            return;
        }

        if (UserId > 0 && UserId != signedInUserId)
        {
            Nav.NavigateTo($"/roadmap/{signedInUserId}", true);
            return;
        }

        UserId = signedInUserId;
        user = await UserService.GetUserByIdAsync(UserId);
        assessments = (await AssessmentService.GetLatestResultsAsync(UserId)).ToList();
        var roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);

        // Old plans can contain generic intro/summary rows without a SkillName.
        // Keep them in the database to preserve history, but do not present them
        // as personalized skill weeks in this new UI.
        items = roadmap.Items
            .Where(x => !string.IsNullOrWhiteSpace(x.SkillName))
            .OrderBy(x => SkillRank(SkillKey(x)))
            .ThenBy(x => x.WeekNumber)
            .ThenBy(x => x.Id)
            .ToList();

        selectedIndex = RoadmapReviewMode.Enabled ? 0 : ActiveIndex;
        loading = false;
    }

    private void ToggleReason() => showReason = !showReason;
    private void ToggleVideoPanel() => videoExpanded = !videoExpanded;
    private void SelectWeek(int index)
    {
        if (!RoadmapReviewMode.Enabled && index > ActiveIndex) return;
        selectedIndex = Math.Clamp(index, 0, items.Count - 1);
        videoExpanded = true;
        contentTab = ContentTab.Script;
    }

    private string WeekClass(RoadmapItemDto item, int index)
        => $"{(item.IsCompleted ? "done" : index == selectedIndex || !RoadmapReviewMode.Enabled && index == ActiveIndex ? "current" : !RoadmapReviewMode.Enabled && index > ActiveIndex ? "locked" : "")} {(index == selectedIndex ? "selected" : "")}";

    private string WeekStatus(RoadmapItemDto item, int index) => item.IsCompleted
        ? Tx("Completed", "Hoàn thành")
        : RoadmapReviewMode.Enabled ? Tx("Ready to review", "Sẵn sàng kiểm tra") : index == ActiveIndex ? Tx("Learning", "Đang học") : Tx("Upcoming", "Sắp tới");

    private string ModuleState(int moduleIndex)
    {
        if (RoadmapReviewMode.Enabled)
            return moduleIndex switch { 0 when SelectedItem.IsVideoCompleted => "done", 1 when SelectedItem.IsPracticeCompleted => "done", 2 when SelectedItem.IsScenarioCompleted => "done", 3 when SelectedItem.IsReflectionCompleted => "done", _ => "current" };
        if (selectedIndex > ActiveIndex) return "locked";
        return moduleIndex switch
        {
            0 => SelectedItem.IsVideoCompleted ? "done" : "current",
            1 => SelectedItem.IsPracticeCompleted ? "done" : SelectedItem.IsVideoCompleted ? "current" : "locked",
            2 => SelectedItem.IsScenarioCompleted ? "done" : SelectedItem.IsPracticeCompleted ? "current" : "locked",
            3 => SelectedItem.IsReflectionCompleted ? "done" : SelectedItem.IsScenarioCompleted ? "current" : "locked",
            _ => "locked"
        };
    }

    private string SkillDisplayName(RoadmapItemDto item)
    {
        var key = SkillKey(item);
        return key switch
        {
            "communication" => Tx("Communication", "Giao tiếp"),
            "time" => Tx("Time management", "Quản lý thời gian"),
            "critical" => Tx("Critical thinking", "Tư duy phản biện"),
            _ => string.IsNullOrWhiteSpace(item.SkillName) ? Tx("Soft skills", "Kỹ năng mềm") : item.SkillName
        };
    }

    private string LocalizedItemTitle(RoadmapItemDto item)
    {
        var skill = SkillDisplayName(item);
        return IsPracticePhase(item)
            ? Tx($"{skill} Practice", $"Thực hành {skill}")
            : Tx($"{skill} Foundations", $"Nền tảng {skill}");
    }

    private string LocalizedItemDescription(RoadmapItemDto item)
    {
        var skill = SkillDisplayName(item).ToLowerInvariant();
        return IsPracticePhase(item)
            ? Tx($"Apply {skill} in realistic situations, review feedback, and reflect on what to improve after each attempt.", $"Áp dụng {skill} vào tình huống thực tế, xem phản hồi và tự đánh giá điểm cần cải thiện sau mỗi lượt thực hành.")
            : Tx($"Learn the core principles of {skill} and complete short guided exercises to build a consistent foundation.", $"Nắm kiến thức cốt lõi của {skill} và hoàn thành các bài luyện tập ngắn để xây dựng nền tảng vững chắc.");
    }

    private static bool IsPracticePhase(RoadmapItemDto item)
        => item.Title.Contains("Thực hành", StringComparison.OrdinalIgnoreCase)
            || item.Title.Contains("Practice", StringComparison.OrdinalIgnoreCase);

    private static string SkillKey(RoadmapItemDto item)
    {
        var value = $"{item.SkillName} {item.Title}".ToLowerInvariant();
        if (value.Contains("giao tiếp") || value.Contains("communication")) return "communication";
        if (value.Contains("quản lý thời gian") || value.Contains("time management")) return "time";
        if (value.Contains("tư duy phản biện") || value.Contains("critical thinking")) return "critical";
        return "other";
    }

    private static int SkillId(RoadmapItemDto item) => SkillKey(item) switch
    {
        "communication" => 1,
        "time" => 3,
        "critical" => 4,
        _ => 0
    };

    private static int SkillRank(string key) => key switch
    {
        "communication" => 0,
        "time" => 1,
        "critical" => 2,
        _ => 3
    };

    private string SkillGroupName(string key) => key switch
    {
        "communication" => Tx("Communication Skills", "Kỹ năng giao tiếp"),
        "time" => Tx("Time Management Skills", "Kỹ năng quản lý thời gian"),
        "critical" => Tx("Critical Thinking Skills", "Kỹ năng tư duy phản biện"),
        _ => Tx("Other Skills", "Kỹ năng khác")
    };

    private static string SkillIcon(string key) => key switch
    {
        "communication" => "bi bi-chat-dots-fill",
        "time" => "bi bi-clock-fill",
        "critical" => "bi bi-lightbulb-fill",
        _ => "bi bi-stars"
    };

    private int SkillLessonOrdinal(RoadmapItemDto item)
    {
        var key = SkillKey(item);
        var skillItems = items.Where(x => SkillKey(x) == key).ToList();
        var index = skillItems.FindIndex(x => x.Id == item.Id);
        return index < 0 ? 0 : index + 1;
    }

    private int AssessmentPercent(RoadmapItemDto item)
    {
        var result = assessments.FirstOrDefault(x => x.SkillId == SkillId(item));
        return result is null ? 0 : (int)Math.Round(Math.Clamp(result.Score, 0, AssessmentScoring.MaxScore) * 100d / AssessmentScoring.MaxScore);
    }

    private string ResolveGoalLabel(string? goal)
    {
        if (string.IsNullOrWhiteSpace(goal)) return Tx("Develop soft skills", "Phát triển kỹ năng mềm");
        return goal.StartsWith("wizard.goal.", StringComparison.OrdinalIgnoreCase) ? L[goal] : goal;
    }

    private string VideoRoute(RoadmapItemDto item)
    {
        return SkillKey(item) switch
        {
            "time" or "communication" => $"/roadmap/lecture/{UserId}/{item.Id}",
            _ => string.Empty
        };
    }

    private string PracticeRoute(RoadmapItemDto item)
    {
        return SkillKey(item) switch
        {
            "time" or "communication" or "critical" => $"/roadmap/game/{UserId}/{item.Id}",
            _ => string.Empty
        };
    }

    private void OpenVideo()
    {
        var route = VideoRoute(SelectedItem);
        if (!string.IsNullOrWhiteSpace(route)) Nav.NavigateTo(route);
    }

    private void OpenPractice()
    {
        var route = PracticeRoute(SelectedItem);
        if (!string.IsNullOrWhiteSpace(route)) Nav.NavigateTo(route);
    }

    private void OpenScenario() => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{SelectedItem.Id}?step=scenario");
    private void OpenReflection() => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{SelectedItem.Id}?step=reflection");

    private string DayClass(int day)
    {
        var today = ((int)DateTime.Today.DayOfWeek + 6) % 7;
        if (day < Math.Min(ActivityDays, today + 1)) return "done";
        return day == today ? "current" : string.Empty;
    }

    private string DayLabel(int day) => L.Current == AppLanguage.Vi
        ? day switch { 0 => "T2", 1 => "T3", 2 => "T4", 3 => "T5", 4 => "T6", 5 => "T7", _ => "CN" }
        : day switch { 0 => "Mon", 1 => "Tue", 2 => "Wed", 3 => "Thu", 4 => "Fri", 5 => "Sat", _ => "Sun" };
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;

    private enum ContentTab { Video, Script, Summary }
}

