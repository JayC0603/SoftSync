@page "/roadmap"
@page "/roadmap/{UserId:int}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IRoadmapService RoadmapService
@inject NavigationManager Nav

@if (roadmap is null)
{
    <div class="rm-loading"><span></span>@L["roadmap.loading"]</div>
}
else
{
    <div class="rm-shell">
        <aside class="rm-left">
            <section class="rm-panel rm-summary">
                <div class="rm-label">@Tx("YOUR ROADMAP", "LỘ TRÌNH CỦA BẠN")</div>
                <img src="/images/syncy-fish.png" alt="SYNCY" />
                <h2>@CurrentSkill<br />Mastery</h2>
                <p><b>@ProgressPercent%</b> @Tx("completed", "hoàn thành")</p>
                <div class="rm-progress"><i style="width:@(ProgressPercent)%"></i></div>
                <button @onclick="ScrollToCurrent">@Tx("View overview", "Xem tổng quan")</button>
            </section>

            <section class="rm-panel rm-stages">
                <div class="rm-label">@Tx("STAGES", "GIAI ĐOẠN")</div>
                @foreach (var section in Sections.Select((value, index) => (value, index)))
                {
                    var percent = SectionPercent(section.value);
                    <button class="rm-stage @(section.index == selectedSection ? "active" : "")"
                            @onclick="() => SelectSection(section.index)">
                        <span>@(section.index + 1)</span>
                        <b>@section.value.Title</b>
                        <small>@percent%</small>
                        @if (section.index > selectedSection && percent == 0) { <i class="bi bi-lock-fill"></i> }
                    </button>
                }
            </section>

            <section class="rm-panel rm-mentor">
                <div class="rm-label">@Tx("AI MENTOR SUGGESTS", "AI MENTOR GỢI Ý")</div>
                <p>@Tx("You're doing great! Complete each step to reinforce your knowledge.", "Bạn đang học rất tốt! Hãy hoàn thành từng bước để củng cố kiến thức nhé.")</p>
                <img src="/images/syncy-fish.png" alt="Nova" />
                <button @onclick='() => Nav.NavigateTo("/assistant")'>@Tx("Chat with Nova", "Chat với Nova")</button>
            </section>
        </aside>

        <main class="rm-main" id="roadmap-current">
            <header class="rm-head">
                <div><h1>@Tx("Stage", "Giai đoạn") @(selectedSection + 1): @Selected.Title <i class="bi bi-info-circle"></i></h1><p>@Tx("Build a strong foundation and apply your skills in practice.", "Xây dựng nền tảng vững chắc và áp dụng kỹ năng vào thực tế.")</p></div>
                <span><i class="bi bi-star-fill"></i> @CompletedCount/@TotalCount @Tx("lessons", "bài học")</span>
            </header>

            <div class="rm-track">
                @foreach (var entry in Selected.Items.Select((value, index) => (value, index)))
                {
                    var state = ItemState(entry.value, entry.index);
                    <button class="rm-track-item @state" @onclick="() => SelectItem(entry.value)">
                        <span><i class="bi @(entry.value.IsCompleted ? "bi-check-lg" : entry.index == ActiveIndex ? "bi-play-fill" : "bi-lock-fill")"></i></span>
                        <b>@(selectedSection + 1).@(entry.index + 1) @entry.value.Title</b>
                    </button>
                }
            </div>

            <section class="rm-lesson">
                <div class="rm-lesson-title"><i class="bi bi-headphones"></i><div><h2>@(selectedSection + 1).@(SelectedItemIndex + 1) @SelectedItem.Title</h2><p>@SelectedItem.Description</p></div><span><i class="bi bi-clock"></i> ~ 40 @Tx("minutes", "phút")</span></div>
                <div class="rm-steps">
                    @foreach (var step in LessonSteps.Select((value, index) => (value, index)))
                    {
                        var locked = step.index > 1;
                        <article class="rm-step @(step.index == 0 ? "done" : locked ? "locked" : "current")">
                            <div class="rm-step-no">@(step.index == 0 ? "✓" : (step.index + 1).ToString())</div>
                            <div class="rm-step-visual @step.value.Color"><i class="bi @step.value.Icon"></i></div>
                            <div class="rm-step-copy"><small>@step.value.Type</small><h3>@step.value.Title</h3><p>@step.value.Description</p></div>
                            <div class="rm-step-action">
                                @if (step.index == 0) { <em>✓ @Tx("Completed", "Đã hoàn thành")</em><button @onclick="() => OpenLecture(SelectedItem)">@Tx("Review", "Xem lại")</button> }
                                else if (step.index == 1) { <button class="primary" @onclick="() => OpenLecture(SelectedItem)">@Tx("Start learning", "Bắt đầu học")</button><small>~ 15 @Tx("minutes", "phút")</small> }
                                else { <span><i class="bi bi-lock-fill"></i> @Tx("Locked", "Chưa mở khóa")</span><small>@Tx("Complete step", "Hoàn thành bước") @step.index</small> }
                            </div>
                        </article>
                    }
                </div>
            </section>

            <footer class="rm-reward"><span>🏆 @Tx("Complete all 4 steps to earn", "Hoàn thành tất cả 4 bước để nhận")</span><b>⭐ +80 XP</b><b>♙ +1 @Tx("Badge", "Huy hiệu")</b><button disabled>@Tx("Claim reward", "Nhận phần thưởng")</button></footer>
        </main>

        <aside class="rm-right">
            <section class="rm-panel"><div class="rm-label">@Tx("STAGE PROGRESS", "TIẾN ĐỘ GIAI ĐOẠN") @(selectedSection + 1)</div><div class="rm-ring" style="--p:@SectionPercent(Selected)"><b>@SectionPercent(Selected)%</b></div><strong>@Selected.Items.Count(x => x.IsCompleted)/@Selected.Items.Count @Tx("lessons", "bài học")</strong><button>@Tx("View details", "Xem chi tiết")</button></section>
            <section class="rm-panel rm-skills"><div class="rm-label">@Tx("SKILLS EARNED", "KỸ NĂNG ĐẠT ĐƯỢC")</div><p><i class="bi bi-headphones"></i> @Tx("Active listening", "Lắng nghe chủ động")</p><p><i class="bi bi-heart"></i> @Tx("Understanding others", "Thấu hiểu người khác")</p><p><i class="bi bi-people"></i> @Tx("Effective questioning", "Đặt câu hỏi hiệu quả")</p></section>
            <section class="rm-panel rm-stats"><div class="rm-label">@Tx("THIS WEEK'S ACHIEVEMENTS", "THÀNH TÍCH TUẦN NÀY")</div><p>◷ @Tx("Study time", "Thời gian học") <b>2h 15m</b></p><p>☑ @Tx("Lessons completed", "Bài học hoàn thành") <b>@CompletedCount</b></p><p>⭐ @Tx("XP earned", "XP nhận được") <b>@(CompletedCount * 80)</b></p><p>🔥 @Tx("Study streak", "Chuỗi ngày học") <b>5 @Tx("days", "ngày")</b></p></section>
            <section class="rm-panel rm-reminder"><div class="rm-label">@Tx("STUDY REMINDER", "LỊCH NHẮC HỌC")</div><p>📅 <span>@Tx("Study", "Học") @SelectedItem.Title<small>@Tx("Today", "Hôm nay"), 19:00</small></span></p><button>@Tx("View schedule", "Xem lịch học")</button></section>
        </aside>
    </div>
}

@code {
    [Parameter] public int UserId { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = default!;
    private RoadmapDto? roadmap;
    private List<RoadmapSection> Sections = [];
    private int selectedSection;
    private int selectedItem;
    private RoadmapSection Selected => Sections[Math.Min(selectedSection, Sections.Count - 1)];
    private RoadmapItemDto SelectedItem => Selected.Items[Math.Min(selectedItem, Selected.Items.Count - 1)];
    private int SelectedItemIndex => Selected.Items.IndexOf(SelectedItem);
    private int TotalCount => roadmap?.Items.Count ?? 0;
    private int CompletedCount => roadmap?.Items.Count(x => x.IsCompleted) ?? 0;
    private int ProgressPercent => TotalCount == 0 ? 0 : CompletedCount * 100 / TotalCount;
    private string CurrentSkill => Sections.Count == 0 ? "Communication" : Selected.Title;
    private int ActiveIndex => Math.Max(0, Selected.Items.FindIndex(x => !x.IsCompleted));
    private LessonStep[] LessonSteps => [
        new("VIDEO", Tx("Video lesson", "Video bài giảng"), Tx("Watch the video for an overview of the core concepts and principles.", "Xem video để nắm tổng quan về khái niệm và nguyên tắc cốt lõi."), "bi-play-circle-fill", "blue"),
        new(Tx("THEORY", "LÝ THUYẾT"), Tx("Theory content", "Nội dung lý thuyết"), Tx("Read detailed theory, examples, and important principles.", "Đọc chi tiết lý thuyết, ví dụ minh họa và các nguyên tắc quan trọng."), "bi-book", "green"),
        new(Tx("QUIZ", "BÀI TẬP TRẮC NGHIỆM"), Tx("Knowledge check", "Kiểm tra kiến thức"), Tx("Answer 10 questions to reinforce what you have learned.", "Trả lời 10 câu hỏi trắc nghiệm để củng cố kiến thức vừa học."), "bi-clipboard-check", "orange"),
        new("GAME", Tx("Practice game", "Game thực hành"), Tx("Complete an interactive challenge to apply the skill in real situations.", "Vượt qua thử thách tương tác để áp dụng kỹ năng vào tình huống thực tế."), "bi-controller", "purple")];

    protected override async Task OnInitializedAsync() {
        if (UserId == 0) UserId = await AuthProvider.GetUserIdAsync();
        roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
        Sections = (roadmap.Items.Count == 0 ? DemoItems() : roadmap.Items)
            .GroupBy(x => string.IsNullOrWhiteSpace(x.SkillName) ? "Communication" : x.SkillName)
            .Select(g => new RoadmapSection(g.Key, g.OrderBy(x => x.WeekNumber).ThenBy(x => x.Id).ToList())).ToList();
    }
    private static List<RoadmapItemDto> DemoItems() => [new(){Id=1,WeekNumber=1,SkillName="Nền tảng giao tiếp",Title="Hiểu về giao tiếp",Description="Khám phá nền tảng giao tiếp hiệu quả.",IsCompleted=true},new(){Id=2,WeekNumber=2,SkillName="Nền tảng giao tiếp",Title="Lắng nghe chủ động",Description="Học cách lắng nghe để thấu hiểu và kết nối hiệu quả hơn."},new(){Id=3,WeekNumber=3,SkillName="Nền tảng giao tiếp",Title="Ngôn ngữ cơ thể",Description="Nhận biết và sử dụng tín hiệu phi ngôn ngữ."},new(){Id=4,WeekNumber=4,SkillName="Nền tảng giao tiếp",Title="Đặt câu hỏi hiệu quả",Description="Đặt câu hỏi để mở rộng đối thoại."}];
    private int SectionPercent(RoadmapSection s) => s.Items.Count == 0 ? 0 : s.Items.Count(x => x.IsCompleted) * 100 / s.Items.Count;
    private string ItemState(RoadmapItemDto item, int index) => item.IsCompleted ? "done" : index == ActiveIndex ? "active" : "locked";
    private void SelectSection(int index) { selectedSection = index; selectedItem = 0; }
    private void SelectItem(RoadmapItemDto item) { selectedItem = Selected.Items.IndexOf(item); }
    private void OpenLecture(RoadmapItemDto item) => Nav.NavigateTo($"/roadmap/lecture/{UserId}/{item.Id}");
    private void ScrollToCurrent() => Nav.NavigateTo("/roadmap#roadmap-current");
    private string Tx(string en, string vi) => L.Current == AppLanguage.Vi ? vi : en;
    private sealed record RoadmapSection(string Title, List<RoadmapItemDto> Items);
    private sealed record LessonStep(string Type, string Title, string Description, string Icon, string Color);
}

