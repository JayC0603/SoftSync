    .pr-shell{max-width:1500px;margin:auto}.pr-loading,.pr-empty{min-height:62vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:.8rem}.pr-loading{flex-direction:row;color:var(--pr-muted);font-weight:750}.pr-loading span{width:28px;height:28px;border:3px solid #dfd8ff;border-top-color:var(--pr-primary);border-radius:50%;animation:pr-spin .8s linear infinite}.pr-empty{max-width:760px;margin:auto}.pr-empty>i{font-size:3rem;color:var(--pr-primary)}.pr-empty h1{margin:0;font-size:clamp(1.6rem,4vw,2.6rem)}.pr-empty p{color:var(--pr-muted)}.pr-empty button{padding:.8rem 1.2rem;color:#fff;border:0;border-radius:12px;background:var(--pr-primary);font-weight:800}
