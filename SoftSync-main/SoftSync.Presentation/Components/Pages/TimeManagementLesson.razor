@page "/time-management-lesson"
@rendermode InteractiveServer
@inject NavigationManager Nav
<PageTitle>Video Quản lý thời gian</PageTitle>
<main class="tml"><button @onclick='()=>Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i> Roadmap</button><article><header><span>VIDEO BÀI GIẢNG · QUẢN LÝ THỜI GIAN</span><h1>Làm chủ thời gian và vượt qua trì hoãn</h1><p>Xem bài giảng từ Mentor trước khi làm bài trắc nghiệm 20 câu.</p></header><video controls preload="metadata" playsinline><source src="/videos/time-management-mentor-lesson.mp4" type="video/mp4"/>Trình duyệt không hỗ trợ video HTML5.</video><footer><div><i class="bi bi-lightbulb"></i><span><b>Gợi ý học tập</b>Ghi lại Daily Top Three, Pomodoro và bốn nhóm Eisenhower.</span></div><button @onclick='()=>Nav.NavigateTo("/time-management-quiz")'>Làm trắc nghiệm <i class="bi bi-arrow-right"></i></button></footer></article></main>
<style>.tml{max-width:1000px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:#19163d}.tml>button{margin-bottom:1rem;border:0;background:none;color:#707789;font-weight:800}.tml article{overflow:hidden;border:1px solid #ded8f5;border-radius:26px;background:#fff;box-shadow:0 22px 55px #4c1d9518}.tml header{padding:1.6rem}.tml header span{color:#6847eb;font-size:.65rem;font-weight:900;letter-spacing:.08em}.tml h1{margin:.4rem 0;font-size:clamp(1.8rem,4vw,2.8rem)}.tml header p{color:#6b7280}.tml video{display:block;width:100%;max-height:580px;aspect-ratio:16/9;object-fit:contain;background:#080914}.tml footer{display:flex;justify-content:space-between;align-items:center;gap:1rem;padding:1.2rem 1.6rem;background:#f8f7fc}.tml footer>div{display:flex;gap:.7rem}.tml footer>div>i{color:#6847eb;font-size:1.4rem}.tml footer span,.tml footer b{display:block}.tml footer span{color:#6b7280;font-size:.75rem}.tml footer b{color:#19163d}.tml footer button{padding:.8rem 1rem;color:#fff;border:0;border-radius:11px;background:#6847eb;font-weight:800}@@media(max-width:600px){.tml footer{align-items:stretch;flex-direction:column}.tml footer button{width:100%}}</style>
