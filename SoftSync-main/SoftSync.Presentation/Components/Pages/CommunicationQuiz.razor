@page "/communication-quiz"
@rendermode InteractiveServer
@using SoftSync.Presentation.Services
@inject IGameBankService GameBankService
@inject NavigationManager Nav

<PageTitle>Trắc nghiệm Kỹ năng Giao tiếp</PageTitle>

<main class="cq-page">
    <button class="cq-back" @onclick='() => Nav.NavigateTo("/roadmap")'><i class="bi bi-arrow-left"></i> Quay lại Roadmap</button>

    <header class="cq-hero">
        <div>
            <span class="cq-eyebrow"><i class="bi bi-chat-heart-fill"></i> COMMUNICATION REVIEW</span>
            <h1>Trắc nghiệm ôn tập<br /><em>Kỹ năng Giao tiếp</em></h1>
            <p>Kiểm tra khả năng vận dụng lý thuyết vào email, lắng nghe chủ động, xử lý xung đột và giao tiếp khẳng định ôn hòa.</p>
        </div>
        <div class="cq-hero-stat"><small>MỖI LƯỢT</small><strong>05</strong><span>câu hỏi ngẫu nhiên</span><i>từ ngân hàng 20 tình huống</i></div>
    </header>

    <section class="cq-theory">
        <button @onclick="() => theoryOpen = !theoryOpen">
            <span><i class="bi bi-journal-bookmark-fill"></i><b>Ôn nhanh nền tảng lý thuyết</b><small>4 chủ đề · đọc trong 3 phút</small></span>
            <i class="bi bi-chevron-down @(theoryOpen ? "open" : "")"></i>
        </button>
        @if (theoryOpen)
        {
            <div class="cq-theory-grid">
                @foreach (var topic in Topics)
                {
                    <article><span><i class="bi @topic.Icon"></i></span><div><small>@topic.Number</small><h3>@topic.Title</h3><p>@topic.Body</p></div></article>
                }
            </div>
        }
    </section>

    @if (session is null)
    {
        <section class="cq-shell cq-loading"><span></span><p>Đang khởi tạo bộ câu hỏi...</p></section>
    }
    else if (submitted)
    {
        <section class="cq-shell cq-result">
            <div class="cq-score-ring rating-@Rating.Css"><strong>@totalScore/50</strong><span>@ScorePercent%</span></div>
            <div class="cq-result-copy"><small>@Rating.Name.ToUpperInvariant()</small><h2>@Rating.Headline</h2><p>@Rating.Feedback</p><div class="cq-result-actions"><button @onclick="RestartAsync">Làm bộ câu hỏi mới <i class="bi bi-arrow-repeat"></i></button><button class="secondary" @onclick='() => Nav.NavigateTo("/communication-roleplay")'>Tiếp tục Quiz 2 <i class="bi bi-arrow-right"></i></button></div></div>
            <div class="cq-review">
                @foreach (var row in reviewRows.Select((value,index)=>(value,index)))
                {
                    <article class="@(row.value.Score == 10 ? "ok" : row.value.Score == 5 ? "neutral" : "miss")"><span>+@row.value.Score</span><div><small>CÂU @(row.index + 1) · @ScoreLabel(row.value.Score)</small><h3>@row.value.Question</h3><p>Phương án tối ưu: <b>@row.value.Answer</b></p></div></article>
                }
            </div>
        </section>
    }
    else
    {
        var question = session.Questions[currentIndex];
        <section class="cq-shell">
            <div class="cq-progress"><div><span>CÂU HỎI @(currentIndex + 1)</span><b>@(currentIndex + 1)/5</b></div><div class="cq-bar"><i style="width:@((currentIndex + 1) * 20)%"></i></div></div>
            <article class="cq-question">
                <span class="cq-context"><i class="bi bi-people-fill"></i> TÌNH HUỐNG GIAO TIẾP</span>
                <h2>@question.QuestionText</h2>
                <div class="cq-options">
                    @foreach (var option in question.Options)
                    {
                        var score = GetOptionScore(question.Number, option);
                        <button disabled="@answered" class="@(OptionClass(option.Id, score))" @onclick="() => SelectOption(option)"><span>@option.DisplayLabel</span><p>@option.Text</p><i class="bi bi-check-circle-fill"></i></button>
                    }
                </div>
                @if (answered)
                {
                    <div class="cq-instant-feedback score-@selectedScore"><i class="bi @(selectedScore == 10 ? "bi-check-circle-fill" : selectedScore == 5 ? "bi-info-circle-fill" : "bi-x-circle-fill")"></i><div><b>@ScoreLabel(selectedScore) · @selectedScore điểm</b><p>@InstantFeedback(question)</p></div></div>
                }
                <footer><span><i class="bi bi-lightbulb"></i> Tối ưu 10 · Trung lập 5 · Tiêu cực 0 điểm</span><button disabled="@(!answered)" @onclick="NextQuestion">@(currentIndex == 4 ? "Xem kết quả" : "Câu tiếp theo") <i class="bi bi-arrow-right"></i></button></footer>
            </article>
        </section>
    }
</main>

@code {
    private Game1SessionDto? session;
    private int currentIndex, totalScore, selectedScore;
    private string? selectedOptionId;
    private bool theoryOpen, submitted, answered;
    private List<ReviewRow> reviewRows { get; } = [];
    private HashSet<int> seenQuestionNumbers { get; } = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();
    private async Task LoadAsync()
    {
        if (seenQuestionNumbers.Count >= 20) seenQuestionNumbers.Clear();
        session = await GameBankService.CreateSessionAsync(1, 5, seenQuestionNumbers);
        if (session is not null)
            foreach (var question in session.Questions) seenQuestionNumbers.Add(question.Number);
    }

    private void SelectOption(GameBankOptionDto option)
    {
        if (session is null || answered) return;
        var question = session.Questions[currentIndex];
        selectedOptionId = option.Id;
        selectedScore = GetOptionScore(question.Number, option);
        answered = true;
    }

    private void NextQuestion()
    {
        if (session is null || selectedOptionId is null || !answered) return;
        var question = session.Questions[currentIndex];
        var correct = question.Options.First(x => x.IsCorrect);
        totalScore += selectedScore;
        reviewRows.Add(new(question.QuestionText, $"{correct.DisplayLabel}. {correct.Text}", selectedScore));
        selectedOptionId = null;
        answered = false;
        if (currentIndex < session.QuestionLimit - 1) currentIndex++;
        else submitted = true;
    }

    private async Task RestartAsync()
    {
        currentIndex = totalScore = selectedScore = 0;
        selectedOptionId = null;
        submitted = answered = false;
        reviewRows.Clear();
        session = null;
        await LoadAsync();
    }

    private static readonly List<Topic> Topics =
    [
        new("I", "Thành phần & mô hình giao tiếp", "Giao tiếp gồm Nguồn, Thông điệp, Kênh, Người nhận, Phản hồi, Môi trường, Bối cảnh và Nhiễu. Mô hình giao dịch diễn ra hai chiều; mô hình kiến tạo nhấn mạnh ý nghĩa được đàm phán.", "bi-diagram-3"),
        new("II", "Lắng nghe chủ động", "Tập trung tuyệt đối, không phán xét, paraphrase để xác nhận và đọc tín hiệu phi ngôn từ. Trong 5 nhóm Carl Rogers, phản hồi thấu hiểu là cấp độ cao nhất.", "bi-ear"),
        new("III", "Rào cản & thiên kiến nhận thức", "Bypassing, jargon, slang, khác biệt phi ngôn ngữ và phản ứng phòng vệ đều có thể làm sai lệch thông điệp. Hãy chuyển từ môi trường phòng vệ sang hỗ trợ.", "bi-sign-stop"),
        new("IV", "Assertive Communication", "Dùng I-statements để mô tả quan sát và cảm xúc thay cho lời quy chụp. Giữ netiquette chuyên nghiệp và không dùng ALL CAPS vì dễ bị hiểu là quát tháo.", "bi-chat-square-heart")
    ];

    private int ScorePercent => totalScore * 100 / 50;
    private RatingInfo Rating => ScorePercent switch
    {
        <= 30 => new("Bị động", "passive", "Bạn đang có xu hướng phản ứng thụ động", "Trong các tình huống vừa rồi, bạn có xu hướng phản ứng theo cảm xúc nhất thời hoặc né tránh vấn đề. Hãy tập dừng lại vài giây trước khi phản hồi và đặt câu hỏi thay vì phán xét ngay."),
        <= 55 => new("Đang phát triển", "developing", "Bạn đang đi đúng hướng", "Bạn đã có ý thức xử lý hợp lý hơn, nhưng đôi khi vẫn né tránh hoặc giải quyết cho xong. Hãy diễn đạt rõ mong muốn một cách nhẹ nhàng thay vì im lặng hoặc làm thay người khác."),
        <= 80 => new("Chủ động", "proactive", "Khả năng giao tiếp chủ động khá tốt", "Bạn biết lắng nghe, nêu ý kiến tôn trọng và không né tránh xung đột. Tiếp tục rèn phản xạ bình tĩnh phân tích để giao tiếp tự tin hơn trong nhóm."),
        _ => new("Làm chủ", "exceptional", "Bạn làm chủ tốt các tình huống khó", "Bạn giữ bình tĩnh, tôn trọng người khác và hướng cuộc trò chuyện về giải quyết vấn đề. Hãy tiếp tục phát huy và hỗ trợ các thành viên khác trong nhóm.")
    };

    private static readonly Dictionary<int, string> NeutralOptions = new()
    {
        [1]="B", [2]="D", [3]="D", [4]="D", [5]="A", [6]="C", [7]="D", [8]="C", [9]="D", [10]="B",
        [11]="D", [12]="D", [13]="C", [14]="A", [15]="C", [16]="D", [17]="B", [18]="D", [19]="C", [20]="C"
    };
    private static int GetOptionScore(int questionNumber, GameBankOptionDto option) => option.IsCorrect ? 10 : NeutralOptions.TryGetValue(questionNumber, out var key) && option.Key == key ? 5 : 0;
    private string OptionClass(string id, int score) => !answered ? (selectedOptionId == id ? "selected" : "") : selectedOptionId == id ? $"selected reveal-{score}" : "faded";
    private static string ScoreLabel(int score) => score == 10 ? "Tối ưu" : score == 5 ? "Trung lập" : "Tiêu cực";
    private string InstantFeedback(GameBankQuestionDto question)
    {
        if (selectedScore == 10) return "Bạn vừa chọn cách phản hồi thẳng thắn, tôn trọng và hướng đến giải quyết vấn đề.";
        var best = question.Options.First(x => x.IsCorrect);
        return selectedScore == 5
            ? $"Cách này tạm ổn nhưng chưa giải quyết trọn vẹn vấn đề. Phương án {best.DisplayLabel} giúp bạn vừa rõ ràng vừa giữ thiện chí hợp tác hơn."
            : $"Phản hồi này dễ tạo phòng vệ, hiểu lầm hoặc né tránh vấn đề. Hãy cân nhắc phương án {best.DisplayLabel} để giao tiếp xây dựng hơn.";
    }

    private sealed record Topic(string Number, string Title, string Body, string Icon);
    private sealed record ReviewRow(string Question, string Answer, int Score);
    private sealed record RatingInfo(string Name, string Css, string Headline, string Feedback);
}

<style>
    .cq-page{--cq:#6847eb;--ink:#17163e;--muted:#667085;max-width:1180px;margin:auto;padding:clamp(1rem,3vw,2.5rem);color:var(--ink)}.cq-page button{font-family:inherit}.cq-back{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;padding:.5rem 0;color:#6b7280;border:0;background:transparent;font-weight:750}.cq-hero{display:grid;grid-template-columns:1fr 230px;gap:2rem;align-items:center;padding:clamp(1.5rem,4vw,3.5rem);border:1px solid rgba(109,77,244,.13);border-radius:30px;background:radial-gradient(circle at 90% 20%,rgba(236,72,153,.16),transparent 19rem),linear-gradient(135deg,#fff,#f0ebff);box-shadow:0 25px 60px rgba(76,29,149,.1)}.cq-eyebrow{display:inline-flex;align-items:center;gap:.5rem;color:var(--cq);font-size:.72rem;font-weight:900;letter-spacing:.09em}.cq-hero h1{margin:.8rem 0;font-size:clamp(2.4rem,5vw,4rem);line-height:1.05;letter-spacing:-.045em}.cq-hero h1 em{font-style:normal;color:var(--cq)}.cq-hero p{max-width:680px;margin:0;color:var(--muted);line-height:1.7}.cq-hero-stat{padding:1.4rem;border:1px solid rgba(255,255,255,.9);border-radius:22px;background:rgba(255,255,255,.72);text-align:center}.cq-hero-stat>*{display:block}.cq-hero-stat small{color:#8b93a4;font-size:.65rem;font-weight:900}.cq-hero-stat strong{margin:.2rem 0;color:var(--cq);font-size:3rem}.cq-hero-stat span{font-weight:800}.cq-hero-stat i{margin-top:.3rem;color:#8b93a4;font-size:.68rem;font-style:normal}
    .cq-theory{margin:1rem 0}.cq-theory>button{width:100%;display:flex;justify-content:space-between;align-items:center;padding:1rem 1.2rem;color:var(--ink);border:1px solid rgba(109,77,244,.13);border-radius:18px;background:#fff;text-align:left}.cq-theory>button span{display:grid;grid-template-columns:38px 1fr;align-items:center}.cq-theory>button span>i{grid-row:1/3;color:var(--cq);font-size:1.3rem}.cq-theory>button small{color:#8b93a4}.cq-theory>button>i{transition:.2s}.cq-theory>button>i.open{transform:rotate(180deg)}.cq-theory-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;padding:1rem;border:1px solid rgba(109,77,244,.1);border-top:0;border-radius:0 0 18px 18px}.cq-theory-grid article{display:grid;grid-template-columns:44px 1fr;gap:.8rem;padding:1rem;border-radius:15px;background:#f8f7ff}.cq-theory-grid article>span{display:grid;place-items:center;width:42px;height:42px;color:var(--cq);border-radius:12px;background:#ece8ff}.cq-theory-grid small{color:var(--cq);font-weight:900}.cq-theory-grid h3{margin:.2rem 0;font-size:.95rem}.cq-theory-grid p{margin:0;color:var(--muted);font-size:.8rem;line-height:1.6}
    .cq-shell{padding:clamp(1rem,3vw,2rem);border:1px solid rgba(109,77,244,.13);border-radius:25px;background:linear-gradient(145deg,#fff,#faf8ff);box-shadow:0 22px 55px rgba(76,29,149,.09)}.cq-loading{min-height:300px;display:grid;place-items:center;align-content:center;color:#858c9c}.cq-loading span{width:38px;height:38px;border:3px solid #e3ddfa;border-top-color:var(--cq);border-radius:50%;animation:cqspin 1s linear infinite}.cq-progress>div:first-child{display:flex;justify-content:space-between;color:var(--cq);font-size:.72rem;font-weight:900}.cq-bar{height:7px;margin-top:.6rem;overflow:hidden;border-radius:9px;background:#e5dffb}.cq-bar i{display:block;height:100%;background:linear-gradient(90deg,#5b43e5,#a855f7);transition:.3s}.cq-question{margin-top:1rem;padding:clamp(1rem,3vw,2rem);border:1px solid #e9e5f5;border-radius:20px;background:#fff}.cq-context{display:inline-flex;align-items:center;gap:.45rem;color:var(--cq);font-size:.66rem;font-weight:900}.cq-question h2{margin:.8rem 0 1.2rem;font-size:1.15rem;line-height:1.55}.cq-options{display:grid;gap:.7rem}.cq-options button{display:grid;grid-template-columns:38px 1fr 20px;align-items:center;gap:.8rem;padding:.8rem;text-align:left;color:#4e5769;border:1px solid #e5e2ef;border-radius:14px;background:#fff;transition:.15s}.cq-options button:hover{border-color:#b5a6f5;transform:translateY(-1px)}.cq-options button>span{display:grid;place-items:center;width:36px;height:36px;border-radius:10px;background:#f0edfa;font-weight:900}.cq-options button p{margin:0;line-height:1.5}.cq-options button>i{color:#d8d3e9}.cq-options button.selected{color:#4f35c8;border-color:var(--cq);background:#f3efff}.cq-options button.selected>i{color:var(--cq)}.cq-question footer{display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-top:1.2rem;padding-top:1rem;border-top:1px solid #eeeaf8;color:#8b93a4;font-size:.75rem}.cq-question footer>button,.cq-result-copy button{padding:.75rem 1rem;color:#fff;border:0;border-radius:11px;background:linear-gradient(135deg,#6044e4,#8b5cf6);font-weight:800}.cq-question footer>button:disabled{opacity:.45}
    .cq-result{display:grid;grid-template-columns:170px 1fr;gap:2rem;align-items:center}.cq-score-ring{display:grid;place-items:center;width:160px;height:160px;border:12px solid #ddd6fa;border-top-color:var(--cq);border-radius:50%}.cq-score-ring.retry{border-top-color:#f59e0b}.cq-score-ring strong{font-size:2rem}.cq-score-ring span{color:#7e8595}.cq-result-copy>small{color:#1c9c68;font-weight:900}.cq-result-copy h2{margin:.35rem 0}.cq-result-copy p{color:var(--muted)}.cq-review{grid-column:1/-1;display:grid;gap:.65rem}.cq-review article{display:grid;grid-template-columns:36px 1fr;gap:.8rem;padding:1rem;border-radius:14px}.cq-review article.ok{background:#ebfaf3}.cq-review article.miss{background:#fff2f2}.cq-review article>span{font-size:1.25rem;font-weight:900}.cq-review article.ok>span{color:#16a269}.cq-review article.miss>span{color:#dc5454}.cq-review small{font-size:.62rem;font-weight:900}.cq-review h3{margin:.2rem 0;font-size:.9rem}.cq-review p{margin:0;color:#687084;font-size:.8rem}
    .cq-options button:disabled{opacity:1}.cq-options button.faded{opacity:.5}.cq-options button.reveal-10{color:#13744c;border-color:#22a06b;background:#ebfaf3}.cq-options button.reveal-5{color:#906315;border-color:#e7a82f;background:#fff8e8}.cq-options button.reveal-0{color:#a43e45;border-color:#e96a73;background:#fff1f2}.cq-instant-feedback{display:flex;align-items:flex-start;gap:.75rem;margin-top:1rem;padding:1rem;border-radius:14px}.cq-instant-feedback>i{margin-top:.15rem;font-size:1.15rem}.cq-instant-feedback p{margin:.2rem 0 0;font-size:.8rem;line-height:1.55}.cq-instant-feedback.score-10{color:#13744c;background:#ebfaf3}.cq-instant-feedback.score-5{color:#906315;background:#fff8e8}.cq-instant-feedback.score-0{color:#a43e45;background:#fff1f2}.cq-score-ring.rating-passive{border-top-color:#ef6b73}.cq-score-ring.rating-developing{border-top-color:#f59e0b}.cq-score-ring.rating-proactive{border-top-color:#3b82f6}.cq-score-ring.rating-exceptional{border-top-color:#22a06b}.cq-result-copy p{line-height:1.65}.cq-review article.neutral{background:#fff8e8}.cq-review article.neutral>span{color:#c28216}.cq-review article>span{font-size:1rem}
    .cq-result-actions{display:flex;flex-wrap:wrap;gap:.6rem}.cq-result-actions button.secondary{color:#6044d9;border:1px solid #d9d0fa;background:#fff}
    html[data-theme="dark"] .cq-page{--ink:#f8fafc;--muted:#cbd5e1}html[data-theme="dark"] .cq-hero,html[data-theme="dark"] .cq-theory>button,html[data-theme="dark"] .cq-shell,html[data-theme="dark"] .cq-question,html[data-theme="dark"] .cq-options button{background:#211c47;border-color:rgba(167,139,250,.2)}html[data-theme="dark"] .cq-theory-grid article{background:#292352}@@keyframes cqspin{to{transform:rotate(360deg)}}@@media(max-width:760px){.cq-hero{grid-template-columns:1fr}.cq-theory-grid{grid-template-columns:1fr}.cq-result{grid-template-columns:1fr}.cq-score-ring{margin:auto}}@@media(max-width:520px){.cq-page{padding:.75rem}.cq-question footer{align-items:stretch;flex-direction:column}.cq-question footer>button{width:100%}.cq-options button{grid-template-columns:36px 1fr}.cq-options button>i{display:none}}
</style>
