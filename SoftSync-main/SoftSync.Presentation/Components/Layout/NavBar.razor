@rendermode InteractiveServer
@implements IDisposable
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.Presentation.Services
@inject LocalizationService L
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthProvider
@inject UserProfileState UserProfileState

@* Top navigation. Interactive so the language toggle (@onclick + JS interop)
   works — the surrounding MainLayout renders as static SSR. *@

<nav class="ss-navbar tw:py-3 tw:px-6 tw:flex tw:justify-between tw:items-center">
    <!-- Brand -->
    <div class="ss-brand tw:flex tw:items-center tw:gap-2 cursor-pointer" @onclick='() => Nav.NavigateTo(HomeHref)'>
        <div class="ss-brand-logo tw:flex tw:items-center tw:justify-center">
            <img src="images/logo.png" alt="S" class="tw:w-full tw:h-full tw:object-cover" />
        </div>
        <span class="tw:text-xl tw:font-bold ss-gradient-text">SoftSync</span>
    </div>

    <!-- Center: nav pills -->
    <div class="ss-navpills tw:flex tw:items-center tw:gap-1">
        <NavLink class="ss-navpill" href="@HomeHref" Match="NavLinkMatch.All">
            <i class="bi bi-house-door"></i> <span>@L["nav.home"]</span>
        </NavLink>
        <NavLink class="ss-navpill" href="/assistant">
            <i class="bi bi-robot"></i> <span>@L["nav.assistant"]</span>
        </NavLink>
        <NavLink class="ss-navpill" href="/roadmap">
            <i class="bi bi-mortarboard"></i> <span>@L["nav.roadmap"]</span>
        </NavLink>
        <NavLink class="ss-navpill" href="/progress">
            <i class="bi bi-graph-up-arrow"></i> <span>@L["nav.progress"]</span>
        </NavLink>
        <NavLink class="ss-navpill" href="/community">
            <i class="bi bi-people"></i> <span>@L["nav.community"]</span>
        </NavLink>
    </div>

    <!-- Right: actions -->
    <div class="ss-nav-actions tw:flex tw:items-center tw:gap-3">
        <button class="ss-icon-btn ss-lang-btn" @onclick="ToggleLanguage" title="@LanguageSwitchTitle">
            <i class="bi bi-translate"></i>
            <span class="ss-lang-code">@CurrentLanguageCode</span>
            <span class="ss-lang-name">@TargetLanguageName</span>
        </button>

        <AuthorizeView>
            <Authorized>
                <button class="ss-icon-btn" title="@L["nav.search"]">
                    <i class="bi bi-search"></i>
                </button>
                <button class="ss-icon-btn ss-bell" title="@L["nav.notifications"]">
                    <i class="bi bi-bell"></i>
                    <span class="ss-bell-badge">3</span>
                </button>

                <div class="ss-userchip" @onclick='() => Nav.NavigateTo("/settings")' title="@L["nav.settings"]">
                    <div class="ss-avatar tw:flex tw:items-center tw:justify-center">
                        @if (!string.IsNullOrEmpty(profile?.AvatarUrl))
                        {
                            <img src="@profile.AvatarUrl" alt="avatar" class="ss-avatar-img" />
                        }
                        else
                        {
                            <img src="@Mascot.ImageFor(profile?.Gender ?? Gender.Unspecified)"
                                 alt="avatar"
                                 class="ss-avatar-img"
                                 onerror="this.style.display='none';this.parentElement.querySelector('.ss-avatar-fallback').style.display='flex'" />
                            <i class="bi bi-person-fill ss-avatar-fallback"></i>
                        }
                    </div>
                    <div class="tw:flex tw:flex-col tw:leading-tight">
                        <span class="tw:font-semibold tw:text-sm">@(profile?.PublicName ?? context.User.Identity?.Name)</span>
                        <span class="ss-userchip-sub">@L["nav.level"] @(profile?.Level ?? 1)</span>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="ss-auth-actions">
                    <a href="Account/Login" class="ss-login-link">@L["nav.login"]</a>
                    <a href="Account/Register" class="ss-register-link">@L["auth.register"]</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

<style>
    .ss-navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--glass-bg-strong);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        border-bottom: 1px solid var(--glass-border);
    }
    .ss-brand-logo {
        width: 38px; height: 38px;
        background: var(--gradient);
        border-radius: 10px;
        overflow: hidden;
    }
    .cursor-pointer { cursor: pointer; }

    /* Center nav pills */
    .ss-navpill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        color: #4b5563;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.18s ease;
        white-space: nowrap;
    }
    .ss-navpill i { font-size: 1.05rem; }
    .ss-navpill:hover {
        color: var(--color-brand);
        background: rgba(99, 102, 241, 0.08);
    }
    .ss-navpill.active {
        color: var(--color-brand-dark);
        background: rgba(99, 102, 241, 0.14);
    }

    /* Icon buttons (language, search, bell) */
    .ss-icon-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 40px;
        padding: 0 0.6rem;
        border-radius: 12px;
        border: none;
        background: rgba(255, 255, 255, 0.6);
        color: #4b5563;
        cursor: pointer;
        transition: all 0.18s ease;
    }
    .ss-icon-btn:hover {
        background: #fff;
        color: var(--color-brand);
    }
    .ss-icon-btn i { font-size: 1.05rem; }
    .ss-lang-btn {
        gap: 0.4rem;
        width: 142px;
        padding: 0 0.75rem;
    }
    .ss-lang-code {
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.02em;
    }
    .ss-lang-name {
        color: inherit;
        font-size: 0.78rem;
        font-weight: 650;
        opacity: 0.82;
    }
    .ss-lang-code::after {
        content: "·";
        margin-left: 0.35rem;
        opacity: 0.55;
    }

    /* Notification bell badge */
    .ss-bell { position: relative; }
    .ss-bell-badge {
        position: absolute;
        top: -4px; right: -4px;
        min-width: 18px; height: 18px;
        padding: 0 4px;
        border-radius: 999px;
        background: var(--color-brand-accent);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 0 2px var(--glass-bg-strong);
    }

    /* User chip */
    .ss-userchip {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.3rem 0.6rem 0.3rem 0.35rem;
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.18s ease;
    }
    .ss-userchip:hover { background: rgba(255, 255, 255, 0.6); }
    .ss-avatar {
        width: 38px; height: 38px;
        border-radius: 999px;
        background: var(--gradient);
        color: #fff;
        font-size: 1.1rem;
        flex-shrink: 0;
        overflow: hidden;
    }
    .ss-avatar .ss-avatar-img {
        width: 100%; height: 100%;
        border-radius: 999px;
        object-fit: cover;
    }
    .ss-userchip-sub {
        font-size: 0.75rem;
        color: var(--color-brand);
        font-weight: 600;
    }
    .ss-auth-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
    }
    .ss-login-link,
    .ss-register-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        padding: 0 0.95rem;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }
    .ss-login-link {
        color: #4b5563;
        background: rgba(255, 255, 255, 0.6);
    }
    .ss-register-link {
        color: #fff;
        background: var(--gradient);
        box-shadow: 0 10px 24px rgba(99, 102, 241, 0.24);
    }

    @@media (max-width: 900px) {
        .ss-navpill span { display: none; }
        .ss-userchip .tw\:flex-col { display: none; }
    }

    /* Narrow phones: the row (brand + 5 pills + lang + search + bell + avatar)
       gets cramped. Tighten padding/gaps and drop the "EN"/"VI" label so the
       bar never overflows or wraps. */
    @@media (max-width: 560px) {
        .ss-navbar { padding-left: 0.75rem; padding-right: 0.75rem; }
        .ss-navpills { gap: 0; }
        .ss-navpill { padding: 0.5rem 0.55rem; }
        .ss-icon-btn { min-width: 36px; height: 36px; padding: 0 0.4rem; }
        .ss-lang-btn { width: 36px; }
        .ss-lang-name,
        .ss-lang-code::after { display: none; }
    }

    /* Mobile app shell: compact header plus thumb-friendly bottom navigation. */
    @@media (max-width: 760px) {
        .ss-navbar {
            position: sticky;
            top: 0;
            z-index: 900;
            min-height: 58px;
            padding: 0.55rem 0.75rem !important;
            gap: 0.5rem;
        }
        .ss-brand { flex: 1; min-width: 0; }
        .ss-brand-logo { width: 38px; height: 38px; }
        .ss-nav-actions { gap: 0.45rem !important; }
        .ss-nav-actions > .ss-icon-btn:not(.ss-lang-btn),
        .ss-bell { display: none; }
        .ss-lang-btn {
            width: auto;
            min-width: 58px;
            height: 38px;
            padding-inline: 0.55rem;
        }
        .ss-lang-name, .ss-lang-code::after { display: none; }
        .ss-userchip { padding: 2px; border-radius: 50%; }
        .ss-avatar { width: 38px; height: 38px; }

        .ss-navpills {
            position: fixed;
            left: 0.65rem;
            right: 0.65rem;
            bottom: max(0.65rem, env(safe-area-inset-bottom));
            z-index: 1000;
            display: grid !important;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 0.2rem !important;
            min-height: 64px;
            padding: 0.4rem;
            border: 1px solid rgba(139, 92, 246, 0.22);
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 18px 45px rgba(49, 46, 129, 0.24);
            -webkit-backdrop-filter: blur(18px) saturate(160%);
            backdrop-filter: blur(18px) saturate(160%);
        }
        .ss-navpill {
            min-width: 0;
            min-height: 52px;
            padding: 0.35rem 0.15rem;
            flex-direction: column;
            justify-content: center;
            gap: 0.1rem;
            border-radius: 15px;
            line-height: 1.05;
        }
        .ss-navpill i { font-size: 1.1rem; }
        .ss-navpill span {
            display: block;
            max-width: 100%;
            overflow: hidden;
            font-size: 0.58rem;
            font-weight: 700;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        html[data-theme="dark"] .ss-navpills {
            background: rgba(28, 24, 57, 0.94);
            border-color: rgba(167, 139, 250, 0.25);
        }
    }

    @@media (max-width: 390px) {
        .ss-brand > span { display: inline; font-size: 0.95rem; }
        .ss-brand-logo { width: 34px; height: 34px; }
        .ss-auth-actions .ss-register-link { display: none; }
        .ss-auth-actions .ss-login-link {
            display: inline-flex;
            min-height: 38px;
            padding-inline: 0.55rem;
            background: transparent;
            font-size: 0.75rem;
        }
    }

    /* Dark theme: lighten nav text/icons so they read on the deep canvas. */
    html[data-theme="dark"] .ss-navpill { color: #cbd5e1; }
    html[data-theme="dark"] .ss-navpill:hover { color: #fff; background: rgba(139, 92, 246, 0.18); }
    html[data-theme="dark"] .ss-navpill.active { color: #fff; background: rgba(139, 92, 246, 0.28); }
    html[data-theme="dark"] .ss-icon-btn {
        background: rgba(45, 39, 86, 0.6);
        color: #cbd5e1;
    }
    html[data-theme="dark"] .ss-icon-btn:hover { background: rgba(139, 92, 246, 0.3); color: #fff; }
    html[data-theme="dark"] .ss-userchip:hover { background: rgba(139, 92, 246, 0.18); }
    html[data-theme="dark"] .ss-login-link { background: rgba(45, 39, 86, 0.6); color: #e5e7eb; }

    /* Shared modal (used by Settings suspend/delete confirm) */
    .ss-modal-backdrop {
        position: fixed; inset: 0; z-index: 200;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        padding: 1rem;
        animation: ss-fade-in 0.2s ease;
    }
    .ss-modal {
        width: 100%; max-width: 380px;
        background: #fff;
        border-radius: 22px;
        padding: 1.75rem;
        box-shadow: var(--shadow-glass-hover);
        animation: ss-pop-in 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @@keyframes ss-fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes ss-pop-in {
        from { opacity: 0; transform: translateY(12px) scale(0.94); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>

@code {
    private UserDto? profile;
    private string HomeHref => profile is null ? "/" : "/dashboard";

    protected override void OnInitialized()
    {
        L.OnChanged += StateHasChangedSafe;
        UserProfileState.AvatarChanged += OnAvatarChanged;
        UserProfileState.DisplayNameChanged += OnDisplayNameChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load the user's profile (avatar + level) in its own DI scope so we
            // don't share the page's scoped DbContext (avoids a concurrent-query
            // crash when a page also queries the DB during its own init).
            await LoadProfileAsync();
        }
    }

    private async Task ToggleLanguage()
    {
        var next = L.Current == AppLanguage.En ? AppLanguage.Vi : AppLanguage.En;
        var nextCode = next == AppLanguage.Vi ? "vi" : "en";
        await JS.InvokeVoidAsync("ssLang.set", nextCode);
        L.SetLanguage(next);
    }

    private string CurrentLanguageCode => L.Current == AppLanguage.Vi ? "VI" : "EN";
    private string TargetLanguageName => L.Current == AppLanguage.Vi ? "English" : "Vietnamese";
    private string LanguageSwitchTitle => L.Current == AppLanguage.Vi
        ? "Switch to English"
        : "Chuyển sang tiếng Việt";

    private void StateHasChangedSafe() => InvokeAsync(StateHasChanged);

    private void OnAvatarChanged(string avatarUrl)
    {
        if (profile is not null)
        {
            profile.AvatarUrl = avatarUrl;
            _ = InvokeAsync(StateHasChanged);
        }
        else
        {
            _ = LoadProfileAsync();
        }
    }

    private void OnDisplayNameChanged(string displayName)
    {
        if (profile is not null)
        {
            profile.DisplayName = displayName;
            _ = InvokeAsync(StateHasChanged);
        }
        else
        {
            _ = LoadProfileAsync();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        var userId = await AuthProvider.GetUserIdAsync();
        if (userId <= 0) return;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var userService = scope.ServiceProvider.GetRequiredService<IUserService>();
        profile = await userService.GetUserByIdAsync(userId);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnChanged -= StateHasChangedSafe;
        UserProfileState.AvatarChanged -= OnAvatarChanged;
        UserProfileState.DisplayNameChanged -= OnDisplayNameChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
