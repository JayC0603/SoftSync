@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="@ServerLanguage" data-theme="@ServerTheme" data-reduce-motion="@ReduceMotionAttr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="@BrowserThemeColor" />
    <base href="/" />
    <style>
        /* Critical first-paint canvas. This is intentionally inline and appears
           before external styles so refresh never exposes the purple fallback
           while Blazor/CSS is still loading. */
        html, body { min-height: 100%; margin: 0; background: #f7f6fc; }
        html[data-theme="dark"], html[data-theme="dark"] body { background: #100d24; }
    </style>
    <script>
        // Migrate the old localStorage-only preference before the first paint.
        // Once the cookie exists, the server renders the selected language
        // directly and this block becomes a no-op on every later visit.
        (function () {
            try {
                var saved = localStorage.getItem('ss-lang');
                if (saved !== 'vi' && saved !== 'en') return;
                var match = document.cookie.match(/(?:^|; )ss-lang=([^;]*)/);
                var cookie = match ? decodeURIComponent(match[1]) : null;
                if (cookie === saved) {
                    sessionStorage.removeItem('ss-lang-cookie-migration');
                    return;
                }
                // Avoid a reload loop if this browser blocks cookies.
                if (sessionStorage.getItem('ss-lang-cookie-migration') === saved) return;
                sessionStorage.setItem('ss-lang-cookie-migration', saved);
                document.cookie = 'ss-lang=' + saved + '; path=/; max-age=31536000; samesite=lax';
                location.replace(location.href);
            } catch (e) { /* ignore */ }
        })();
    </script>
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="dist/app.css" />
    <link rel="stylesheet" href="css/liquid-glass.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <script>
        // The server already renders data-theme on <html> from the ss-theme
        // cookie, so there's no flash and no revert on Blazor enhanced navigation.
        // This script only handles the parts the server can't know:
        //   1. Resolving "system" against the OS setting.
        //   2. Keeping the cookie in sync so the next SSR paints correctly.
        //   3. Reacting to OS theme changes while "system" is selected.
        (function () {
            function setCookie(name, value) {
                try { document.cookie = name + '=' + value + '; path=/; max-age=31536000; samesite=lax'; }
                catch (e) { /* ignore */ }
            }
            function apply() {
                try {
                    var pref = localStorage.getItem('ss-theme') || 'light';
                    var rm = localStorage.getItem('ss-reduce-motion') === '1';
                    var resolved = (pref === 'light' || pref === 'dark') ? pref
                        : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    var el = document.documentElement;
                    el.setAttribute('data-theme', resolved);
                    if (rm) el.setAttribute('data-reduce-motion', '1');
                    else el.removeAttribute('data-reduce-motion');
                    // Persist the RESOLVED value so the server can paint it next time.
                    setCookie('ss-theme', resolved);
                    setCookie('ss-reduce-motion', rm ? '1' : '0');
                } catch (e) { /* ignore */ }
            }
            apply();
            document.addEventListener('enhancedload', apply);
            // If the user chose "system", follow OS theme changes.
            try {
                window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () {
                    if (localStorage.getItem('ss-theme') === 'system') apply();
                });
            } catch (e) { /* older browsers */ }
        })();
    </script>
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="dist/app.js"></script>
</body>

</html>

@code {
    // Read the resolved theme the browser last persisted to the ss-theme cookie
    // and paint it straight onto <html> during SSR / enhanced navigation. This is
    // what stops the theme from flashing to light and reverting between pages.
    private string ServerTheme =>
        HttpContextAccessor.HttpContext?.Request.Cookies["ss-theme"] is "dark" ? "dark" : "light";

    private string BrowserThemeColor => ServerTheme == "dark" ? "#100d24" : "#f7f6fc";

    private string ServerLanguage =>
        HttpContextAccessor.HttpContext?.Request.Cookies["ss-lang"] is "en" ? "en" : "vi";

    // Returns "1" or null — Blazor omits the attribute entirely when it's null,
    // so we never emit a broken/empty data-reduce-motion.
    private string? ReduceMotionAttr =>
        HttpContextAccessor.HttpContext?.Request.Cookies["ss-reduce-motion"] == "1" ? "1" : null;
}
